	~	GtBiomass
	~		|

Use_of_TROP_for_energy_in_2000_GtBiomass=
	TROP_Living_biomass_in_1850 * Use_of_TROP_biomass_for_energy_in_1850_pct / 100
	~	GtBiomass
	~		|

Frac_blocked_by_ALL_GHG_LESS_watervapor=
	Blocked_by_CO2 + Blocked_by_CH4 + Blocked_by_otherGHG
	~	fraction
	~		~	:SUPPLEMENTARY 

	~	1
	~		|

XtaxFrac_policy_with_RW[region]=
	Xtaxfrac_policy_Min + ( XtaxFrac_rounds_via_Excel[region] - Xtaxfrac_policy_Min ) * \
		Smoothed_Reform_willingness[region
	]
	~	1
	~		|

SSGDR_policy_with_RW[region]=
	SSGDR_policy_Min + (SSGDR_rounds_via_Excel[region] - SSGDR_policy_Min) * Smoothed_Reform_willingness\
		[region]
	~	1
	~	The Min is not equal to 0, hence the effect of Smoothed Reform willingness \
		must be calculated on the policy less Min and the Min then be added in \
		afterwards
	|

Lfrac_policy_with_RW[region]=
	Lfrac_rounds_via_Excel[region] * Smoothed_Reform_willingness[region]
	~	1
	~		|


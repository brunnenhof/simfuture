	~	Mkm2
	~		|

BARREN_land_normal_albedo_Mkm2=
	Barren_land_Mkm2
	~	Mkm2
	~		|

N2O_in_atmosphere_MtN2O= INTEG (
	All_N2O_emissions-N2O_degradation_MtN2O_py,
		N2O_in_atmosphere_MtN2O_in_1980)
	~	MtN2O
	~		|

N2O_in_atmosphere_MtN2O_in_1980=
	1082.4
	~	MtN2O
	~	IPCC gives a value of about 1340 MtN2O for 2000
	|

BB_radiation_at_surface_temp_ZJ_py=
	Emissivity_surface * Stephan_Boltzmann_constant * Temp_surface_average_K^4 * UNIT_conversion_W_p_m2_earth_to_ZJ_py
	~	ZJ/yr
	~		|

BB_radiation_at_Temp_in_atm_ZJ_py=
	Emissivity_atm * Stephan_Boltzmann_constant * Temp_atm_average_K^4 * UNIT_conversion_W_p_m2_earth_to_ZJ_py
	~	ZJ/yr
	~		|

Fossil_fuel_reserves_in_ground_at_initial_time_GtC=
	5827.98
	~	GtC
	~	read off 1980 value from the original ESMICON that starts in 1850
	|

Time_in_intermediate_yr=
	211.397
	~	yr
	~	calibration
	|

Biological_removal_of_C_from_WSW_GtC_per_yr=
	SMOOTH(Net_marine_primary_production_NMPP_GtC_pr_yr , Time_to_let_shells_form_and_sink_to_sediment_yr\
		)
	~	GtC/yr
	~		|

Net_CO2_flow_between_grass_and_atmosphere_GtC=
	CO2_flux_from_atm_to_GRASS_for_new_growth_GtC_py - CO2_flux_GRASS_to_atm_GtC_py
	~	GtC/yr
	~		~	:SUPPLEMENTARY 
	|

Net_CO2_flow_between_TUNDRA_and_atmosphere=
	CO2_flux_from_atm_to_TUNDRA_for_new_growth - CO2_flux_TUNDRA_to_atm
	~	GtC/yr
	~		~	:SUPPLEMENTARY 
	|

Frac_atm_absorption=
	75/340
	~	fraction
	~		|

Frac_blocked_by_ALL_GHG=
	Blocked_by_CO2 + Blocked_by_CH4 + Blocked_by_H20 + Blocked_by_otherGHG
	~	fraction
	~		|

Net_heat_flow_ocean_from_surface_to_deep_W_p_m2=
	Net_heat_flow_ocean_from_surface_to_deep_ZJ_py / UNIT_conversion_W_p_m2_earth_to_ZJ_py
	~	W/m2
	~		~	:SUPPLEMENTARY 
	|

Net_heat_flow_ocean_from_surface_to_deep_ZJ_py=
	Surface_deep_ocean_temp_diff_degC * Net_heat_flow_ocean_between_surface_and_deep_per_K_of_difference_ZJ_py_K
	~	ZJ/yr
	~	"Surface deep ocean temp diff degC" * "Net heat flow ocean between surface \
		and deep per K of difference ZJ py K"
	|

Blocked_by_CH4=
	Fraction_blocked_by_CH4_spectrum
	~	fraction
	~		|

Blocked_by_CO2=
	Fraction_blocked_by_CO2_spectrum
	~	fraction
	~		|

Blocked_by_H20=
	Blocked_by_H20_Table_lookup
	~	fraction
	~		|

Blocked_by_H20_Table_lookup= WITH LOOKUP (
	Humidity_of_atmosphere_current_g_p_kg,
		([(1.7,0)-(2.5,0.2)],(1.76,0.06),(1.85,0.0638),(1.9,0.0649123),(1.95,0.071),(1.97,0.0753\
		),(1.99,0.081),(2.00026,0.0846),(2.02999,0.092),(2.05039,0.0976),(2.07286,0.1025),(\
		2.10017,0.109),(2.11642,0.113),(2.14996,0.1205),(2.16275,0.1235),(2.18522,0.129),(2.20009\
		,0.132),(2.21288,0.135),(2.235,0.14),(2.25022,0.144),(2.26992,0.148),(2.3,0.155),(2.4\
		,0.174),(2.5,0.19) ))
	~	fraction
	~		|

Blocked_by_otherGHG=
	Fraction_blocked_by_other_GHG
	~	fraction
	~		|

Blocking_multiplier_from_Kyoto_Fluor=
	IF_THEN_ELSE( Time > 1970, 1 + Slope_btw_Kyoto_Fluor_ppt_and_blocking_multiplier/1000\
		 * (Kyoto_Fluor_concentration_ppt /Kyoto_Fluor_concentration_in_1970_ppt-1), 1)
	~	Dmnl
	~	There are no Kyoto Fluor gases in the atmosphere in 1850, hence we need to compare \
		current concentrations with concentrations at a different time, we chose \
		1970 when they were very samll.
		If we run the model with zero emissions, to test initial start up \
		conditions, we must not let "Kyoto Fluor gases concentration in 1970 ppt" \
		be active, because it will be zero
	|

Blocking_multiplier_from_Montreal_gases=
	IF_THEN_ELSE( Time > 1970, 1+Slope_btw_Montreal_gases_ppt_and_blocking_multiplier/100\
		*(Montreal_gases_concentration_ppt/Montreal_gases_concentration_in_1970_ppt-1), 1 )
	~	dimensionless
	~	There are no Montreal gases in the atmosphere in 1850, hence we need to compare \
		current concentrations with concentrations at a different time, we chose \
		1970 when they were very samll.
		If we run the model with zero emissions, to test initial start up \
		conditions, we must not let "Montreal gases concentration in 1970 ppt" be \
		active, because it will be zero
	|

Blocking_multiplier_from_N2O=
	 1 + Slope_btw_N2O_ppb_and_blocking_multiplier * ( N2O_concentration_ppb
	 / Model_N2O_concentration_in_1850_ppb - 1 )
	~	dimensionless
	~		|

Blocking_of_LW_rad_by_clouds=
	LW_LO_cloud_radiation + LW_HI_cloud_radiation
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 26.7 +/- 4 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

C_absorption_by_ocean_from_atm_for_accumulation=
	C_diffusion_into_ocean_from_atm_net
	~	GtC/yr
	~		|

C_diffusion_into_atm_from_ocean=
	IF_THEN_ELSE(C_diffusion_into_ocean_from_atm_net<0, C_diffusion_into_ocean_from_atm_net\
		 * -1 , 0)
	~	GtC/Year
	~		~	:SUPPLEMENTARY 
	|

C_diffusion_into_ocean_from_atm_MtC_py=
	C_diffusion_into_ocean_from_atm_net * UNIT_conversion_GtC_to_MtC
	~	MtC/Year
	~		~	:SUPPLEMENTARY 
	|

C_in_atmosphere_GtC= INTEG (
	Avg_volcanic_activity_GtC_py+C_release_from_permafrost_melting_as_CO2_GtC_py+CH4_in_the_atmosphere_converted_to_CO2\
		+CO2_flux_GRASS_to_atm_GtC_py+CO2_flux_NF_to_atm_GtC_py+CO2_flux_TROP_to_atm_GtC_py\
		+CO2_flux_TUNDRA_to_atm+Man_made_fossil_C_emissions_GtC_py-C_diffusion_into_ocean_from_atm_net\
		-Carbon_captured_and_stored_GtC_py-CO2_flux_from_atm_to_GRASS_for_new_growth_GtC_py\
		-CO2_flux_from_atm_to_NF_for_new_growth_GtC_py-CO2_flux_from_atm_to_TROP_for_new_growth_GtC_py\
		-CO2_flux_from_atm_to_TUNDRA_for_new_growth,
		C_in_atmosphere_in_1980)
	~	GtC
	~		|

C_in_atmosphere_in_1850_GtC=
	600
	~	GtC
	~		|

C_in_atmosphere_in_1980=
	752.397
	~	GtC
	~	600
	|

C_in_atmosphere_in_form_of_CH4= INTEG (
	CH4_release_or_capture_from_permafrost_area_loss_or_gain_GtC_py+Human_activity_CH4_emissions\
		+Natural_CH4_emissions-CH4_conversion_to_CO2_and_H2O,
		C_in_the_form_of_CH4_in_atm_1980)
	~	GtC
	~		|

C_in_biomass=
	C_in_NF_GtC + C_in_TROP_GtC + C_in_GRASS_GtC + C_in_TUNDRA_GtC
	~	GtC
	~		~	:SUPPLEMENTARY 
	|

C_in_cold_surface_water_GtC= INTEG (
	C_diffusion_into_ocean_from_atm_net
	+ Carbon_flow_from_warm_to_cold_surface_GtC_per_yr
	- Carbon_flow_from_cold_surface_downwelling_Gtc_per_yr,
		Carbon_in_cold_ocean_0_to_100m_1850)
	~	GtC
	~		|

C_in_cold_water_trunk_downwelling_GtC= INTEG (
	Carbon_flow_from_cold_surface_downwelling_Gtc_per_yr-Carbon_flow_from_cold_to_deep_GtC_per_yr\
		,
		Carbon_in_cold_ocean_trunk_100m_to_bottom_1850)
	~	GtC
	~		|

C_in_deep_water_volume_1km_to_bottom_GtC= INTEG (
	Carbon_flow_from_cold_to_deep_GtC_per_yr
	- Depositing_of_C_to_sediment
	- Carbon_flow_from_deep,
		Carbon_in_ocean_deep_1k_to_bottom_ocean_1850)
	~	GtC
	~		|

C_in_GRASS_DeadB_and_soil_GtC=
	GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass *  Carbon_per_biomass
	~	GtC
	~		|

C_in_GRASS_GtC=
	C_in_GRASS_LB_GtC
	+ C_in_GRASS_DeadB_and_soil_GtC
	+ GRASS_Biomass_locked_in_construction_material_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_GRASS_LB_GtC=
	GRASS_Living_biomass_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_intermediate_upwelling_water_100m_to_1km_GtC= INTEG (
	Carbon_flow_from_deep-Carbon_flow_from_intermediate_to_surface_box_GtC_per_yr,
		Carbon_in_ocean_upwelling_100m_to_1km_1850)
	~	GtC
	~		|

C_in_NF_DeadB_and_soil_GtC=
	NF_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass *  Carbon_per_biomass
	~	GtC
	~		|

C_in_NF_GtC=
	C_in_NF_LB_GtC
	+ C_in_NF_DeadB_and_soil_GtC
	+ NF_Biomass_locked_in_construction_material_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_NF_LB_GtC=
	NF_Living_biomass_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_permafrost_in_form_of_CH4= INTEG (
	-CH4_release_or_capture_from_permafrost_area_loss_or_gain_GtC_py,
		1199.78
		)
	~	GtC
	~	The best source of information about carbon in permafrost is the \
		Permafrost Carbon Network https://www2.nau.edu/schuurlab-p/ and \
		http://www.permafrostcarbon.org/index.html with it´s links
	|

C_in_the_form_of_CH4_in_atm_1850=
	1.69
	~	GtC [550,680,1]
	~	calculated from conversion factor and known concentration in 1850 to set \
		this to be truly in equilibrium when historical input is constant, value \
		must be 1.35
	~	:SUPPLEMENTARY 
	|

C_in_the_form_of_CH4_in_atm_1980=
	2.79426
	~	GtC [550,680,1]
	~	calculated from conversion factor and known concentration in 1850 to set this to be \
		truly in equilibrium when historical input is constant, value must be 1.35
		The value is read off for 1980 from the full ESMICON model, which starts \
		in 1850
	|

C_in_TROP_DeadB_and_soil_GtC=
	TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass *  Carbon_per_biomass
	~	GtC
	~		|

C_in_TROP_GtC=
	C_in_TROP_LB_GtC
	+ C_in_TROP_DeadB_and_soil_GtC
	+ TROP_Biomass_locked_in_construction_material_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_TROP_LB_GtC=
	TROP_Living_biomass_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_TUNDRA_DeadB_and_soil_GtC=
	TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass *  Carbon_per_biomass
	~	GtC
	~		|

C_in_TUNDRA_GtC=
	C_in_TUNDRA_LB_GtC
	+ C_in_TUNDRA_DeadB_and_soil_GtC
	+ TUNDRA_Biomass_locked_in_construction_material_GtBiomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_TUNDRA_LB_GtC=
	TUNDRA_Living_biomass * Carbon_per_biomass
	~	GtC
	~		|

C_in_warm_surface_water_GtC= INTEG (
	Carbon_flow_from_intermediate_to_surface_box_GtC_per_yr
	+ C_runoff_from_biomass_soil
	- Biological_removal_of_C_from_WSW_GtC_per_yr
	- Carbon_flow_from_warm_to_cold_surface_GtC_per_yr,
		Carbon_in_warm_ocean_0_to_100m_1850)
	~	GtC
	~		|

C_release_from_permafrost_melting_as_CO2_GtC_py=
	CH4_in_permafrost_area_melted_or_frozen_before_heat_constraint *  Melting_restraint_for_permafrost_from_heat_in_atmophere
	 * (1 - Fraction_of_C_released_from_permafrost_released_as_CH4_dmnl)
	~	GtC/Year
	~		|

C_runoff_from_biomass_soil=
	(TROP_runoff + NF_runoff + GRASS_runoff + TUNDRA_runoff) * Carbon_per_biomass
	~	GtC/yr
	~		|

NF_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires=
	0
	~	fraction
	~	A value of 0 means that if living biomass is destroyed by (natural) fires, \
		the soil remains intact. One can specify a multiplier between 0 and 1 to \
		signal that at 1 all soil (under the fire) is destroyed, or at eg 0.5 50% \
		of the soil (under the fire) is destroyed.
	|

NF_historical_deforestation_pct_py=
	(NF_Ref_historical_deforestation_pct_py / 100)
	~	1/yr
	~		|

NF_living_biomass_densitiy_in_1850_tBiomass_pr_km2=
	7500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

NF_Living_biomass_GtBiomass= INTEG (
	NF_biomass_new_growing-NF_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting\
		-NF_for_construction_use-NF_Living_biomass_rotting,
		NF_Living_biomass_in_1980)
	~	GtBiomass
	~		|

NF_Living_biomass_in_1850=
	115
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] \
		Note, units here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

NF_Living_biomass_in_1980=
	150.39
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] \
		Note, units here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

NF_Living_biomass_rotting=
	NF_Living_biomass_GtBiomass / NF_Avg_life_biomass_yr
	~	GtBiomass/yr
	~		|

NF_Normal_fire_incidence_fraction_py=
	0.7
	~	fraction/yr
	~	In the US about 2 Mha burn 'naturally' each yr out of 303 Mha
	|

NF_potential_area_Mkm2= INTEG (
	Shifting_GRASS_to_NF_Mkm2_py+Shifting_TROP_to_NF_Mkm2_py+Shifting_Tundra_to_NF_Mkm2_py\
		-Shifting_NF_to_GRASS_Mkm2_py-Shifting_NF_to_TROP_Mkm2_py-Shifting_NF_to_Tundra_Mkm2_py\
		,
		17.0089
		)
	~	Mkm2
	~		|

Carbon_flow_from_cold_surface_downwelling_Gtc_per_yr=
	C_in_cold_surface_water_GtC / Time_in_cold
	~	GtC/yr
	~		|

Carbon_flow_from_cold_to_deep_GtC_per_yr=
	C_in_cold_water_trunk_downwelling_GtC / Time_in_trunk
	~	GtC/yr
	~		|

Carbon_flow_from_deep=
	C_in_deep_water_volume_1km_to_bottom_GtC / Time_in_deep
	~	GtC/yr
	~		|

Carbon_flow_from_intermediate_to_surface_box_GtC_per_yr=
	C_in_intermediate_upwelling_water_100m_to_1km_GtC / Time_in_intermediate_yr
	~	GtC/yr
	~		|

Carbon_flow_from_warm_to_cold_surface_GtC_per_yr=
	C_in_warm_surface_water_GtC / Time_in_warm
	~	GtC/yr
	~		|

Carbon_in_cold_ocean_0_to_100m_1850=
	(CC_in_cold_ocean_0_to_100m_in_1980 / UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre ) *\
		 Volume_cold_ocean_0_to_100m
	~	GtC
	~		|

Carbon_in_cold_ocean_trunk_100m_to_bottom_1850=
	(CC_in_cold_ocean_downwelling_100m_bottom_in_1980 / UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre\
		 ) * Volume_cold_ocean_downwelling_100m_to_bottom
	~	GtC
	~		|

Carbon_in_ocean_deep_1k_to_bottom_ocean_1850=
	(CC_ocean_deep_1km_to_bottom_in_1980 / UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre ) \
		* Volume_ocean_deep_1km_to_bottom
	~	GtC
	~		|

Carbon_in_ocean_upwelling_100m_to_1km_1850=
	(CC_in_ocean_upwelling_100m_to_1km_in_1980 / UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre\
		 ) * Volume_ocean_upwelling_100m_to_1km
	~	GtC
	~		|

Carbon_in_top_ocean_layer_1850=
	Carbon_in_cold_ocean_0_to_100m_1850 + Carbon_in_warm_ocean_0_to_100m_1850
	~	GtC
	~		|

Carbon_in_top_ocean_layer_GtC=
	C_in_cold_surface_water_GtC + C_in_warm_surface_water_GtC
	~	GtC
	~		|

Carbon_in_warm_ocean_0_to_100m_1850=
	(CC_in_warm_ocean_0_to_100m_in_1980 / UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre ) *\
		 Volume_warm_ocean_0_to_100m
	~	GtC
	~		|

Carbon_per_biomass=
	0.5
	~	GtC/GtBiomass
	~		|

TROP_DeadB_and_SOM_tB_per_km2=
	TROP_DeadB_and_SOM_densitiy_in_1850_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl
	~	tB/km2
	~		|

TROP_DeadB_SOM_being_lost_due_to_deforestation=
	TROP_being_deforested_Mkm2_py * TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting\
		 * TROP_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~	/ 1000 to convert M (illion) to G (iga)
	|

TROP_DeadB_SOM_being_lost_due_to_energy_harvesting=
	TROP_being_harvested_normally * TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting\
		 * TROP_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~		|

TROP_deforestation_cutoff= WITH LOOKUP (
	TROP_deforested_as_pct_of_potential_area,
		([(0.5,0)-(0.8,1)],(0.5,1),(0.621101,0.921053),(0.700917,0.732456),(0.738532,0.442982\
		),(0.761468,0.223684),(0.777064,0.0789474),(0.8,0) ))
	~	dimensionless
	~		|

CC_in_cold_downwelling_ymoles_per_litre=
	Carbon_concentration_in_CWTtB * UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre
	~	ymoles/litre
	~		|

CC_in_cold_downwelling_ymoles_per_litre_dmnl=
	CC_in_cold_downwelling_ymoles_per_litre * UNIT_conversion_ymoles_p_litre_to_dless
	~	dimensionless
	~		|

CC_in_cold_ocean_0_to_100m_in_1980=
	2325.64
	~	ymoles/litre [2000,2400,20]
	~	2240 in 1850
	|

CC_in_cold_ocean_downwelling_100m_bottom_in_1980=
	2253.86
	~	ymoles/litre
	~	2240 in 1850
	|

CC_in_cold_surface_ymoles_per_litre=
	Carbon_concentration_in_cold_surface_ocean * UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre
	~	ymoles/litre
	~	1e+006 / 12.01 *1000 converts units from GtC/Gm3 to ymoles/litre, about 83 \
		260 000
	|

CC_in_cold_surface_ymoles_per_litre_dmnl=
	CC_in_cold_surface_ymoles_per_litre * UNIT_conversion_ymoles_p_litre_to_dless
	~	dimensionless
	~		|

CC_in_deep_box_ymoles_per_litre=
	Carbon_concentration_in_deep_box_GtC_per_G_cubicM * UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre
	~	ymoles/litre
	~		|

CC_in_deep_box_ymoles_per_litre_dmnl=
	CC_in_deep_box_ymoles_per_litre * UNIT_conversion_ymoles_p_litre_to_dless
	~	dimensionless
	~		|

CC_in_intermediate_box_ymoles_per_litre=
	Carbon_concentration_in_intermdiate_box_GtC_per_G_cubicM * UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre
	~	ymoles/litre
	~		|

CC_in_intermediate_box_ymoles_per_litre_dmnl=
	CC_in_intermediate_box_ymoles_per_litre * UNIT_conversion_ymoles_p_litre_to_dless
	~	dimensionless
	~		|

CC_in_ocean_upwelling_100m_to_1km_in_1980=
	2237.8
	~	ymoles/litre
	~	2240 in 1850
	|

CC_in_warm_ocean_0_to_100m_in_1980=
	2242.96
	~	ymoles/litre
	~	2240 in 1850
	|

CC_in_warm_surface_ymoles_per_litre=
	Carbon_concentration_in_warm_surface *UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre
	~	ymoles/litre
	~		|

CC_in_warm_surface_ymoles_per_litre_dmnl=
	CC_in_warm_surface_ymoles_per_litre * UNIT_conversion_ymoles_p_litre_to_dless
	~	dimensionless
	~		|

CC_ocean_deep_1km_to_bottom_in_1980=
	2232.12
	~	ymoles/litre
	~	2240 in 1850
	|

TROP_Living_biomass_in_1850=
	370
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] \
		Note, units here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

TROP_Living_biomass_in_1980=
	379.797
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] \
		Note, units here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

TROP_Living_biomass_rotting=
	TROP_Living_biomass_GtBiomass / TROP_Avg_life_biomass_yr
	~	GtBiomass/yr
	~		|

TROP_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting=
	(TROP_being_deforested_Mkm2_py + TROP_burning + TROP_being_harvested_by_clear_cutting\
		 + TROP_being_harvested_normally
	) * TROP_living_biomass_densitiy_tBiomass_pr_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~	/ 1000 to convert M (illion) to G (iga)
	|

TROP_regrowing_after_harvesting_Mkm2_py=
	TROP_area_harvested_Mkm2 / Time_to_regrow_TROP_yr
	~	Mkm2/yr
	~		|

TROP_Normal_fire_incidence=
	0.3
	~	fraction/yr
	~	estimated from FRA 2010 - 2015 GLOBAL FOREST RESOURCES ASSESSMENT 2015, \
		Desk reference, FOOD AND AGRICULTURE ORGANIZATION OF THE UNITED NATIONS, \
		Rome, 2015, ISBN 978-92-5-108826-5, \
		http://www.fao.org/forest-resources-assessment/en/
	|

TROP_potential_area_Mkm2= INTEG (
	Shifting_GRASS_to_TROP_Mkm2_py+Shifting_NF_to_TROP_Mkm2_py-Shifting_TROP_to_GRASS_Mkm2_py\
		-Shifting_TROP_to_NF_Mkm2_py,
		25.0208
		)
	~	Mkm2
	~		|

TROP_potential_less_actual_living_biomass_GtBiomass=
	TROP_potential_living_biomass_GtBiomass - TROP_Living_biomass_GtBiomass
	~	GtBiomass
	~		|

TROP_potential_living_biomass_GtBiomass=
	(TROP_potential_area_Mkm2 - TROP_area_deforested )* TROP_living_biomass_densitiy_tBiomass_pr_km2\
		 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass
	~	/ 1000 converts M(illion) to G(iga)
	|

TROP_Ref_historical_deforestation=
	1
	~	1/yr
	~	[Source: guess, so far]
	|

Global_Warming_Potential_CH4=
	25
	~	GtCO2e/GtC
	~	http://ecometrica.com/white-papers/greenhouse-gases-co2-co2e-and-carbon-wha\
		t-do-all-these-terms-mean
	|

Zero_C_on_K_scale_K=
	273.15
	~	k
	~		|

TROP_regrowing_after_being_burnt_Mkm2_py=
	TROP_area_burnt / Time_to_regrow_TROP_yr
	~	Mkm2/yr
	~		|

TROP_regrowing_after_being_clear_cut=
	TROP_area_clear_cut / (Time_to_regrow_TROP_yr * 2)
	~	Mkm2/yr
	~	I need to keep track of the clear cutting only because of the albedo.
	|

CH4_concentration_ppb=
	MODEL_CH4_in_atm_in_ppb
	~	ppb
	~		|

CH4_conversion_to_CO2_and_H2O=
	C_in_atmosphere_in_form_of_CH4 / CH4_halflife_in_atmosphere
	~	GtC/yr
	~	CH4[g] + 2 O2[g] -> CO2[g] + 2 H2O[l] + 891 kJ Source: \
		http://www.naturalgas.org/overview/combust.asp That the process in the \
		atmosphere is 'like' burning CH4 see here: \
		http://www.eci.ox.ac.uk/research/energy/downloads/methaneuk/methaneukreport\
		.pdf Appendix1 pg 89 1st paragraph
	|

TROP_soil_degradation_from_forest_fires=
	TROP_burning * TROP_DeadB_and_SOM_tB_per_km2 / UNIT_conversion_GtBiomass_py_to_Mkm2_py\
		 * TROP_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires
	~	GtBiomass/yr
	~	factor 1000 is to convert Giga to Million
	|

TROP_Speed_of_regrowth_yr=
	3
	~	yr [0.1,5,0.5]
	~		|

TROP_Sum_outflows_TROP_Dead_biomass_litter_and_soil_organic_matter_SOM=
	TROP_DeadB_SOM_being_lost_due_to_deforestation
	+ TROP_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ TROP_runoff
	+ TROP_soil_degradation_from_clear_cutting
	+ TROP_soil_degradation_from_forest_fires
	+ TROP_Dead_biomass_decomposing
	~	GtBiomass/yr
	~		|

Ocean_area_km2=
	5.1e+08 *0.7
	~	km2
	~		|

CH4_halflife_in_atmosphere=
	7.3
	~	yr [10,30,0.1]
	~	Ruddiman in Plows, Plagues, and Petroleum. Princeton University Press, \
		Princeton, NJ (2005, 2010) says that in 10 yrs most CH4 has been converted \
		to non GWG The 7 yrs comes from \
		http://en.wikipedia.org/wiki/Atmospheric_methane citing \
		http://phys.org/tags/methane/
	|

CH4_in_the_atmosphere_converted_to_CO2=
	CH4_conversion_to_CO2_and_H2O
	~	GtC/yr
	~		|

TUNDRA_area_harvested_in_1980=
	2.5
	~	Mkm2
	~		|

TUNDRA_area_harvested_Mkm2= INTEG (
	TUNDRA_being_harvested_Mkm2_py-TUNDRA_regrowing_after_harvesting_Mkm2_py,
		TUNDRA_area_harvested_in_1980)
	~	Mkm2
	~		|

TUNDRA_Avg_life_of_building_yr=
	10
	~	yr
	~		|

Ocean_surface_area_km2=
	0.3619 * 1e+09
	~	km2
	~	Eakins, B.W. and G.F. Sharman, Volumes of the World's Oceans from ETOPO1, \
		NOAA National Geophysical Data Center, Boulder, CO, 2010. \
		http://www.ngdc.noaa.gov/mgg/global/etopo1_ocean_volumes.html
	|

TUNDRA_being_deforested_Mkm2_py=
	TUNDRA_with_normal_cover_Mkm2 * Fraction_TUNDRA_being_deforested_1_py
	~	Mkm2/yr
	~	pos is deforestation, neg is afforestation planting trees is best modeled \
		by making the slope of effect of temp shifting GRASS to TROP steeper
	|

TUNDRA_Biomass_locked_in_construction_material_GtBiomass= INTEG (
	TUNDRA_for_construction_use
	-TUNDRA_Biomass_in_construction_material_being_burnt
	-TUNDRA_Biomass_in_construction_material_left_to_rot,
		TUNDRA_Biomass_locked_in_construction_material_in_1980)
	~	GtBiomass
	~		|

TUNDRA_burning_Mkm2_py=
	TUNDRA_with_normal_cover_Mkm2 * Effect_of_temperature_on_fire_incidence * TUNDRA_Normal_fire_incidence_fraction_py
	 / 100
	~	Mkm2/yr
	~		|

Heat_withdrawn_from_ocean_surface_by_melting_pos_or_added_neg_by_freezing_antarctic_ice_ZJ_py\
		=
	Heat_used_in_melting_is_pos_or_freezing_is_neg_antarctic_ice_ZJ_py * ( 1 - Fraction_of_heat_needed_to_melt_antarctic_ice_coming_from_air
	 )
	~	ZJ/yr
	~		|

CO2_conc_atm_less_CO2_conc_sea=
	CO2_concentration_used_after_any_experiments_ppm - CO2_conc_in_cold_surface_water_in_ppm
	~	ppm
	~	micro atm = ppm
	|

CO2_conc_in_cold_surface_water_in_ppm=
	CC_in_cold_surface_ymoles_per_litre * Conversion_ymoles_per_kg_to_pCO2_yatm
	~	ppm
	~		|

CO2_conc_in_warm_surface_water_in_ppm=
	CC_in_warm_surface_ymoles_per_litre * Conversion_ymoles_per_kg_to_pCO2_yatm
	~	ppm
	~	For display only
	~	:SUPPLEMENTARY 
	|

CO2_concentration_2020=
	426
	~	ppm [400,450,5]
	~		|

CO2_concentration_ppm=
	CO2_concentration_used_after_any_experiments_ppm
	~	ppm
	~		|

CO2_concentration_ppm_in_1850=
	284.725
	~	ppm
	~	Read off of the 1850 value from the ESMICON full model (from 1980) run
	|

CO2_concentration_ratio_wrt_2020=
	IF_THEN_ELSE(Time < 2020, 1, CO2_concentration_used_after_any_experiments_ppm / CO2_concentration_2020\
		)
	~	1
	~		|

CO2_concentration_used_after_any_experiments_ppm=
	MODEL_CO2_concentration_in_atmosphere2_ppm
	~	ppm
	~		|

GRASS_area_burnt_Mkm2= INTEG (
	GRASS_burning_Mkm2_py-GRASS_regrowing_after_being_burnt_Mkm2_py,
		GRASS_area_burned_in_1980)
	~	Mkm2
	~		|

CO2_emissions_before_co2e_exp=
	 Emissions_of_CO2_1850_to_2100_GtC_py* RCPFossil_fuel_usage_cutoff
	~	GtC/yr
	~		|

GRASS_area_harvested_Mkm2= INTEG (
	GRASS_being_harvested_Mkm2_py-GRASS_regrowing_after_harvesting_Mkm2_py,
		GRASS_area_harvested_in_1980)
	~	Mkm2
	~		|

CO2_flow_from_NF_to_atmosphere_GtC_py=
	(NF_Biomass_in_construction_material_being_burnt
	+ NF_Dead_biomass_decomposing
	+ NF_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting
	+ NF_DeadB_SOM_being_lost_due_to_deforestation
	+ NF_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ NF_soil_degradation_from_clear_cutting
	+ NF_soil_degradation_from_forest_fires
	+ NF_runoff) * Carbon_per_biomass
	~	GtC/yr
	~		|

GRASS_Avg_life_of_building_yr=
	10
	~	yr
	~		|

GRASS_being_deforested_Mkm2_py=
	 GRASS_with_normal_cover_Mkm2 * Fraction_GRASS_being_deforested_1_py
	~	Mkm2/yr
	~	pos is deforestation, neg is afforestation planting trees is best modeled \
		by making the slope of effect of temp shifting GRASS to TROP steeper
	|

CO2_flux_from_atm_to_GRASS_for_new_growth_GtC_py=
	GRASS_biomass_new_growing * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flux_from_atm_to_NF_for_new_growth_GtC_py=
	 NF_biomass_new_growing * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flux_from_atm_to_TROP_for_new_growth_GtC_py=
	TROP_biomass_new_growing * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flux_from_atm_to_TUNDRA_for_new_growth=
	 TUNDRA_biomass_new_growing * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flux_GRASS_to_atm_GtC_py=
	CO2_flow_from_GRASS_to_atmosphere_GtC_py
	~	GtC/yr
	~		|

CO2_flux_NF_to_atm_GtC_py=
	CO2_flow_from_NF_to_atmosphere_GtC_py
	~	GtC/yr
	~		|

CO2_flux_TROP_to_atm_GtC_py=
	CO2_flow_from_TROP_to_atmosphere_GtC_py
	~	GtC/yr
	~		|

CO2_flux_TUNDRA_to_atm=
	CO2_flow_from_TUNDRA_to_atmosphere
	~	GtC/yr
	~		|

GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass= INTEG (
	GRASS_Biomass_in_construction_material_left_to_rot+GRASS_Living_biomass_rotting-GRASS_Dead_biomass_decomposing\
		-GRASS_DeadB_SOM_being_lost_due_to_deforestation-GRASS_DeadB_SOM_being_lost_due_to_energy_harvesting\
		-GRASS_runoff-GRASS_soil_degradation_from_forest_fires,
		GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980)
	~	GtBiomass
	~		|

GRASS_DeadB_and_SOM_tB_per_km2=
	GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / GRASS_with_normal_cover_Mkm2\
		 * 1000
	~	GtBiomass/Mkm2
	~		|

GRASS_DeadB_SOM_being_lost_due_to_deforestation=
	GRASS_being_deforested_Mkm2_py * GRASS_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting\
		 * GRASS_DeadB_and_SOM_tB_per_km2 / 1000
	~	GtBiomass/yr
	~	/ 1000 to convert M (illion) to G (iga)
	|

GRASS_DeadB_SOM_being_lost_due_to_energy_harvesting=
	GRASS_being_harvested_Mkm2_py * GRASS_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting\
		 * GRASS_DeadB_and_SOM_tB_per_km2 / 1000
	~	GtBiomass/yr
	~		|

GRASS_deforested_Mkm2= INTEG (
	GRASS_being_deforested_Mkm2_py-GRASS_regrowing_after_being_deforested_Mkm2_py,
		GRASS_area_deforested_in_1980)
	~	Mkm2
	~		|

pct_change_in_fraction_blocked_by_ALL_GHG_wrt_1980=
	(Frac_blocked_by_ALL_GHG - Fraction_blocked_by_ALL_GHG_in_1980) / Fraction_blocked_by_ALL_GHG_in_1980\
		 * 100
	~	fraction
	~		~	:SUPPLEMENTARY 
	|

pct_change_in_fraction_blocked_by_C02_wrt_1980=
	(Blocked_by_CO2 - Fraction_blocked_CO2_in_1980) / Fraction_blocked_CO2_in_1980 * 100
	~	fraction
	~		~	:SUPPLEMENTARY 
	|

pct_change_in_fraction_blocked_by_CH4_wrt_1980=
	(Blocked_by_CH4 - Fraction_blocked_CH4_in_1980) / Fraction_blocked_CH4_in_1980 * 100
	~	fraction
	~		~	:SUPPLEMENTARY 
	|

pct_change_in_fraction_blocked_by_othGHG_wrt_1980=
	(Blocked_by_otherGHG - Fraction_blocked_othGHG_in_1980) / Fraction_blocked_othGHG_in_1980\
		 * 100
	~	fraction
	~		~	:SUPPLEMENTARY 
	|

GRASS_living_biomass_densitiy_in_1850_tBiomass_pr_km2=
	14500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

GRASS_living_biomass_densitiy_tBiomass_pr_km2=
	GRASS_living_biomass_densitiy_in_1850_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl
	~	tB/km2
	~		|

GRASS_Living_biomass_GtBiomass= INTEG (
	GRASS_biomass_new_growing-GRASS_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting\
		-GRASS_for_construction_use-GRASS_Living_biomass_rotting,
		GRASS_Living_biomass_in_1980)
	~	GtBiomass
	~		|

GRASS_Living_biomass_in_1850=
	310
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

GRASS_Living_biomass_in_1980=
	381.43
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

GRASS_Living_biomass_rotting=
	GRASS_Living_biomass_GtBiomass / GRASS_Avg_life_biomass_yr
	~	GtBiomass/yr
	~		|

GRASS_Normal_fire_incidence_fraction_py=
	1
	~	fraction/yr
	~	guess
	|

per_annum_yr=
	1
	~	yr [0,5,1]
	~	we calculate the change per annum
	|

GRASS_potential_less_actual_living_biomass_GtBiomass=
	GRASS_potential_living_biomass_GtBiomass - GRASS_Living_biomass_GtBiomass
	~	GtBiomass
	~		|

GRASS_potential_living_biomass_GtBiomass=
	( GRASS_potential_area_Mkm2 - GRASS_deforested_Mkm2 ) * GRASS_living_biomass_densitiy_tBiomass_pr_km2\
		 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass
	~	/ 1000 converts M(illion) to G(iga)
	|

GRASS_Ref_historical_deforestation_pct_py=
	0.1
	~	1/yr
	~	[Source: guess, so far]
	|

GRASS_regrowing_after_being_burnt_Mkm2_py=
	GRASS_area_burnt_Mkm2 / Time_to_regrow_GRASS_yr
	~	Mkm2/yr
	~		|

GRASS_regrowing_after_being_deforested_Mkm2_py=
	GRASS_deforested_Mkm2 / Time_to_regrow_GRASS_after_deforesting_yr
	~	Mkm2/yr
	~		|

GRASS_regrowing_after_harvesting_Mkm2_py=
	GRASS_area_harvested_Mkm2 / Time_to_regrow_GRASS_yr
	~	Mkm2/yr
	~		|

GRASS_runoff=
	GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / GRASS_runoff_time
	~	GtBiomass/yr
	~		|

Permafrost_area_km2=
	C_in_permafrost_in_form_of_CH4 /Avg_amount_of_C_in_the_form_of_CH4_per_km2
	~	km2
	~		~	:SUPPLEMENTARY 
	|

Permafrost_melting_cutoff= WITH LOOKUP (
	C_in_permafrost_in_form_of_CH4,
		 ([(0,0)-(200,1)],(0,0),(50,0.6),(100,0.9),(150,0.965),(200,1) ))
	~	dimensionless
	~	Our release formulation depends only on temperature, thus a cutoff needs \
		to be formulated so that no C is released when there is no more in the \
		ground.
	|

pH_in_cold_deep_water=
	UNIT_conversion_C_to_pH * (1 - 0.0017 * Temp_ocean_deep_in_C - 0.0003) * (163.2 * CC_in_deep_box_ymoles_per_litre_dmnl\
		^(-0.385))
	~	pH
	~	Formula calculated from R-code (converted to PHP) from this site \
		http://biocycle.atmos.colostate.edu/shiny/carbonate/ from the Scott \
		Denning research group at Colorado State \
		http://biocycle.atmos.colostate.edu/ see Tab "Toy Models" for more neat \
		models
	~	:SUPPLEMENTARY 
	|

ph_in_cold_downwelling_water=
	UNIT_conversion_C_to_pH * (1 - 0.0017 * Temp_of_cold_downwelling_water - 0.0003) * (\
		163.2 * CC_in_cold_downwelling_ymoles_per_litre_dmnl^(-0.385))
	~	pH
	~	Formula calculated from R-code (converted to PHP) from this site \
		http://biocycle.atmos.colostate.edu/shiny/carbonate/ from the Scott \
		Denning research group at Colorado State \
		http://biocycle.atmos.colostate.edu/ see Tab "Toy Models" for more neat \
		models
	|

pH_in_cold_suface_water=
	UNIT_conversion_C_to_pH * (1 - 0.0017 * Temp_of_cold_surface_water - 0.0003) * (163.2\
		 * CC_in_cold_surface_ymoles_per_litre_dmnl^(-0.385))
	~	pH
	~		|

pH_in_surface=
	pH_in_warm_surface_water * Volume_warm_ocean_0_to_100m / (Volume_warm_ocean_0_to_100m\
		 + Volume_cold_ocean_0_to_100m) + 
	pH_in_cold_suface_water * Volume_cold_ocean_0_to_100m / (Volume_warm_ocean_0_to_100m\
		 + Volume_cold_ocean_0_to_100m)
	~	pH
	~		|

pH_in_upwelling_water=
	UNIT_conversion_C_to_pH * (1 - 0.0017 * ((Temp_ocean_deep_in_C + Temp_surface ) / 2)\
		 - 0.0003) * (163.2 * CC_in_intermediate_box_ymoles_per_litre_dmnl^(-0.385))
	~	pH
	~	Formula calculated from R-code (converted to PHP) from this site \
		http://biocycle.atmos.colostate.edu/shiny/carbonate/ from the Scott \
		Denning research group at Colorado State \
		http://biocycle.atmos.colostate.edu/ see Tab "Toy Models" for more neat \
		models
	~	:SUPPLEMENTARY 
	|

pH_in_warm_surface_water=
	UNIT_conversion_C_to_pH * (1 - 0.0017 * Temp_surface - 0.0003) * (163.2 * CC_in_warm_surface_ymoles_per_litre_dmnl\
		^(-0.385))
	~	pH
	~	Formula calculated from R-code (converted to PHP) from this site \
		http://biocycle.atmos.colostate.edu/shiny/carbonate/ from the Scott \
		Denning research group at Colorado State \
		http://biocycle.atmos.colostate.edu/ see Tab "Toy Models" for more neat \
		models
		162.9
	|


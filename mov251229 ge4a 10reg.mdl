	~		|

Fraction_blocked_by_ALL_GHG_in_1980=
	0.213577
	~	fraction [0,2,0.1]
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1980 value
	|

Fraction_blocked_by_CH4_spectrum= WITH LOOKUP (
	CH4_concentration_ppb,
		([(0,0)-(1e+06,0.2)],(0,0),(350,0.0028),(700,0.0042),(1200,0.0056),(1700,0.007),(3000\
		,0.0106),(5000,0.0125),(7000,0.013477),(10000,0.0153945),(20000,0.0201881),(40000,0.0259404\
		),(70000,0.0316927),(100000,0.0355276),(150000,0.0403212),(250000,0.0456888),(500000\
		,0.0539356),(1e+06,0.0625641),(1e+07,0.0954476),(1e+08,0.130154),(5e+08,0.152204),(\
		9e+08,0.159776),(1e+09,0.16112) ))
	~	fraction
	~	http://scienceofdoom.com/2010/03/30/how-much-work-can-one-molecule-do/ \
		http://climatemodels.uchicago.edu/modtran/ U Chicago David Archer, see his \
		book for detail http://geosci.uchicago.edu/directory/david-archer
	|

Fraction_blocked_by_CO2_spectrum= WITH LOOKUP (
	CO2_concentration_ppm,
		([(0,0)-(1000,0.2)],(0,0),(40,0.0508772),(100,0.0756579),(200,0.085978),(285,0.091138\
		),(300,0.0919195),(400,0.0960065),(500,0.0993184),(570,0.10117),(600,0.1019),(800,0.106134\
		),(1000,0.109347),(10000,0.146835) ))
	~	fraction
	~	http://climatemodels.uchicago.edu/modtran/ U Chicago David Archer, see his \
		book for detail http://geosci.uchicago.edu/directory/david-archer Note \
		that altitude should be set to 17km looking down, by default the model on \
		the site looks down from 70km: "The main reason for that is in the \
		influence of stratosphere. Radiative forcing is defined as a change in the \
		flux just above troposphere after stratospheric temperatures have reached \
		the new radiative energy balance, i.e., after the stratosphere has cooled. \
		UChicago MODTRAN does not allow for cooling stratosphere. Results \
		calculated at 17 km looking down are closer to the correct ones, but fully \
		correct values require a model that makes the stratospheric corrections." \
		We use tropical atm looking down from 70km because that is closest to \
		Myhre 1998 New estimates of radiative forcing due to well mixed green \
		house gases.
	|

Fraction_blocked_by_other_GHG=
	LW_radiation_fraction_blocked_by_other_GHG_in_1850 * LW_Blocking_multiplier_from_other_GHG
	~	fraction
	~		|


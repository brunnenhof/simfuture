Fossil_fuels_for_el_gen[region]=
	El_gen_from_fossil_fuels[region] / Conversion_Mtoe_to_TWh[region]
	~	Mtoe/Year
	~		|

kWh_per_kgH=
	55
	~	kWh/kgH
	~	Source: \
		https://www.sidmartinbio.org/how-much-water-does-it-take-to-produce-1kg-of-\
		hydrogen/
	|

Fossil_use_pp_NOT_for_El_gen_CN=
	Fossil_use_pp_NOT_for_El_gen_CN_a + Fossil_use_pp_NOT_for_El_gen_CN_b * (LN(GDPpp_USED\
		[cn] * UNIT_conv_to_make_exp_dmnl))
	~	1

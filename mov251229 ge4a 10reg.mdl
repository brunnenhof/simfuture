toe_to_CO2_b[region]=
	1, 0, -0.0036, 0.1599, 0.1, 0.15, 0.8, 0.0347, 1, 0.1
	~	GtCO2/y [-1,2,0.05]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c171' )
	|

El_from_wind_and_PV[region]=
	wind_and_PV_el_capacity[region] * wind_and_PV_capacity_factor[region] * Hours_per_year\
		 * UNIT_conv_GWh_and_TWh
	~	TWh/Year
	~		|

El_gen_from_fossil_fuels[region]=
	Fossil_el_gen_cap[region] * Hours_per_year * Fossil_actual_uptime_factor[region] * UNIT_conv_GWh_and_TWh
	~	TWh/Year
	~		|

UNIT_conv_toe_to_Mtoe=
	1
	~	(Mtoe*p)/(Mp*toe)
	~	The Vensim unit parsr does not know the Mp/p = M
	|

Global_Total_CO2_emissions=
	SUM ( Total_CO2_emissions[region!] )
	~	GtCO2/Year
	~		|

CO2_emi_from_IPC2_use_b[region]=
	0.7855, -0.0029, -0.5722, -0.35, 0.0396, -0.1619, 0.0264, 0.4819, 0.4481, -0.0839
	~	GtCO2/yr
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c169' )
	|

CO2_from_fossil_fuels_to_atm[region]=
	MAX( 0 , toe_to_CO2_a[region] * ( Total_use_of_fossil_fuels_NOT_compensated[region] \
		* UNIT_conv_to_Gtoe) + toe_to_CO2_b[region])
	~	GtCO2/Year
	~		|

El_use_pp_US_h=
	55
	~	Dmnl
	~		|

El_use_pp_US_k=
	18
	~	Dmnl
	~		|

Lifetime_of_wind_and_PV_el_cap=
	40
	~	y
	~		|

El_use_pp_WO_US[region]=
	El_use_pp_WO_US_L[region] / (1 + EXP(-El_use_pp_WO_US_k[region] * ((GDPpp_USED[region\
		] * UNIT_conv_to_make_exp_dmnl) - El_use_pp_WO_US_x0[region])))

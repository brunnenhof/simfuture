		[region] * Smoothed_Multplier_from_empowerment_on_speed_of_food_TA
	[region]
	~	1
	~		|

ExPS_policy_with_RW[region]=
	ExPS_rounds_via_Excel[region] * Smoothed_Reform_willingness[region]
	~	1
	~		|

Effect_of_heat_in_atm_on_melting_ice_cut_off= WITH LOOKUP (
	Heat_in_atmosphere_current_to_initial_ratio,
		([(0,0)-(1,1)],(0,0),(0.16,0.85),(0.5,1),(1,1) ))
	~	dimensionless
	~	Melting is modeled as a function of surface temp, but the heat to melt ice \
		comes mostly from the atmosphere (only floating arctic ice is partially \
		melted through heat in the upper ocean). Since the atmospheric heat \
		reservoir is very tiny, there needs to be an effect from that reservoir to \
		limit melting if and when the reservoir is close to being depleted, for \
		whatever reason. One reason could be the large scale experimental (in this \
		model) release of methane hydrates.
	|

Snowball_earth_cutoff= WITH LOOKUP (
	Land_covered_with_ice_to_land_area_ratio,
		([(0.8,0)-(1,1)],(0.8,1),(0.9,0.97),(0.97,0.75),(1,0) ))
	~	dimensionless
	~	If the earth is mostly covered in ice, additional freezing stops. This is \
		a crutch due to the way we drew the system boundaries. In reality, water \
		would evaporate, lower the oceans, shift the ocean / land balance and \
		finally increase the volume of ice.
	|

RCPFossil_fuel_usage_cutoff= WITH LOOKUP (
	Fossil_fuel_reserves_in_ground_current_to_inital_ratio,
		([(0,0)-(1,1)],(0,0),(0.25,0.657895),(0.5,0.881579),(0.75,0.960526),(1,1) ))
	~	dimensionless
	~	To prevent using more fossil fuels than there are - a typical JW Forrester \
		formulation
	|

Arctic_freezing_cutoff= WITH LOOKUP (
	Arctic_ice_on_sea_area_to_arctic_ice_area_max_ratio,
		([(0.8,0)-(1,1)],(0.8,1),(0.899694,0.934211),(0.949847,0.710526),(1,0) ))
	~	dimensionless
	~	Again, a crutch to prevent more area to be covered by sea ice than the \
		ocean has. Our model system boundary does not really include freezing at a \
		very large scale (aka the snowball earth), still some experiments may lead \
		to a significantly colder earth and in order not to get tripped up by \
		impossible outcomes (eg more ocean square km freezing than the ocean has) \
		this cut off exists.
	|

Melting_restraint_for_permafrost_from_heat_in_atmophere= WITH LOOKUP (
	Heat_in_atmosphere_needed_to_available_ratio,
		([(0,0)-(0.5,1)],(0,1),(0.4,0.95),(0.45,0.75),(0.5,0.01) ))
	~	dimensionless
	~		|

Perceived_inventory_ratio[region]=
	SMOOTH3 ( Inventory_coverage_to_goal_ratio[region] , Time_required_for_inventory_fluctuations_to_impact_inflation_rate
	 )
	~	1
	~		|

Effective_purchasing_power[region]=
	SMOOTHI ( Consumption_and_investment[region] , Demand_adjustment_time , Demand_in_1980\
		[region] )
	~	G2017pppUSD/y
	~		|

Perceived_relative_inventory[region]=
	SMOOTHI (Inventory_coverage_to_goal_ratio[region], Inventory_coverage_perception_time\
		, Perceived_relative_inventory_in_1980
	[region] )
	~	1
	~		|

Desired_crop_import[region]=
	SMOOTHI ( Desired_crop_import_indicated[region] , One_year , Reference_crop_import_in_1980\
		[region])
	~	Mtac/Year
	~		|

FMPLDD_policy[region]=
	SMOOTH3(FMPLDD_policy_converted_to_pa[region], Time_to_implement_UN_policies[region]\
		)
	~	1/Year
	~		|

Future_leakage[region]=
	SMOOTH3(Future_leakage_indicated[region] , Time_to_implement_UN_policies[region])
	~	Dmnl
	~		|

TOW_policy[region]=
	SMOOTH3(TOW_policy_converted_to_pa[region], Time_to_implement_UN_policies[region])
	~	1/Year
	~		|

Thermal_expansion_surface_anfang_pct= WITH LOOKUP (
	Temp_surface_anfang_less_zero_k,
		([(0,0)-(20,0.2)],(0,0.015),(1,0.008),(2,0.0033),(3,0.001),(4,0),(5,0.0012),(6,0.0033\
		),(7,0.008),(8,0.013),(9,0.021),(
		10,0.0287),(20,0.1963) ))
	~	dimensionless
	~	Original graph here http://physics.info/expansion/ data read off, curve \
		fitted in Excel
	|

RIPLGF_policy[region]=
	SMOOTH3(RIPLGF_pol_div_100[region], RIPLGF_smoothing_time[region]
	)
	~	1
	~		|

Future_volcanic_emissions_shape=
	IF_THEN_ELSE(Future_volcanic_eruptions_1_is_ON_0_is_OFF=0, 0, 
	Future_volcanic_emissions_shape_pulse_train)
	~	GtVAe/yr
	~	PULSE TRAIN( {start} , {duration} , {repeattime} , {end} ); 2.1e+006 is \
		the end time, ie never
	|

SGRPI_policy[region]=
	SMOOTH3(SGRPI_pol_div_100[region], Time_to_implement_SGRPI_policy[region]
	)
	~	1
	~		|

Ctax_policy[region]=
	SMOOTH3(Ctax_policy_with_inequality_effect[region], Ctax_Time_to_implement_goal)
	~	Dmnl
	~		|

Carbon_intensity[region]=
	(Total_CO2_emissions[region] - Actual_CO2_taken_directly_out_of_the_atmosphere_ie_direct_air_capture\
		[region]) / GDP_USED[region] * UNIT_conv_to_tCO2_pr_USD
	~	kgCO2/USD
	~		|

Actual_inequality_index_higher_is_more_unequal[region]=
	SMOOTH3I ( Indicated_inequality_index_with_tax[region] , Time_for_inequality_to_impact_wellbeing\
		 , 1)
	~	Dmnl
	~		|

NF_living_biomass_densitiy_tBiomass_pr_km2=
	NF_living_biomass_densitiy_in_1850_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl * Smoothed_Forest_land_rel_to_init
	~	tB/km2
	~		|

TROP_living_biomass_densitiy_tBiomass_pr_km2=
	TROP_living_biomass_densitiy_in_1850_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl * Smoothed_Forest_land_rel_to_init
	~	tB/km2
	~		|

future_deforestation[region]=
	IF_THEN_ELSE(Time > Policy_start_year, Forest_land[region] * Fraction_deforested[region\
		],0)
	~	Mha/Year
	~		|

Forest_land[region]= INTEG (
	acgl_to_fa[region]-historical_deforestation[region]+Reforestation_policy[region]-fa_to_c\
		[region]-fa_to_gl[region]-future_deforestation[region],
		Forest_land_in_1980[region])
	~	Mha
	~	History Calculated from Hyde 3.2 (https://www.pbl.nl/en/image/data#HYDE%20data)
		Scripts: get_hydedata.R and plot_process_hydedata.R
	|

Barren_land_which_is_ice_and_snow[region]= INTEG (
	future_deforestation[region]+historical_deforestation[region]-Reforestation_policy[region\
		],
		Barren_land_in_1980[region])
	~	Mha
	~	History Calculated from Hyde 3.2 (https://www.pbl.nl/en/image/data#HYDE%20data)
		Scripts: get_hydedata.R and plot_process_hydedata.R
	|

El_from_nuclear[region]=
	Nuclear_gen_cap_after_depreciation[region] * Nuclear_capacity_factor * Hours_per_year\
		 * UNIT_conv_GWh_and_TWh
	~	TWh/Year
	~		|

Nuclear_gen_cap[region]=
	IF_THEN_ELSE( region = eu, Nuclear_gen_cap_EU, Nuclear_gen_cap_WO_EU[region])
	~	GW
	~		|

Hydro_gen_cap[region]=
	(Hydro_gen_cap_L[region] / ( 1 + EXP ( - Hydro_gen_cap_k[region] * ( (GDPpp_USED[region\
		] * UNIT_conv_to_make_exp_dmnl) -
	 Hydro_gen_cap_x0[region]) ) )) * Hydro_net_depreciation_multiplier_on_gen_cap
	~	GW
	~		|

Renewable_energy_share_in_the_total_final_energy_consumption[region]=
	El_from_wind_and_PV[region] / (El_from_all_sources[region] + Fossil_fuel_for_NON_El_use_that_IS_NOT_being_electrified\
		[region
	] * Conversion_Mtoe_to_TWh[region])
	~	1
	~		|

Worker_interest_payment_obligation[region]=
	Workers_debt[region] * Cost_of_capital_for_worker_borrowing_smoothed[region] * Effect_of_defaulting_on_debt_obligations_on_cost_of_capital_for_worker_borrowing
	[region]
	~	G2017pppUSD/Year
	~		|

SDG_12_Score[region]=
	IF_THEN_ELSE(Food_footprint_kgN_ppy[region] < SDG_12_threshold_green_PES, 1, IF_THEN_ELSE\
		(Food_footprint_kgN_ppy[region] < 
	SDG_12_threshold_red_PES
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries with addition from PES July 2024 who uses \
		https://www.science.org/doi/10.1126/sciadv.adh2458 as a more up to date \
		source
	|

Long_term_interest_rate_applied[region]=
	Long_term_interest_rate_used_by_public_lenders[region] 
	+ Effect_of_public_loan_defaults_on_interest_rate[region]
	~	1/Year
	~		|

Total_consumption[region]=
	Worker_consumption_demand[region] + Govt_consumption_ie_purchases[region] + Owner_consumption\
		[region] - Consumption_taxes[region]
	~	G2017pppUSD/y
	~		|

FPGDC_contribution_to_GL[region]=
	FPGDC_logically_constrained[region] * Public_Debt_cancelling_pulse[region] / UNIT_conv_to_1_per_yr\
		 / UNIT_conv_to_1_per_yr
	~	1
	~	The contribution to GL is not the entire policy over time, but actually \
		only when the cancellation pulse occurs.
	|

StrUP_pol_div_100[region]=
	MIN( StrUP_policy_Max, MAX( StrUP_policy_Min , StrUP_policy_with_RW[region])) / 100
	~	Dmnl
	~		|

StrUP_policy[region]=
	SMOOTH3(StrUP_pol_div_100[region], StrUP_Time_to_implement_policy)
	~	Dmnl
	~		|


	Time,
		 ([(0,0)-(10,10)],(1980,0.82),(1981,0.82),(1982,0.85),(1983,0.89),(1984,0.89),(1985\
		,0.91),(1986,0.92),(1987,0.93),(1988,0.92),(1989,0.88),(1990,0.84),(1991,0.78),(1992\
		,0.73),(1993,0.68),(1994,0.6),(1995,0.56),(1996,0.53),(1997,0.53),(1998,0.51),(1999\
		,0.49),(2000,0.49),(2001,0.49),(2002,0.5),(2003,0.48),(2004,0.51),(2005,0.5),(2006,\
		0.5),(2007,0.5),(2008,0.53),(2009,0.53),(2010,0.51),(2011,0.54),(2012,0.52),(2013,0.55\
		),(2014,0.55),(2015,0.56),(2016,0.59),(2017,0.59),(2018,0.61),(2019,0.61) )) ~~|
N2O_emi_from_agri_hist_table[eu]= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,0.78),(1981,0.77),(1982,0.79),(1983,0.79),(1984,0.8),(1985,\
		0.8),(1986,0.81),(1987,0.8),(1988,0.79),(1989,0.79),(1990,0.78),(1991,0.75),(1992,0.72\
		),(1993,0.7),(1994,0.69),(1995,0.7),(1996,0.71),(1997,0.71),(1998,0.71),(1999,0.71)\
		,(2000,0.7),(2001,0.69),(2002,0.68),(2003,0.67),(2004,0.68),(2005,0.67),(2006,0.66)\
		,(2007,0.67),(2008,0.66),(2009,0.65),(2010,0.65),(2011,0.65),(2012,0.66),(2013,0.67\
		),(2014,0.69),(2015,0.68),(2016,0.69),(2017,0.7),(2018,0.69),(2019,0.69) )) ~~|
N2O_emi_from_agri_hist_table[se]= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,0.18),(1981,0.18),(1982,0.19),(1983,0.2),(1984,0.2),(1985,0.2\
		),(1986,0.21),(1987,0.22),(1988,0.22),(1989,0.22),(1990,0.23),(1991,0.23),(1992,0.24\
		),(1993,0.25),(1994,0.25),(1995,0.26),(1996,0.27),(1997,0.27),(1998,0.27),(1999,0.27\
		),(2000,0.27),(2001,0.27),(2002,0.28),(2003,0.29),(2004,0.3),(2005,0.31),(2006,0.31\
		),(2007,0.32),(2008,0.33),(2009,0.34),(2010,0.35),(2011,0.35),(2012,0.36),(2013,0.36\
		),(2014,0.36),(2015,0.35),(2016,0.37),(2017,0.39),(2018,0.39),(2019,0.39) ))
	~	MtN2O/y
	~	Source: https://www.fao.org/faostat/en/#data/EMN
		Script: plot5_process_faodata.R
	~	:SUPPLEMENTARY 
	|

Inequality_considered_normal_in_1980[region]=
	1.1
	~	Dmnl
	~		|

Weight_disposable_income=
	1
	~	1
	~		|

Global_Population_below_2p5_kusd_p_py=
	SUM ( Population_below_2p5_kusd_ppy[region!] )
	~	Mp
	~		~	:SUPPLEMENTARY 
	|

Weight_food=
	1
	~	1
	~		|

Weight_inequality=
	0.1
	~	Dmnl
	~		|

Wellbeing_from_white_meat[region]=
	( 1 / ( stdev * SQRT( 2 * 3.14142 ))) * EXP( -(( Ratio_of_actual_to_healthy_white_meat\
		[region] - mean_value)^2)/(2* stdev ^2))
	~	1
	~		|

Weight_on_living_conditions=
	0.65
	~	Dmnl
	~		|

Weight_on_physical_conditions=
	0.75
	~	Dmnl
	~		|

Population_below_2p5_kusd_ppy[region]=
	Population[region] * Fraction_of_population_below_existential_minimum[region]
	~	Mp
	~	is the equivalent of 6.85 $ per person per year
	|

Weight_on_red_meat=
	0.25
	~	Dmnl
	~		|

Logistic_k[region]=
	Normal_k * JR_inequality_effect_on_logistic_k[region]
	~	1
	~		|

Wellbeing_from_crops[region]=
	( 1 / ( stdev * SQRT( 2 * 3.14142 ))) * EXP( -(( Ratio_of_actual_to_healthy_all_crop\
		[region] - mean_value)^2)/(2* stdev
	 ^2))
	~	1
	~		|

Wellbeing_from_disposable_income[region]=
	Worker_cash_inflow_seasonally_adjusted_pp[region] / Disposable_income_threshold_for_wellbeing
	~	1
	~		|

Worker_cash_inflow_seasonally_adjusted_pp[region]=
	Worker_cash_inflow_seasonally_adjusted[region] / Population[region]
	~	G2017pppUSD/(Year*Mp)
	~		|

Wellbeing_from_food[region]=
	( Wellbeing_from_white_meat[region] * Weight_on_white_meat + 
	Wellbeing_from_red_meat[region] * Weight_on_red_meat + 
	Wellbeing_from_crops[region] * Weight_on_crops ) 
	/ Sum_of_food_weights
	~	1
	~		|

Wellbeing_from_inequality[region]=
	1 / Actual_inequality_index_higher_is_more_unequal[region]
	~	1
	~		|

Wellbeing_from_population_with_regular_job[region]=
	1 + Slope_of_wellbeing_from_fraction_of_people_outside_of_labor_pool * ( Frac_outside_of_labour_pool_in_1980\
		[region] / Fraction_of_people_outside_of_labour_market_FOPOLM[region] - 1 )
	~	Dmnl
	~		|

Wellbeing_from_red_meat[region]=
	( 1 / ( stdev * SQRT( 2 * 3.14142 ))) * EXP( -(( Ratio_of_actual_to_healthy_red_meat\
		[region] - mean_value)^2)/(2* stdev ^2))
	~	1
	~		|

Ratio_of_actual_to_healthy_all_crop[region]=
	all_crop_not_wasted_pp[region] / Healthy_all_crop_consumption
	~	1
	~		|

Healthy_all_crop_consumption=
	800
	~	kg/(y*p)
	~		|

Ratio_of_actual_to_healthy_white_meat[region]=
	white_meat_not_wasted_pp[region] / Healthy_white_meat_consumption
	~	1
	~		|

Change_in_social_trust[region]=
	( Indicated_social_trust[region] - Social_trust[region] ) / Time_to_change_social_trust
	~	stu/Year
	~		|

Food_footprint[region]=

	~		|

Fraction_of_available_capital_to_new_capacity[region]=
	(WSO_effect_on_available_capital[region] + Corporate_borrowing_cost_eff_on_available_capital\
		[region] + Eff_of_dmd_imbalance_on_flow_of_available_capital[region])/3

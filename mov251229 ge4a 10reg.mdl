		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_50_to_54[region]=
	Cohort_50_to_54[region] * death_rate_dr50[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_70_to_74[region]=
	Cohort_70_to_74[region] * death_rate_dr70[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_55_to_59[region]=
	Cohort_55_to_59[region] * death_rate_dr55[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_35_to_39[region]=
	Cohort_35_to_39[region] * death_rate_dr35[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_60_to_64[region]=
	Cohort_60_to_64[region] * death_rate_dr60[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_40_to_45[region]=
	Cohort_40_to_44[region] * death_rate_dr40[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_85_to_89[region]=
	Cohort_85_to_89[region] * death_rate_dr85[region] * mort_85_to_89_adjust_factor[region\
		] * Eff_of_env_damage_on_dying[region
	] * Effect_of_malnutrition_on_dying_smoothed[region] * Effect_of_poverty_on_dying_smoothed\
		[region]  * Inequality_effect_on_mortality[region]
	~	Mp/y
	~		|

dying_90_to_94[region]=
	Cohort_90_to_94[region] * death_rate_dr90[region] * mort_90_to_94_adjust_factor[region\
		] * Eff_of_env_damage_on_dying[region
	] * Effect_of_malnutrition_on_dying_smoothed[region] * Effect_of_poverty_on_dying_smoothed\
		[region]  * Inequality_effect_on_mortality[region]
	~	Mp/y
	~		|

dying_95p[region]=
	Cohort_95p[region] * death_rate_dr95_plus[region] * mort_95plus_adjust_factor[region\
		] * Eff_of_env_damage_on_dying[region
	] * Effect_of_malnutrition_on_dying_smoothed[region] * Effect_of_poverty_on_dying_smoothed\
		[region] * Inequality_effect_on_mortality[region]
	~	Mp/y
	~		|

dying_80_to_84[region]=
	Cohort_80_to_84[region] * death_rate_dr80[region] * mort_80_to_84_adjust_factor[region\
		] * Eff_of_env_damage_on_dying[region
	] * Effect_of_malnutrition_on_dying_smoothed[region] * Effect_of_poverty_on_dying_smoothed\
		[region]  * Inequality_effect_on_mortality[region]
	~	Mp/y
	~		|

dying_75_to_79[region]=
	Cohort_75_to_79[region] * death_rate_dr75[region] * Eff_of_env_damage_on_dying[region\
		] * Effect_of_malnutrition_on_dying_smoothed
	[region] * Effect_of_poverty_on_dying_smoothed[region]  * Inequality_effect_on_mortality\
		[region]
	~	Mp/y
	~		|

dying_0_to_4[region]=
	Cohort_0_to_4[region] * death_rate_dr0[region] * Eff_of_env_damage_on_dying[region] \
		* Effect_of_malnutrition_on_dying_smoothed[region] * Effect_of_poverty_on_dying_smoothed\
		[region] * Inequality_effect_on_mortality[region]
	~	Mp/y
	~		|

GDPpp_model[region]=
	GDP_model[region] / Population[region] * UNIT_conv_to_k2017pppUSD_pr_py[region]
	~	k2017pppUSD/(Year*p)
	~		|

Theoretical_fraction_of_people_60plus_drawing_a_pension[region]=
	MAX(0,(Max_age - Pension_age[region])/Years_between_60_and_max_age)
	~	1
	~		|

Eff_of_env_damage_on_dying[region]=
	SMOOTH (Indicated_Eff_of_env_damage_on_dying[region] , Time_lag_for_env_damage_to_affect_mortality\
		)
	~	1
	~	We assume damage to be exponentially rising - the parameters are so far \
		educated guesses, which they have to be, since we are moving into \
		territory where humanity has never been.
	|

death_rate_dr35[region]=
	dr35_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr35_b[region]
	~	1/y
	~		|

death_rate_dr45[region]=
	dr45_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr45_b[region]
	~	1/y
	~		|

death_rate_dr50[region]=
	dr50_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr50_b[region]
	~	1/y
	~		|

death_rate_dr55[region]=
	dr55_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr55_b[region]
	~	1/y
	~		|

death_rate_dr60[region]=
	dr60_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr60_b[region]
	~	1/y
	~		|

death_rate_dr70[region]=
	dr70_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr70_b[region]
	~	1/y
	~		|

death_rate_dr75[region]=
	dr75_a[region] * ((GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr75_b[region]
	~	1/y
	~		|

death_rate_dr80[region]=
	dr80_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr80_b[region]
	~	1/y
	~		|

death_rate_dr85[region]=
	dr85_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr85_b[region]
	~	1/y
	~		|

death_rate_dr90[region]=
	dr90_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr90_b[region]
	~	1/y
	~		|

death_rate_dr95_plus[region]=
	dr95p_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr95p_b[region]
	~	1/y
	~		|

death_rate_dr0[region]=
	dr0_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		) ^ dr0_b[region])
	~	1/y
	~		|

death_rate_dr40[region]=
	dr40_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr40_b[region]
	~	1/y
	~		|

death_rate_dr65[region]=
	dr65_a[region] * (( GDPpp_USED_for_influencing_death_rates[region] * UNIT_conv_to_make_exp_dmnl\
		)) ^ dr65_b[region]
	~	1/y
	~		|

Population_over_50_still_working[region]=
	Cohort_50plus[region] * Fraction_of_population_over_50_still_working[region]
	~	Mp
	~		|

birth_rate_CN=
	(birth_rate_a_CN * EXP( birth_rate_b_CN * GDPpp_USED[cn] *UNIT_conv_to_make_exp_dmnl\
		) - birth_rate_c_CN 
	* EXP( birth_rate_d_CN * GDPpp_USED[cn] * UNIT_conv_to_make_exp_dmnl ) )
	 * UNIT_conv_to_make_the_bell_shaped_birth_rate_formula_have_units_of_1_pr_y
	~	1/y
	~		|

Global_GDPpp_USED=
	GDPpp_USED[us] * Regional_population_as_fraction_of_total[us]
	+ GDPpp_USED[af] * Regional_population_as_fraction_of_total[af]
	+ GDPpp_USED[cn] * Regional_population_as_fraction_of_total[cn]
	+ GDPpp_USED[me] * Regional_population_as_fraction_of_total[me]
	+ GDPpp_USED[sa] * Regional_population_as_fraction_of_total[sa]
	+ GDPpp_USED[la] * Regional_population_as_fraction_of_total[la]
	+ GDPpp_USED[pa] * Regional_population_as_fraction_of_total[pa]
	+ GDPpp_USED[ec] * Regional_population_as_fraction_of_total[ec]
	+ GDPpp_USED[eu] * Regional_population_as_fraction_of_total[eu]
	+ GDPpp_USED[se] * Regional_population_as_fraction_of_total[se]
	~	k2017pppUSD/(y*p)
	~		|

Life_expectancy_at_birth_as_f_of_GDPpp[region]=
	Life_expec_a[region] + Life_expec_b[region] * LN( GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl\
		)
	~	y
	~		|

Global_GDPpp_model=
	GDPpp_model[us] * Regional_population_as_fraction_of_total[us]
	+ GDPpp_model[af] * Regional_population_as_fraction_of_total[af]
	+ GDPpp_model[cn] * Regional_population_as_fraction_of_total[cn]
	+ GDPpp_model[me] * Regional_population_as_fraction_of_total[me]
	+ GDPpp_model[sa] * Regional_population_as_fraction_of_total[sa]
	+ GDPpp_model[la] * Regional_population_as_fraction_of_total[la]
	+ GDPpp_model[pa] * Regional_population_as_fraction_of_total[pa]
	+ GDPpp_model[ec] * Regional_population_as_fraction_of_total[ec]
	+ GDPpp_model[eu] * Regional_population_as_fraction_of_total[eu]
	+ GDPpp_model[se] * Regional_population_as_fraction_of_total[se]
	~	k2017pppUSD/(Year*p)
	~	G2017pppUSD/(Mp*Year) = k2017pppUSD / y / p
	~	:SUPPLEMENTARY 
	|

birth_rate_WO_CN[region]=
	birth_rate_a[region] * ( GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl) ^ birth_rate_b\
		[region] + birth_rate_c[region]
	~	1/y
	~		|

Fraction_of_population_over_50_still_working[region]= WITH LOOKUP (
	GDPpp_USED[region],
		 ([(0,0)-(10,10)],(0,0.95),(50,0.8),(100,0.5) ))
	~	Dmnl
	~		|

net_migration_function[region]=
	nmf_a[region] * LN( GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl) + nmf_b[region]\
		 + nmf_c[region]
	~	Mp/y
	~		|

Regional_population_as_fraction_of_total[region]=
	Population[region] / Global_population
	~	1
	~		|

UNIT_conv_to_kUSDpp=
	1
	~	(G2017pppUSD*p)/(Mp*k2017pppUSD)
	~		|

GDP_model[region]=
	Output[region]
	~	G2017pppUSD/y
	~		|

Global_dying=
	SUM(dying[region!])
	~	Mp/y
	~		~	:SUPPLEMENTARY 
	|

Cohort_50plus[region]=
	Cohort_50_to_54[region] + Cohort_55_to_59[region] + Cohort_60plus[region]
	~	Mp
	~		|

Dependency_ratio[region]=
	(Cohort_0_to_20[region] + Cohort_60plus[region]) / (Cohort_20_to_40[region] + Cohort_40_to_60\
		[region])
	~	1
	~		~	:SUPPLEMENTARY 
	|

Cohort_40_to_60[region]=
	Cohort_40_to_44[region] + Cohort_45_to_49[region] + Cohort_50_to_54[region] + Cohort_55_to_59\
		[region]
	~	Mp
	~		|

Life_expec_a[region]=
	47, 36, 64, 40, 57, 40, 53, 47, 35, 58
	~	y [0,100,5]
	~	calibrated GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c163' )
	|

Life_expec_b[region]=
	10, 15, 7, 10, 8, 10, 8, 10, 13, 8
	~	y [0,20,2]
	~	calibrated GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c164' )
		10, 15, 7, 13, 10, 14, 8, 10, 13, 8
	|

Life_expectancy_at_birth[region]=
	SMOOTH(Life_expectancy_at_birth_as_f_of_GDPpp[region], Time_to_affect_life_expectancy\
		)
	~	y
	~		|

Max_age=
	100
	~	y
	~	Arbitrary age limit
	|

SoE_of_LE_on_Pension_age[region]=
	0.6, 0.6, 0.6, 0.6, 0.6, 0.6, 0.6, 0.6, 0.6, 0.6
	~	Dmnl [-1,2]
	~	Slope of effect of life expectancy on pension age GET XLS \
		CONSTANTS('e4a-exo.xlsx', 'para' , 'c165' )
	|

Cohort_60plus[region]=
	Cohort_60_to_64[region] + Cohort_65_to_69[region] + Cohort_70_to_74[region] + Cohort_75_to_79\
		[region] + Cohort_80_to_84[region] + Cohort_85_to_89[region] + Cohort_90_to_94[region\
		] + Cohort_95p[region]
	~	Mp
	~		|

Average_Age[region]=
	(Cohort_0_to_4[region] / Population[region]*2.5
	+ Cohort_5_to_9[region]/ Population[region]*7.5
	+ Cohort_10_to_14[region]/ Population[region]*12.5
	+ Cohort_15_to_19[region]/ Population[region]*17.5
	+ Cohort_20_to_24[region]/ Population[region]*22.5
	+ Cohort_25_to_29[region]/ Population[region]*27.5
	+ Cohort_30_to_34[region]/ Population[region]*32.5
	+ Cohort_35_to_39[region]/ Population[region]*37.5
	+ Cohort_40_to_44[region]/ Population[region]*42.5
	+ Cohort_45_to_49[region]/ Population[region]*47.5
	+ Cohort_50_to_54[region]/ Population[region]*52.5
	+ Cohort_55_to_59[region]/ Population[region]*57.5
	+ Cohort_60_to_64[region]/ Population[region]*62.5
	+ Cohort_65_to_69[region]/ Population[region]*67.5
	+ Cohort_70_to_74[region]/ Population[region]*72.5
	+ Cohort_75_to_79[region]/ Population[region]*77.5
	+ Cohort_80_to_84[region]/ Population[region]*82.5
	+ Cohort_85_to_89[region]/ Population[region]*87.5
	+ Cohort_90_to_94[region]/ Population[region]*92.5
	+ Cohort_95p[region]/ Population[region]*98) * UNIT_conv_to_y
	~	y
	~		~	:SUPPLEMENTARY 
	|

UNIT_conv_to_per_thousand=
	1000
	~	1/k
	~		|

UNIT_conv_to_y=
	1
	~	y
	~		|

Years_between_60_and_max_age=
	40
	~	y
	~		|

dying[region]=
	dying_0_to_4[region] + dying_35_to_39[region] + dying_40_to_45[region] + dying_50_to_54\
		[region] + dying_55_to_59[region] + dying_60_to_64[region] + dying_65_to_69[region]\
		 + dying_70_to_74[region] + dying_75_to_79[region] + dying_80_to_84[region] + dying_85_to_89\
		[region] + dying_90_to_94[region] + dying_95p[region]
	~	Mp/y
	~		|

Cohort_0_to_20[region]=
	Cohort_0_to_4[region] + Cohort_10_to_14[region] + Cohort_15_to_19[region] + Cohort_5_to_9\
		[region]
	~	Mp
	~		|

Population[region]=
	Cohort_0_to_20[region] + Cohort_20_to_40[region] + Cohort_40_to_60[region] + Cohort_60plus\
		[region]
	~	Mp
	~		|

crude_birth_rate[region]=
	Births[region] / Population[region] * UNIT_conv_to_per_thousand
	~	1/(y*k)
	~		~	:SUPPLEMENTARY 
	|

Cohort_20_to_40[region]=
	Cohort_20_to_24[region] + Cohort_25_to_29[region] + Cohort_30_to_34[region] + Cohort_35_to_39\
		[region]
	~	Mp
	~		|

Pension_age[region]=
	IF_THEN_ELSE(Life_expectancy_at_birth[region] < Life_expectancy_at_birth_in_1980[region\
		], Pension_age_in_1980[region], Pension_age_in_1980[region] + SoE_of_LE_on_Pension_age\
		[region] * (Life_expectancy_at_birth[region] - Life_expectancy_at_birth_in_1980[region\
		]))
	~	y
	~		|

Global_population=
	SUM( Population[region!] )
	~	Mp
	~		|

Pension_age_in_1980[region]=
	65, 65, 65, 65, 65, 65, 65, 65, 65, 65
	~	y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c166' )
	|

Time_to_affect_life_expectancy=
	10
	~	y
	~		|

Aging_14_to_15[region]=
	Cohort_10_to_14[region] / Cohort_duration_is_5_yrs
	~	Mp/yr
	~		|

Aging_19_to_20[region]=
	Cohort_15_to_19[region] / Cohort_duration_is_5_yrs
	~	Mp/yr
	~		|

Aging_24_to_25[region]=

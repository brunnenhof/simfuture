	~	dimensionless
	~		|

CO2_flow_from_GRASS_to_atmosphere_GtC_py=
	(GRASS_Biomass_in_construction_material_being_burnt
	+ GRASS_Dead_biomass_decomposing
	+ GRASS_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting
	+ GRASS_DeadB_SOM_being_lost_due_to_deforestation
	+ GRASS_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ GRASS_soil_degradation_from_forest_fires
	+ GRASS_runoff) * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flow_from_TROP_to_atmosphere_GtC_py=
	(TROP_Biomass_in_construction_material_being_burnt
	+ TROP_Dead_biomass_decomposing
	+ TROP_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting
	+ TROP_DeadB_SOM_being_lost_due_to_deforestation
	+ TROP_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ TROP_soil_degradation_from_clear_cutting
	+ TROP_soil_degradation_from_forest_fires
	+ TROP_runoff) * Carbon_per_biomass
	~	GtC/yr
	~		|

CO2_flow_from_TUNDRA_to_atmosphere=
	(TUNDRA_Biomass_in_construction_material_being_burnt
	+ TUNDRA_Dead_biomass_decomposing
	+ TUNDRA_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting
	+ TUNDRA_DeadB_SOM_being_lost_due_to_deforestation
	+ TUNDRA_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ TUNDRA_soil_degradation_from_forest_fires
	+ TUNDRA_runoff) * Carbon_per_biomass
	~	GtC/yr
	~		|

Effective_time_to_melt_Arctic_ice_at_the_reference_delta_temp=
	Time_to_melt_Arctic_ice_at_the_reference_delta_temp
	~	yr
	~		|

LW_Blocking_multiplier_from_other_GHG=
	(Blocking_multiplier_from_Kyoto_Fluor + Blocking_multiplier_from_Montreal_gases + Blocking_multiplier_from_N2O\
		) / 3
	~	dimensionless
	~	additive assumption
	|

Albedo_Antarctic=
	0.7
	~	fraction
	~	guess; ice = 0.7 Units: 0 to 1; 1 is bright i.e. reflects all incoming \
		energy, 0 is dark i.e. reflects no incoming energy.
	|

Albedo_BARREN_normal=
	0.17
	~	fraction
	~	Albedo values for various surface types are tabulated here \
		http://agsys.cra-cin.it/tools/solarradiation/help/Albedo.html from Davies \
		and Idso in Barfield and Gerber 1979; Oke 1987; and Campbell and Norman \
		1998
	|

Albedo_DESERT_normal=
	0.24
	~	fraction
	~	Albedo values for various surface types are tabulated here \
		http://agsys.cra-cin.it/tools/solarradiation/help/Albedo.html from Davies \
		and Idso in Barfield and Gerber 1979; Oke 1987; and Campbell and Norman \
		1998
	|

Albedo_glacier=
	0.4
	~	fraction
	~	guess, ice is about 0.8, glaciers are not always pristine white Units: \
		0-1; 1 is bright i.e. reflects all incoming energy, 0 is dark i.e. \
		reflects no incoming energy. Albedo values for various surface types are \
		tabulated here \
		http://agsys.cra-cin.it/tools/solarradiation/help/Albedo.html from 1) \
		Davies, J.A., and S.B. Idso. Estimating the surface radiation balance and \
		its components. p. 183-210. In: Barfield, B.J., Gerber J.F. (Eds.), \
		Modifications of the aerial environment of crops. ASAE St. Joseph, MO, \
		USA, 2) Oke, T.R. 1987. Boundary layer climates. Routledge, New York, NY, \
		USA and 3) Campbell, G.S., and J.M. Norman. 1998. An introduction to \
		environmental biophysics, 2nd edition. Springer, New York, NY, USA
	|

Albedo_GRASS_burnt=
	0.08
	~	fraction
	~	Burning makes the ground, on which grass previously grew, darker. [Source: \
		Fisch et al 1994]
	|

Albedo_GRASS_deforested=
	0.3
	~	fraction
	~	Deforesting makes the ground, on which grass previously grew, darker. This \
		is, however, a theoretical point since the variable that controls how much \
		grass area is 'deforested', Fraction GRASS being deforested 1 py, is set \
		to 0.
	|

Albedo_GRASS_normal_cover=
	0.16
	~	fraction
	~	Albedo values for various surface types are tabulated here \
		http://agsys.cra-cin.it/tools/solarradiation/help/Albedo.html from Davies \
		and Idso in Barfield and Gerber 1979; Oke 1987; and Campbell and Norman \
		1998
	|

Albedo_Greenland=
	0.7
	~	fraction
	~	guess, ice=0.7
	|

Albedo_land_biomes=
	Contrib_of_BARREN_land_to_albedo_land
	+ Albedo_DESERT_normal * DESERT_Mkm2 / Area_of_land_Mkm2
	+ Contrib_of_GRASS_to_albedo_land
	+ Contrib_of_ICE_ON_LAND_to_albedo_land
	+ Contrib_of_NF_to_albedo_land
	+ Contrib_of_TROP_to_albedo_land
	+ Contrib_of_TUNDRA_to_albedo_land
	+ Albedo_URBAN * Urban_Mkm2 / Area_of_land_Mkm2
	~	fraction
	~	Units: 0 to 1; 1 is bright i.e. reflects all incoming energy, 0 is dark \
		i.e. reflects no incoming energy.
	|

Albedo_NF_burnt=
	0.13
	~	fraction
	~	Burning makes the ground, on which northern forest previously grew, \
		brighter. [Source: Bala et al 2007, Lyons et al 2008 and Betts and Ball \
		1997]
	|

Albedo_NF_deforested=
	0.18
	~	fraction
	~	Deforesting makes the ground, on which northern forest previously grew, \
		twice as bright as before. [Source: Bala et al 2007 and Betts and Ball \
		1997]
	|

Albedo_NF_normal_cover=
	0.08
	~	fraction
	~	Albedo values for various surface types are tabulated here \
		http://agsys.cra-cin.it/tools/solarradiation/help/Albedo.html from Davies \
		and Idso in Barfield and Gerber 1979; Oke 1987; and Campbell and Norman \
		1998
	|

Albedo_ocean_with_arctic_ice_changes=
	Arctic_ice_albedo_1850 * Arctic_as_fraction_of_ocean
	+ Open_ocean_albedo * Open_water_as_frac_of_ocean_area
	~	fraction
	~	We model ice on water in the Arctic as volume and area. Hence we can model \
		one biome, ice on ocean, with its albedo effect directly.
	|

Albedo_TROP_burnt=
	0.1

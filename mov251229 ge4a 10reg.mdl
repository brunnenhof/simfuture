Energy_footprint_pp[region]=
	( Total_CO2_emissions[region] ) / Population[region] * UNIT_conv_to_t_ppy
	~	tCO2/(p*Year)
	~		|

Discarding_wind_and_PV_el_capacity[region]=
	wind_and_PV_el_capacity[region] / Lifetime_of_wind_and_PV_el_cap
	~	GW/Year
	~		|

UNIT_conv_to_toe_py=
	1
	~	toe/p/y
	~		|

UNIT_conv_to_TWh=
	1
	~	TWh*p/(Mp*MWh)
	~		|

UNIT_conv_to_TWh_per_Mth=
	1
	~	(kgH*TWh)/(MtH*kWh)
	~		|

Total_use_of_fossil_fuels_NOT_compensated[region]=
	Total_use_of_fossil_fuels[region] * ( 1 - Fraction_of_fossil_fuels_compensated_by_CCS\
		[region] )
	~	Mtoe/Year
	~		|

wind_and_PV_capacity_factor[region]=
	0.1
	~	Dmnl
	~		|

Fossil_actual_uptime_factor[region]=
	0.82, 1, 1, 1, 1, 1, 1, 1, 0.81, 1
	~	Dmnl [0.5,1,0.05]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c176' )
	|

Fossil_capacity_factor[region]=
	0.45, 0.4, 0.4, 0.4, 0.4, 0.3, 0.4, 0.5, 0.45, 0.4
	~	Dmnl [0,1,0.05]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c173' )
	|

Global_CO2_from_fossil_fuels_to_atm=
	SUM ( CO2_from_fossil_fuels_to_atm[region!] )
	~	GtCO2/Year
	~		|

wind_and_PV_el_cap_in_1980=
	0.1
	~	GW
	~	In 1980 in many reagions there were only rudimentary wind and PV \
		capacities installed
	|

Fossil_fuel_for_NON_El_use_that_COULD_be_electrified[region]=
	Fossil_fuel_NOT_for_El_gen[region] - Fossil_fuel_for_NON_El_use_that_CANNOT_be_electrified\
		[region]
	~	Mtoe/Year
	~		|

UNIT_conv_to_Gtoe=
	1/1000
	~	Gtoe/Mtoe
	~		|

Time_to_verify_emi=
	2
	~	y
	~		|

toe_per_tH=
	0.338524
	~	Mtoe/MtH
	~	1 kg H = 0.0211 bbl of crude oil \
		https://h2tools.org/hyarc/calculator-tools/energy-equivalency-fuels
		1 bbl crude oil = 0.14 toe \
		https://www.unitjuggler.com/convert-energy-from-boe-to-toe.html
		Thus, 1 tH = 2.954 toe or 1 toe = 0.338524035 tH
	|

toe_to_CO2_a[region]=
	2.7, 2.8, 2.6, 2.16, 2.4, 2.37, 2, 3, 2.1, 2.1
	~	GtCO2/Gtoe [0,5,0.5]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c170' )
	|

Fossil_use_pp_NOT_for_El_gen_toe_py[region]=
	Fossil_use_pp_NOT_for_El_gen[region] * UNIT_conv_to_toe_py
	~	toe/(p*Year)
	~		|

Fossil_use_pp_NOT_for_El_gen_WO_CN[region]=
	Fossil_use_pp_NOT_for_El_gen_WO_CN_L[region] / (1+EXP(- Fossil_use_pp_NOT_for_El_gen_WO_CN_k\
		[region] * ((GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl) - Fossil_use_pp_NOT_for_El_gen_WO_CN_x0\
		[region])))
	~	Dmnl
	~	Source: curve fitted to BP Statistical Review 2021 and Penn World Tables \
		v.10, https://www.rug.nl/ggdc/productivity/pwt/
	|


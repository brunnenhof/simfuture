	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted for regions
	|

SDG_16_threshold_red=
	5
	~	G2017pppUSD/(y*Mp)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted for regions
	|


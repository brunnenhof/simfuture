	~	GtCO2e/yr
	~		|

Kyoto_Fluor_gases_in_atm= INTEG (
	Kyoto_Fluor_emissions-Kyoto_Fluor_degradation,
		361.575
		)
	~	kt
	~	"Kyoto Fluor gases" are gases controlled under the Kyoto protocol, WITHOUT \
		CO2, CH4 and N2O that we each track separately
	|

Kyoto_Fluor_Global_Warming_Potential=
	7000
	~	dimensionless
	~	http://ecometrica.com/white-papers/greenhouse-gases-co2-co2e-and-carbon-wha\
		t-do-all-these-terms-mean pointing to Contribution of Working Group I to \
		the Fourth Assessment Report of the Intergovernmental Panel on Climate \
		Change, 2007 Solomon, S., D. Qin, M. Manning, Z. Chen, M. Marquis, K.B. \
		Averyt, M. Tignor and H.L. Miller (eds.) Cambridge University Press, \
		Cambridge, United Kingdom and New York, NY, USA. Table 2.10.2 Direct \
		Global Warming Potentials available at \
		https://archive.ipcc.ch/publications_and_data/ar4/wg1/en/ch2s2-10-2.html
	|

Global_Warming_Potential_N20=
	298
	~	dimensionless
	~	http://ecometrica.com/white-papers/greenhouse-gases-co2-co2e-and-carbon-wha\
		t-do-all-these-terms-mean pointing to Contribution of Working Group I to \
		the Fourth Assessment Report of the Intergovernmental Panel on Climate \
		Change, 2007 Solomon, S., D. Qin, M. Manning, Z. Chen, M. Marquis, K.B. \
		Averyt, M. Tignor and H.L. Miller (eds.) Cambridge University Press, \
		Cambridge, United Kingdom and New York, NY, USA. Table 2.10.2 Direct \
		Global Warming Potentials available at \
		https://archive.ipcc.ch/publications_and_data/ar4/wg1/en/ch2s2-10-2.html
	|

TROP_regrowing_after_being_deforested=
	TROP_area_deforested / Effective_Time_to_regrow_TROP_after_deforesting
	~	Mkm2/yr
	~		|

CH4_all_emissions_GtC_py=
	CH4_release_or_capture_from_permafrost_area_loss_or_gain_GtC_py
	+ Human_activity_CH4_emissions
	+ Natural_CH4_emissions
	~	GtC/yr
	~		~	:SUPPLEMENTARY 
	|

Slope_of_temp_eff_on_potential_biomass_per_km2=
	-0.5
	~	dimensionless [-1.5,0,0.1]
	~	The higher the temperature, the less growth - the value is pure \
		calibration, so far
	|

Land_area_km2=
	5.1e+08 * 0.3
	~	km2
	~	https://en.wikipedia.org/wiki/Earth
	|

Land_covered_with_ice_km2=
	Antarctic_ice_area_km2 + Glacial_ice_area_km2 + Greenland_ice_area_km2
	~	km2
	~		|

Land_covered_with_ice_Mkm2=
	Land_covered_with_ice_km2 * UNIT_conversion_km2_to_Mkm2
	~	Mkm2
	~		~	:SUPPLEMENTARY 
	|

Land_sink_Net_C_flow_from_atm_to_biomass=
	Flow_from_atm_to_biomass
	- Flow_from_biomass_to_atm_Gtc_pr_yr
	~	GtC/yr
	~	In the base case the model moves carbon from biomass to the atmosphere. \
		This is opposite of what the IPCC AR5 Fig 6-08 suggests, where "land" is a \
		sink. The source of that figure is \
		http://www.globalcarbonproject.org/carbonbudget/14/data.htm Download the \
		Excel sheet to get the detailed sources in addition to the data. The tab \
		"Terrestrial Sink" gives the numbers for the "land". While it lists 9 \
		models that provide data from 1959 onwards, it actually generates a \
		residual (col B) that is close, but not identical, to the mean value of \
		the models. I looked at one of the models (ISAM) in detail, PDF here: \
		http://www.earth-syst-dynam.net/4/333/2013/esd-4-333-2013.html and found, \
		as far as I understand, that only when PFT (plant functional type) \
		fractions are kept constant (!) (experiment CTL) does the model produce a \
		net flow of land carbon uptake from atmosphere to land which is reported \
		in the Excel sheet. The other experiments are dropped. Thus, at the very \
		least, more research is needed!
	~	:SUPPLEMENTARY 
	|

Land_surface_temp_adjustment_time_yr=
	25
	~	yr
	~	calibration
	|

CH4_release_or_capture_from_permafrost_area_loss_or_gain_GtC_py=
	CH4_in_permafrost_area_melted_or_frozen_before_heat_constraint *  Melting_restraint_for_permafrost_from_heat_in_atmophere
	* Fraction_of_C_released_from_permafrost_released_as_CH4_dmnl
	~	GtC/yr
	~		|

Ocean_surface_delta_temp_to_anfang_degC=
	Temp_ocean_surface_in_K - Temp_ocean_surface_in_1850_C
	~	C
	~		~	:SUPPLEMENTARY 
	|

Actual_time_to_degrade_all_GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM=
	GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / Sum_outflows_GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM
	~	yr
	~		~	:SUPPLEMENTARY 
	|

Actual_time_to_degrade_all_NF_Dead_biomass_litter_and_soil_organic_matter_SOM=
	NF_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / NF_Sum_outflows_NF_Dead_biomass_litter_and_soil_organic_matter_SOM
	~	yr
	~		~	:SUPPLEMENTARY 
	|

Actual_time_to_degrade_all_TROP_Dead_biomass_litter_and_soil_organic_matter_SOM=
	TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / TROP_Sum_outflows_TROP_Dead_biomass_litter_and_soil_organic_matter_SOM
	~	yr
	~		~	:SUPPLEMENTARY 
	|

Effect_of_acidification_on_NMPP=
	1 + Slope_of_efffect_of_acidification_on_NMPP * (ph_in_cold_downwelling_water / ph_in_cold_water_in_1980\
		 -1)
	~	dimensionless
	~		|

Effect_of_C_concentration_on_NMPP=
	1 + LN(Avg_C_concentration_in_top_layer / Concentration_of_C_in_ocean_top_layer_in_1850\
		)/LN(2)
	~	dimensionless
	~		|

Effect_of_CO2_on_new_biomass_growth=
	1 + Sensitivity_of_biomass_new_growth_to_CO2_concentration * LN (CO2_concentration_used_after_any_experiments_ppm\
		 /
	 CO2_concentration_ppm_in_1850)
	~	dimensionless
	~	[Source: Shape from from https://www.e-education.psu.edu/earth103/node/1020, or \
		google "co2 ppm vs photosynthesis"; the actual numbers are calibrated to \
		give the observed assimilation of CO2 in biomass i.e. Fig 6-08 in IPCC \
		AR5, which rests on C. Le Quéré, R. Moriarty, R. M. Andrew, G. P. \
		Peters, P. Ciais, P. Friedlingstein, S. D. Jones, S. Sitch, P. Tans, A. \
		Arneth, T. A. Boden, L. Bopp, Y. Bozec, J. G. Canadell, F. Chevallier, C. \
		E. Cosca, I. Harris, M. Hoppema, R. A. Houghton, J. I. House, A. K. Jain, \
		T. Johannessen, E. Kato, R. F. Keeling, V. Kitidis, K. Klein Goldewijk, C. \
		Koven, C. S. Landa, P. Landschützer, A. Lenton, I. D. Lima, G. H. \
		Marland, J. T. Mathis, N. Metzl, Y. Nojiri, A. Olsen, T. Ono, W. Peters, \
		B. Pfeil, B. Poulter, M. R. Raupach, P. Regnier, C. Rödenbeck, S. Saito, \
		J. E. Sailsbury, U. Schuster, J. Schwinger, R. Séférian, J. \
		Segschneider, T. Steinhoff, B. D. Stocker, A. J. Sutton, T. Takahashi, B. \
		Tilbrook, G. R. van der Werf, N. Viovy, Y.-P. Wang, R. Wanninkhof, A. \
		Wiltshire, and N. Zeng 2014. Global Carbon Budget 2014. Earth System \
		Science Data Discussions, doi:10.5194/essdd-7-521-2014 at \
		http://www.globalcarbonproject.org/carbonbudget] In fact the calibrating \
		needs to consider this varibale as well as the slope from temperature on \
		new growth and the crowding effect on new growth (which can be thought of \
		as a nutrient effect)
		For the gory details of the reletionships between biomass growth and CO2, \
		temperature etc see Strain and Cure, 1985. Also the source code of MAGICC6 \
		(www.magicc.org) gives some clues - the high level description is in \
		Meinshausen et all 2011, Part 1
	|

SoE_of_CO2_on_yield=
	0.2
	~	Dmnl [0,1,0.2]
	~		|

Aerosol_anthropogenic_emissions=
	IF_THEN_ELSE(Time >= 2015, Future_shape_of_anthropogenic_aerosol_emissions * Value_of_anthropogenic_aerosol_emissions_during_2015
	, Historical_aerosol_emissions_anthro)
	~	GtAAe/yr
	~	The variable splices the historical anthropogenic emissions to the future \
		ones. The future is entered as a shape to make changing the future simpler \
		- but then I need a value in 2015 to turn the shape into real emissions. \
		GtAAe/yr is Giga tone Anthropogenic Aerosol equivalents per year.
	|

Effect_of_temp_on_melting_greenland_ice=
	1 + Slope_temp_vs_greenland_ice_melting * ((Arctic_land_surface_temp_anomaly_compared_to_anfang\
		 / Ref_temp_difference_for_greenland_ice_melting_C
	) - 1)
	~	dimensionless
	~		|

Logistics_curve_param_c=
	20
	~	1 [0,45,5]
	~		|

Logistics_curve_param_k=
	0.1
	~	1/yr [0,0.3,0.01]
	~		|

Logistics_curve_param_shift=
	2000
	~	Year [1500,2500,100]
	~		|

Effect_of_temperature_on_fire_incidence=
	1 + Slope_temp_eff_on_fire_incidence * (Temp_surface  / (Temp_surface_1850 - 273.15)\
		 - 1)
	~	dimensionless
	~		|

Effect_of_temperature_on_new_biomass_growth_dmnl=

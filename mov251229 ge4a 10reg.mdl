		(2007,0.2),(2008,0.21),(2009,0.21),(2010,0.21),(2011,0.21),(2012,0.22),(2013,0.23),\
		(2014,0.22),(2015,0.22),(2016,0.23),(2017,0.23),(2018,0.23),(2019,0.23) )) ~~|

	~	Mkm2/yr
	~		|

Greenland_ice_volume_in_1980=
	2.85e+06
	~	km3
	~	2.66946 * 1e+018 kg / 916.7 kg/m3 first \
		http://bprc.osu.edu/wiki/Greenland_Factsheet second \
		http://www.convert-me.com/en/convert/density/densice.html for 1850
	|

Open_ocean_albedo=
	0.065
	~	fraction
	~	i.e. ocean not covered by floating ice
	|

TUNDRA_DeadB_and_SOM_tB_per_km2=
	TUNDRA_DeadB_and_SOM_densitiy_at_initial_time_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl
	~	tB/km2
	~		|

TROP_being_harvested=
	TROP_Use_of_NF_biomass_for_energy / TROP_living_biomass_densitiy_tBiomass_pr_km2 * UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	Mkm2/yr
	~		|

NF_runoff_time=
	2000
	~	yr
	~	The value is not very sensitive: A value of 20 years lowers the delta temp \
		from 1850 (the so-called temperature anomaly) by 10%. Increasing the value \
		has no effect. A value of 2000 years means that annualy 0.02 % of dead \
		biomass and soil organic carbon are washed out to sea - via rivers. The \
		IPCC gives a value of 0.9 GtC per yr being washed out to see for all types \
		of vegetation / soil (Source: IPCC Climate Change 2013, The Physical \
		Science Basis, Fig 6.1 pg 471), up from 0.4 GtC pr yr reported in the \
		previous IPCC report. (Source: IPCC AR4WG1 Figure 7.3).
	|

Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py=
	Glacial_ice_volume_km3 / Effective_time_to_melt_glacial_ice_at_the_reference_delta_temp\
		 * Effect_of_temp_on_melting_or_freezing_glacial_ice * Effect_of_heat_in_atm_on_melting_ice_cut_off
	~	km3/yr
	~		|

Glacial_ice_melting_km3_py=
	IF_THEN_ELSE(Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py > 0 , Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		, 0)
	~	km3/yr
	~	Splitting melting and freezing into two variables that range between 0 and \
		inf
	|

NF_Speed_of_regrowth_yr=
	3
	~	yr
	~		|

TROP_Biomass_locked_in_construction_material_in_1980=
	44.963
	~	GtBiomass
	~	calibration
	|

NF_Time_to_decompose_undisturbed_dead_biomass_yr=
	250
	~	yr [0,300,20]
	~		|

NF_TUNDRA_Biomass_in_construction_material_left_to_rot=
	NF_Biomass_locked_in_construction_material_GtBiomass / NF_Avg_life_of_building_yr * \
		(1 - NF_Fraction_of_construction_waste_burned_0_to_1)
	~	GtBiomass/yr
	~		|

NF_usage_as_pct_of_potential_area=

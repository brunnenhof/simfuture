	-0.06, 0.25, 0.01, 0.055, 0.197, 0.027, 0.0395, 0.05, -0.0205, 0.1
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c36' )

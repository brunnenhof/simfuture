		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_8_Score[region]=
	IF_THEN_ELSE(Disposable_income_pp_post_tax_pre_loan_impact[region] < SDG_8_threshold_red\
		, 0, IF_THEN_ELSE(Disposable_income_pp_post_tax_pre_loan_impact[region] < SDG_8_threshold_green
	, 0.5, 1))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_8_threshold_green=
	25
	~	G2017pppUSD/(y*Mp)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG6b_Score[region]=
	IF_THEN_ELSE(Safe_sanitation[region] < SDG6b_threshold_red, 0, IF_THEN_ELSE(Safe_sanitation\
		[region] < SDG6b_threshold_green
	, 0.5, 1))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_6_score[region]=
	(SDG6a_Score[region] + SDG6b_Score[region]) / 2
	~	1
	~		|

SDG_9_threshold_green=
	0
	~	kgCO2/USD
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_9_threshold_red=
	0.1
	~	kgCO2/USD
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

Owner_to_worker_income_ratio[region]=
	Owner_income_after_tax_but_before_lending_transactions[region] / Worker_income_after_tax\
		[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

SDG6b_threshold_green=
	0.9
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG6b_threshold_red=
	0.65
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

UNIT_conv_to_tCO2_pr_USD=
	1000
	~	(kgCO2/USD)/(GtCO2/G2017pppUSD)
	~		|

SDG_2_Score[region]=
	IF_THEN_ELSE(Fraction_of_population_undernourished[region] > SDG2_threshold_red, 0, \
		IF_THEN_ELSE(Fraction_of_population_undernourished[region] > SDG2_threshold_green, \
		0.5, 1))
	~	1
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG2_threshold_green=
	0.03
	~	Dmnl
	~	SDG3 threshold red fraction of pop below 3 pct of total
		Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG2_threshold_red=
	0.07
	~	Dmnl
	~	SDG2 threshold red fraction of pop below 7 pct of total
		Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_3_Score[region]=
	IF_THEN_ELSE(Average_wellbeing_index[region] < SDG3_threshold_red, 0, IF_THEN_ELSE(Average_wellbeing_index\
		[region] < SDG3_threshold_green, 0.5, 1))
	~	1
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG3_threshold_green=
	1.4
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG3_threshold_red=
	1.2
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG4_a=
	1.3463
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab education
	|

Safe_water[region]=
	IF_THEN_ELSE(region = cn, Safe_water_cn, Safe_water_rest[region])
	~	1
	~		|

Safe_water_cn=
	Safe_water_cn_L / (1+EXP(-Safe_water_cn_k*((GDPpp_USED[cn]/UNIT_conv_to_make_base_dmnless\
		)-Safe_water_cn_x0))) + Safe_water_cn_min
	~	1
	~		|

Safe_water_cn_k=
	1
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_cn_L=
	0.999
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_cn_min=
	-0.02
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_cn_x0=
	0
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_rest[region]=
	Safe_water_rest_L / (1+EXP(-Safe_water_rest_k*((GDPpp_USED[region]/UNIT_conv_to_make_base_dmnless\
		)-Safe_water_rest_x0))) + Safe_water_rest_min
	~	1
	~		|

Safe_sanitation[region]=
	Safe_sanitation_L / (1+EXP(-Safe_sanitation_k*((GDPpp_USED[region]/UNIT_conv_to_make_base_dmnless\
		)-Safe_sanitation_x0))) + Safe_sanitation_min
	~	1
	~		|

Safe_water_rest_k=
	0.2
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_sanitation_k=
	0.15
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_rest_L=
	0.999
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_sanitation_L=
	0.999
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_rest_min=
	-0.02
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_sanitation_min=
	-0.02
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_water_rest_x0=
	10
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

Safe_sanitation_x0=
	12
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab water
	|

UNIT_conv_to_make_base_and_ln_dmnl=
	1
	~	G2017pppUSD/(y*Mp)
	~		|

GenEq_cn=
	GenEq_cn_a * (GDPpp_USED[cn] / UNIT_conv_to_make_base_dmnless)^GenEq_cn_b
	~	Dmnl
	~		|

GenEq_cn_a=
	0.4314
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_cn_b=
	-0.095
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_ec=
	GenEq_ec_a * LN(GDPpp_USED[ec] / UNIT_conv_to_make_base_dmnless) + GenEq_ec_b
	~	1
	~		|

GenEq_ec_a=
	0.0152
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_ec_b=
	0.3476
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_me=
	GenEq_me_a * (GDPpp_USED[me] / UNIT_conv_to_make_base_dmnless ) + GenEq_me_b
	~	1
	~		|

SDG1_Score[region]=
	IF_THEN_ELSE(Fraction_of_population_below_existential_minimum[region] > SDG1_threshold_red\
		, 0, IF_THEN_ELSE(Fraction_of_population_below_existential_minimum[region] > SDG1_threshold_green\
		, 0.5, 1))
	~	1
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG1_threshold_green=
	0.05
	~	Dmnl
	~	SDG1 threshold red fraction of pop below 5 pct of total
		Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

GenEq_sa=
	GenEq_sa_la_af_a * LN(GDPpp_USED[sa] / UNIT_conv_to_make_base_dmnless) + GenEq_sa_la_af_b
	~	Dmnl
	~		|

SDG2_a=
	0.42
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab hunger
	|

SDG2_b=
	-0.747
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab hunger
	|

GenEq_se_eu_pa_us[region]=
	GenEq_se_eu_pa_us_a * (GDPpp_USED[region] / UNIT_conv_to_make_base_dmnless ) + GenEq_se_eu_pa_us_b
	~	1
	~		|

GenEq_se_eu_pa_us_a=
	0.0021
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_se_eu_pa_us_b=
	0.241
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

SDG5_threshold_green=
	0.48
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG5_threshold_red=
	0.4
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG6a_Score[region]=
	IF_THEN_ELSE(Safe_water[region] < SDG6a_threshold_red, 0, IF_THEN_ELSE(Safe_water[region\
		] < SDG6a_threshold_green
	, 0.5, 1))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG6a_threshold_green=
	0.95
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG4_b=
	9.734
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab education
	|

SDG4_threshold_green=
	15
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG4_threshold_red=
	13
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG6a_threshold_red=
	0.8
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

GenEq_sa_la_af_a=
	0.06
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_me_b=
	0.1032
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

Fraction_of_population_undernourished[region]=
	MIN(1, SDG2_a * (GDPpp_USED[region] / UNIT_conv_to_make_base_dmnless)^(SDG2_b))
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab hunger
	|

GenEq_sa_la_af_b=
	0.15
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

GenEq_me_a=
	0.0003
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab gender
	|

SDG1_threshold_red=
	0.13
	~	Dmnl
	~	SDG1 threshold red fraction of pop below 13 pct of total
		Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

UNIT_conv_to_make_base_dmnless=
	1
	~	k2017pppUSD/(y*p)
	~	For use in equations that use EXP or LN that Vensim requires to be \
		dimensionless
	|

Population_last_year[region]=
	SMOOTH3I(Population[region] , One_year,Population_in_1979[region])
	~	Mp
	~		|

RoC_in_Population[region]=
	(Population[region] - Population_last_year[region]) / Population_last_year[region] /\
		 One_year
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

RoC_in_in_RoTA_from_public_capacity[region]=
	( SoE_of_PC_on_RoC_in_change_in_rate_of_tech_advance[region] / 1000) * (1 + Public_capacity\
		[region] / Public_capacity_N_yrs_ago[region]-1)
	~	1/y
	~	This is the idea of Ms Mazzucato, see her book "The entrepreneurial state"
	|

Effect_of_GDPpp_on_RoC_of_CLR[region]=
	1 + SoE_of_GDPpp_on_RoC_of_CLR[region]* ( GDPpp_USED[region]  / GDPpp_in_1980[region\
		] - 1 )
	~	Dmnl
	~		|

GDPpp_model_One_yr_ago[region]=
	SMOOTH3(GDPpp_model[region], One_year)
	~	k2017pppUSD/(Year*p)
	~		|

RoC_in_GDPpp[region]=
	(GDPpp_model[region] - GDPpp_model_One_yr_ago[region]) / GDPpp_model_One_yr_ago[region\
		] / One_year
	~	1/Year
	~		|

UNIT_conv_to_k2017pppUSD_pr_py[region]=
	1
	~	(k2017pppUSD/p)/(G2017pppUSD/Mp)
	~	Vensim's unit parser does not know that Giga/Million = kilo (G/M=k)
	|

Which_Scenario_is_run_globally=
	Which_Scenario_is_run[us] * Regional_population_as_fraction_of_total[us] 
	+ Which_Scenario_is_run[af] * Regional_population_as_fraction_of_total[af] 
	+ Which_Scenario_is_run[cn] * Regional_population_as_fraction_of_total[cn] 
	+ Which_Scenario_is_run[me] * Regional_population_as_fraction_of_total[me] 
	+ Which_Scenario_is_run[sa] * Regional_population_as_fraction_of_total[sa] 
	+ Which_Scenario_is_run[la] * Regional_population_as_fraction_of_total[la] 
	+ Which_Scenario_is_run[pa] * Regional_population_as_fraction_of_total[pa] 
	+ Which_Scenario_is_run[ec] * Regional_population_as_fraction_of_total[ec] 
	+ Which_Scenario_is_run[eu] * Regional_population_as_fraction_of_total[eu] 
	+ Which_Scenario_is_run[se] * Regional_population_as_fraction_of_total[se]
	~	1
	~		|

Nbr_of_policies=
	30
	~	Dmnl
	~		|

Reference_max_fraction_of_forest_possible_to_cut=
	0.8
	~	1/y
	~		|

Global_Total_CCS_from_fossil_fuels_BEING_compensated=
	SUM(Total_CCS_from_fossil_fuels_BEING_compensated[region!])
	~	GtCO2/Year
	~		|

Carbon_captured_and_stored_GtC_py=
	Global_C_taken_directly_out_of_the_atmosphere_ie_direct_air_capture + Global_Total_CCS_from_fossil_fuels_BEING_compensated\
		 / UNIT_conv_CO2_to_C
	~	GtC/yr
	~		|

Total_CCS_from_fossil_fuels_BEING_compensated[region]=
	IF_THEN_ELSE(Total_use_of_fossil_fuels_BEING_compensated[region] = 0 , 0, toe_to_CO2_a\
		[region] * ( Total_use_of_fossil_fuels_BEING_compensated[region] * UNIT_conv_to_Gtoe\
		) + toe_to_CO2_b[region])
	~	GtCO2/Year
	~		|

death_rate_0_to_4[region]=
	dying_0_to_4[region]/Cohort_0_to_4[region]
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

Effect_of_poverty_on_dying_smoothed[region]=
	SMOOTH(Effect_of_poverty_on_dying_from_policy_start[region], Time_to_smooth_poverty_effect\
		)
	~	Dmnl
	~		|

Ratio_of_regionally_available_crop_including_imports_to_regional_demand[region]=
	All_crop_regional_dmd[region] / (Crop_grown_regionally[region] + Actual_crop_import[\
		region] )
	~	1
	~	... used to calculate malnutrition
	|

Time_to_smooth_malnutrition_effect=
	3
	~	y
	~		|

Effect_of_poverty_on_dying[region]= WITH LOOKUP (
	Fraction_of_population_below_existential_minimum[region],
		    ([(0,0)-(10,10)],(0,1),(0.5,1.025),(1,1.1) ))
	~	Dmnl
	~	For the time being, this is a placeholder. When real data becomes \
		available please insert.
	|

Effect_of_malnutrition_on_dying[region]= WITH LOOKUP (
	Malnutrition[region],
		    ([(0,0)-(10,10)],(1,1),(2,1.15),(3,1.5),(4,2),(5,3),(10,15) ))
	~	Dmnl
	~	For the time being, this is a placeholder. When real data becomes \
		available please insert.
	|

Effect_of_malnutrition_on_dying_smoothed[region]=
	SMOOTH(Effect_of_malnutrition_on_dying[region], Time_to_smooth_malnutrition_effect)
	~	Dmnl
	~		|

Strength_of_poverty_effect=
	2
	~	Dmnl [0,3,1]
	~	This is a handle to change the impact of the poverty effect on dying for \
		calibration / what-if purposes
	|

Time_to_smooth_poverty_effect=
	3
	~	y
	~		|

Strength_of_malnutrition_effect=
	6
	~	Dmnl [0,8,1]
	~	This is a handle to change the impact of the malnutrition effect for \
		calibration / what-if purposes
	|

Ratio_of_demand_and_supply_of_crops_smoothed[region]=
	SMOOTH3(Ratio_of_regionally_available_crop_including_imports_to_regional_demand[region\
		] , Time_to_smooth_regional_food_balance)
	~	Dmnl
	~		|

Time_to_smooth_regional_food_balance=
	3
	~	y
	~		|

Soil_quality[region]=
	(Soil_quality_in_1980[region] / Eff_of_cumulative_N_use_on_soil_quality[region] )
	* ( ( 1 - Regenerative_cropland_fraction[region]) + Soil_quality_of_regenerative_cropland\
		[region] * Regenerative_cropland_fraction[region])
	~	1
	~		|

Future_volcanic_emissions=
	SMOOTH3(Future_volcanic_emissions_shape, FVE_shape_time)
	~	GtVAe/yr
	~		|

Max_govt_debt_smoothed[region]=
	SMOOTH(Max_govt_debt[region], Time_to_smooth_max_govt_debt)
	~	G2017pppUSD
	~		|

CH4_in_permafrost_area_melted_or_frozen_before_heat_constraint=
	(Area_equivalent_of_linear_retreat_km2_py * Avg_amount_of_C_in_the_form_of_CH4_per_km2
	* Effect_of_temp_on_permafrost_melting_dmnl_smoothed 
	* Slowing_of_recapture_of_CH4_dmnl
	* Permafrost_melting_cutoff)
	~	GtC/Year
	~		|

FVE_shape_time=
	3
	~	y
	~		|

Eff_of_dmd_imbalance_on_flow_of_available_capital[region]=
	1+ Slope_of_Eff_of_dmd_imbalance_on_flow_of_available_capital *(Perceived_demand_imblance\
		[region] /Dmd_imbalance_in_1980[region]-1)
	~	1
	~		|

Eff_of_dmd_imbalance_on_life_of_capacity[region]=
	1+ Slope_of_Eff_of_dmd_imbalnce_on_life_of_capacity * ( Perceived_demand_imblance[region\
		] / Dmd_imbalance_in_1980[region] -1)
	~	1
	~		|

Effective_time_to_melt_glacial_ice_at_the_reference_delta_temp=
	Time_to_melt_or_freeze_glacial_ice_at_the_reference_delta_temp
	~	yr
	~		|

Effective_time_to_melt_greenland_ice_at_the_reference_delta_temp=
	Time_to_melt_greenland_ice_at_the_reference_delta_temp
	~	yr
	~		|

Perceived_demand_imblance[region]=
	SMOOTH3I (Demand_imbalance[region] , Time_to_form_an_opinion_about_demand_imbalance \
		, Dmd_imbalance_in_1980[region] )
	~	Dmnl
	~		|

Area_covered_by_high_clouds=
	Area_covered_by_high_clouds_in_1980 * ( 1 + Sensitivity_of_high_cloud_coverage_to_temp_logistics\
		 * (Temp_surface_current_divided_by_value_anfang
	 - 1 ) )
	~	fraction
	~		|

Time_to_smooth_max_govt_debt=
	2
	~	y
	~		|

Area_covered_by_low_clouds=
	Area_covered_by_low_clouds_in_1980 * ( 1 + Sensitivity_of_low_cloud_coverage_to_temp\
		 * (Temp_surface_current_divided_by_value_anfang
	 - 1 ) )
	~	fraction
	~		|

Effective_time_to_melt_or_freeze_antarctic_ice_at_the_reference_delta_temp=
	Time_to_melt_or_freeze_antarctic_ice_at_the_reference_delta_temp
	~	yr
	~		|

Inventory_in_1980[region]=
	Optimal_output_in_1980[region] * Hours_worked_index_in_1980[region] * Goal_for_inventory_coverage
	~	G2017pppUSD
	~		|

Demand_in_1980[region]=
	Optimal_output_in_1980[region] * Hours_worked_index_in_1980[region]
	~	G2017pppUSD/y
	~		|

Volcanic_aerosols_emissions=
	IF_THEN_ELSE(Time < 2008, Historical_aerosol_forcing_volcanic / Conversion_of_volcanic_aerosol_forcing_to_volcanic_aerosol_emissions
	, Future_volcanic_emissions)
	~	GtVAe/yr
	~	Giga ton Volcanic Activity equivalent / yr
		IF THEN ELSE(Switch to choose input emission scenario for CO2 CH4 and oth GHG = 11, \
		0, 
		      IF THEN ELSE(Time < 2008, Historical aerosol forcing volcanic / Conversion of \
		volcanic aerosol forcing to volcanic aerosol emissions, Future volcanic \
		emissions)
		)
	|

Output[region]=
	Optimal_real_output[region] * Hours_worked_index[region] / Hours_worked_index_in_1980\
		[region]
	~	G2017pppUSD/y
	~		|

FEU_Total_use_of_fossil_fuels[region]=
	Total_use_of_fossil_fuels[region]
	~	Mtoe/Year
	~		~	:SUPPLEMENTARY 
	|

Scaled_Effect_of_poverty_on_social_tension_and_trust[region]=
	((Raw_Effect_of_poverty_on_social_tension[region] - 1) * Scaling_factor_of_eff_of_poverty_on_social_tension\
		 ) +
	1
	~	1
	~		|

Scaled_and_smoothed_Effect_of_poverty_on_social_tension_and_trust[region]=
	SMOOTHI(Scaled_Effect_of_poverty_on_social_tension_and_trust[region], Time_for_poverty_to_affect_social_tension_and_trust\
		, 1)
	~	1
	~		|

JR_inequality_effect_on_logistic_k[region]=
	1 + JR_sINEeolLOK_lt_0 * ( Indicated_inequality_index_higher_is_more_unequal[region]\
		 / 0.5 - 1 )
	~	1
	~		|

Existential_minimum_income=
	SMOOTH(Indicated_Existential_minimum_income, Time_to_adjust_Existential_minimum_income\
		)
	~	k2017pppUSD/(Year*p)
	~		|

Increase_in_existential_minimum_income=
	Indicated_Existential_minimum_income * Increase_in_existential_minimum
	~	k2017pppUSD/(Year*Year*p)
	~		|

Time_to_adjust_Existential_minimum_income=
	5
	~	y
	~		|

Raw_Effect_of_poverty_on_social_tension[region]=
	Effect_of_poverty_on_social_tension[region] / Effect_of_poverty_on_social_tension_in_1980\
		[region]
	~	1
	~		|

Time_for_poverty_to_affect_social_tension_and_trust=
	5
	~	y
	~	could be differentiated by region or regional causal structure
	|

Fraction_of_population_below_existential_minimum[region]=
	1 - ( 0.975 / ( 1 + EXP( - Logistic_k[region] * ((GDPpp_USED[region] - Existential_minimum_income\
		 ) / UNIT_conv_to_dmnl
	)) ) )
	~	1
	~	The existential minimum is 6.85 USD per per person per day = 2.5 \
		k2017pppUSD/py
	|

Scaling_factor_of_eff_of_poverty_on_social_tension=
	0.08
	~	Dmnl
	~	sytem-wide causal calibratrion
	|

Effect_of_poverty_on_social_tension[region]= WITH LOOKUP (
	Fraction_of_population_below_existential_minimum[region],
		 ([(0,0)-(10,10)],(0,1),(0.1,0.7),(0.25,0.4),(0.5,0.2),(0.75,0.15),(1,0.1) ))
	~	Dmnl
	~		|

Increase_in_existential_minimum=
	IF_THEN_ELSE(Time > 2023 , 0 ,0)
	~	1/y
	~	Even though we run the model in real money, the exitential minimum increases over \
		time to reflect the growth in wealth and income, in real terms
		0.008
	|

Indicated_Existential_minimum_income= INTEG (
	Increase_in_existential_minimum_income,
		2.5)
	~	k2017pppUSD/(Year*p)
	~	The existential mimimum is a UN inspired threshold, thus globally valid, \
		they use 6.85 $ per person per day which gives 2.5 k2017pppUSD/p-y
	|

Effect_of_poverty_on_social_tension_in_1980[region]=
	0.895992, 0.212402, 0.192882, 0.361938, 0.189584, 0.379113, 0.753294, 0.56287, 0.807669\
		, 0.198562
	~	Dmnl
	~	= INITIAL(Effect_of_poverty_on_social_tension)
	|

Social_trust_init_is_1[region]=
	Social_trust[region] / Social_trust_in_1980
	~	Dmnl
	~		|

C_in_sediment= INTEG (
	Biological_removal_of_C_from_WSW_GtC_per_yr+Depositing_of_C_to_sediment,
		C_in_sediment_initially)
	~	GtC
	~	For display only
	~	:SUPPLEMENTARY 
	|

C_in_sediment_initially=
	3e+09
	~	GtC
	~		|

Wellbeing_from_public_spending[region]= WITH LOOKUP (
	Public_spending_ratio[region],
		 ([(0,0)-(10,10)],(0,0),(0.25,0.02907),(0.5,0.08995),(0.75,0.2175),(1,0.4699),(1.25\
		,0.9055),(1.5,1.5),(1.75,2.095),(2,
		2.53),(2.25,2.782),(2.5,2.91),(2.75,2.971),(3,3) ))
	~	Dmnl
	~		|

N_excreted_per_unit_of_meat_production[region]=
	N_excreted_per_unit_of_meat_production_func[region] * UNIT_conv_to_MtN_from_meat
	~	MtN/Mtmeat
	~		|

Output_last_year[region]=
	SMOOTHI (Optimal_real_output[region], One_year, Output_last_year_in_1980[region] )
	~	G2017pppUSD/y
	~		|

Living_conditions_index[region]=
	( Weight_disposable_income * Wellbeing_from_disposable_income[region] +
	Weight_el_use * Wellbeing_from_el_use_scaled[region] +
	Weight_food * Wellbeing_from_food[region] +
	Weight_inequality * Wellbeing_from_inequality[region] +
	Weight_population_in_job_market * Wellbeing_from_population_with_regular_job[region]\
		 +
	Weight_public_spending * Wellbeing_from_public_spending[region])
	/ Sum_weights_living_conditions
	~	1
	~		|

Output_last_year_in_1980[region]=
	(Optimal_output_in_1980[region] / (1+ Output_growth_in_1980 )) / One_year
	~	G2017pppUSD/y
	~		|

Fossil_fuel_reserves_in_ground_GtC= INTEG (
	-Man_made_fossil_C_emissions_GtC_py,
		Fossil_fuel_reserves_in_ground_at_initial_time_GtC)
	~	GtC
	~		|

Fraction_of_CO2_emi_from_fossils_attributable_to_a_region[region]=
	CO2_from_fossil_fuels_to_atm[region] / Global_CO2_from_fossil_fuels_to_atm
	~	1
	~		|

Crop_yield_with_soil_quality_CO2_and_env_dam_effects[region]=
	Smoothed_Crop_yield_from_N_use[region] * Soil_quality[region] * Eff_of_CO2_on_yield \
		/ Eff_of_env_damage_on_agri_yield[region]
	~	Mtac/(Year*Mha)
	~	History Calculated from FAO statitics https://www.fao.org/faostat/en/#data
		Mtac/(Mha*Year) = t/ha/y
	|

Long_term_interest_rate_used_by_private_lenders[region]=
	SMOOTH (Indicated_long_term_interest_rate[region] , Long_term_interest_rate_expectation_formation_time\
		 )
	~	1/y
	~		|

Effect_of_temp_on_permafrost_melting_dmnl_smoothed=
	SMOOTH(Effect_of_temp_on_permafrost_melting_dmnl,Time_to_propagate_temperature_change_through_the_volume_of_permafrost_yr\
		)
	~	dimensionless
	~		|

Cumulative_N_use_since_2020_in_1980[region]=
	0
	~	MtN/Mha
	~		|

Indicated_cost_of_capital_for_secured_debt[region]=
	Short_term_interest_rate[region] + Normal_bank_operating_margin
	~	1/y
	~		|

Inequality_effect_on_social_trust[region]= WITH LOOKUP (
	Ratio_of_actual_inequality_to_norm[region],
		 ([(0,0)-(10,10)],(0,2),(0.2,1.975),(0.4,1.913),(0.6,1.767),(0.8,1.465),(1,1),(1.2,\
		0.5352),(1.4,0.2331),(1.6,0.08682),
		(1.8,0.02526),(2,0) ))
	~	1
	~		|

Public_Capacity_in_1980[region]=
	Capacity_in_1980[region] * Size_of_public_capacity_in_1980
	~	G2017pppUSD
	~	specified in terms of the size of the private sector, should differ by \
		region
	|

Forest_area_last_year[region]=
	SMOOTH3I ( Forest_land[region] , One_year, Forest_land_in_1980[region] )
	~	Mha
	~		|

Actual_inequality_index_higher_is_more_unequal_N_years_ago[region]=
	SMOOTH3I ( Actual_inequality_index_higher_is_more_unequal[region] , N_number_of_years_ago\
		 , Inequality_considered_normal_in_1980[region] )
	~	Dmnl
	~		|

Public_capacity[region]= INTEG (
	Increase_in_public_capacity[region]-Decrease_in_public_capacity[region],
		Public_Capacity_in_1980[region])
	~	G2017pppUSD
	~		|

Slowing_of_recapture_of_CH4_dmnl=
	IF_THEN_ELSE(Effect_of_temp_on_permafrost_melting_dmnl_smoothed < 0, 0.01, 1)
	~	dimensionless
	~	0.01 slows the recapture to 1/100 of the rate of release. This tries to \
		capture the effect that refreezing does not recapture CH4 at the same rate \
		as melting releases it. It is a different (much slower biological) process.
	|

Ratio_of_actual_inequality_to_norm[region]=
	Actual_inequality_index_higher_is_more_unequal_N_years_ago[region] / Inequality_considered_normal_in_1980\
		[region]
	~	1
	~		|

Worker_resistance_or_resignation[region]= INTEG (
	Change_in_worker_resistance[region],
		Worker_resistance_initially)
	~	Dmnl
	~	We conceive the "resistance" of workers (to the claim of owners on output) \
		to lie on a continuum between -1 and +1, where negative values signal \
		resignation and positive values signal defiance.
	|

Worker_resistance_initially=
	1 - Owner_power_in_1980
	~	Dmnl
	~		|

Effect_of_temp_on_permafrost_melting_dmnl=
	1 + Slope_btw_temp_and_permafrost_melting_or_freezing  * ((Temp_diff_relevant_for_melting_or_freezing_from_anfang_smoothed
	 / Ref_temp_difference_4_degC) - 1)
	~	dimensionless
	~		|

Crop_grown_regionally[region]=
	Cropland[region] * Crop_yield_with_soil_quality_CO2_and_env_dam_effects[region]
	~	Mtac/Year
	~		|

Indicated_eff_of_relative_wealth_on_env_damage[region]=
	IF_THEN_ELSE(Time > 2020, 1 + SoE_of_relative_wealth_on_env_damage[region] * (Ratio_of_regional_GDPpp_to_richest_region_GDPpp\
		[region] - 1) , 1)
	~	1
	~	The idea is that rich regions can organize the response to env damage \
		better than poor regions. Thus, I compare the current region to the \
		richest one (measured by GDPpp and which can change over time) and make \
		the env damage effect 'worse'. Think of the difference between the \
		Netherlands and Bangladesh responding to rising sea levels.
	|

Ratio_of_actual_public_spending_vs_reference[region]=
	Public_spending_as_share_of_GDP[region] / Reference_public_spending_fraction
	~	1
	~	stu = social trust units
	|

Fraction_of_CO2_emi_from_fossils_attributable_to_a_region_smoothed[region]=
	SMOOTH ( Fraction_of_CO2_emi_from_fossils_attributable_to_a_region[region] , Time_to_verify_emi\
		 )
	~	1
	~		~	:SUPPLEMENTARY 
	|

Smoothed_cumulative_N_use_for_regenerative_choice[region]=
	SMOOTHI ( Cumulative_N_use_since_2020[region] , Time_for_N_use_to_affect_regeneative_choice\
		 , Cumulative_N_use_since_2020_in_1980[region]
	)
	~	MtN/Mha
	~		|

Cost_of_capital_for_secured_debt[region]=
	SMOOTHI ( Indicated_cost_of_capital_for_secured_debt[region] , Finance_sector_response_time_to_central_bank
	, Indicated_cost_of_capital_for_secured_debt[region])
	~	1/y
	~		|

Temp_diff_relevant_for_melting_or_freezing_from_anfang_smoothed=
	SMOOTH(Temp_diff_relevant_for_melting_or_freezing_anfang, Time_to_smooth_out_temperature_diff_relevant_for_melting_or_freezing_from_1850_yr
	)
	~	C
	~		|

Public_spending_effect_on_social_trust[region]= WITH LOOKUP (
	Ratio_of_actual_public_spending_vs_reference[region],
		       ([(0,0)-(0.601626,0.822581)],(0,0.8),(0.25,0.82),(0.5,0.87),(0.75,0.93),(1,1\
		),(1.25,1.07),(1.5,1.13),(1.75,1.18),(2,1.2) ))
	~	stu
	~	stu = social trust units
	|

Cumulative_N_use_since_2020[region]= INTEG (
	Addition_to_N_use_over_the_years[region],
		Cumulative_N_use_since_2020_in_1980[region])
	~	MtN/Mha
	~		|

TROP_historical_deforestation=
	(TROP_Ref_historical_deforestation / 100) * TROP_deforestion_multiplier
	~	1/yr
	~		|

red_meat_demand_pp[region]=
	red_meat_dmd_pp[region] * UNIT_conv_to_kg_red_meat_ppy * RMDR_multiplier_used[region\
		]
	~	kgrmeat/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

Indicated_Eff_of_env_damage_on_dying[region]=
	EXP(Combined_env_damage_indicator * expSoE_of_ed_on_dying) / Actual_eff_of_relative_wealth_on_env_damage\
		[region]
	~	1
	~		|

Time_lag_for_env_damage_to_affect_mortality=
	5
	~	y [1,10,1]
	~		|

Income_tax_rate_workers[region]=
	Income_tax_rate_workers_after_GITx[region]
	~	1
	~		|

Income_tax_rate[region]=
	Income_tax_rate_owners_after_GITx[region]
	~	1
	~		|

Worker_share_of_output_with_unemployment_effect[region]=
	Worker_share_of_output_with_policy[region] * Effect_of_unemployment_ratio_on_Worker_share_of_output\
		[region]
	~	Dmnl
	~		|

Max_transfer_share[region]=
	MIN(1,  Fraction_of_govt_income_transferred_to_workers_a)
	~	1
	~	You cannot tranfer more than 100% of govt income to workers
	|

Worker_share_of_output_with_policy[region]=
	Worker_share_of_output[region] * StrU_mult_used[region]
	~	1
	~		|

Indicated_signal_rate[region]=
	Normal_signal_rate[region] * 
	( Eff_of_inflation_on_Indicated_signal_rate[region] + Eff_of_unemployment_on_Indicated_signal_rate\
		[region])
	~	1/y
	~		|

Govt_investment_in_public_capacity[region]=
	Actual_govt_cash_inflow_seasonally_adjusted[region] - Govt_consumption_ie_purchases[\
		region]
	~	G2017pppUSD/y
	~		|

Consumption_taxes_last_year[region]=
	SMOOTHI ( Consumption_taxes[region] , One_year , Consumption_taxes_in_1980[region] )
	~	G2017pppUSD/y
	~		|

Eff_of_unemployment_on_Indicated_signal_rate[region]=
	SoE_of_unemployment_rate_on_indicated_signal_rate * (Perceived_unemployment_rate[region\
		] / 
	Unemployment_rate_used[region]-1)
	~	1
	~		|

Full_time_jobs_with_participation_constraint[region]=
	MIN (Theoretical_full_time_jobs_at_current_CLR[region] , Max_people_in_labour_pool[region\
		])
	~	Mp
	~		|

check_regional_GDP_weights=
	SUM( Regional_GDP_weight[region!] )
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Unemployment_rate_used[region]=
	IF_THEN_ELSE(SWITCH_unemp_target_or_long_term[region] = 1, Unemployment_target_for_interest\
		[region], Long_term_unemployment_rate[region])
	~	1
	~		|

Time_for_GDPpp_to_affect_death_rates=
	1
	~	y
	~		|

GDPpp_USED_for_influencing_death_rates[region]=
	SMOOTH3 ( GDPpp_USED[region] , Time_for_GDPpp_to_affect_death_rates )
	~	k2017pppUSD/(Year*p)
	~		|

El_from_Hydro[region]=
	Hydro_gen_cap[region] * Hydrocapacity_factor[region] * Hours_per_year * UNIT_conv_GWh_and_TWh
	~	TWh/Year
	~		|

TFP_including_effect_of_env_damage[region]=
	Total_factor_productivity_TFP_before_env_damage[region] / Eff_of_env_damage_on_TFP[region\
		]
	~	1
	~		|

Urban_area_fraction=
	MAX( 0 , MIN ( 1 , Global_population_in_Bp / Population_2000_bn * Urban_area_fraction_2000\
		))
	~	fraction
	~	Max Min is a crude way to make sure that the value is bounded between 0 \
		and 1
	|

Global_Total_CO2_emissions_GtC_py=
	Global_Total_CO2_emissions / UNIT_conv_CO2_to_C
	~	GtC/Year
	~		|

UNIT_conv_to_Bp=
	1000
	~	Mp/Bp
	~		|

UNIT_conv_CO2_to_C=
	3.667
	~	GtCO2/GtC
	~		|

Demand_for_El_before_NEP[region]=
	(((Population[region] * El_use_pp_in_MWh_ppy[region] ) / Extra_energy_productivity_index_2024_is_1\
		[region] ) ) * UNIT_conv_to_TWh
	~	TWh/Year
	~		|

Global_CH4_emissions_GtC_py=
	Global_CH4_emissions * UNIT_conversion_from_MtCH4_to_GtC
	~	GtC/Year
	~		|

Effect_of_population_and_urbanization_on_biomass_use=
	Global_population_in_Bp / Population_2000_bn * Urbanzation_Effect_on_biomass_use
	~	dimensionless
	~	Our assumption is that the use of biomass for energy has something to do \
		with population; certainly in the past. Questionable how that relationship \
		develops as more and more people live in cities (see urbanization effect)
	|

Global_population_in_Bp=
	Global_population / UNIT_conv_to_Bp
	~	Bp
	~		|

Indicated_wellbeing_from_env_damage=
	MAX(0, 1 + SoE_of_env_damage_indicator * Combined_env_damage_indicator)
	~	1
	~		|

CH4_emi_from_waste_AF=
	CH4_emi_from_waste_AF_a * (GDPpp_USED[af] * UNIT_conv_to_make_exp_dmnl )^CH4_emi_from_waste_AF_b
	~	MtCH4/Year
	~		|

CH4_emi_from_waste_AF_a=
	1.2596
	~	MtCH4/y
	~		|

CH4_emi_from_waste_AF_b=
	0.9904
	~	Dmnl
	~		|

CH4_emi_from_waste_b[region]=
	25.387, 1, 1, -4.58, 1, -11.039, 3.4589, 0.5983, 22.115, -6
	~	MtCH4/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c216' )
	|

CH4_emi_from_waste_CN=
	CH4_emi_from_waste_CN_a * (GDPpp_USED[cn] * UNIT_conv_to_make_exp_dmnl )^CH4_emi_from_waste_CN_b
	~	MtCH4/Year
	~		|

CH4_emi_from_energy_a[region]=
	1, 25, 9.7, 22.561, 3.2, 6.9187, 3.7161, 16, 1, 6
	~	MtCH4/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c213' )
	|

CH4_emi_from_energy_b[region]=

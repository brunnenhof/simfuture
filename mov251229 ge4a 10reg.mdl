:TABLE HESO
:TITLE HESO
:PRETTYNUM
:PRINT-EVERY 5
:X-MIN 1980
:X-MAX 2100
:SPECIAL-TIME 5
:FONT Times New Roman|12||0-0-0
:VAR GDP USED[region]
:DATASET *1

:GRAPH Population
:TITLE Population
:SCALE
:VAR Global population H
:Y-MIN 0
:DATASET *1
:LINE-WIDTH 2
:VAR Global Population|TLTL
:DATASET tltl
:LINE-WIDTH 2
:VAR Global Population|GL
:DATASET gl
:LINE-WIDTH 2

:GRAPH Pop_US
:TITLE Pop US
:SCALE
:VAR Population[us]
:DATASET *1
:VAR Population H[us]
:DATASET *1

:GRAPH Pop_AF
:TITLE Pop AF
:SCALE
:VAR Population[af]|TLTL
:DATASET tltl
:LINE-WIDTH 2
:VAR Population[af]|GL
:DATASET gl
:LINE-WIDTH 2
:VAR Population H[af]|History
:DATASET *1
:LINE-WIDTH 2
:VAR Population[af]|current
:DATASET current
:LINE-WIDTH 2

:GRAPH Pop_CN
:TITLE Pop CN
:SCALE
:VAR Population[cn]
:DATASET *1
:VAR Population H[cn]
:DATASET *1

:GRAPH GDPpp
:TITLE GDPpp
:SCALE
:VAR Global GDPpp H
:Y-MAX 120
:DATASET *1
:LINE-WIDTH 2
:VAR Global GDPpp USED|TLTL
:DATASET tltl
:LINE-WIDTH 2
:VAR Global GDPpp USED|GL
:DATASET gl
:LINE-WIDTH 2

:GRAPH GDP
:TITLE GDP
:SCALE
:VAR Global GDP H
:DATASET *1
:LINE-WIDTH 2
:VAR Global GDP|TLTL
:DATASET tltl
:LINE-WIDTH 2
:VAR Global GDP USED|GL
:DATASET gl
:LINE-WIDTH 2

:GRAPH CH4_emissions
:TITLE CH4 emissions
:SCALE
:VAR Global CH4 emissions H GtC py|H
:DATASET *1
:LINE-WIDTH 2

Fossil_fuel_NOT_for_El_gen[region]=
	(( Fossil_use_pp_NOT_for_El_gen_toe_py[region] * Population[region] ) / Extra_energy_productivity_index_2024_is_1\
		[region
	] ) * UNIT_conv_toe_to_Mtoe - Low_carbon_heat_production[region]
	~	Mtoe/Year

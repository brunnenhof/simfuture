SW_to_surface=
	Incoming_solar_ZJ_py - SW_Atmospheric_absorption - SW_HI_cloud_efffect_aka_cloud_albedo\
		 - SW_LO_cloud_efffect_aka_cloud_albedo - SW_clear_sky_reflection_aka_scattering
	~	ZJ/yr
	~		|

Shifting_NF_to_TROP_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC > 0, NF_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_NF_to_TROP
	 * Temp_driver_to_shift_biomes_degC, 0)
	~	Mkm2/yr
	~		|

Shifting_NF_to_Tundra_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC < 0, NF_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_on_shifting_NF_to_Tundra
	  * Temp_driver_to_shift_biomes_degC , 0) * (-1)
	~	Mkm2/yr
	~		|

Shifting_TROP_to_GRASS_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC > 0, TROP_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_TROP_to_GRASS
	 * Temp_driver_to_shift_biomes_degC * (1/Effect_of_humidity_on_shifting_biomes), 0)
	~	Mkm2/yr
	~		|

Shifting_TROP_to_NF_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC < 0, TROP_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_on_shifting_TROP_to_NF
	  * Temp_driver_to_shift_biomes_degC , 0) * (-1)
	~	Mkm2/yr
	~		|

Evaporation_aka_latent_heat_flow=
	Evaporation_as_f_of_temp
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 88 +/- 10 W p m2 for the \
		period 2000 to 2010 Since we shift some of the heat energy leaving the \
		surface of the earth to evaporative energy, our value is higher.  To \
		convert ZJ py to W p m2 (for the entire earth's surface) divide by 16.09
	|

Evaporation_as_f_of_temp=
	( Incoming_solar_in_1850_ZJ_py * Evaporation_as_fraction_of_incoming_solar_in_1850 )\
		 * (1 + Sensitivity_of_evaporation_to_temp
	 * (Temp_surface_anomaly_compared_to_anfang_degC/Reference_temp_C))
	~	ZJ/yr
	~	The normal formulation is ref value (usually in 1850) * (1 + Sensitivity * \
		(Current driver value/ ref driver value -1)) Since the ref driver value \
		(the temp anomaly) can be zero we'd get a division by zero error.  Thus we \
		only use the current driver value and divide by 10.
	|

Evaporation_as_fraction_of_incoming_solar_in_1850=
	0.289
	~	dimensionless
	~		|

Population_2000_bn=
	6.187
	~	Bp
	~		|

UNIT_conversion_1_p_km3=
	1
	~	1/km3
	~		|

UNIT_conversion_C_to_pH=
	1
	~	pH/C
	~		|

Combined_env_damage_indicator=
	( sea_level_rise_ratio_wrt_2020 + temp_ratio_wrt_2020 ) / 2 - 1
	~	1
	~	We assume damage from sea level rise and from temperature to be additive. \
		1 = no addtional damage relative to 2020
	|

Concentration_of_C_in_ocean_top_layer_in_1850=
	Carbon_in_top_ocean_layer_1850
	/ ( Volume_cold_ocean_0_to_100m + Volume_warm_ocean_0_to_100m)
	~	GtC/Gm3
	~		|

Greenland_ice_area_increase_Mkm2_pr_yr=
	(Greenland_ice_freezing_km3_py / Avg_thickness_Greenland_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

Greenland_ice_area_km2=
	(Greenland_ice_volume_on_Greenland_km3 / Avg_thickness_Greenland_km) * UNIT_Conversion_from_km3_to_km2
	~	km2
	~		|

Greenland_ice_freezing_km3_py=
	IF_THEN_ELSE(Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py < 0 , Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		 * (-1)
	 , 0)
	~	km3/yr
	~		|

Contrib_of_BARREN_land_to_albedo_land=
	BARREN_land_normal_albedo_Mkm2 / Area_of_land_Mkm2 * Albedo_BARREN_normal
	~	fraction
	~		|

Contrib_of_GRASS_to_albedo_land=
	(GRASS_potential_area_Mkm2 - GRASS_area_burnt_Mkm2 - GRASS_deforested_Mkm2) / Area_of_land_Mkm2
	 * Albedo_GRASS_normal_cover
	+ GRASS_area_burnt_Mkm2 / Area_of_land_Mkm2 * Albedo_GRASS_burnt
	+ GRASS_deforested_Mkm2 / Area_of_land_Mkm2 * Albedo_GRASS_deforested
	~	fraction
	~		|

Contrib_of_NF_to_albedo_land=
	(NF_potential_area_Mkm2 - NF_area_burnt_Mkm2 - NF_area_deforested_Mkm2 - NF_area_clear_cut_Mkm2\
		) / Area_of_land_Mkm2 * Albedo_NF_normal_cover
	+ NF_area_burnt_Mkm2 / Area_of_land_Mkm2 * Albedo_NF_burnt
	+ NF_area_deforested_Mkm2 / Area_of_land_Mkm2 * Albedo_NF_deforested
	+ NF_area_clear_cut_Mkm2 / Area_of_land_Mkm2 * Albedo_NF_deforested
	~	fraction
	~		|

Contrib_of_TROP_to_albedo_land=
	(TROP_potential_area_Mkm2 - TROP_area_burnt - TROP_area_deforested) / Area_of_land_Mkm2\
		 * Albedo_TROP_normal_cover
	+ TROP_area_burnt / Area_of_land_Mkm2 * Albedo_TROP_burnt
	+ TROP_area_deforested / Area_of_land_Mkm2 * Albedo_TROP_deforested
	+ TROP_area_clear_cut / Area_of_land_Mkm2 * Albedo_TROP_deforested
	~	fraction
	~		|

Contrib_of_TUNDRA_to_albedo_land=
	(Tundra_potential_area_Mkm2 - TUNDRA_area_burnt_Mkm2 - TUNDRA_deforested_Mkm2) / Area_of_land_Mkm2
	 * Albedo_TUNDRA_normal_cover
	+ TUNDRA_area_burnt_Mkm2 / Area_of_land_Mkm2 * Albedo_TUNDRA_burnt
	+ TUNDRA_deforested_Mkm2 / Area_of_land_Mkm2 * Albedo_TUNDRA_deforested
	~	fraction
	~		|

Contribution_to_forcing_by_CH4=
	Blocked_by_CH4 / Frac_blocked_by_ALL_GHG
	~	1
	~		~	:SUPPLEMENTARY 
	|

Contribution_to_forcing_by_CO2=
	Blocked_by_CO2 / Frac_blocked_by_ALL_GHG
	~	1
	~		~	:SUPPLEMENTARY 
	|

Contribution_to_forcing_by_H2O=
	Blocked_by_H20 / Frac_blocked_by_ALL_GHG
	~	1
	~		~	:SUPPLEMENTARY 
	|

Contribution_to_forcing_by_othGHG=
	Blocked_by_otherGHG / Frac_blocked_by_ALL_GHG
	~	1
	~		~	:SUPPLEMENTARY 
	|

Convection_aka_sensible_heat_flow=
	Convection_as_f_of_temp_ZJ_py
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 24 +/- 7 W p m2 for the \
		period 2000 to 2010.  To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

Convection_as_f_of_incoming_solar_in_1850=
	0.071
	~	fraction
	~		|

Convection_as_f_of_temp_ZJ_py=
	( Incoming_solar_in_1850_ZJ_py * Convection_as_f_of_incoming_solar_in_1850 ) * (1 + \
		Sensitivity_of_convection_to_temp
	 * (Temp_surface_current_divided_by_value_anfang - 1))
	~	ZJ/yr
	~		|

Conversion_constant_GtC_to_ppm=
	C_in_atmosphere_in_1850_GtC / CO2_concentration_ppm_in_1850

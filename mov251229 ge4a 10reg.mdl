Time_to_close_gap_in_fossil_el_cap[region]=
	15, 5, 6, 10, 5, 5, 5, 5, 10, 6
	~	y [0,25,5]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c174' )

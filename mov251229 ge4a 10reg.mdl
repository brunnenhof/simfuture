		0.52),(2014,0.54),(2015,0.56),(2016,0.57),(2017,0.59),(2018,0.6),(2019,0.6) )) ~~|
N2O_emi_from_agri_hist_table[la]= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,0.74),(1981,0.74),(1982,0.74),(1983,0.74),(1984,0.75),(1985\
		,0.76),(1986,0.78),(1987,0.81),(1988,0.8),(1989,0.81),(1990,0.82),(1991,0.82),(1992\
		,0.83),(1993,0.84),(1994,0.85),(1995,0.86),(1996,0.84),(1997,0.85),(1998,0.87),(1999\
		,0.87),(2000,0.89),(2001,0.93),(2002,0.94),(2003,0.99),(2004,0.99),(2005,1.02),(2006\
		,1.03),(2007,1.06),(2008,1.05),(2009,1.05),(2010,1.07),(2011,1.1),(2012,1.11),(2013\
		,1.11),(2014,1.12),(2015,1.09),(2016,1.14),(2017,1.18),(2018,1.16),(2019,1.18) )) ~~|
N2O_emi_from_agri_hist_table[pa]= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,0.19),(1981,0.18),(1982,0.19),(1983,0.19),(1984,0.19),(1985\
		,0.21),(1986,0.2),(1987,0.19),(1988,0.18),(1989,0.19),(1990,0.19),(1991,0.19),(1992\
		,0.19),(1993,0.19),(1994,0.2),(1995,0.2),(1996,0.2),(1997,0.21),(1998,0.21),(1999,0.21\

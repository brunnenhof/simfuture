	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c37' )
	|

El_use_pp_WO_US_x0[region]=
	6.2, 13, 13, 22.6, 13.49, 22.6, 20.34, 26, 6.2, 28
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c38' )

	~	1/yr
	~		|

Temp_atm_1850=
	274.31
	~	k [270,285,1]
	~	for equilibrium at start
	|

Temp_atm_average_K=
	Heat_in_atmosphere_ZJ * Conversion_heat_atm_to_temp
	~	k
	~		|

Montreal_gases_in_atm= INTEG (
	Montreal_gases_emissions-Montreal_gases_degradation,
		16239.5
		)
	~	kt
	~		|

TROP_deforestation_cutoff_effect= WITH LOOKUP (
	TROP_deforested_as_pct_of_potential_area,
		([(0.5,0)-(0.8,10)],(0.5,1),(0.619266,1.92982),(0.683486,2.7193),(0.733028,4.03509)\
		,(0.76055,5.26316),(0.783486,6.84211),(0.8,10) ))
	~	dimensionless
	~		|

TROP_deforested_as_pct_of_potential_area=
	TROP_area_deforested / TROP_potential_area_Mkm2
	~	dimensionless
	~		|

TROP_deforestion_multiplier= WITH LOOKUP (
	Time,
		([(1850,0)-(2100,2)],(1850,0),(1970,0.4),(2000,0.5),(2020,0.5),(2100,0) ))
	~	dimensionless
	~	system-wide calibration against Global Carbon Project data, esp 1959 to \
		2020 https://essd.copernicus.org/articles/12/3269/2020/
	|

TROP_for_construction_use=
	Use_of_TROP_biomass_for_construction
	~	GtBiomass/yr
	~		|

TROP_Fraction_of_construction_waste_burned_0_to_1=
	0.5
	~	fraction
	~		|

TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_clear_cutting=
	0.5
	~	fraction
	~	This variable controls how much of the forest soil (litter and soil \
		organic matter) is destroyed (ie washed out) through clear cutting \
		techniques. Valid range is 0 (nothing is destroyed through clear cutting \
		techniques) to 1 (everything is destroyed through clear cutting \
		techniques) Not that the actual fraction destroyed is a multiplication of \
		this variable and of "TROP fraction clear cut", if either is 0 the result \
		is also 0.
	|

TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting=
	1
	~	fraction
	~		|

TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting=
	0.1
	~	fraction
	~		|

TROP_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires=
	0
	~	fraction
	~	A value of 0 means that if living biomass is destroyed by (natural) fires, \
		the soil remains intact. One can specify a multiplier between 0 and 1 to \
		signal that at 1 all soil (under the fire) is destroyed, or at eg 0.5 50% \
		of the soil (under the fire) is destroyed.
	|

UNIT_conversion_Gt_to_kt=
	1e+06
	~	kt/GtCO2e
	~		|

Greenland_ice_melting_as_water_km3_py=
	Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py * Densitiy_of_water_relative_to_ice
	~	km3/yr
	~		|

Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py=
	(Greenland_ice_volume_on_Greenland_km3 / Effective_time_to_melt_greenland_ice_at_the_reference_delta_temp\
		) * Effect_of_temp_on_melting_greenland_ice
	 * Effect_of_heat_in_atm_on_melting_ice_cut_off
	* Snowball_earth_cutoff
	* Melting_constraint_from_the_heat_in_atmosphere_reservoir_fraction
	~	km3/yr
	~		|

TROP_Living_biomass_GtBiomass= INTEG (
	TROP_biomass_new_growing-TROP_for_construction_use-TROP_Living_biomass_rotting-TROP_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting\
		,
		TROP_Living_biomass_in_1980)
	~	GtBiomass
	~		|

K_to_C_conversion=
	273.15
	~	C/k
	~	Temp in K = Temp in C + 273.15
	|

GRASS_historical_deforestation_pct_py=
	(GRASS_Ref_historical_deforestation_pct_py / 100)
	~	1/yr
	~		|

Kyoto_Fluor_concentration_in_1970_ppt=
	9.32074
	~	ppt [9,10,0.1]
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1970 value
	|

Kyoto_Fluor_concentration_ppt=
	Kyoto_Fluor_gases_in_atm * Conversion_from_Kyoto_Fluor_amount_to_concentration_ppt_p_kt
	~	ppt
	~		|

Kyoto_Fluor_degradation=
	Kyoto_Fluor_gases_in_atm / Time_to_degrade_Kyoto_Fluor_yr
	~	kt/yr
	~		|

Kyoto_Fluor_emissions=
	Kyoto_Fluor_emissions_JR_RCP3_or_SSP245
	~	kt/yr
	~		|

Zetta=
	1e+21
	~	dimensionless
	~		|

UNIT_conversion_to_km2_py=
	1
	~	1/km
	~		|

UNIT_conversion_to_yr=
	1
	~	1/yr
	~		|

UNIT_conversion_ymoles_p_litre_to_dless=
	1
	~	dimensionless / (ymoles/litre)
	~	This variable is used in the next equation as an matissa in an exponential \
		function. Vensim only allows dimensionless units for mantissa variables
	|

UNIT_converter_GtC_p_Gm3_to_ymoles_p_litre=
	1e+06 / 12.01 * 1000
	~	(ymoles/litre)/(GtC/Gm3)
	~	GtC/Gm3 = tC / m3 = tC / 1000 litre = 1000 kg C / 1000 litre = kg C / \
		litre = 1000 g C / litre = 1000 * 12.01 mol / litre = 1000 * 12.01 * 1e-6 \
		micro mol / litre
	|

Seconds_per_yr=
	60 * 60 * 24 * 365
	~	s/yr
	~		|

LW_TOA_radiation_from_atm_to_space_difference_wrt_1850=
	LW_TOA_radiation_from_atm_to_space_in_1850 - LW_TOA_radiation_from_atm_to_space
	~	ZJ/Year
	~		~	:SUPPLEMENTARY 
	|

TROP_Time_to_decompose_undisturbed_dead_biomass_yr=
	24
	~	yr
	~		|

TROP_Use_of_NF_biomass_for_energy=
	 Use_of_TROP_for_energy_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use
	 * UNIT_conversion_to_yr
	~	GtBiomass/yr
	~		|

TROP_with_normal_cover=
	TROP_potential_area_Mkm2 - TROP_area_burnt - TROP_area_deforested - TROP_area_clear_cut
	 - TROP_area_harvested_Mkm2
	~	Mkm2
	~		|

TUNDRA_area_burned_in_1980=
	1.8566
	~	Mkm2
	~		|

TUNDRA_area_burnt_Mkm2= INTEG (
	TUNDRA_burning_Mkm2_py-TUNDRA_regrowing_after_being_burnt_Mkm2_py,
		TUNDRA_area_burned_in_1980)
	~	Mkm2
	~		|

Ocean_heat_used_for_melting_last_year_ZJ_py=
	SMOOTHI(Ocean_heat_used_for_melting_ZJ_py, per_annum_yr, Ocean_heat_used_for_melting_Initially_1_py\
		)
	~	1/yr
	~		|

GRASS_with_normal_cover_Mkm2=
	GRASS_potential_area_Mkm2 - GRASS_area_burnt_Mkm2 - GRASS_deforested_Mkm2 - GRASS_area_harvested_Mkm2
	~	Mkm2
	~		|

GRASS_Dead_biomass_decomposing=
	GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / GRASS_Time_to_decompose_undisturbed_dead_biomass_yr
	~	GtBiomass/yr
	~		|

TUNDRA_Ref_historical_deforestation_pct_py=
	0
	~	1/yr
	~	[Source: guess, so far]
	|

Use_of_GRASS_for_energy_in_2000_GtBiomass=
	GRASS_Living_biomass_in_1850 * Use_of_GRASS_biomass_for_energy_in_1850_pct / 100
	~	GtBiomass
	~		|

TUNDRA_regrowing_after_being_deforested_Mkm2_py=
	TUNDRA_deforested_Mkm2 / Time_to_regrow_TUNDRA_after_deforesting_yr
	~	Mkm2/yr
	~		|

TUNDRA_regrowing_after_harvesting_Mkm2_py=
	TUNDRA_area_harvested_Mkm2 / Time_to_regrow_TUNDRA_yr
	~	Mkm2/yr
	~		|

Use_of_NF_biomass_for_energy=
	Use_of_NF_for_energy_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use
	 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

TUNDRA_runoff_time=
	2000
	~	yr
	~	The value is not very sensitive: A value of 20 years lowers the delta temp \
		from 1850 (the so-called temperature anomaly) by 10%. Increasing the value \
		has no effect. A value of 2000 years means that annualy 0.02 % of dead \
		biomass and soil organic carbon are washed out to sea - via rivers. The \
		IPCC gives a value of 0.9 GtC per yr being washed out to see for all types \
		of vegetation / soil (Source: IPCC Climate Change 2013, The Physical \
		Science Basis, Fig 6.1 pg 471), up from 0.4 GtC pr yr reported in the \
		previous IPCC report. (Source: IPCC AR4WG1 Figure 7.3).
	|

GRASS_for_construction_use=
	Use_of_GRASS_biomass_for_construction
	~	GtBiomass/yr
	~		|

GRASS_Fraction_of_construction_waste_burned_0_to_1=
	0.5
	~	fraction
	~		|

TROP_area_harvested_in_1980=
	0.24296
	~	Mkm2
	~		|

NF_Ref_historical_deforestation_pct_py=
	0.02
	~	1/yr
	~	[Source: guess, so far]
	|

GRASS_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires=
	0
	~	fraction
	~	A value of 0 means that if living biomass is destroyed by (natural) fires, \
		the soil remains intact. One can specify a multiplier between 0 and 1 to \
		signal that at 1 all soil (under the fire) is destroyed, or at eg 0.5 50% \
		of the soil (under the fire) is destroyed.
	|

TUNDRA_DeadB_SOM_being_lost_due_to_energy_harvesting=
	TUNDRA_being_harvested_Mkm2_py * TUNDRA_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting\
		 * TUNDRA_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~		|

TUNDRA_for_construction_use=
	Use_of_TUNDRA_biomass_for_construction
	~	GtBiomass/yr
	~		|

TUNDRA_Fraction_of_construction_waste_burned_0_to_1=
	0.5
	~	fraction
	~		|

GRASS_area_burned_in_1980=
	1.741
	~	Mkm2
	~		|

TUNDRA_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting=
	0.1
	~	fraction
	~		|

Volume_cold_ocean_0_to_100m=
	Area_of_ocean_at_surface_361900_Gm2 * Thickness_of_surface_water_box_100m * Fraction_of_ocean_classified_as_cold_surface\
		 * UNIT_conversion_to_Gm3
	~	Gm3
	~		|

TUNDRA_living_biomass_densitiy_at_initial_time_tBiomass_pr_km2=
	14500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

TUNDRA_living_biomass_densitiy_tBiomass_pr_km2=
	TUNDRA_living_biomass_densitiy_at_initial_time_tBiomass_pr_km2 * Effect_of_CO2_on_new_biomass_growth\
		 * Effect_of_temperature_on_new_biomass_growth_dmnl
	~	tB/km2
	~		|

TUNDRA_Living_biomass= INTEG (
	TUNDRA_biomass_new_growing-TUNDRA_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting\
		-TUNDRA_for_construction_use-TUNDRA_Living_biomass_rotting,
		TUNDRA_Living_biomass_in_1980)
	~	GtBiomass
	~		|

GRASS_Biomass_in_construction_material_left_to_rot=
	GRASS_Biomass_locked_in_construction_material_GtBiomass / GRASS_Avg_life_of_building_yr\
		 * (1 - GRASS_Fraction_of_construction_waste_burned_0_to_1)
	~	GtBiomass/yr
	~		|

GRASS_Biomass_locked_in_construction_material_GtBiomass= INTEG (
	GRASS_for_construction_use
	-GRASS_Biomass_in_construction_material_being_burnt
	-GRASS_Biomass_in_construction_material_left_to_rot,
		GRASS_Biomass_locked_in_construction_material_in_1980)
	~	GtBiomass
	~	This level is being emptied by a 3rd order delay of the inflow rate.
	|

GRASS_Biomass_locked_in_construction_material_in_1980=
	1.99186
	~	GtBiomass
	~	calibration
	|

GRASS_biomass_new_growing=
	GRASS_potential_less_actual_living_biomass_GtBiomass / GRASS_Speed_of_regrowth_yr
	~	GtBiomass/yr
	~		|

GRASS_burning_Mkm2_py=
	GRASS_with_normal_cover_Mkm2 * Effect_of_temperature_on_fire_incidence * GRASS_Normal_fire_incidence_fraction_py
	 / 100
	~	Mkm2/yr
	~		|

Greenland_ice_area_decrease_Mkm2_pr_yr=
	(Greenland_ice_melting_km3_py / Avg_thickness_Greenland_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

UNIT_conversion_from_MtCH4_to_GtC=
	1 /( 1000 / 12 * 16)
	~	GtC/MtCH4
	~	converted to carbon using relative molar weights (16/12)
	|

GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980=
	1086.88
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

UNIT_conversion_Gm3_to_km3=
	1
	~	km3/Gm3
	~		|

Water_content_of_evaporation_g_p_kg_per_ZJ_py=
	0.001253
	~	(g/kg) / (ZJ/y)
	~	system-wide calibration agains Global Carbon Project data, esp 1959 to \
		2020 https://essd.copernicus.org/articles/12/3269/2020/ The extreme \
		sensitivity of this parameter shows that the hydrological cycle should be \
		the number one priority of any further work
	|

TUNDRA_runoff=
	TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / TUNDRA_runoff_time
	~	GtBiomass/yr
	~		|

Temp_surface_1850=
	286.815
	~	k
	~	for equilibrium at start
	|

Greenland_ice_melting_km3_py=
	IF_THEN_ELSE(Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py > 0 , Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		 , 0)
	~	km3/yr
	~		|

GRASS_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting=
	1
	~	fraction
	~		|

GRASS_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting=
	0.1
	~	fraction
	~		|

NF_being_harvested_normally_Mkm2_py=
	NF_being_harvested_Mkm2_py * (1-NF_clear_cut_fraction)
	~	Mkm2/yr
	~		|

NF_Biomass_locked_in_construction_material_GtBiomass= INTEG (
	NF_for_construction_use
	-NF_Biomass_in_construction_material_being_burnt
	-NF_TUNDRA_Biomass_in_construction_material_left_to_rot,
		NF_Biomass_locked_in_construction_material_in_1980)
	~	GtBiomass
	~		|

Sea_level_change_from_melting_ice_and_thermal_expansion_m=
	Total_sea_level_change_from_thermal_expansion_m + Sea_level_rise_from_melting_ice_m
	~	m
	~		|

Sea_level_change_from_thermal_expansion_deep_m=
	Volume_expansion_from_thermal_expansion_deep_Gm3_is_km3 / Ocean_surface_area_km2 * UNIT_Conversion_from_km3_to_km2
	~	km
	~		|

LW_surface_emission=
	BB_radiation_at_surface_temp_ZJ_py
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 398 +/- 5 W p m2 for the \
		period 2000 to 2010 However, this seems to be a mistake since a radiation \
		of this magnitude needs a temperature of 16.4  degC or 289.55  degK at the \
		maximum emissivity of 1. We use a lower surface temperature as seen in the \
		record and shift some of the heat energy leaving the surface of the earth \
		to evaporative energy.  To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

Incoming_solar_in_1850_ZJ_py=
	5470.69
	~	ZJ/yr
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1850 value
	|

LW_surface_emissions_escaping_through_atm_window=
	LW_surface_emission * Frac_of_surface_emission_through_atm_window
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 20 +/- 4 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

GRASS_potential_area_Mkm2= INTEG (
	Shifting_NF_to_GRASS_Mkm2_py+Shifting_TROP_to_GRASS_Mkm2_py+Shifting_DESERT_to_GRASS_Mkm2_py\
		-Shifting_GRASS_to_DESERT_Mkm2_py-Shifting_GRASS_to_NF_Mkm2_py-Shifting_GRASS_to_TROP_Mkm2_py\
		,
		22.5095
		)
	~	Mkm2
	~		|

LW_TOA_radiation_from_atm_to_space_in_1850= INITIAL(
	3826.2)
	~	ZJ/Year
	~	= INITIAL (LW_TOA_radiation_from_atm_to_space) it is actually the 1980 \
		value!!
	|

GRASS_runoff_time=
	2000
	~	yr
	~	The value is not very sensitive: A value of 20 years lowers the delta temp \
		from 1850 (the so-called temperature anomaly) by 10%. Increasing the value \
		has no effect. A value of 2000 years means that annualy 0.02 % of dead \
		biomass and soil organic carbon are washed out to sea - via rivers. The \
		IPCC gives a value of 0.9 GtC per yr being washed out to see for all types \
		of vegetation / soil (Source: IPCC Climate Change 2013, The Physical \
		Science Basis, Fig 6.1 pg 471), up from 0.4 GtC pr yr reported in the \
		previous IPCC report. (Source: IPCC AR4WG1 Figure 7.3).
	|

GRASS_soil_degradation_from_forest_fires=
	GRASS_burning_Mkm2_py * GRASS_DeadB_and_SOM_tB_per_km2 / 1000 * GRASS_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires
	~	GtBiomass/yr
	~	factor 1000 is to convert Giga to Million
	|

GRASS_Speed_of_regrowth_yr=
	2
	~	yr [0.1,5,0.5]
	~		|

GRASS_Time_to_decompose_undisturbed_dead_biomass_yr=
	1000
	~	yr [0,200,20]
	~		|

UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py=
	1e-06
	~	Mkm2*km/km3
	~	Vensim does not know that km3 = km2 * km, nor km^3 = km^2 * km is known to \
		the Vensim unit parser. Hence the convoluted unit. Sorry. The only thing \
		it does know is km * km * km = (km * km) * km. 1e-006 converts to Million
	|

Use_of_GRASS_biomass_for_energy=
	 Use_of_GRASS_for_energy_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use
	 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

UNIT_Conversion_from_N2O_amount_to_concentration_ppb_p_MtN2O=
	0.305
	~	ppb/MtN2O
	~		|

NF_area_deforested_Mkm2= INTEG (
	NF_being_deforested_Mkm2_py-NF_regrowing_after_being_deforested_Mkm2_py,
		NF_area_deforested_in_1980)
	~	Mkm2
	~		|

temp_ratio_wrt_2020=
	IF_THEN_ELSE(Time < 2020, 1, Temp_surface_anomaly_compared_to_anfang_degC / temp_in_2020\
		)
	~	1
	~		|

LW_HI_cloud_radiation=
	LW_HI_cloud_radiation_reference_in_1980 * UNIT_conversion_W_p_m2_earth_to_ZJ_py * Ratio_of_area_covered_by_high_clouds_current_to_init
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 26.7 +/- 4 W p m2 and 26.5 +/- 5 for \
		the period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
		Even when starting the model in 1980, the radiation comes from the \
		"Stephens values" for 1850, what has changed in between is the extent of \
		the cloud cover
	|

NF_Avg_life_biomass_yr=
	60
	~	yr
	~		|

NF_Avg_life_of_building_yr=
	20
	~	yr
	~		|

Temp_surface=
	Temp_surface_average_K - 273.15
	~	C
	~		|

UNIT_conversion_km2_to_Mkm2=
	1/1e+06
	~	Mkm2/km2
	~		|

SCALE_converter_zero_C_to_K=
	273.15
	~	k
	~	273.15 is zero C in K
	|

Open_water_as_frac_of_ocean_area=
	1-(Arctic_ice_on_sea_area_km2/Ocean_area_km2)
	~	fraction
	~		|

Use_of_TUNDRA_biomass_for_construction=
	Use_of_TUNDRA_for_construction_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use\
		 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

TROP_being_harvested_normally=
	TROP_being_harvested * (1-TROP_clear_cut_fraction)
	~	Mkm2/yr
	~		|

NF_soil_degradation_from_clear_cutting=
	NF_being_harvested_by_clear_cutting_Mkm2_py * NF_fraction_of_DeadB_and_SOM_being_destroyed_by_clear_cutting\
		 * NF_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~		|

NF_soil_degradation_from_forest_fires=
	NF_burning_Mkm2_py * NF_DeadB_and_SOM_tB_per_km2 / UNIT_conversion_GtBiomass_py_to_Mkm2_py\
		 * NF_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires
	~	GtBiomass/yr
	~	factor 1000 is to convert Giga to Million
	|

TROP_Biomass_locked_in_construction_material_GtBiomass= INTEG (
	TROP_for_construction_use
	-TROP_Biomass_in_construction_material_being_burnt
	-TROP_Biomass_in_construction_material_left_to_rot,
		TROP_Biomass_locked_in_construction_material_in_1980)
	~	GtBiomass
	~		|

TROP_biomass_new_growing=
	TROP_potential_less_actual_living_biomass_GtBiomass / TROP_Speed_of_regrowth_yr
	~	GtBiomass/yr
	~		|

TROP_burning=
	TROP_with_normal_cover * Effect_of_temperature_on_fire_incidence * TROP_Normal_fire_incidence
	 / 100
	~	Mkm2/yr
	~		|

TROP_clear_cut_fraction=
	0.5
	~	dimensionless
	~		|

Montreal_gases_concentration_ppt=
	Montreal_gases_in_atm * Conversion_from_Montreal_gases_amount_to_concentration_ppt_p_kt
	~	ppt
	~		|

Time_to_degrade_N2O_in_atmopshere_yr=
	95
	~	yr
	~	This is a systems dynamics adjustment time, which means that it takes 3 \
		times the time to reduce the level almost to zero (if inflow is stopped)
	|

Time_to_deposit_C_in_sediment=
	20000
	~	yr
	~		|

Volcanic_aerosols_removed_from_stratosphere=
	Volcanic_aerosols_in_stratosphere / Time_for_volcanic_aerosols_to_remain_in_the_stratosphere
	~	GtVAe/yr
	~		|

Temp_atm_in_C=
	Temp_atm_average_K - 273.15
	~	C
	~		~	:SUPPLEMENTARY 
	|

Montreal_Global_Warming_Potential=
	10000
	~	dimensionless
	~	http://ecometrica.com/white-papers/greenhouse-gases-co2-co2e-and-carbon-wha\
		t-do-all-these-terms-mean pointing to Contribution of Working Group I to \
		the Fourth Assessment Report of the Intergovernmental Panel on Climate \
		Change, 2007 Solomon, S., D. Qin, M. Manning, Z. Chen, M. Marquis, K.B. \
		Averyt, M. Tignor and H.L. Miller (eds.) Cambridge University Press, \
		Cambridge, United Kingdom and New York, NY, USA. Table 2.10.2 Direct \
		Global Warming Potentials available at \
		https://archive.ipcc.ch/publications_and_data/ar4/wg1/en/ch2s2-10-2.html
	|

UNIT_conversion_Celsius_to_Kelvin_C_p_K=
	1
	~	C/k
	~		|

UNIT_conversion_for_CH4_from_CO2e_to_C=
	1/(16/12 * Global_Warming_Potential_CH4)
	~	GtC / GtCO2e
	~		|

UNIT_conversion_for_CO2_from_CO2e_to_C=
	12/44
	~	GtC / GtCO2e
	~		|

UNIT_conversion_from_km_to_m=
	1000
	~	m/km
	~		|

Solar_sine_forcing_amplitude=
	0.085
	~	W/m2 [-1,2,0.2]
	~	value calibrated to match RCP solar forcing history best during the last \
		40 yrs
	|

UNIT_Conversion_from_km3_to_km2=
	1
	~	km2*km/km3
	~	Vensim does not know that km3 = km2 * km, nor km^3 = km^2 * km is known to \
		the Vensim unit parser. Hence the convoluted unit. Sorry. The only thing \
		it does know is km * km * km = (km * km) * km
	|

LW_Clear_sky_emissions_from_atm_W_p_m2=
	LW_Clear_sky_emissions_from_atm / UNIT_conversion_W_p_m2_earth_to_ZJ_py
	~	W/m2
	~		~	:SUPPLEMENTARY 
	|

Slope_btw_temp_and_permafrost_melting_or_freezing_base=
	1
	~	dimensionless [0,2,0.1]
	~	see eg \
		http://www.nature.com/nature/journal/v480/n7377/full/nature10576.html \
		"Metagenomic analysis of a permafrost microbial community reveals a rapid \
		response to thaw" The slope could itself be a function (exponentially? \
		rising?) of temperature
	|

UNIT_conversion_W_p_m2_earth_to_ZJ_py=
	(Seconds_per_yr * Area_of_earth_m2) * UNIT_conversion_W_to_ZJ_p_sec / Zetta
	~	(ZJ/yr) / (W/m2)
	~		|

NF_area_harvested_in_1980=
	0.897719
	~	Mkm2
	~		|

UNIT_conversion_Gt_to_Mt=
	1000
	~	MtN2O/GtCO2e
	~		|

UNIT_conversion_GtBiomass_py_to_Mkm2_py=
	1000
	~	(Mkm2 * tB) / ( GtBiomass * km2)
	~	The Vensim unit parser does not understand that M = 1e6, that G = 1e9, \
		that Mkm2 = 1e6 * km2 and that tB = tBiomass
	|

NF_being_deforested_Mkm2_py=
	NF_with_normal_cover_Mkm2 * NF_historical_deforestation_pct_py
	~	Mkm2/yr
	~	pos is deforestation, neg is afforestation planting trees is best modeled \
		by making the slope of effect of temp shifting GRASS to TROP steeper
	|

NF_being_harvested_by_clear_cutting_Mkm2_py=
	 NF_being_harvested_Mkm2_py * NF_clear_cut_fraction
	~	Mkm2/yr
	~		|

UNIT_conversion_km2_times_km_to_km3=
	1
	~	km2 * km
	~		|

TUNDRA_with_normal_cover_Mkm2=
	Tundra_potential_area_Mkm2 - TUNDRA_area_burnt_Mkm2 - TUNDRA_deforested_Mkm2 - TUNDRA_area_harvested_Mkm2
	~	Mkm2
	~		|

NF_burning_Mkm2_py=
	NF_with_normal_cover_Mkm2 * Effect_of_temperature_on_fire_incidence * NF_Normal_fire_incidence_fraction_py
	 / 100
	~	Mkm2/yr
	~		|

UNIT_conversion_to_Gm3=
	1
	~	Gm3/(Gm2*m)
	~		|

NF_Dead_biomass_decomposing=
	NF_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / NF_Time_to_decompose_undisturbed_dead_biomass_yr
	~	GtBiomass/yr
	~		|

Incoming_solar_W_p_m2=
	340 + Solar_cycle_W_p_m2
	~	W/m2
	~		|

NF_DeadB_and_SOM_tB_per_km2=
	NF_DeadB_and_SOM_densitiy_in_1850 * Effect_of_CO2_on_new_biomass_growth * Effect_of_temperature_on_new_biomass_growth_dmnl
	~	tB/km2
	~		|

Urban_area_fraction_2000=
	0.004
	~	fraction
	~		|

Heat_in_deep_ZJ= INTEG (
	Heat_flow_from_the_earths_core + Net_heat_flow_ocean_from_surface_to_deep_ZJ_py,
		Heat_in_ocean_deep_in_1980)
	~	ZJ
	~		|

Heat_in_ocean_deep_in_1850_ZJ=
	1.9532e+06
	~	ZJ
	~	Using numbers from JRs note 140210 (hand written PDF) 1.764e+006
	|

Use_of_GRASS_biomass_for_construction=
	Use_of_GRASS_for_construction_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use\
		 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

ph_in_cold_water_in_1980=
	8.30948
	~	pH
	~	1980 value read off from ESMICON which runs from 1850
	|

NF_area_burned_in_1980=
	2.09605
	~	Mkm2
	~		|

NF_area_burnt_Mkm2= INTEG (
	NF_burning_Mkm2_py-NF_regrowing_after_being_burnt_Mkm2_py,
		NF_area_burned_in_1980)
	~	Mkm2
	~		|

NF_area_clear_cut_Mkm2= INTEG (
	NF_being_harvested_by_clear_cutting_Mkm2_py-NF_regrowing_after_being_clear_cut_Mkm2_py\
		,
		NF_area_clear_cut_in_1980)
	~	Mkm2
	~		|

TUNDRA_regrowing_after_being_burnt_Mkm2_py=
	TUNDRA_area_burnt_Mkm2 / Time_to_regrow_TUNDRA_yr
	~	Mkm2/yr
	~		|

Incoming_solar_ZJ_py=
	Incoming_solar_W_p_m2 * UNIT_conversion_W_p_m2_earth_to_ZJ_py
	~	ZJ/yr
	~		|

Time_to_degrade_Montreal_gases_yr=
	30
	~	yr
	~	This is a systems dynamics adjustment time, which means that it takes 3 \
		times the time to reduce the level almost to zero (if inflow is stopped)
	|

Time_to_propagate_temperature_change_through_the_volume_of_permafrost_yr=
	5
	~	yr [0,10,1]
	~		|

TUNDRA_soil_degradation_from_forest_fires=
	TUNDRA_burning_Mkm2_py * TUNDRA_DeadB_and_SOM_tB_per_km2 / UNIT_conversion_GtBiomass_py_to_Mkm2_py\
		 * TUNDRA_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires
	~	GtBiomass/yr
	~	factor 1000 is to convert Giga to Million
	|

TUNDRA_Time_to_decompose_undisturbed_dead_biomass_yr=
	1000
	~	yr [0,2000,100]
	~		|

Volume_expansion_from_thermal_expansion_surface_Gm3_is_km3=
	Surface_ocean_warm_volume * (Thermal_expansion_surface_pct - Thermal_expansion_surface_anfang_pct\
		) / 100 * (1 - Pressure_adjustment_surface_pct
	/100) * UNIT_conversion_Gm3_to_km3
	~	km3
	~		|

UNIT_conversion_km3_div_km_to_km2=
	1
	~	km2/(km3/km)
	~	the Vensim unit parser does not know that km3/km = km2
	|

NF_Biomass_in_construction_material_being_burnt=
	NF_Biomass_locked_in_construction_material_GtBiomass / NF_Avg_life_of_building_yr
	 * NF_Fraction_of_construction_waste_burned_0_to_1
	~	GtBiomass/yr
	~		|

Thermal_expansion_deep_anfang_pct= WITH LOOKUP (
	Temp_ocean_deep_in_1850_C,
		([(0,0)-(20,0.2)],(0,0.015),(1,0.008),(2,0.0033),(3,0.001),(4,0),(5,0.0012),(6,0.0033\
		),(7,0.008),(8,0.013),(9,0.021),(
		10,0.0287),(20,0.1963) ))
	~	dimensionless
	~	Original graph here http://physics.info/expansion/ data read off, curve \
		fitted in Excel
	|

Ref_shifting_biome_yr=
	50
	~	yr
	~	This value tells in how many years one biome shift to another (in size) \
		when the temperature in degC doubles / halfs with respect to the \
		temperature in 1850
	|

Ref_temp_difference_4_degC=
	4
	~	C [0,2,0.2]
	~	This means that at 2 degC difference (to 1850) permafrost retreats at 5 km \
		/ yr on the surface and needs 20 yrs to release 63pct its CH4 under that \
		surface.
	|

Net_marine_primary_production_in_1850=
	0.4
	~	GtC/yr
	~	calibration
	|

Net_marine_primary_production_NMPP_GtC_pr_yr=
	Net_marine_primary_production_in_1850 * Effect_of_C_concentration_on_NMPP * Effect_of_acidification_on_NMPP\
		 * Effect_of_temperature_on_NMPP
	~	GtC/yr
	~		|

VAES_puls_repetition=
	30
	~	yr [0,30,0.5]
	~		|

NF_DeadB_and_SOM_densitiy_in_1850=
	27500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

Reference_temp_C=
	10
	~	C
	~		|

Value_of_anthropogenic_aerosol_emissions_during_2015=
	0.225
	~	GtAAe/yr
	~		|

Volcanic_aerosols_in_stratosphere= INTEG (
	Volcanic_aerosols_emissions-Volcanic_aerosols_removed_from_stratosphere,
		0.118607
		)
	~	GtVAe
	~	GtVAe = Giga tonnes of volcanic aerosols equivalents
	|

Volume_cold_ocean_downwelling_100m_to_bottom=
	Area_of_ocean_at_surface_361900_Gm2 * (Thickness_of_intermediate_water_box_800m + Thickness_of_deep_water_box_1km_to_bottom
	) * Fraction_of_ocean_classified_as_cold_surface * UNIT_conversion_to_Gm3
	~	Gm3
	~		|

Volume_expansion_from_thermal_expansion_deep_Gm3_is_km3=
	Deep_ocean_cold_volume * (Thermal_expansion_deep_pct - Thermal_expansion_deep_anfang_pct\
		) / 100 * (1 - Pressure_adjustment_deep_pct
	/100) * UNIT_conversion_Gm3_to_km3
	~	km3
	~		|

Total_net_aerosol_forcings_W_p_m2=
	Anthropogenic_aerosol_forcing + Model_Volcanic_aerosol_forcing_W_p_m2
	~	W/m2
	~		|

Volume_ocean_deep_1km_to_bottom=
	Area_of_ocean_at_surface_361900_Gm2 * Thickness_of_deep_water_box_1km_to_bottom
	* Fraction_of_ocean_classified_warm_surface * UNIT_conversion_to_Gm3
	~	Gm3
	~		|

Volume_ocean_upwelling_100m_to_1km=
	Area_of_ocean_at_surface_361900_Gm2 * Thickness_of_intermediate_water_box_800m
	* Fraction_of_ocean_classified_warm_surface * UNIT_conversion_to_Gm3
	~	Gm3
	~		|

Volume_warm_ocean_0_to_100m=
	Area_of_ocean_at_surface_361900_Gm2 * Thickness_of_surface_water_box_100m * Fraction_of_ocean_classified_warm_surface\
		 * UNIT_conversion_to_Gm3
	~	Gm3
	~		|

TUNDRA_Normal_fire_incidence_fraction_py=
	1
	~	fraction/yr
	~	guess
	|

Pressure_adjustment_surface_pct=
	0.2
	~	dimensionless
	~	calculated ('eyeballed') from http://www.thermopedia.com/content/1150/
	|

TUNDRA_potential_less_actual_living_biomass_GtBiomass=
	TUNDRA_potential_living_biomass_GtBiomass - TUNDRA_Living_biomass
	~	GtBiomass
	~		|

NF_area_clear_cut_in_1980=
	3.99473
	~	Mkm2
	~	[Source: estimate to start in equilibrium]
	|

Time_to_melt_Arctic_ice_at_the_reference_delta_temp=
	500
	~	yr
	~	Calibrated so that arctic ice area declines from 10 M km2 in 1978 \
		(earliest data I have) to about 8 M km2 in 2010.
	|

NF_area_deforested_in_1980=
	0.129448
	~	Mkm2
	~	[Source: estimate to start in equilibrium]
	|

LW_surface_emissions_NOT_escaping_through_atm_window=
	LW_surface_emission * ( 1- Frac_of_surface_emission_through_atm_window)
	~	ZJ/yr
	~		|

Time_to_degrade_Kyoto_Fluor_yr=
	50
	~	yr
	~	This is a systems dynamics adjustment time, which means that it takes 3 \
		times the time to reduce the level almost to zero (if inflow is stopped)
	|

NF_Biomass_locked_in_construction_material_in_1980=
	16.8741
	~	GtBiomass
	~	calibration
	|

LW_LO_cloud_radiation=
	LW_LO_cloud_radiation_reference_in_1980 * UNIT_conversion_W_p_m2_earth_to_ZJ_py * Ratio_of_area_covered_by_low_clouds_current_to_init
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 26.7 +/- 4 W p m2 and 26.5 +/- 5 for \
		the period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
		Even when starting the model in 1980, the radiation comes from the \
		"Stephens values" for 1850, what has changed in between is the extent of \
		the cloud cover
	|

LW_LO_cloud_radiation_reference_in_1980=
	20
	~	W/m2 [19,22,0.1]
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1850 value
	|

Temp_diff_relevant_for_melting_or_freezing_anfang=
	Temp_surface - (Temp_surface_1850 - SCALE_converter_zero_C_to_K)*UNIT_conversion_Celsius_to_Kelvin_C_p_K
	~	C
	~		|

NF_fraction_of_DeadB_and_SOM_being_destroyed_by_energy_harvesting=
	0.1
	~	fraction
	~		|

Urbanzation_Effect_on_biomass_use= WITH LOOKUP (
	Time,
		([(1850,0)-(2300,5)],(1850,5),(1880,4.71),(1900,4.4),(1925,3.73),(1945,3.11),(1965,\
		2.37),(1975,1.93),(1988,1.4),(2000,1),(2012,0.79),(2028,0.59),(2060,0.37),(2100,0.25\
		),(2300,0) ))
	~	dimensionless
	~	The more people live in cities, the less demands they make on biomass as a \
		source of energy and construction material.  We have no source for this \
		other than 1 datapoint, namely the FAOs Forest Resource Assessments FAO \
		2012
	|

Pressure_adjustment_deep_pct=
	1
	~	dimensionless
	~	calculated ('eyeballed') from http://www.thermopedia.com/content/1150/
	|

NF_biomass_new_growing=
	NF_potential_less_actual_living_biomass_GtBiomass / NF_Speed_of_regrowth_yr
	~	GtBiomass/yr
	~		|

TROP_Biomass_in_construction_material_left_to_rot=
	TROP_Biomass_locked_in_construction_material_GtBiomass / TROP_Avg_life_of_building_yr\
		 * (1 - TROP_Fraction_of_construction_waste_burned_0_to_1)
	~	GtBiomass/yr
	~		|

Ref_temp_difference_for_Arctic_ice_melting=
	0.4
	~	C [0,3,0.1]
	~	This means that at 1 degC difference (to 1850) the effect is 1, i.e. ice \
		melts at the rate given by "Time to melt ... ice" This time is a SD time, \
		i.e. it means that about 63pct are melted away during this time and that \
		it takes 3 * time to melt away about 99pct or the original ice. See \
		Michael Goodman, Study Notes in System Dynamics, 1989, Pegasus \
		Communications ISBN 1-883823-40-4, Chapter 3, esp section 5
	|

Ref_temp_difference_for_glacial_ice_melting_1_degC=
	3
	~	C [0,20,0.5]
	~	This means that at 3 degC difference (to 1850) the effect is 1, i.e. ice \
		melts at the rate given by "Time to melt glacial ice"
	|

NF_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass= INTEG (
	NF_TUNDRA_Biomass_in_construction_material_left_to_rot+NF_Living_biomass_rotting-NF_Dead_biomass_decomposing\
		-NF_DeadB_SOM_being_lost_due_to_deforestation-NF_DeadB_SOM_being_lost_due_to_energy_harvesting\
		-NF_runoff-NF_soil_degradation_from_clear_cutting-NF_soil_degradation_from_forest_fires\
		,
		NF_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980)
	~	GtBiomass
	~		|

TUNDRA_Living_biomass_in_1850=
	300
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

Ratio_of_area_covered_by_high_clouds_current_to_init=
	Area_covered_by_high_clouds / Area_covered_by_high_clouds_in_1980
	~	dimensionless
	~		|

UNIT_conversion_m2_to_km2=
	1e+06
	~	m2/km2
	~	1 million m2 = 1 km2
	|

LW_Clear_sky_emissions_from_atm=
	(BB_radiation_at_Temp_in_atm_ZJ_py + LW_surface_emissions_escaping_through_atm_window\
		 ) * (1 - Frac_blocked_by_ALL_GHG)
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 266.4 +/- 3.3 W p m2 for \
		the period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

Temp_diff_relevant_for_melting_or_freezing_arctic_ice_from_anfang=
	SMOOTH(Temp_surface_anomaly_compared_to_anfang_degC, Arctic_surface_temp_delay_yr )
	~	C
	~		|

Ocean_heat_used_for_melting_Initially_1_py=
	0
	~	1/yr
	~	For the unit check to pass, the initial value of a DELAY1I variable needs \
		a unit; kind of ludicrous if the value is numerical 0; esp. when the \
		local, ie variable wide check says OK, but the model wide one says NOT ok. \
		Would help if Vensim parsed both the same way.
	|

Total_sea_level_change_from_thermal_expansion_m=
	(Sea_level_change_from_thermal_expansion_surface_m + Sea_level_change_from_thermal_expansion_deep_m\
		) * UNIT_conversion_from_km_to_m
	~	m
	~		|

Solar_cycle_W_p_m2=
	IF_THEN_ELSE(Time > 2019, 
	Solar_sine_forcing_W_p_m2, 
	Historical_forcing_from_solar_insolation_W_p_m2
	)
	~	W/m2
	~	value tuned to match RCP solar forcing history best during the last 40 yrs
	|

UNIT_conversion_mm_to_m=
	1/1000
	~	m/mm
	~		|

TROP_Biomass_in_construction_material_being_burnt=
	TROP_Biomass_locked_in_construction_material_GtBiomass / TROP_Avg_life_of_building_yr\
		 * TROP_Fraction_of_construction_waste_burned_0_to_1
	~	GtBiomass/yr
	~		|

Solar_sine_forcing_lift=
	0.06
	~	W/m2
	~	value calibrated to match RCP solar forcing history best during the last \
		40 yrs
	|

TUNDRA_potential_living_biomass_GtBiomass=
	( Tundra_potential_area_Mkm2 - TUNDRA_deforested_Mkm2 ) * TUNDRA_living_biomass_densitiy_tBiomass_pr_km2\
		 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass
	~	/ 1000 converts M(illion) to G(iga)
	|

Use_of_TUNDRA_for_construction_in_2000_GtBiomass=
	TUNDRA_Living_biomass_in_1850 * Use_of_TUNDRA_biomass_for_construction_in_1850_pct /\
		 100
	~	GtBiomass
	~		|

Ref_temp_difference_for_greenland_ice_melting_C=
	1
	~	C
	~	This means that at n degC difference (to 1850) the effect is 1, i.e. ice \
		melts at the rate given by "Time to melt greenland ice"
	|

VAES_pulse_height=
	1
	~	GtVAe/yr [0,2,0.1]
	~	To get a Pinatubo eruption this value should be 5, For a Krakatoa type \
		eruption, double at least
	|

NEvt_2a_Volcanic_eruptions_in_the_future_VAEs_first_future_pulse=
	2025
	~	yr [2015,2100,10]
	~	Set the year (in the future) when vocanoes start to erupt For no future \
		eruptions set to a really large value eg 2.1e+007
	|

UNIT_conversion_m2_to_Mkm2=
	1e+12
	~	m2 / Mkm2
	~	1 Mkm2 = 1 million * million m2
	|

Tundra_potential_area_Mkm2= INTEG (
	Shifting_ice_on_land_to_tundra_Mkm2_py
	+ Shifting_NF_to_Tundra_Mkm2_py
	- Shifting_tundra_to_ice_on_land_Mkm2_py
	- Shifting_Tundra_to_NF_Mkm2_py,
		22.5089
		)
	~	Mkm2
	~		|

UNIT_conversion_GtC_to_MtC=
	1000
	~	MtC/GtC
	~		|

UNIT_conversion_GtIce_to_ZJ_melting=
	1
	~	1/GtIce
	~		|

UNIT_conversion_km3_to_Gm3=
	1
	~	Gm3/km3
	~	The Vensiom parser does not know that 1 km3 IS 1 Gm3
	|

TUNDRA_Living_biomass_rotting=
	TUNDRA_Living_biomass / TUNDRA_Avg_life_biomass_yr
	~	GtBiomass/yr
	~		|

Use_of_TUNDRA_for_energy_in_2000_GtBiomass=
	TUNDRA_Living_biomass_in_1850 * Use_of_TUNDRA_biomass_for_energy_in_1850_pct / 100
	~	GtBiomass
	~		|

Ref_temp_difference_for_antarctic_ice_melting_3_degC=
	3
	~	C
	~	This means that at 3 degC difference (to 1850) the effect is 1, i.e. ice \
		melts at the rate given by "Time to melt antartic ice"
	|

Solar_sine_forcing_offset_yr=
	-7
	~	yr
	~	value calibrated to match RCP solar forcing history best during the last \
		40 yrs
	|

NF_fraction_of_DeadB_and_SOM_being_destroyed_by_clear_cutting=
	0.5
	~	fraction
	~	This variable controls how much of the forest soil (litter and soil \
		organic matter) is destroyed (ie washed out) through clear cutting \
		techniques. Valid range is 0 (nothing is destroyed through clear cutting \
		techniques) to 1 (everything is destroyed through clear cutting \
		techniques) Not that the actual fraction destroyed is a multiplication of \
		this variable and of "TROP fraction clear cut", if either is 0 the result \
		is also 0.
	|

Use_of_TUNDRA_biomass_for_construction_in_1850_pct=
	0.05
	~	dimensionless
	~	We have, of course, no clue how much of the GRASS biomass was used in 1850 \
		for construction. Thus complete guess, works for calibration
	|

VAES_pulse_duration=
	4
	~	yr [0,40,0.5]
	~	To get a Pinatubo eruption this value should be 0.5, i.e. a duration of \
		half a year For a Krakatoa type eruption, double at least
	|

TUNDRA_Sum_outflows_Dead_biomass_litter_and_soil_organic_matter_SOM=
	TUNDRA_DeadB_SOM_being_lost_due_to_deforestation
	+ TUNDRA_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ TUNDRA_runoff
	+ TUNDRA_soil_degradation_from_forest_fires
	+ TUNDRA_Dead_biomass_decomposing
	~	GtBiomass/yr
	~		~	:SUPPLEMENTARY 
	|

Surface_deep_ocean_temp_diff_degC=
	Temp_ocean_surface_in_K - Temp_ocean_deep_in_K
	~	k
	~		|

Upper_to_deep_ocean_temp_diff_anfang_1850_degC=
	Temp_ocean_surface_in_1850_C - Temp_ocean_deep_in_1850_C
	~	C
	~		~	:SUPPLEMENTARY 
	|

Use_of_TUNDRA_biomass_for_energy=
	Use_of_TUNDRA_for_energy_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use
	 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

Urban_Mkm2=
	Area_of_earth_Mkm2 * (1 - Fraction_of_earth_surface_as_ocean ) * Urban_area_fraction
	~	Mkm2
	~		|

NF_Fraction_of_construction_waste_burned_0_to_1=
	0.5
	~	fraction
	~		|

TUNDRA_Speed_of_regrowth_yr=
	3
	~	yr [0.1,5,0.5]
	~		|

Sum_outflows_GRASS_Dead_biomass_litter_and_soil_organic_matter_SOM=
	GRASS_DeadB_SOM_being_lost_due_to_deforestation
	+ GRASS_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ GRASS_runoff
	+ GRASS_soil_degradation_from_forest_fires
	+ GRASS_Dead_biomass_decomposing
	~	GtBiomass/yr
	~		|

NF_for_construction_use=
	 Use_of_NF_biomass_for_construction
	~	GtBiomass/yr
	~		|

TUNDRA_Living_biomass_in_1980=
	391.84
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

Weight_on_env_conditions=
	1 - Weight_on_living_conditions
	~	Dmnl
	~		|

El_use_wellbeing_a=
	4
	~	Dmnl [0,10,2]
	~		|

El_use_wellbeing_b=
	1
	~	Dmnl [0,2,0.5]
	~		|

Reference_public_spending_fraction=
	0.3
	~	Dmnl
	~	Used to anchor the causally following lookup function
	|

Current_year=
	2025
	~	y [2023,2100,1]
	~		~	:SUPPLEMENTARY 
	|

stdev=
	0.4
	~	Dmnl
	~		|

Public_spending_ratio[region]=
	Smoothed_Public_spending_as_share_of_GDP[region] / Satisfactory_public_spending
	~	Dmnl
	~		|

Strength_of_inequality_proxy=
	6
	~	Dmnl [1,10,1]
	~	to scale the model generated inequality to the published GINI index
	|

Perceived_RoC_in_Living_conditions_index_with_env_damage[region]=
	SMOOTHI ( RoC_in_Living_conditions_index_with_env_damage[region] , Social_tension_perception_delay\
		 , 0 )
	~	Dmnl/Year
	~		|

RoC_in_Living_conditions_index_with_env_damage[region]=
	( Living_conditions_index_with_env_damage[region] - Past_Living_conditions_index_with_env_damage\
		[region] ) / Social_tension_perception_delay
	~	1/Year
	~		|

Sum_of_food_weights=
	Weight_on_crops + Weight_on_red_meat + Weight_on_white_meat
	~	1
	~		|

Sum_weights_living_conditions=
	Weight_disposable_income + Weight_el_use + Weight_food + Weight_inequality + Weight_population_in_job_market\
		 + Weight_public_spending
	~	1
	~	All the weights could be made different for different regions if one \
		wanted to
	|

Indicated_inequality_index_higher_is_more_unequal[region]=
	1 + Strength_of_inequality_proxy * ( Worker_share_of_output_with_unemployment_effect_in_1980\
		[region] / Worker_share_of_output_with_unemployment_effect[region] -1)
	~	1
	~	History Gini index rescaled to 1980 = 1
		SWIID Version 9.2, December 2021 \
		https://dataverse.harvard.edu/dataset.xhtml?persistentId=doi:10.7910/DVN/LM\
		4OWF
		Solt, Frederick. 2020. “Measuring Income Inequality Across Countries and \
		Over Time: The Standardized World Income Inequality Database.” Social \
		Science Quarterly 101(3):1183-1199. SWIID Version 9.3, June 2022.
	|

Scaling_factor_for_amplitude_in_RoC_in_living_conditions_index=
	20
	~	1/y
	~	1
	|

Normal_k=
	0.3
	~	Dmnl
	~		|

Global_Food_footprint_kgN_ppy=
	Food_footprint_kgN_ppy[us] * Regional_population_as_fraction_of_total[us] +
	Food_footprint_kgN_ppy[af] * Regional_population_as_fraction_of_total[af] +
	Food_footprint_kgN_ppy[cn] * Regional_population_as_fraction_of_total[cn] +
	Food_footprint_kgN_ppy[me] * Regional_population_as_fraction_of_total[me] +
	Food_footprint_kgN_ppy[sa] * Regional_population_as_fraction_of_total[sa] +
	Food_footprint_kgN_ppy[la] * Regional_population_as_fraction_of_total[la] +
	Food_footprint_kgN_ppy[pa] * Regional_population_as_fraction_of_total[pa] +
	Food_footprint_kgN_ppy[ec] * Regional_population_as_fraction_of_total[ec] +
	Food_footprint_kgN_ppy[eu] * Regional_population_as_fraction_of_total[eu] +
	Food_footprint_kgN_ppy[se] * Regional_population_as_fraction_of_total[se]
	~	kgN/(Year*p)
	~		~	:SUPPLEMENTARY 
	|

Basic_el_use=
	2
	~	kWh/(p*y)
	~		|

Weight_on_crops=
	1
	~	Dmnl
	~		|

UNIT_conv_to_dmnl=
	1
	~	k2017pppUSD/(p*y)
	~		|

Past_Living_conditions_index_with_env_damage[region]=
	SMOOTH ( Living_conditions_index_with_env_damage[region] , Social_tension_perception_delay\
		 )
	~	Dmnl
	~		|

Weight_on_white_meat=
	0.5
	~	Dmnl
	~		|

Time_for_env_damage_to_affect_wellbeing=
	3
	~	y
	~		|

UNIT_conv_to_k217pppUSD_ppy=
	1
	~	p*G2017pppUSD/(k2017pppUSD*Mp)
	~	The Vensim unit parser does not know that G/M = k (giga / mega = kilo), \
		etc..
	|

Eff_of_social_trust_on_reform_willingness_and_social_tension[region]=
	1 + SoE_of_social_trust_on_reform * (Social_trust[region] / Social_trust_in_1980 - 1\
		)
	~	1
	~		|

Wellbeing_from_el_use_raw[region]=
	El_use_wellbeing_a + El_use_wellbeing_b * LN( Ratio_actual_to_basic_el_use[region])
	~	1
	~		|

UNIT_conv_to_kgN=
	1000
	~	kgN*Mp/(MtN*p)
	~		|

Time_for_public_spending_to_affect_wellbeing=
	5
	~	y
	~		|

UNIT_conv_to_kWh_ppp=
	1
	~	kWh*Year*Mp/(p*yr*TWh)
	~		|

Slope_of_wellbeing_from_fraction_of_people_outside_of_labor_pool=
	3
	~	Dmnl
	~		|

Disposable_income_threshold_for_wellbeing=
	8
	~	G2017pppUSD/(Mp*yr)
	~		|

JR_sINEeolLOK_lt_0=
	-0.45
	~	Dmnl [-0.75,-0.25,0.05]
	~		|

Ratio_of_actual_to_healthy_red_meat[region]=
	red_meat_not_wasted_pp[region] / Healthy_red_meat_consumption
	~	1
	~		|

Global_Wellbeing_from_disposable_income=
	Wellbeing_from_disposable_income[us] * Regional_population_as_fraction_of_total[us] \
		+
	Wellbeing_from_disposable_income[af] * Regional_population_as_fraction_of_total[af] \
		+
	Wellbeing_from_disposable_income[cn] * Regional_population_as_fraction_of_total[cn] \
		+
	Wellbeing_from_disposable_income[me] * Regional_population_as_fraction_of_total[me] \
		+
	Wellbeing_from_disposable_income[sa] * Regional_population_as_fraction_of_total[sa] \
		+
	Wellbeing_from_disposable_income[la] * Regional_population_as_fraction_of_total[la] \
		+
	Wellbeing_from_disposable_income[pa] * Regional_population_as_fraction_of_total[pa] \
		+
	Wellbeing_from_disposable_income[ec] * Regional_population_as_fraction_of_total[ec] \
		+
	Wellbeing_from_disposable_income[eu] * Regional_population_as_fraction_of_total[eu] \
		+
	Wellbeing_from_disposable_income[se] * Regional_population_as_fraction_of_total[se]
	~	1
	~		~	:SUPPLEMENTARY 
	|

All_N_use_syn_and_excreted[region]=
	Nitrogen_syn_use[region] + N_excreted_on_pasture[region]
	~	MtN/Year
	~		|

Healthy_white_meat_consumption=
	30
	~	kg/(y*p)
	~		|

Healthy_red_meat_consumption=
	30
	~	kg/(y*p)
	~		|

Social_tension_index_in_1980=
	1
	~	1
	~		|

Social_tension_perception_delay=
	5
	~	y
	~		|

Social_trust[region]= INTEG (
	Change_in_social_trust[region],
		Social_trust_in_1980)
	~	stu
	~		|

Social_trust_in_1980=
	0.6
	~	stu
	~	should differ by region once we have the data
	|

Food_footprint_kgN_ppy[region]=
	Food_footprint[region] * UNIT_conv_to_kgN
	~	kgN/(Year*p)
	~		|

SoE_of_env_damage_indicator=
	-0.4
	~	Dmnl
	~		|


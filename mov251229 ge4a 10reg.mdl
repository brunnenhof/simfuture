		differs slighty from RCP, is at \
		http://www.pmodwrc.ch/pmod.php?topic=tsi/composite/SolarConstant and \
		ftp://ftp.pmodwrc.ch/pub/Claus/IrradianceData/) and see Earth's Energy \
		Imbalance and Implications, 2011, James Hansen, Makiko Sato, Pushker \
		Kharecha, Karina von Schuckmann Atmos. Chem. Phys., 11, 13421-13449, \
		doi:10.5194/acp-11-13421-2011
	|

Volume_of_total_ocean_Gm3=
	Volume_cold_ocean_0_to_100m
	+Volume_cold_ocean_downwelling_100m_to_bottom
	+Volume_ocean_deep_1km_to_bottom
	+Volume_ocean_upwelling_100m_to_1km
	+Volume_warm_ocean_0_to_100m
	~	Gm3
	~		|

Human_activity_CH4_emissions_GtCO2e_py=
	Human_activity_CH4_emissions / UNIT_conversion_for_CH4_from_CO2e_to_C
	~	GtCO2e/yr
	~		|

Human_aerosol_forcing_1_is_ON_0_is_OFF=
	1
	~	1 [0,1,1]
	~		|

Humidity_of_atmosphere_at_initial_time_g_p_kg= INITIAL(
	Humidity_of_atmosphere)
	~	g/kg
	~		~	:SUPPLEMENTARY 
	|

Humidity_of_atmosphere_current_g_p_kg=
	Humidity_of_atmosphere
	~	g/kg
	~		|

Humidity_of_atmosphere=
	Evaporation_as_f_of_temp * Water_content_of_evaporation_g_p_kg_per_ZJ_py
	~	g/kg
	~		|

Humidity_of_atmosphere_in_1850_g_p_kg=
	1.98018
	~	g/kg
	~	The value comes from running the full ESMICON model from 1850
	|

Time_to_regrow_GRASS_after_deforesting_yr=
	80
	~	yr
	~	guess, so far
	|

Time_to_regrow_TUNDRA_yr=
	10
	~	yr
	~		|

delta_Temp_deep_ocean_wrt_1850_degC=
	Temp_ocean_deep_in_C - Temp_ocean_deep_in_1850_C
	~	C
	~		~	:SUPPLEMENTARY 
	|

Sea_level_change_from_thermal_expansion_surface_m=
	Volume_expansion_from_thermal_expansion_surface_Gm3_is_km3 / Ocean_surface_area_km2 \
		* UNIT_Conversion_from_km3_to_km2
	~	km
	~		|

sea_level_rise_2020=
	0.2725
	~	m
	~	Should be handled by SAMPLE IF TRUE, but this is such an akward equation \
		to handle in python ...
	|

Sea_level_rise_from_melting_ice_m=
	Cumulative_ocean_volume_increase_due_to_ice_melting_km3 / Ocean_surface_area_km2 * UNIT_Conversion_from_km3_to_km2
	 * UNIT_conversion_from_km_to_m * Avg_flatness_of_worlds_coastline
	~	m
	~		|

sea_level_rise_ratio_wrt_2020=
	IF_THEN_ELSE(Time < 2020, 1, Sea_level_change_from_melting_ice_and_thermal_expansion_m\
		 / sea_level_rise_2020)
	~	1
	~		|

Densitiy_of_water_relative_to_ice=
	0.916
	~	dimensionless
	~	density ice at 0 degC 916.2 kg/m3 densitiy of water at 0 degC 999.8 kg/m3 \
		http://www.engineeringtoolbox.com/ice-thermal-properties-d_576.html
	|

Depositing_of_C_to_sediment=
	C_in_deep_water_volume_1km_to_bottom_GtC / Time_to_deposit_C_in_sediment
	~	GtC/yr
	~		|

DESERT_Mkm2= INTEG (
	Shifting_GRASS_to_DESERT_Mkm2_py-Shifting_DESERT_to_GRASS_Mkm2_py,
		25.4039
		)
	~	Mkm2
	~		|

Sensitivity_of_biomass_new_growth_to_CO2_concentration=
	1.5
	~	dimensionless [1.5,2.5,0.1]
	~	system-wide calibration agains Global Carbon Project data, esp 1959 to \
		2020 https://essd.copernicus.org/articles/12/3269/2020/
	|

Sensitivity_of_convection_to_temp=
	2.5
	~	fraction
	~		|

Sensitivity_of_evaporation_to_temp=
	0.36
	~	dimensionless [0.35,0.45,0.01]
	~	system-wide calibration agains Global Carbon Project data, esp 1959 to \
		2020 https://essd.copernicus.org/articles/12/3269/2020/
	|

Sensitivity_of_high_cloud_coverage_to_temp_logistics=
	Sensitivity_of_high_cloud_coverage_to_temp_normal + (Logistics_curve_param_c / (1 + \
		EXP(-Logistics_curve_param_k*(Time-Logistics_curve_param_shift
	))))
	~	dimensionless [30,70,5]
	~	IPCC AR6 Figure TS-17(a) suggestes that more or the feedback is caused by clouds \
		than by water vapor, The parameters are estimated through system-wide \
		calibration.
		https://www.ipcc.ch/report/ar6/wg1/downloads/report/IPCC_AR6_WGI_TS.pdf2.1.
	|

Sensitivity_of_high_cloud_coverage_to_temp_normal=
	50
	~	dimensionless [30,70,5]
	~		|

Sensitivity_of_low_cloud_coverage_to_temp=
	58
	~	dimensionless [50,65,1]
	~	calibration
	|

Sensitivity_of_trop_to_humidity=
	5
	~	dimensionless
	~		|

Shifting_DESERT_to_GRASS_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC < 0, DESERT_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_DESERT_to_GRASS
	  * Temp_driver_to_shift_biomes_degC , 0) * (-1)
	~	Mkm2/yr
	~		|

Shifting_GRASS_to_DESERT_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC > 0, GRASS_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_GRASS_to_DESERT
	 * Temp_driver_to_shift_biomes_degC  * Temp_driver_to_shift_biomes_degC * (1/Effect_of_humidity_on_shifting_biomes\
		), 0)
	~	Mkm2/yr
	~		|

Shifting_GRASS_to_NF_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC < 0, GRASS_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_GRASS_to_NF
	  * Temp_driver_to_shift_biomes_degC , 0) * (-1)
	~	Mkm2/yr
	~		|

Shifting_GRASS_to_TROP_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC < 0, GRASS_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_GRASS_to_TROP
	  * Temp_driver_to_shift_biomes_degC , 0) * (-1)
	~	Mkm2/yr
	~		|

Shifting_ice_on_land_to_tundra_Mkm2_py=
	Shifting_ice_to_tundra_from_detail_ice_on_land_Mkm2_pr_yr
	~	Mkm2/yr
	~		|

Shifting_ice_to_tundra_from_detail_ice_on_land_Mkm2_pr_yr=
	Antarctic_ice_area_decrease_Mkm2_pr_yr + Glacial_ice_area_decrease_Mkm2_pr_yr + Greenland_ice_area_decrease_Mkm2_pr_yr
	~	Mkm2/yr
	~		|

Shifting_NF_to_GRASS_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC > 0, NF_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_NF_to_GRASS
	 * Temp_driver_to_shift_biomes_degC, 0)
	~	Mkm2/yr
	~		|

Glacial_ice_area_decrease_Mkm2_pr_yr=
	(Glacial_ice_melting_km3_py / Avg_thickness_glacier_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

Glacial_ice_area_increase_Mkm2_pr_yr=
	(Glacial_ice_freezing_km3_py / Avg_thickness_glacier_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

Glacial_ice_area_km2=
	Glacial_ice_volume_km3 / Avg_thickness_glacier_km * UNIT_conversion_km3_div_km_to_km2
	~	km2
	~		|

Glacial_ice_freezing_km3_py=
	IF_THEN_ELSE(Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py < 0 , Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		 * (-1), 0)
	~	km3/yr
	~	Splitting melting and freezing into two variables that range between 0 and \
		inf
	|

Shifting_tundra_to_ice_from_detail_ice_on_land_Mkm2_pr_yr=
	Antarctic_ice_area_increase_Mkm2_pr_yr + Glacial_ice_area_increase_Mkm2_pr_yr + Greenland_ice_area_increase_Mkm2_pr_yr
	~	Mkm2/yr
	~		|

Shifting_tundra_to_ice_on_land_Mkm2_py=
	Shifting_tundra_to_ice_from_detail_ice_on_land_Mkm2_pr_yr
	~	Mkm2/yr
	~		|

Shifting_Tundra_to_NF_Mkm2_py=
	IF_THEN_ELSE(Temp_driver_to_shift_biomes_degC > 0, Tundra_potential_area_Mkm2 / Ref_shifting_biome_yr\
		 * Slope_of_effect_of_temp_shifting_tundra_to_NF
	 * Temp_driver_to_shift_biomes_degC, 0)
	~	Mkm2/yr
	~		|

Glacial_ice_volume_in_1980=
	165694
	~	km3
	~	IPCC AR5 Table 4.2 on pg 336. Range 114000 to 192000 Gt, avg = 153000 Gt = \
		1.53 e17 kg = 1.67 e14 m3 = 1.67 e5 km3 = 167000 km3 in 1850
	|

Glacial_ice_volume_km3= INTEG (
	-Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py,
		Glacial_ice_volume_in_1980)
	~	km3
	~		|

TROP_Dead_biomass_decomposing=
	TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / TROP_Time_to_decompose_undisturbed_dead_biomass_yr
	~	GtBiomass/yr
	~		|

TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass= INTEG (
	TROP_Biomass_in_construction_material_left_to_rot+TROP_Living_biomass_rotting-TROP_Dead_biomass_decomposing\
		-TROP_DeadB_SOM_being_lost_due_to_deforestation-TROP_DeadB_SOM_being_lost_due_to_energy_harvesting\
		-TROP_runoff-TROP_soil_degradation_from_clear_cutting-TROP_soil_degradation_from_forest_fires\
		,
		TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980)
	~	GtBiomass
	~		|

TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980=
	158.789
	~	GtBiomass [0,800,50]
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000]  \
		Note, units here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

TROP_DeadB_and_SOM_densitiy_in_1850_tBiomass_pr_km2=
	8500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

NF_with_normal_cover_Mkm2=
	NF_potential_area_Mkm2 
	- NF_area_burnt_Mkm2 
	- NF_area_deforested_Mkm2 
	- NF_area_clear_cut_Mkm2
	- NF_area_harvested_Mkm2
	~	Mkm2
	~		|

expSoE_of_ed_on_dying=
	0.15
	~	Dmnl [0,2,0.25]
	~		|

Temp_driver_to_shift_biomes_degC=
	Temp_surface / ((Temp_surface_1850 - Zero_C_on_K_scale_K) * K_to_C_conversion) - 0
	~	dimensionless
	~		|

Slope_btw_Kyoto_Fluor_ppt_and_blocking_multiplier=
	0.3
	~	dimensionless [0,1,0.1]
	~	pure calibration
	|

Slope_btw_Montreal_gases_ppt_and_blocking_multiplier=
	0.3
	~	dimensionless [0,1,0.1]
	~	pure calibration
	|

Slope_btw_N2O_ppb_and_blocking_multiplier=
	0.1
	~	dimensionless [0,1,0.1]
	~	pure calibration
	|

Slope_btw_temp_and_permafrost_melting_or_freezing=
	IF_THEN_ELSE(Time < 2020, 
	Slope_btw_temp_and_permafrost_melting_or_freezing_base, 
	Slope_btw_temp_and_permafrost_melting_or_freezing_sensitivity)
	~	dimensionless
	~	see eg \
		http://www.nature.com/nature/journal/v480/n7377/full/nature10576.html \
		"Metagenomic analysis of a permafrost microbial community reveals a rapid \
		response to thaw" The slope could itself be a function (exponentially? \
		rising?) of temperature
	|

Slope_btw_temp_and_permafrost_melting_or_freezing_sensitivity=
	1
	~	dimensionless [0,1200,100]
	~	see eg \
		http://www.nature.com/nature/journal/v480/n7377/full/nature10576.html \
		"Metagenomic analysis of a permafrost microbial community reveals a rapid \
		response to thaw" The slope could itself be a function (exponentially? \
		rising?) of temperature
	|

Slope_Effect_Temp_on_NMPP=
	2
	~	dimensionless
	~		|

TROP_living_biomass_densitiy_in_1850_tBiomass_pr_km2=
	16500
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

Slope_of_effect_of_temp_on_shifting_NF_to_Tundra=
	0.1
	~	dimensionless
	~		|

Slope_of_effect_of_temp_on_shifting_TROP_to_NF=
	1
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_DESERT_to_GRASS=
	0.4
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_GRASS_to_DESERT=
	5
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_GRASS_to_NF=
	0.1
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_GRASS_to_TROP=
	0.2
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_NF_to_GRASS=
	0.01
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_NF_to_TROP=
	0.2
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_TROP_to_GRASS=
	0.05
	~	dimensionless
	~		|

Slope_of_effect_of_temp_shifting_tundra_to_NF=
	0.2
	~	dimensionless
	~		|

Slope_of_efffect_of_acidification_on_NMPP=
	5
	~	dimensionless
	~		|

Thickness_of_surface_water_box_100m=
	100
	~	m
	~		|

Guldberg_Waage_air_sea_formulation=
	(CO2_conc_atm_less_CO2_conc_sea * Conversion_constant_GtC_to_ppm) / Time_to_reach_C_equilibrium_between_atmosphere_and_ocean
	~	GtC/yr
	~		|

TROP_runoff=
	TROP_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / TROP_runoff_time
	~	GtBiomass/yr
	~		|

TROP_runoff_time=
	2000
	~	yr
	~	The value is not very sensitive: A value of 20 years lowers the delta temp \
		from 1850 (the so-called temperature anomaly) by 10%. Increasing the value \
		has no effect. A value of 2000 years means that annualy 0.02 % of dead \
		biomass and soil organic carbon are washed out to sea - via rivers. The \
		IPCC gives a value of 0.9 GtC per yr being washed out to see for all types \
		of vegetation / soil (Source: IPCC Climate Change 2013, The Physical \
		Science Basis, Fig 6.1 pg 471), up from 0.4 GtC pr yr reported in the \
		previous IPCC report. (Source: IPCC AR4WG1 Figure 7.3).
	|

TROP_soil_degradation_from_clear_cutting=
	TROP_being_harvested_by_clear_cutting * TROP_fraction_of_DeadB_and_SOM_being_destroyed_by_clear_cutting\
		 * TROP_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~		|

Ratio_of_area_covered_by_low_clouds_current_to_init=
	Area_covered_by_low_clouds / Area_covered_by_low_clouds_in_1980
	~	dimensionless
	~		|

Slope_temp_eff_on_fire_incidence=
	0.1
	~	dimensionless
	~		|

Slope_temp_vs_antarctic_ice_melting=
	1.2
	~	dimensionless
	~	pure tuning
	|

Slope_temp_vs_Arctic_ice_melting=
	0.65
	~	dimensionless [0,1,0.01]
	~	calibrating to sea ice extent and sea level rise
	|

Slope_temp_vs_glacial_ice_melting=
	1
	~	dimensionless
	~	pure tuning
	|

Slope_temp_vs_greenland_ice_melting=
	0.1
	~	dimensionless
	~	pure tuning
	|

Eff_of_CO2_on_yield=
	1 + SoE_of_CO2_on_yield * ( CO2_concentration_ratio_wrt_2020 - 1 )
	~	1
	~		|

TUNDRA_area_deforested_in_1980=
	0
	~	Mkm2
	~		|

Ocean_sink_C_diffusion_into_ocean_from_atm=
	IF_THEN_ELSE(C_diffusion_into_ocean_from_atm_net>=0, C_diffusion_into_ocean_from_atm_net\
		, 0)
	~	GtC/Year
	~		~	:SUPPLEMENTARY 
	|

TUNDRA_Avg_life_biomass_yr=
	100
	~	yr [0,100,5]
	~		|

Time_for_volcanic_aerosols_to_remain_in_the_stratosphere=
	1
	~	yr [0,5,0.2]
	~		|

Time_in_cold=
	6.51772
	~	yr
	~		|

TUNDRA_being_harvested_Mkm2_py=
	Use_of_TUNDRA_biomass_for_energy / TUNDRA_living_biomass_densitiy_tBiomass_pr_km2
	 * UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	Mkm2/yr
	~		|

TUNDRA_Biomass_in_construction_material_being_burnt=
	TUNDRA_Biomass_locked_in_construction_material_GtBiomass / TUNDRA_Avg_life_of_building_yr\
		 * TUNDRA_Fraction_of_construction_waste_burned_0_to_1
	~	GtBiomass/yr
	~		|

TUNDRA_Biomass_in_construction_material_left_to_rot=
	TUNDRA_Biomass_locked_in_construction_material_GtBiomass / TUNDRA_Avg_life_of_building_yr\
		 * (1 - TUNDRA_Fraction_of_construction_waste_burned_0_to_1)
	~	GtBiomass/yr
	~		|

TUNDRA_Biomass_locked_in_construction_material_in_1980=
	1.92761
	~	GtBiomass
	~	calibration
	|

TUNDRA_biomass_new_growing=
	TUNDRA_potential_less_actual_living_biomass_GtBiomass / TUNDRA_Speed_of_regrowth_yr
	~	GtBiomass/yr
	~		|

Melting_constraint_from_the_heat_in_ocean_surface_reservoir= WITH LOOKUP (
	Ocean_heat_used_for_melting_last_year_ZJ_py,
		([(0,0)-(0.5,1)],(0,1),(0.4,0.95),(0.45,0.75),(0.5,0.01) ))
	~	dimensionless
	~		|

TUNDRA_Dead_biomass_decomposing=
	TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / TUNDRA_Time_to_decompose_undisturbed_dead_biomass_yr
	~	GtBiomass/yr
	~		|

TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass= INTEG (
	TUNDRA_Biomass_in_construction_material_left_to_rot+TUNDRA_Living_biomass_rotting-TUNDRA_Dead_biomass_decomposing\
		-TUNDRA_DeadB_SOM_being_lost_due_to_deforestation-TUNDRA_DeadB_SOM_being_lost_due_to_energy_harvesting\
		-TUNDRA_runoff-TUNDRA_soil_degradation_from_forest_fires,
		TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980)
	~	GtBiomass
	~		|

TUNDRA_Dead_biomass_litter_and_soil_organic_matter_SOM_in_1980=
	1207.56
	~	GtBiomass
	~	[Source: calculated from FAO Global Forest Assessment Report, ca 2000] We \
		deduct northern and tropical forests from the the values given in IPCC AR \
		Fig 6.1 and split the result 50 / 50 between grass and tundra. Note, units \
		here are GtBiomass(iomass) and NOT GtC(arbon in biomass)
	|

TUNDRA_DeadB_and_SOM_densitiy_at_initial_time_tBiomass_pr_km2=
	65000
	~	tB/km2
	~	Calculated from FAO FRA (Forest Resource Assessment) 2005 Global tables \
		and IPCC estimates on total carbon in biomass
	|

Effect_of_humidity_on_shifting_biomes=
	1 + Sensitivity_of_trop_to_humidity * (Humidity_of_atmosphere / Humidity_of_atmosphere_in_1850_g_p_kg\
		 - 
	1 )
	~	dimensionless
	~		|

TUNDRA_DeadB_SOM_being_lost_due_to_deforestation=
	TUNDRA_being_deforested_Mkm2_py * TUNDRA_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting\
		 * TUNDRA_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~	/ 1000 to convert M (illion) to G (iga)
	|

Effect_of_temp_on_melting_antarctic_ice=
	1 + Slope_temp_vs_antarctic_ice_melting * (( Temp_diff_relevant_for_melting_or_freezing_anfang\
		 / Ref_temp_difference_for_antarctic_ice_melting_3_degC) -1)
	~	dimensionless
	~		|

TUNDRA_deforested_Mkm2= INTEG (
	TUNDRA_being_deforested_Mkm2_py-TUNDRA_regrowing_after_being_deforested_Mkm2_py,
		TUNDRA_area_deforested_in_1980)
	~	Mkm2
	~		|

Effect_of_temp_on_melting_or_freezing_glacial_ice=
	1 + Slope_temp_vs_glacial_ice_melting * ((Temp_diff_relevant_for_melting_or_freezing_anfang\
		 / Ref_temp_difference_for_glacial_ice_melting_1_degC
	)-1)
	~	dimensionless
	~		|

Effect_of_temp_on_melting_or_freezing_of_Arctic_ice=
	1 + Slope_temp_vs_Arctic_ice_melting *  ((Temp_diff_relevant_for_melting_or_freezing_arctic_ice_from_anfang\
		 / Ref_temp_difference_for_Arctic_ice_melting
	) - 1 )
	~	dimensionless
	~		|

TUNDRA_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting=
	1
	~	fraction
	~		|

GRASS_area_deforested_in_1980=
	1.22174
	~	Mkm2
	~		|

GRASS_area_harvested_in_1980=
	2.15683
	~	Mkm2
	~		|

TUNDRA_fraction_of_DeadB_and_SOM_destroyed_by_natural_fires=
	0
	~	fraction
	~	A value of 0 means that if living biomass is destroyed by (natural) fires, \
		the soil remains intact. One can specify a multiplier between 0 and 1 to \
		signal that at 1 all soil (under the fire) is destroyed, or at eg 0.5 50% \
		of the soil (under the fire) is destroyed.
	|

GRASS_Avg_life_biomass_yr=
	100
	~	yr [0,100,5]
	~		|

GRASS_being_harvested_Mkm2_py=
	Use_of_GRASS_biomass_for_energy / GRASS_living_biomass_densitiy_tBiomass_pr_km2 * UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	Mkm2/yr
	~		|

GRASS_biomass_being_lost_from_deforestation_fires_energy_harvesting_and_clear_cutting\
		=
	(GRASS_being_deforested_Mkm2_py + GRASS_burning_Mkm2_py + GRASS_being_harvested_Mkm2_py\
		) * GRASS_living_biomass_densitiy_tBiomass_pr_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~		|

GRASS_Biomass_in_construction_material_being_burnt=
	GRASS_Biomass_locked_in_construction_material_GtBiomass / GRASS_Avg_life_of_building_yr\
		 * GRASS_Fraction_of_construction_waste_burned_0_to_1
	~	GtBiomass/yr
	~		|

Effective_Time_to_regrow_TROP_after_deforesting=
	Reference_Time_to_regrow_TROP_after_deforesting / TROP_deforestation_cutoff_effect
	~	yr
	~	when most of the tropical forest has been deforested, increased \
		afforestation efforts
	|

Solar_sine_forcing_period_yr=
	11
	~	yr
	~	value calibrated to match RCP solar forcing history best during the last \
		40 yrs
	|

Solar_sine_forcing_W_p_m2=
	SIN(2 * 3.14 * (Time - Solar_sine_forcing_offset_yr) / Solar_sine_forcing_period_yr)\
		 * (Solar_sine_forcing_amplitude) + Solar_sine_forcing_lift
	~	W/m2
	~		|

LW_clear_sky_emissions_to_surface=
	BB_radiation_at_Temp_in_atm_ZJ_py
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 319 +/- 9 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

LW_Cloudy_sky_emissions_from_atm=
	LW_Clear_sky_emissions_from_atm - Blocking_of_LW_rad_by_clouds
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 239.7 +/- 3.3 W p m2 for \
		the period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

Stephan_Boltzmann_constant=
	5.67037e-08
	~	W/(m2*k*k*k*k)
	~	The Vensim unit parser does not understand the ^ operator
	|

LW_HI_cloud_radiation_reference_in_1980=
	7.9
	~	W/m2 [7,9,0.1]
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 26.7 +/- 4 W p m2 and 26.5 +/- 5 for \
		the period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
		The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1980 value
	|

Stop_of_human_deforestation=
	IF_THEN_ELSE(Time > Time_at_which_human_deforestation_is_stopped, 0, 1)
	~	dimensionless
	~		|

LW_radiation_blocked_by_CH4_pct=
	Blocked_by_CH4 * UNIT_conversion_to_pct
	~	pct
	~		~	:SUPPLEMENTARY 
	|

LW_radiation_blocked_by_CO2_pct=
	Blocked_by_CO2 * UNIT_conversion_to_pct
	~	pct
	~		~	:SUPPLEMENTARY 
	|

LW_radiation_blocked_by_H2O_pct=
	Blocked_by_H20 * UNIT_conversion_to_pct
	~	pct
	~		~	:SUPPLEMENTARY 
	|

LW_radiation_blocked_by_other_GHG_pct=
	Blocked_by_otherGHG * UNIT_conversion_to_pct
	~	pct
	~		~	:SUPPLEMENTARY 
	|

LW_radiation_fraction_blocked_by_other_GHG_in_1850=
	0.0398
	~	fraction [0,0.1,0.02]
	~	calibration value
	|

LW_re_radiated_by_clouds=
	LW_LO_cloud_radiation + LW_HI_cloud_radiation
	~	ZJ/yr
	~		|

Sum_biomes_Mkm2=
	Land_covered_with_ice_km2 * UNIT_conversion_km2_to_Mkm2 + Tundra_potential_area_Mkm2\
		 + NF_potential_area_Mkm2 + DESERT_Mkm2
	 + GRASS_potential_area_Mkm2
	 + TROP_potential_area_Mkm2
	~	Mkm2
	~		|

Sum_C_absorbed_by_ocean_GtC= INTEG (
	C_absorption_by_ocean_from_atm_for_accumulation,
		73.012
		)
	~	GtC
	~		~	:SUPPLEMENTARY 
	|

SW_Atmospheric_absorption=
	Incoming_solar_ZJ_py * Frac_atm_absorption
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 75 +/- 10 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

SW_clear_sky_reflection_aka_scattering=
	Incoming_solar_ZJ_py * Frac_SW_clear_sky_reflection_aka_scattering  - Total_net_aerosol_forcing_ZJ_py
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 27.2 +/- 4.6 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

SW_HI_cloud_efffect_aka_cloud_albedo=
	Incoming_solar_ZJ_py * Frac_SW_HI_cloud_efffect_aka_cloud_albedo * Ratio_of_area_covered_by_high_clouds_current_to_init
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 47.5 +/- 3 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

TROP_area_clear_cut= INTEG (
	TROP_being_harvested_by_clear_cutting-TROP_regrowing_after_being_clear_cut,
		TROP_area_clear_cut_in_1980)
	~	Mkm2
	~		|

TROP_area_deforested_in_1980=
	5.97649
	~	Mkm2
	~		|

SW_surface_absorption=
	SW_to_surface - SW_surface_reflection
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 165 +/- 6 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

Melting_constraint_from_the_heat_in_atmosphere_reservoir_fraction= WITH LOOKUP (
	Atmos_heat_used_for_melting_last_year_1_py,
		([(0,0)-(0.5,1)],(0,1),(0.4,0.95),(0.45,0.75),(0.5,0.01) ))
	~	dimensionless
	~		|

TROP_Avg_life_of_building_yr=
	20
	~	yr
	~		|

Melting_of_permafrost_at_all_depths_at_4_deg_C_temp_diff_km_py=
	0.71
	~	km/yr [0,50,10]
	~	http://en.wikipedia.org/wiki/Arctic_methane_release modified by an \
		assumption (aka as wild guess) of what it takes to release all CH4 to all \
		depths. The "to all depths" matters a lot since the typical data available \
		for permafrost melting refere to the surface only.
	|

TROP_being_harvested_by_clear_cutting=
	 TROP_being_harvested * TROP_clear_cut_fraction
	~	Mkm2/yr
	~		|

NF_regrowing_after_being_clear_cut_Mkm2_py=
	NF_area_clear_cut_Mkm2 / (Time_to_regrow_NF_yr * 2)
	~	Mkm2/yr
	~	I need to keep track of the clear cutting only because of the albedo.
	|

NF_regrowing_after_being_deforested_Mkm2_py=
	NF_area_deforested_Mkm2 / Time_to_regrow_NF_after_deforesting_yr
	~	Mkm2/yr
	~		|

NF_regrowing_after_harvesting_Mkm2_py=
	NF_area_harvested_Mkm2 / Time_to_regrow_NF_yr
	~	Mkm2/yr
	~		|

NF_runoff=
	NF_Dead_biomass_litter_and_soil_organic_matter_SOM_GtBiomass / NF_runoff_time
	~	GtBiomass/yr
	~		|

Glacial_ice_melting_as_water_km3_py=
	Glacial_ice_melting_is_pos_or_freezing_is_neg_km3_py * Densitiy_of_water_relative_to_ice
	~	km3/yr
	~		|

MODEL_CH4_in_atm_in_ppb=
	C_in_atmosphere_in_form_of_CH4 * conversion_factor_CH4_Gt_to_ppb
	~	ppb
	~		|

MODEL_CO2_concentration_in_atmosphere2_ppm=
	C_in_atmosphere_GtC / Conversion_constant_GtC_to_ppm
	~	ppm
	~		|

NF_Sum_outflows_NF_Dead_biomass_litter_and_soil_organic_matter_SOM=
	NF_DeadB_SOM_being_lost_due_to_deforestation
	+ NF_DeadB_SOM_being_lost_due_to_energy_harvesting
	+ NF_runoff
	+ NF_soil_degradation_from_clear_cutting
	+ NF_soil_degradation_from_forest_fires
	+ NF_Dead_biomass_decomposing
	~	GtBiomass/yr
	~		|

Montreal_emissions_GtCO2e_py=
	Montreal_gases_emissions * Montreal_Global_Warming_Potential / UNIT_conversion_Gt_to_kt
	~	GtCO2e/yr
	~		|

Montreal_gases_concentration_in_1970_ppt=
	262.353
	~	ppt
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1970 value
	|

Montreal_gases_degradation=
	Montreal_gases_in_atm / Time_to_degrade_Montreal_gases_yr
	~	kt/yr
	~		|

Montreal_gases_emissions=
	 Montreal_gases_emissions_JR_RCP3_or_SSP245
	~	kt/yr
	~		|

UNIT_conversion_1_py=
	1
	~	1/yr
	~		|

Temp_gradient_in_surface_degK=
	9.7
	~	C
	~	This odd variable is meant to capture the fact that heat not only diffuses \
		from the warmer to the colder part of the ocean, but that heat transfer is \
		critically dependent on circulation, down and upwelling.  We don't model \
		that physical process in the required detail (partly because the physics \
		is poorly understood), nor do we allow for the structure of circulation, \
		down and upwelling to change so we need to introduce this effect in a \
		general way, which we do through this 'gradient'.  One consequence is that \
		the warmer part of the ocean will never be equal to the colder part, even \
		if you run the model for tens of thousands of years, or even longer.
	|

temp_in_2020=
	1.09922
	~	degC [1,1.2,0.01]
	~	We assume that all damage before now has already been 'priced' in all causal \
		structures and parameters of the model.
		Should be handled by SAMPLE IF TRUE, but this is such an akward equation \
		to handle in python ...
	|

Temp_ocean_deep_in_1850_C=
	4
	~	C [1,6,1]
	~	http://hypertextbook.com/facts/2007/LilyLi.shtml
	|

Temp_ocean_deep_in_1850_in_K=
	Temp_ocean_deep_in_1850_C+273.15
	~	k
	~		|

Temp_ocean_deep_in_C=
	Temp_ocean_deep_in_K - 273.15
	~	C
	~		|

Temp_ocean_deep_in_K=
	Heat_in_deep_ZJ * Conversion_constant_heat_ocean_deep_to_temp
	~	k
	~		|

Temp_ocean_surface_in_1850_C=
	Temp_surface_1850 - Temp_gradient_in_surface_degK
	~	C [13,17,0.01]
	~		|

Temp_ocean_surface_in_K=
	Temp_surface_average_K - Temp_gradient_in_surface_degK
	~	k
	~		|

Temp_of_cold_downwelling_water=
	(Temp_of_cold_surface_water + Temp_ocean_deep_in_C)/2
	~	C
	~		|

Temp_of_cold_surface_water=
	Temp_surface / 3
	~	C
	~		|

Flow_from_atm_to_biomass=
	CO2_flux_from_atm_to_GRASS_for_new_growth_GtC_py
	+ CO2_flux_from_atm_to_NF_for_new_growth_GtC_py
	+ CO2_flux_from_atm_to_TROP_for_new_growth_GtC_py
	+ CO2_flux_from_atm_to_TUNDRA_for_new_growth
	~	GtC/yr
	~		|

Flow_from_biomass_to_atm_Gtc_pr_yr=
	CO2_flux_GRASS_to_atm_GtC_py
	+ CO2_flux_NF_to_atm_GtC_py
	+ CO2_flux_TROP_to_atm_GtC_py
	+ CO2_flux_TUNDRA_to_atm
	~	GtC/yr
	~		|

Temp_surface_anomaly_compared_to_anfang_degC=
	Temp_surface - (Temp_surface_1850 - 273.15)
	~	degC
	~		|

Temp_surface_average_K=
	Heat_in_surface * Conversion_heat_surface_to_temp
	~	k
	~		|

Temp_surface_current_divided_by_value_anfang=
	Temp_surface_average_K / Temp_surface_1850
	~	dimensionless
	~		|

Thermal_expansion_deep_pct= WITH LOOKUP (
	Temp_ocean_deep_in_C,
		([(0,0)-(20,0.2)],(0,0.015),(1,0.008),(2,0.0033),(3,0.001),(4,0),(5,0.0012),(6,0.0033\
		),(7,0.008),(8,0.013),(9,0.021),(
		10,0.0287),(20,0.1963) ))
	~	dimensionless
	~	Original graph here http://physics.info/expansion/ data read off, curve \
		fitted in Excel
	|

Thermal_expansion_surface_pct= WITH LOOKUP (
	Temp_surface,
		([(0,0)-(20,0.2)],(0,0.015),(1,0.008),(2,0.0033),(3,0.001),(4,0),(5,0.0012),(6,0.0033\
		),(7,0.008),(8,0.013),(9,0.021),(
		10,0.0287),(20,0.1963) ))
	~	dimensionless
	~	Original graph here http://physics.info/expansion/ data read off, curve \
		fitted in Excel
	|

UNIT_conversion_to_pct=
	100
	~	pct
	~		|

GtIce_vs_km3=
	0.9167
	~	GtIce/km3
	~	http://www.convert-me.com/en/convert/density/densice.html
	|

Thickness_of_intermediate_water_box_800m=
	800
	~	m
	~		|

UNIT_conversion_W_to_ZJ_p_sec=
	1
	~	(ZJ/s)/W
	~	The Vesim parser does not know that 1 Watt = 1 Joule / s
	|

Time_at_which_human_deforestation_is_stopped=
	3000
	~	yr
	~		|

N2O_concentration_ppb=
	N2O_in_atmosphere_MtN2O * UNIT_Conversion_from_N2O_amount_to_concentration_ppb_p_MtN2O
	~	ppb
	~		|

NF_DeadB_SOM_being_lost_due_to_deforestation=
	NF_being_deforested_Mkm2_py * NF_fraction_of_DeadB_and_SOM_being_destroyed_by_deforesting\
		 * NF_DeadB_and_SOM_tB_per_km2
	 / UNIT_conversion_GtBiomass_py_to_Mkm2_py
	~	GtBiomass/yr
	~	/ 1000 to convert M (illion) to G (iga)
	|

Heat_flow_from_the_earths_core=
	0.1*16.09
	~	ZJ/yr
	~	0.1 W p m2 comes from http://www.solid-earth.net/1/5/2010/se-1-5-2010.pdf Davies, J. \
		H. and Davies, D. R.: Earth's surface heat flux, Solid Earth, 1, 5-24, \
		doi:10.5194/se-1-5-2010, 2010.
		16.09 converts W p m2 to ZJ py
	|

Heat_gained_or_needed_for_the_desired_freezing_or_unfreezing_of_permafrost_ZJ_py=
	(CH4_in_permafrost_area_melted_or_frozen_before_heat_constraint / Avg_amount_of_C_in_the_form_of_CH4_per_km2\
		)
	 * Avg_depth_of_permafrost_km * Heat_gained_or_needed_to_freeze_or_unfreeze_1_km3_permafrost_ZJ_p_km3\
		 / UNIT_conversion_km3_div_km_to_km2
	~	ZJ/yr
	~	The units are correct: (GtC/yr) * (km2/GtC) * km * (ZJ/km3) IS ZJ py but \
		since the Vensim unit parser is limited, we need to add the odd UNIT \
		conversion
	|

Heat_gained_or_needed_to_freeze_or_unfreeze_1_km3_permafrost_ZJ_p_km3=
	0.0001717
	~	ZJ/km3
	~	calculated from Fröb, K. (2011): Measuring and modeling of soil thermal properties \
		and ground heat flux at two different sites at Lena Delta, Siberia, Diplom \
		thesis, University of Leipzig. hdl:10013/epic.39260 PDF at \
		http://epic.awi.de/25314/ in Excel sheet Heat needed to melt ice.xlsx The \
		gory details are at http://acwc.sdp.sirsi.net/client/search/asset/1011742 \
		Soil thermal properties are crucial parameters. Those properties include \
		the thermal conductivity, the thermal diffusivity and the heat capacity of \
		the ground. The thermal conductivity is the ability of the soil to conduct \
		heat, the heat capacity of a soil describes its ability to store heat and \
		the thermal diffusivity is the quotient of those two parameters. An \
		interesting new model, with source, is here: \
		http://climatemodels.uchicago.edu/permafrost/ from David Archer and his \
		group the U of Chicago 
		The full calculation is in the this spreadsheet: Heat needed to melt \
		ice.xlsx
	|

Heat_in_atmosphere_in_1850_ZJ=
	1025.67
	~	ZJ
	~	Rough guesstimate using numbers from JRs note 140210 (hand written PDF)
		for equilibrium at start
	|

Heat_in_atmosphere_in_1980=
	1030.43
	~	ZJ
	~	The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1980 value
	|

Heat_in_atmosphere_ZJ= INTEG (
	Convection_aka_sensible_heat_flow+Evaporation_aka_latent_heat_flow+LW_surface_emissions_NOT_escaping_through_atm_window\
		+SW_Atmospheric_absorption-Heat_withdrawn_from_atm_by_melting_pos_or_added_neg_by_freezing_ice_ZJ_py\
		-LW_clear_sky_emissions_to_surface-LW_TOA_radiation_from_atm_to_space,
		Heat_in_atmosphere_in_1980)
	~	ZJ
	~		|

N2O_man_made_emissions_experiment=
	 N2O_emissions_JR_RCP3_or_SSP245
	~	MtN2O/yr
	~		|

N2O_man_made_emissions_GtCO2e_py=
	N2O_man_made_emissions_experiment * Global_Warming_Potential_N20 / UNIT_conversion_Gt_to_Mt
	~	GtCO2e/yr
	~		|

N2O_natural_emissions=
	9
	~	MtN2O/yr
	~	IPCC, 2013: Annex II: Climate System Scenario Tables [Prather, M., G. \
		Flato, P. Friedlingstein, C. Jones, J.-F. Lamarque, H. Liao and P. Rasch \
		(eds.)]. In: Climate Change 2013: The Physical Science Basis. Contribution \
		of Working Group I to the Fifth Assessment Report of the Intergovernmental \
		Panel on Climate Change [Stocker, T.F., D. Qin, G.-K. Plattner, M. Tignor, \
		S.K. Allen, J. Boschung, A. Nauels, Y. Xia, V. Bex and P.M. Midgley \
		(eds.)]. Cambridge University Press, Cambridge, United Kingdom and New \
		York, NY, USA, pp. 1395-1445, published 31 January 2014. Table AII 2-3
	|

Use_of_GRASS_biomass_for_construction_in_1850_pct=
	0.05
	~	dimensionless
	~	We have, of course, no clue how much of the GRASS biomass was used in 1850 \
		for construction. Thus complete guess, works for calibration
	|

Use_of_GRASS_biomass_for_energy_in_1850_pct=
	1
	~	dimensionless [0,2,0.1]
	~	We have, of course, no clue how much of the GRASS biomass was used in 1850 \
		for energy.  Thus complete guess, works for calibration
	|

Use_of_GRASS_for_construction_in_2000_GtBiomass=
	GRASS_Living_biomass_in_1850 * Use_of_GRASS_biomass_for_construction_in_1850_pct / 100
	~	GtBiomass
	~		|

Time_in_deep=
	739.89
	~	yr
	~		|

Use_of_NF_biomass_for_construction=
	Use_of_NF_for_construction_in_2000_GtBiomass * Effect_of_population_and_urbanization_on_biomass_use\
		 * UNIT_conversion_1_py
	~	GtBiomass/yr
	~		|

Time_in_trunk=
	234.638
	~	yr
	~		|

Time_in_warm=
	26.227
	~	yr
	~		|

Use_of_NF_biomass_for_energy_in_1850_pct=
	1.09
	~	dimensionless
	~	We have, of course, no clue how much of the NF biomass was used in 1850 \
		for energy.  The only source we have is FAO, Global Forest Resources \
		Assessment 2005. Calculated, see Tab 17 Removals of wood products \
		1990-2005 for 2000
	|

Use_of_NF_for_construction_in_2000_GtBiomass=
	NF_Living_biomass_in_1850 * Use_of_NF_biomass_for_construction_in_1850_pct / 100
	~	GtBiomass
	~		|

TROP_Avg_life_biomass_yr=
	60
	~	yr
	~		|

SW_surface_reflection=
	Avg_earths_surface_albedo * SW_to_surface
	~	ZJ/yr
	~	Stephens et al 2012 DOI: 10.1038/NGEO1580 give 23 +/- 3 W p m2 for the \
		period 2000 to 2010 To convert ZJ py to W p m2 (for the entire earth's \
		surface) divide by 16.09
	|

TROP_being_deforested_Mkm2_py=
	TROP_with_normal_cover * TROP_historical_deforestation
	 * TROP_deforestation_cutoff * Stop_of_human_deforestation
	~	Mkm2/yr
	~	pos is deforestation, neg is afforestation planting trees is best modeled \
		by making the slope of effect of temp shifting GRASS to TROP steeper
	|

Use_of_TROP_biomass_for_energy_in_1850_pct=
	0.07
	~	dimensionless
	~	We have, of course, no clue how much of the NF biomass was used in 1850 \
		for energy.  The only source we have is FAO, Global Forest Resources \
		Assessment 2005. Calculated, see Tab 17 Removals of wood products \
		1990-2005 for 2000
	|

Use_of_TROP_for_construction_in_2000_GtBiomass=

pl_to_apl[region]=
	ABS ( MIN ( 0 , Populated_land_gap[region] ) ) / Time_for_urban_land_to_become_abandoned
	~	Mha/y
	~		|

Actual_GH_share=
	0
	~	Dmnl
	~		|

Desired_wind_and_PV_el_cap[region]=
	Goal_for_suppy_of_wind_and_PV_el[region] / Hours_per_year / wind_and_PV_capacity_factor\
		[region] / UNIT_conv_GWh_and_TWh
	~	GW
	~		|

Extra_energy_productivity_index_2024_is_1[region]= INTEG (
	Increase_in_exepi[region],

		CONSTANTS('e4a-exo.xlsx', 'para' , 'c195' )
	|

Societal_unemployment_rate_norm=
	0.06
	~	Dmnl
	~		|

SoE_of_GDPpp_on_RoC_of_CLR[region]=
	0.05, 0.3, 0.3, 0.05, 0.05, 0.05, 0.05, 0.05, 0.05, 0.05
	~	Dmnl [0,0.5,0.1]
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c251' )
	|

Limitation_on_entering_the_pool_from_market_imbalance[region]= WITH LOOKUP (
	Labor_market_imbalance[region],
		   ([(0,0)-(10,10)],(0.7,1),(0.75,0.97),(0.8,0.9),(0.85,0.8),(0.9,0.65),(0.95,0.4),\
		(1,0.02) ))
	~	Dmnl
	~		|

Long_term_risk_margin=
	0.015
	~	1/y
	~		|

Long_term_unemployment_rate[region]=
	SMOOTH ( Unemployment_rate[region] , Time_to_establish_Long_term_unemployment_rate )
	~	Dmnl
	~		|

Loosing_a_job[region]=
	Laying_off_rate[region] * Laying_off_cut_off[region]
	~	Mp/Year
	~		|

Max_FOPOLM=
	0.2
	~	Dmnl
	~	No society can employ all its people, the yound, the old, the military, \
		the inform always remain outside of the labour pool. Might make this \
		regionally differentiated.
	|

Max_people_in_labour_pool[region]=
	Population[region] * (1 - Fraction_of_people_outside_of_labour_market_FOPOLM[region]\
		)
	~	Mp
	~		|

SWITCH_unemp_target_or_long_term[region]=
	1, 1, 1, 2, 1, 2, 1, 1, 1, 2
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c188' )
	|

Time_required_to_fill_jobs=
	7
	~	y [0,10,1]
	~	This is time to find, select, on-board and train new workers. You need to \
		think NOT of a company here, but of the total economy
	|

Perceived_unemployment_rate[region]=
	SMOOTH ( Unemployment_rate[region] , Unemployment_perception_time )
	~	Dmnl
	~		|

Time_to_establish_Long_term_unemployment_rate=
	5
	~	y
	~		|

Time_to_implement_actually_entering_the_pool=
	1
	~	y
	~		|

Time_to_implement_actually_leaving_the_pool=
	1.5
	~	y
	~		|

Time_to_implement_lay_off=
	3
	~	y [1,10,1]
	~	If you live in a society with strong job protection rules, this time may well be \
		much longer; conversely, if you life in a society with weak job pretection \
		laws, this time can be much shorter.
		You need to think NOT of a company here, but of the total economy
	|

Normal_basic_bank_margin=
	0.02
	~	1/y
	~		|

Signal_rate_adjustment_time=
	0.1
	~	y
	~		|

Unemployment_in_1980[region]=
	8, 10, 35, 5, 10, 5, 5, 5, 15, 10
	~	Mp
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c197' )
	|

Unemployment_perception_time=
	1
	~	y
	~		|

Unemployment_rate[region]=
	Unemployed[region] / Employed[region]
	~	1
	~		|

Unemployment_ratio[region]=
	Unemployment_rate[region] / Societal_unemployment_rate_norm
	~	1
	~		|

Unemployment_target_for_interest[region]=
	0.05, 0.07, 0.07, 0.03, 0.07, 0.03, 0.03, 0.03, 0.05, 0.04
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c190' )
	|

UNIT_conv_to_Mp=
	1000
	~	Mp*ppp2017USD/(p*G2017pppUSD)
	~		|

People_considering_entering_the_pool_in_1980=
	2
	~	Mp [1,20,2]
	~	Could / should be a fraction of population? / labor pool? / ...
	|

Cost_of_capital_for_worker_borrowing[region]=
	Cost_of_capital_for_secured_debt[region] + Normal_consumer_credit_risk_margin
	~	1/y
	~		|

Worker_power_scaling_factor=
	60
	~	Dmnl
	~		|

Worker_power_scaling_factor_reference=
	0.53
	~	Dmnl [0.45,0.6,0.01]
	~		|

Worker_share_of_output[region]=
	((Owner_power_or_weakness[region] +  1 ) / Worker_power_scaling_factor) + Worker_power_scaling_factor_reference
	~	Dmnl
	~	The result of the owner / worker struggle we are interested in is the \
		share of the output each can claim. Logically, and physically, this needs \
		to be a fraction between 0 and 1. Since owner power/weakness and worker \
		resistance/resignation are both dimensionless variables that oscillate \
		between -1 and +1 we need to scale the power concept to the share of \
		output concept.
	|

Size_of_tertiary_sector_lim=
	80
	~	Dmnl [0,160,20]
	~		|

Slope_of_Indicated_effect_of_worker_share_of_output_on_capital_labour_ratio=
	2
	~	Dmnl
	~		|

Short_term_interest_rate[region]=
	Central_bank_signal_rate[region] + Normal_basic_bank_margin
	~	1/y
	~		|

Strength_of_worker_reaction_to_owner_power_normal=
	0.075
	~	1/y [0,0.2,0.025]
	~	240709 PES wanted the decline in inequality in TLTL less dramatic after 2020 and \
		more in line with the narrative in the book.
		Could / should be differentiated by region - when there is time and money
	|

Normal_corporate_credit_risk_margin=
	0.02
	~	1/y
	~		|

Normal_signal_rate[region]=
	0.02, 0.04, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02, 0.02
	~	1/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c186' )
	|

Number_of_people_to_be_let_go[region]=
	MAX(0 , Employed[region] - Full_time_jobs_with_participation_constraint[region])
	~	Mp
	~		|

Perceived_inflation_in_1980[region]=
	0.15, 0.08, 0.08, 0.1, 0.18, 0.15, 0.1, 0.15, 0.15, 0.08
	~	1/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c192' )
	|

Owner_power_in_1980=
	1
	~	Dmnl [-1,1,0.25]
	~	0.5
	|

Owner_power_or_weakness[region]= INTEG (
	- Change_in_Owner_power[region],
		Owner_power_in_1980)
	~	Dmnl
	~	We conceive the "power" of owners to lie on a continuum between -1 and +1, \
		where negative values signal weakness and positive values signal strength.
	|

SoE_of_unemployment_rate_on_indicated_signal_rate=
	-1.3
	~	Dmnl
	~		|

SoE_of_unemployment_ratio_on_WSO=
	0.01
	~	Dmnl [0,0.05,0.01]
	~		|

People_considering_entering_the_pool[region]= INTEG (
	Change_in_people_considering_entering_the_pool[region],
		People_considering_entering_the_pool_in_1980)
	~	Mp
	~		|

Size_of_agri_sector_b=
	37
	~	Dmnl [0,80,5]
	~		|

Long_term_interest_rate_expectation_formation_time=
	4
	~	y
	~		|

Corporate_borrowing_cost[region]=
	Cost_of_capital_for_secured_debt[region] + Normal_corporate_credit_risk_margin
	~	1/y
	~		|

Corporate_borrowing_cost_in_1980[region]= INITIAL(
	 Normal_bank_operating_margin + Normal_basic_bank_margin + Normal_corporate_credit_risk_margin\
		 + Normal_signal_rate[region])
	~	1/y
	~		|

Size_of_industrial_sector[region]=
	1 - Size_of_agri_sector[region] - Size_of_tertiary_sector[region]
	~	1
	~		|

Size_of_tertiary_sector_a=
	40
	~	Dmnl [0,100,10]
	~		|

Size_of_agri_sector_a=
	1
	~	Dmnl [0,2,0.1]
	~		|

Inflation_target[region]=
	0.02, 0.05, 0.035, 0.035, 0.05, 0.05, 0.02, 0.03, 0.02, 0.025
	~	1/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c189' )
	|

Strength_of_owner_reaction_to_worker_resistance=
	0.05
	~	1/y [0,0.09,0.01]
	~	0.03 240709 PES wanted the decline in inequality in TLTL less dramatic after 2020 \
		and more in line with the narrative in the book.
		Could / should be differentiated by region - when there is time and money
	|

Inflation_perception_time[region]=
	1, 2, 2, 1, 1, 1, 1, 1, 1, 1
	~	y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c187' )
	|

Size_of_agri_sector_c=
	5
	~	k2017pppUSD/(p*y) [0,20,2.5]
	~		|

RoC_in_FOPOLM[region]=
	Eff_of_labour_imbalance_on_FOLP[region]
	~	Dmnl/y
	~		|

RoC_of_people_considering_entering_the_labor_pool[region]=
	Slope_of_RoC_of_people_considering_entering_the_labor_pool * ( Unemployment_ratio[region\
		] - 1)
	~	1/y
	~		|

People_considering_leaving_the_pool_in_1980=
	2
	~	Mp [0,20,5]
	~		|

InitialTime=
	1980
	~	y
	~		~	:SUPPLEMENTARY 
	|

SoE_of_inflation_rate_on_indicated_signal_rate=
	1.4
	~	Dmnl [0,2,0.5]
	~		|

Size_of_tertiary_sector_c=
	20
	~	k2017pppUSD/(p*y) [0,100,10]
	~		|

Labor_market_imbalance[region]=
	Labor_pool[region] / Max_people_in_labour_pool[region]
	~	1
	~		|

Labor_pool[region]=
	Employed[region] + Unemployed[region]
	~	Mp
	~		|

net_migration_25_to_29_0[region]=
	Migration_fraction_30_to_34_cohort[region] * net_migration_function[region] * Factor_to_account_for_net_migration_not_officially_recorded\
		[region]
	~	Mp/y
	~		~	:SUPPLEMENTARY 
	|

********************************************************
	.esmicon
********************************************************~
	|

People_drawing_a_pension[region]=
	Cohort_60plus[region] * Actual_fraction_of_people_60plus_drawing_a_pension[region]
	~	Mp
	~		|

GDPpp_in_1980[region]= INITIAL(
	GDPpp_USED[region])
	~	k2017pppUSD/(y*p)
	~		|

GDPpp_USED[region]=
	GDPpp_model[region]
	~	k2017pppUSD/(y*p)
	~		|

Births[region]=
	Cohort_15_to_45[region] * Births_effect_from_cohorts_outside_15_to_45[region] * birth_rate\
		[region] * FEHC_mult_used[region]
	~	Mp/y
	~		|

Life_expectancy_at_birth_in_1980[region]=
	73.8,48.5,66.8,58.2,54,64.5,73.3,66.8,72,60.4
	~	y
	~	GET XLS DATA('e4a-exo.xlsx', 'ts' , '1', 'D32' )
	|

dying_45_to_49[region]=
	Cohort_45_to_49[region] * death_rate_dr45[region] * Eff_of_env_damage_on_dying[region\
		] * Inequality_effect_on_mortality
	[region] * Effect_of_malnutrition_on_dying_smoothed[region]
	~	Mp/y
	~		|

dying_65_to_69[region]=

SDG_17_threshold_green=
	1
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted for regions
	|

SDG_17_threshold_red=
	0.75
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted for regions
	|

SDG_7_Score[region]=
	IF_THEN_ELSE(Access_to_electricity[region] < SDG_7_threshold_red, 0, IF_THEN_ELSE(Access_to_electricity\
		[region] < SDG_7_threshold_green
	, 0.5, 1))
	~	Dmnl

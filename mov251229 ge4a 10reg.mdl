Antarctic_ice_area_decrease_Mkm2_pr_yr=
	(Antarctic_ice_melting_km3_py / Avg_thickness_Antarctic_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

Antarctic_ice_area_increase_Mkm2_pr_yr=
	(Antarctic_ice_freezing_km3_py / Avg_thickness_Antarctic_km) * UNIT_Conversion_from_km3_p_kmy_to_Mkm2_py
	~	Mkm2/yr
	~		|

Antarctic_ice_area_km2=
	Antarctic_ice_volume_km3 / Avg_thickness_Antarctic_km * UNIT_Conversion_from_km3_to_km2
	~	km2
	~	Dividing volume by average thickness.
	|

Antarctic_ice_freezing_km3_py=
	IF_THEN_ELSE(Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py < 0 , Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		 * (-1), 0)
	~	km3/yr
	~	Splitting melting and freezing into two variables that range between 0 and \
		inf
	|

Antarctic_ice_losing_is_pos_or_gaining_is_neg_GtIce_py=
	Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py * GtIce_vs_km3
	~	GtIce/yr
	~	Losing is melting, gaining is refreezing.
	|

Antarctic_ice_melting_as_water_km3_py=
	Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py * Densitiy_of_water_relative_to_ice
	~	km3/yr
	~	Turning ice volume into water volume – needed to be able to calculate \
		sea level rise.
	|

Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py=
	(Antarctic_ice_volume_km3 / Effective_time_to_melt_or_freeze_antarctic_ice_at_the_reference_delta_temp\
		) * Effect_of_temp_on_melting_antarctic_ice
	 * Effect_of_heat_in_atm_on_melting_ice_cut_off
	* Snowball_earth_cutoff
	* Melting_constraint_from_the_heat_in_atmosphere_reservoir_fraction
	* Melting_constraint_from_the_heat_in_ocean_surface_reservoir
	~	km3/yr
	~		|

Antarctic_ice_melting_km3_py=
	IF_THEN_ELSE(Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py > 0 , Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py\
		, 0)
	~	km3/yr
	~	Splitting melting and freezing into two variables that range between 0 and \
		inf
	|

Antarctic_ice_volume_in_1980=
	3e+07
	~	km3
	~	[Source: \
		http://www.antarctica.ac.uk/about_antarctica/geography/ice/sheets.php]
	|

Antarctic_ice_volume_km3= INTEG (
	-Antarctic_ice_melting_is_pos_or_freezing_is_neg_km3_py,
		Antarctic_ice_volume_in_1980)
	~	km3
	~		|

Anthropogenic_aerosol_forcing=
	IF_THEN_ELSE(Human_aerosol_forcing_1_is_ON_0_is_OFF=0, 0, Aerosol_anthropogenic_emissions\
		 * Conversion_of_anthro_aerosol_emissions_to_forcing
	)
	~	W/m2
	~	The source for aerosol forcing come from the RCP Concentration Calculation \
		& Data Group, M. Meinshausen, S. Smith, K. Riahi, D. van Vuuren, \
		documented at M. Meinshausen, S. Smith et al. (2011) "The RCP GHG \
		concentrations and their extension from 1765 to 2300", DOI \
		10.1007/s10584-011-0156-z, Climatic Change. The data was downloaded from \
		While emission data for SOx (sulfur oxide), CO (carbon oxide), NMVOC \
		(non-methane volatile organic compounds), NOx (nitrogen oxide), BC (black \
		carbon), OC (organic carbon) and NH3 (hydrogen nitride) are given, it \
		seemed to us that the more reliable source are the forcings from these \
		compounds. That data is given as Total direct aerosol forcing (aggregating \
		direct fossil fuel aerosol (organic carbon), direct fossil fuel aerosol \
		(black carbon), direct sulphate aerosol, direct nitrate aerosol, direct \
		biomass burning related aerosol and direct forcing from mineral dust \
		aerosol. In addition, Meinshausen et al give the aerosol forcing from \
		volcanic eruptions. Thus, we use aerosol data at the level of aggregation \
		of radiative forcing, measured in W p m2
	|

Model_N2O_concentration_in_1850_ppb=
	274.5
	~	ppb
	~	The value is read off from the full ESMICON model which starts at 1850
	|

Model_Volcanic_aerosol_forcing_W_p_m2=
	Volcanic_aerosols_in_stratosphere / Time_for_volcanic_aerosols_to_remain_in_the_stratosphere\
		 * Conversion_of_volcanic_aerosol_forcing_to_volcanic_aerosol_emissions
	~	W/m2
	~	volcanic aerosols have a cooling effect
	|

Arctic_as_fraction_of_ocean=
	Arctic_ice_on_sea_area_km2 / Ocean_area_km2
	~	fraction
	~	Dividing the size of the Arctic with the size of the ocean
	|

Arctic_ice_albedo_1850=
	0.7
	~	fraction
	~	guess
	|

Arctic_ice_area_in_1980_km2=
	1.18874e+07
	~	km2
	~	http://neptune.gsfc.nasa.gov/csb/index.php?section=59 data goes back to \
		1978
	|

Arctic_ice_area_max_km2=
	(Area_of_earth_m2 / UNIT_conversion_m2_to_km2 - Land_area_km2)
	~	km2
	~		|

Arctic_ice_melting_is_pos_or_freezing_is_neg_km2_py=
	(Arctic_ice_on_sea_area_km2 / Effective_time_to_melt_Arctic_ice_at_the_reference_delta_temp\
		)
	 * Effect_of_temp_on_melting_or_freezing_of_Arctic_ice
	 * Arctic_freezing_cutoff
	 * Melting_constraint_from_the_heat_in_atmosphere_reservoir_fraction
	 * Melting_constraint_from_the_heat_in_ocean_surface_reservoir
	~	km2/yr
	~		|

Arctic_ice_on_sea_area_km2= INTEG (
	-Arctic_ice_melting_is_pos_or_freezing_is_neg_km2_py,
		Arctic_ice_area_in_1980_km2)
	~	km2
	~		|

Arctic_land_surface_temp_anomaly_compared_to_anfang=
	SMOOTH( Temp_surface_anomaly_compared_to_anfang_degC , Land_surface_temp_adjustment_time_yr\
		)
	~	C
	~	SMOOTH( 6.0425 * Land surface temp anomaly compared to 1850 - 1.2811 , \
		Land surface temp adjustment time yr )
	|

Arctic_surface_temp_delay_yr=
	15
	~	yr [0,80,5]
	~		|

Area_covered_by_high_clouds_in_1980=
	0.214448
	~	fraction [0.19,0.22,0.01]
	~	One reads a lot that the earth is covered to "2/3 with clouds". Real data exists \
		since the early 1980s through the International Satellite Cloud \
		Climatology Project http://isccp.giss.nasa.gov/climanal7.html. They track \
		the area covered by high, middle and low clouds (without, as far as I can \
		see accounting for overlap). Since middle clouds are climate neutral, we \
		track low cloud cover (net cooling) and high cloud cover (net warming) \
		extents.
		The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1980 value
	|

Area_covered_by_low_clouds_in_1980=
	0.431994
	~	fraction [0.39,0.45,0.01]
	~	One reads a lot that the earth is covered to "2/3 with clouds". Real data exists \
		since the early 1980s through the International Satellite Cloud \
		Climatology Project http://isccp.giss.nasa.gov/climanal7.html. They track \
		the area covered by high, middle and low clouds (without, as far as I can \
		see accounting for overlap). Since middle clouds are climate neutral, we \
		track low cloud cover (net cooling) and high cloud cover (net warming) \
		extents.
		The value comes from running the full ESMICON model (from 1850) and \
		looking up the 1980 value
	|

Area_equivalent_of_1km_linear_retreat_km2=
	17500
	~	km2 [0,50,10]
	~	We assume that the permafrost area sits like a ring around the arctic \
		ocean. The arctic ocean has a radius of about 2100 km, to get to the \
		assumed area of permafrost (of 25 Mkm2), the outer ring needs a diamter of \
		about 3500 km. Second, we assume that permafrost melting occurs from the \
		outer radius linearly inwards. Simple calculations result that a retreat \
		of of 1km towards the pole gives at the other ring an area of about 22 000 \
		km2 and at the inner ring an area of about 13 000 km2. Averaging (which is \
		a simplification that not be valid) the two gives about 17 500 km2.
	|

Area_equivalent_of_linear_retreat_km2_py=
	Melting_of_permafrost_at_all_depths_at_4_deg_C_temp_diff_km_py * Area_equivalent_of_1km_linear_retreat_km2\
		 * UNIT_conversion_to_km2_py
	~	km2/yr
	~		|

Area_of_earth_m2=
	5.1e+14
	~	m2
	~	https://en.wikipedia.org/wiki/Earth
	|

Area_of_earth_Mkm2=
	Area_of_earth_m2 / UNIT_conversion_m2_to_Mkm2
	~	Mkm2
	~		|

Area_of_land_Mkm2=
	Area_of_earth_Mkm2 * (1 - Fraction_of_earth_surface_as_ocean )
	~	Mkm2
	~		|

Area_of_ocean_at_surface_361900_Gm2=
	361900
	~	Gm2
	~		|

Atmos_heat_used_for_melting_1_py=
	Heat_withdrawn_from_atm_by_melting_pos_or_added_neg_by_freezing_ice_ZJ_py / Heat_in_atmosphere_ZJ
	~	1/yr
	~		|

Atmos_heat_used_for_melting_Initially_1_py=
	0
	~	1/yr
	~	For the unit check to pass, the initial value of a DELAY1I variable needs \
		a unit; kind of ludicrous if the value is numerical 0; esp. when the \
		local, ie variable wide check says OK, but the model wide one says NOT ok. \
		Would help if Vensim parsed both the same way.
	|

Atmos_heat_used_for_melting_last_year_1_py=

	|

Fossil_fuel_for_NON_El_use_that_CANNOT_be_electrified[region]=
	Fossil_fuel_NOT_for_El_gen[region] * Fraction_of_Fossil_fuel_for_NON_El_use_that_cannot_be_electrified
	~	Mtoe/Year
	~		|

Fossil_fuel_for_NON_El_use_that_IS_NOT_being_electrified[region]=
	Fossil_fuel_for_NON_El_use_that_COULD_be_electrified[region] - Fossil_fuel_for_NON_El_use_that_IS_being_electrified\
		[region]

		      ([(0,0)-(10,10)],(1980,1),(1990,1),(2000,1),(2010,1),(2020,1),(2030,1),(2050,\
		1),(2075,1),(2100,1) )) ~~|
Fraction_of_grazing_land_gap_closed_by_cutting_forests[eu]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,1),(1990,1),(2000,1),(2010,1),(2020,1),(2030,1),(2050\
		,1),(2075,1),(2100,1) )) ~~|
Fraction_of_grazing_land_gap_closed_by_cutting_forests[se]= WITH LOOKUP (
	Time,
		        ([(0,0)-(10,10)],(1980,1),(1990,1),(2000,1),(2010,0),(2020,0),(2030,0),(2050\
		,0),(2075,0),(2100,0) ))
	~	1/y
	~		|

Fraction_of_grazing_land_gap_closed_from_acgl=
	1
	~	1/y
	~		|

UNIT_conv_kgac_to_kg=
	1
	~	kg/kgac
	~		|

All_crop_regional_dmd[region]=
	All_crop_dmd_food[region] + Feed_dmd[region] + Net_export_of_crops[region]
	~	Mtac/Year
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

All_crop_regional_dmd_last_year[region]=
	SMOOTHI (All_crop_regional_dmd[region] , One_year , All_crop_dmd_food_in_1980[region\
		] )
	~	Mtac/Year
	~		|

UNIT_conv_Mtrmeat=
	1
	~	Mtrmeat/Year
	~		|

UNIT_conv_red_meat=
	1
	~	Mtmeat/Mtrmeat
	~		|

apl_to_acgl[region]=
	Abandoned_populated_land[region] / Time_for_abandoned_urban_land_to_become_fallow
	~	Mha/y
	~		|

apl_to_pl[region]=
	MIN ( Abandoned_populated_land[region], MAX ( 0 , Populated_land_gap[region]) ) / Time_to_develop_urban_land_from_abandoned_land
	~	Mha/y
	~	First (MIN) you cannot use more land for development than you have \
		abandoned land, and second (MAX) you only want to develop land if need > \
		actual i.e. gap > 0
	|

UNIT_conv_to_kg_crop_ppy=
	1
	~	kgac/(p*y)
	~		|

UNIT_conv_to_kg_red_meat_ppy=
	1
	~	kgrmeat/(y*p)
	~		|

UNIT_conv_to_kg_white_meat_ppy=
	1
	~	kgwmeat/(p*y)
	~		|

Barren_land_in_1980[region]=
	59.725, 598.224, 302.224, 532.885, 61.2205, 231.005, 562.628, 75.1457, 225.261, 15.9273
	~	Mha
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c3' )
	|

Meat_production[region]=
	Red_meat_production[region] * UNIT_conv_red_meat + White_meat_production[region] * UNIT_conv_white_meat
	~	Mtmeat/Year
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

Global_Cropland=
	SUM ( Cropland[region!] )
	~	Mha
	~		~	:SUPPLEMENTARY 
	|

Grazing_land_gap[region]=
	Grazing_land_need[region] - Grazing_land[region]
	~	Mha
	~		|

Grazing_land_EC_b=
	-0.031
	~	Dmnl
	~		|

Time_to_develop_urban_land_from_abandoned_land=
	2
	~	y
	~		|

UNIT_conv_white_meat=
	1
	~	Mtmeat/Mtwmeat
	~		|

oth_crop_dmd_food_pp[region]=
	oth_crop_dmd_pp[region] * UNIT_conv_to_kg_crop_ppy
	~	kgac/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

oth_crop_dmd_pp[region]=
	oth_crop_dmd_pp_a[region] * LN(GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl ) + oth_crop_dmd_pp_b\
		[region]
	~	Dmnl
	~		|

oth_crop_dmd_pp_a[region]=
	61.5666, 155.265, 218.985, 103.477, 89.3181, 713.147, 44.8079, -63.6056, -118.483, 113.732
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c217' )
	|

oth_crop_dmd_pp_b[region]=
	351.895, 288.935, 157.457, 149.41, 322.62, -129.904, 285.873, 820.263, 1183.46, 280.016
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c218' )
	|

white_meat_dmd_CN_b=
	2.61946
	~	Dmnl
	~		|

white_meat_dmd_func_pp[region]=
	white_meat_dmd_func_pp_L[region] / ( 1 + EXP ( - white_meat_dmd_func_pp_k[region] * \
		( GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl - white_meat_dmd_func_pp_x0[region\
		]) ) )
	~	1
	~		|

white_meat_dmd_func_pp_k[region]=
	0.0313, 0.3, 0.1, 0.122, 0.2, 0.2, 0.04, 0.075, 0.18, 0.1
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c148' )
	|

white_meat_dmd_func_pp_L[region]=
	120, 50, 50, 50, 20, 65, 70, 65, 58, 50
	~	Dmnl
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c149' )
	|

c_to_acgl[region]=
	ABS ( MIN ( 0 , Cropland_gap[region])) / Time_for_agri_land_to_become_abandoned
	~	Mha/y
	~	Only if the gap is negative (ie I have to much cropland) is it abandoned \
		over time
	|

c_to_pl[region]=
	MAX ( 0 , Populated_land_gap[region]) * Fraction_of_cropland_developed_for_urban_land
	~	Mha/y
	~		|

Cropland[region]= INTEG (
	acgl_to_c[region] + fa_to_c[region] - c_to_acgl[region] - c_to_pl[region],
		Cropland_in_1980[region])
	~	Mha
	~	History: Calculated from Hyde 3.2 (https://www.pbl.nl/en/image/data#HYDE%20data)
		Scripts: get_hydedata.R and plot_process_hydedata.R
	|

Cropland_in_1980[region]=
	190.624, 131.158, 100.219, 51.67, 214.32, 138.743, 68.646, 248.075, 145.678, 77.2311
	~	Mha
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c24' )
	|

red_meat_dmd_PA=
	red_meat_dmd_PA_a * (GDPpp_USED[pa] * UNIT_conv_to_make_exp_dmnl )^red_meat_dmd_PA_b
	~	1
	~		|

red_meat_dmd_PA_a=
	11.878
	~	Dmnl
	~		|

Fraction_of_abandoned_agri_land_developed_for_urban_land=
	0.03
	~	1/y
	~		|

red_meat_dmd_pp[region]=
	IF_THEN_ELSE(region = pa, red_meat_dmd_PA, IF_THEN_ELSE(region = sa, red_meat_dmd_SA\
		, red_meat_dmd_func_pp[region] ) )
	~	1
	~		|

Fraction_of_cropland_developed_for_urban_land=
	0.01
	~	1/y
	~		|

Fraction_of_cropland_gap_closed_from_acgl[region]=
	1, 1, 1, 1, 1, 1, 0, 1, 1, 1
	~	1/y
	~	GET XLS CONSTANTS('e4a-exo.xlsx', 'para' , 'c245' )
	|

Net_export_of_crops[region]=
	All_crop_regional_dmd_last_year[region] * Desired_net_export_of_crops[region] - Actual_crop_import\
		[region]
	~	Mtac/Year
	~		|

Net_growth_in_forest_area[region]=
	(Forest_land[region] - Forest_area_last_year[region] ) / One_year
	~	Mha/Year
	~		|

Net_growth_in_forest_area_causing_CO2_emissions_resp_absorption[region]=
	SMOOTH3(Net_growth_in_forest_area[region] , Time_to_adjust_forest_area_to_CO2_emissions\
		)
	~	Mha/Year
	~		|

Populated_land_gap[region]=
	Populated_land_need[region] - Populated_land[region]
	~	Mha
	~		|

Feed_dmd[region]=
	Feed_dmd_a[region] * LN(Meat_production[region] * UNIT_conv_meat_to_feed ) + Feed_dmd_b\
		[region]
	~	Mtac/Year
	~		|


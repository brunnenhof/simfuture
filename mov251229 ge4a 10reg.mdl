	Volume_cold_ocean_0_to_100m / Volume_of_total_ocean_Gm3
	~	dimensionless
	~		|

Frac_vol_cold_ocean_downwelling_of_total=
	Volume_cold_ocean_downwelling_100m_to_bottom / Volume_of_total_ocean_Gm3

Fraction_of_cropland_gap_closed_by_cutting_forests[us]= WITH LOOKUP (
	Time,
		         ([(0,0)-(10,10)],(1980,0),(1990,0),(2000,-0.1),(2010,-0.1),(2020,0),(2030,\
		0),(2050,0),(2100,0) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[af]= WITH LOOKUP (
	Time,
		          ([(0,0)-(10,10)],(1980,0.05),(1990,0.02),(2000,0),(2010,0.03),(2020,0),(2030\
		,0),(2050,0.001),(2100,0.01) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[cn]= WITH LOOKUP (
	Time,
		        ([(0,0)-(10,10)],(1980,0.03),(1990,0.02),(2000,0),(2010,0),(2020,0),(2030,0.0003\
		),(2050,0.001),(2100,0.002) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[me]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,0),(1990,0.03),(2000,0.01),(2010,0.01),(2020,0.01),(2030\
		,0.01),(2050,0.01),(2100,0.01) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[sa]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,0),(1990,0.02),(2000,0),(2010,0.03),(2020,0),(2030,0.0003\
		),(2050,0.001),(2100,0.001) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[la]= WITH LOOKUP (
	Time,
		        ([(0,0)-(10,10)],(1980,0),(1990,0.03),(2000,0.01),(2010,0.01),(2020,0.01),(\
		2030,0.0107),(2050,0.012),(2100,0.015) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[pa]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,0),(1990,0),(2000,0),(2010,0),(2020,0),(2030,0),(2050\
		,0),(2100,0) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[ec]= WITH LOOKUP (
	Time,
		        ([(0,0)-(10,10)],(1980,0),(1990,0),(2000,-0.1),(2010,0),(2020,0),(2030,0.000161\
		),(2050,0.001),(2100,0.002) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[eu]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,0),(1990,0),(2000,-0.1),(2010,-0.1),(2020,0),(2031,0)\
		,(2050,-0.001),(2100,-0.002) )) ~~|
Fraction_of_cropland_gap_closed_by_cutting_forests[se]= WITH LOOKUP (
	Time,
		       ([(0,0)-(10,10)],(1980,0),(1990,0.02),(2000,0),(2010,0.03),(2020,0),(2030,0.00036\
		),(2050,0.001),(2100,0.002) ))
	~	1/y
	~		|


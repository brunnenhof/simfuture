{UTF-8}
Global_cropland_worked_regeneatively=
	Global_Cropland * Global_regenerative_cropland_fraction
	~	Mha
	~		|

Global_Nitrogen_syn_use=
	SUM(Nitrogen_syn_use[region!])
	~	MtN/Year
	~		|

Global_regenerative_cropland_fraction=
	( Cropland[us] * Regenerative_cropland_fraction[us] +
	Cropland[af] * Regenerative_cropland_fraction[af] +
	Cropland[cn] * Regenerative_cropland_fraction[cn] +
	Cropland[me] * Regenerative_cropland_fraction[me] +
	Cropland[sa] * Regenerative_cropland_fraction[sa] +
	Cropland[la] * Regenerative_cropland_fraction[la] +
	Cropland[pa] * Regenerative_cropland_fraction[pa] +
	Cropland[ec] * Regenerative_cropland_fraction[ec] +
	Cropland[eu] * Regenerative_cropland_fraction[eu] +
	Cropland[se] * Regenerative_cropland_fraction[se]) / Global_Cropland
	~	1
	~		|

Global_Energy_intensity_kWh_per_usd_forced_usedby=
	Global_Energy_intensity_kWh_per_usd
	~	TWh/G2017pppUSD
	~		|

Global_population_forced_usedby=
	Global_population
	~	Mp
	~		|

Global_Actual_inequality_index_higher_is_more_unequal_forced_usedby=
	Global_Actual_inequality_index_higher_is_more_unequal
	~	Dmnl
	~		|

Global_average_Energy_footprint_pp_forced_usedby=
	Global_average_Energy_footprint_pp
	~	tCO2/(Year*p)
	~		|

Global_Smoothed_Social_tension_index_with_trust_effect_forced_uedby=
	Global_Smoothed_Social_tension_index_with_trust_effect
	~	Dmnl
	~		|

Global_social_trust_to_force_usedby=
	Global_social_trust
	~	stu
	~	I use Global social trust in python. In order NOT to drop it from the \
		python script, it MUST be "used by" some other variable. I know, I know ...
	|

Global_Population_below_2p5_kusd_p_py_forced_usedby=
	Global_Population_below_2p5_kusd_p_py
	~	Mp
	~		|

Global_Average_wellbeing_index_forced_usedby=
	Global_Average_wellbeing_index
	~	Dmnl
	~		|

Time_to_smooth_effect_of_env_dam_on_TAs=
	5
	~	Year
	~		|

Each_region_max_cost_estimate_energy_PES_with_env_dam_and_reform[region]=
	Each_region_max_cost_estimate_energy_PES[region] * Smoothed_Eff_of_env_damage_on_costs_of_TAs\
		[region] / Smoothed_Reform_willingness
	[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_empowerment_PES_with_env_dam_and_reform[region]=
	Each_region_max_cost_estimate_empowerment_PES[region] * Smoothed_Eff_of_env_damage_on_costs_of_TAs\
		[region] / Smoothed_Reform_willingness
	[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_food_PES_with_env_dam_and_reform[region]=
	Each_region_max_cost_estimate_food_PES[region] * Smoothed_Eff_of_env_damage_on_costs_of_TAs\
		[region] / Smoothed_Reform_willingness
	[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_inequality_PES_with_env_dam_and_reform[region]=
	Each_region_max_cost_estimate_inequality_PES[region] * Smoothed_Eff_of_env_damage_on_costs_of_TAs\
		[region] / Smoothed_Reform_willingness
	[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_poverty_PES_with_env_dam_and_reform[region]=
	Each_region_max_cost_estimate_poverty_PES[region] * Smoothed_Eff_of_env_damage_on_costs_of_TAs\
		[region] / Smoothed_Reform_willingness
	[region]
	~	G2017pppUSD/Year
	~		|

Smoothed_Eff_of_env_damage_on_costs_of_TAs[region]=
	SMOOTH(Eff_of_env_damage_on_costs_of_TAs[region], Time_to_smooth_effect_of_env_dam_on_TAs\
		)
	~	Dmnl
	~		|

Indicated_historical_deforestation[region]=
	historical_deforestation_table[region] * historical_deforestation_cutoff[region]
	~	Mha/Year
	~		|

RoC_in_Forest_land[region]=
	Forest_land[region] / Forest_land_last_year[region] - 1
	~	1
	~		|

historical_deforestation_cutoff[region]= WITH LOOKUP (
	Forest_land[region],
		     ([(0,0)-(3.00813,0.778226)],(0,0),(4.5,0.08),(8,0.27),(10,0.5),(12,0.73),(15.5\
		,0.92),(20,1) ))
	~	1
	~		|

RoC_in_Forest_land_geglaettet[region]=
	RoC_in_Forest_land[region]
	~	1
	~		|

RoC_in_Forest_land_geglaettet_for_display[region]=
	RoC_in_Forest_land_geglaettet[region]
	~	1
	~		|

Cold_surface_water_volume=
	Volume_cold_ocean_0_to_100m
	~	Gm3
	~		|

Cold_water_volume_downwelling=
	Volume_cold_ocean_downwelling_100m_to_bottom
	~	Gm3
	~		|

Warm_surface_water_volume=
	Volume_warm_ocean_0_to_100m
	~	Gm3
	~		|

Deep_water_volume_1km_to_4km=
	Volume_ocean_deep_1km_to_bottom
	~	Gm3
	~		|

Intermediate_upwelling_water_volume_100m_to_1km=
	Volume_ocean_upwelling_100m_to_1km
	~	Gm3
	~		|

Speculative_asset_pool_relative_to_init_in_1980[region]=
	GDP_USED[region]*Multiple_of_spec_assets_to_GDP_in_1980[region]*One_year
	~	G2017pppUSD
	~		|

Owner_wealth_accumulated_in_1980[region]=
	GDP_in_1980[region] * Fraction_multiple_of_regional_GDP_as_owners_wealth_in_1980[region\
		]
	~	G2017pppUSD
	~		|

GL_spending_going_to_public_investments[region]=
	GL_spending_going_to_investments[region] * ( 1- GL_private_investment_fraction)
	~	G2017pppUSD/Year
	~		|

GL_private_investment_fraction=
	0.1
	~	Dmnl
	~	GL investments are mostly unprofitable, hence the bulk goes to public \
		investment
	|

GL_spending_going_to_private_investments[region]=
	GL_spending_going_to_investments[region] * GL_private_investment_fraction
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_TOW[region]=
	Cost_per_regional_poverty_policy[region] * ((TOW_policy[region]/UNIT_conv_to_1_per_yr\
		 * 100) / TOW_policy_Max) * (1-Cutback_fraction_applied[
	region])
	~	G2017pppUSD/Year
	~		|

GL_investment_fraction=
	0.4
	~	Dmnl
	~	Could be a f(GDPpp) to handle that poorer regions are less capital \
		intensive
	|

GL_spending_going_to_investments[region]=
	National_income_used_for_GL[region] * GL_investment_fraction
	~	G2017pppUSD/Year
	~		|

GL_spending_going_to_workers_wages[region]=
	National_income_used_for_GL[region] * (1-GL_investment_fraction)
	~	G2017pppUSD/Year
	~		|

shortfall[region]=
	MAX(0, Planned_investments_for_all_TAs[region] - Budget_earmarked_for_GL[region])
	~	G2017pppUSD/Year
	~		|

Shortfall_as_pct_of_needed[region]=
	ZIDZ(shortfall[region] , Planned_investments_for_all_TAs[region])
	~	1
	~		|

Implemented_spending_on_GL[region]=
	SMOOTH3I(Planned_investments_for_all_TAs[region], Time_to_implement_spending_adjustments\
		, Implemented_spending_on_GL_in_1980[region])
	~	G2017pppUSD/Year
	~		|

Implemented_spending_on_GL_in_1980[region]=
	0
	~	G2017pppUSD/Year
	~		|

National_income_used_for_GL[region]=
	National_income_before_GL[region] * pct_of_GDP_spent_on_GL[region]
	~	G2017pppUSD/Year
	~		|

Cutback_fraction_applied[region]=
	SMOOTH3I(Shortfall_as_pct_of_needed[region], Time_to_implement_cutbacks, 0)
	~	Dmnl
	~		|

Planned_Spending_on_FMPLDD[region]=
	Cost_per_regional_poverty_policy[region] * ((FMPLDD_policy[region]/UNIT_conv_to_1_per_yr\
		 * 100) / FMPLDD_policy_Max) * (1-Cutback_fraction_applied
	[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_FPGDC[region]=
	Cost_per_regional_poverty_policy[region] * ((FPGDC_logically_constrained[region]/UNIT_conv_to_1_per_yr\
		 * 100) / FPGDC_policy_Max) * (1-Cutback_fraction_applied
	[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_Wreaction[region]=
	Cost_per_regional_inequality_policy2[region] * ((WReaction_policy[region] * 100) / WReaction_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_XtaxCom[region]=
	Cost_per_regional_inequality_policy2[region] * ((XtaxCom_policy[region] * 100) / XtaxCom_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_XtaxFrac[region]=
	Cost_per_regional_inequality_policy2[region] * (((Xtaxfrac_policy[region] - Xtaxfrac_policy_Min\
		 / 100 ) * 100) / Xtaxfrac_policy_Max
	) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_IWITR[region]=
	Cost_per_regional_inequality_policy2[region] * ((IWITR_policy[region] * 100) / IWITR_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_investments_for_food[region]=
	Planned_Spending_on_FLWR[region] + Planned_Spending_on_FWRP[region] + Planned_Spending_on_REFOREST
	[region] + Planned_Spending_on_RIPLGF[region] + Planned_Spending_on_RMDR[region]
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_LPB[region]=
	Cost_per_regional_poverty_policy[region] * ((LPB_policy[region] * 100) / LPB_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_CCS[region]=
	Cost_per_regional_energy_policy[region] * ((CCS_policy[region] * 100) / CCS_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_Ctax[region]=
	Cost_per_regional_inequality_policy2[region] * ((Ctax_policy[region] * 1) / Ctax_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_DAC[region]=
	Cost_per_regional_energy_policy[region] * ((DAC_policy[region] * 1) / DAC_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

pct_of_GDP_spent_on_GL[region]=
	Implemented_spending_on_GL[region] / GDP_USED[region]
	~	1
	~		|

Planned_Spending_on_ExPS[region]=
	Cost_per_regional_poverty_policy[region] * ((ExPS_pol_div_100[region] * 100) / ExPS_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_FLWR[region]=
	Cost_per_regional_food_policy[region] * ((FLWR_policy[region] * 100) / FLWR_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_FTPEE[region]=
	Cost_per_regional_energy_policy[region] * (( FTPEE_rate_of_change_policy[region] - FTPEE_policy_Min\
		) / FTPEE_policy_Max
	) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_FWRP[region]=
	Cost_per_regional_food_policy[region] * ((FWRP_policy[region] * 100) / FWRP_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_ICTR[region]=
	Cost_per_regional_inequality_policy2[region] * ((ICTR_policy[region] * 100) / ICTR_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_IOITR[region]=
	Cost_per_regional_inequality_policy2[region] * ((IOITR_policy[region] * 100) / IOITR_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_ISPV[region]=
	Cost_per_regional_energy_policy[region] * (((wind_and_PV_el_share_max[region] - ISPV_policy_Min\
		 / 100 ) * 100) / ISPV_policy_Max
	) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_RIPLGF[region]=
	Cost_per_regional_food_policy[region] * ((RIPLGF_policy[region] * 100) / RIPLGF_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_Lfrac[region]=
	Cost_per_regional_poverty_policy[region] * ((Lfrac_policy[region] * 100) / Lfrac_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_SGRPI[region]=
	Cost_per_regional_inequality_policy2[region] * ((SGRPI_policy[region] * 100) / SGRPI_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_LPBgrant[region]=
	Cost_per_regional_poverty_policy[region] * ((LPBgrant_policy[region] * 100) / LPBgrant_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_LPBsplit[region]=
	Cost_per_regional_poverty_policy[region] * ((LPBsplit_policy[region] * 100) / LPBsplit_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_NEP[region]=
	Cost_per_regional_energy_policy[region] * ((NEP_policy[region] * 100) / NEP_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Spent_on_FEHC[region]=
	Cost_per_regional_empowerment_policy[region] * ((FEHC_policy[region] * 100) / FEHC_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_REFOREST[region]=
	Cost_per_regional_food_policy[region] * ((REFOREST_policy[region] * 100) / REFOREST_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Spent_on_XtaxRateEmp[region]=
	Cost_per_regional_empowerment_policy[region] * ((XtaxRateEmp_policy[region] * 100) /\
		 XtaxRateEmp_policy_Max) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_RMDR[region]=
	Cost_per_regional_food_policy[region] * ((RMDR_policy[region] * 100) / RMDR_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

National_income[region]=
	National_income_before_GL[region] * (1-pct_of_GDP_spent_on_GL[region])
	~	G2017pppUSD/y
	~		|

Planned_Spending_on_SSGDR[region]=
	Cost_per_regional_poverty_policy[region] * (((SSGDR_policy[region] - SSGDR_policy_Min\
		 ) * 1) / SSGDR_policy_Max) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_StrUP[region]=
	Cost_per_regional_inequality_policy2[region] * ((StrUP_policy[region] * 100) / StrUP_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Spent_on_SGMP[region]=
	Cost_per_regional_empowerment_policy[region] * ((SGMP_policy[region] * 100) / SGMP_policy_Max\
		) * (1-Cutback_fraction_applied[region])
	~	G2017pppUSD/Year
	~		|

Time_to_implement_cutbacks=
	5
	~	yr
	~		|

Budget_earmarked_for_GL[region]=
	MIN(Budget_for_all_TA_per_region_calculated_as_pct_of_GDP[region] , Planned_investments_for_all_TAs\
		[region])
	~	G2017pppUSD/Year
	~		|

Planned_investments_for_inequality[region]=
	Planned_Spending_on_Ctax[region] 
	+ Planned_Spending_on_ICTR[region] 
	+ Planned_Spending_on_IOITR[region] 
	+ Planned_Spending_on_IWITR[region] 
	+ Planned_Spending_on_SGRPI[region] 
	+ Planned_Spending_on_StrUP[region] 
	+ Planned_Spending_on_Wreaction[region]
	+ Planned_Spending_on_XtaxCom[region] 
	+ Planned_Spending_on_XtaxFrac[region]
	~	G2017pppUSD/Year
	~		|

Time_to_implement_spending_adjustments=
	3
	~	yr
	~		|

Each_region_max_cost_estimate_energy_PES[region]=
	All_region_max_cost_estimate_energy_PES * Regional_GDP_weight[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_food_PES[region]=
	All_region_max_cost_estimate_food_PES * Regional_GDP_weight[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_inequality_PES[region]=
	All_region_max_cost_estimate_inequality_PES * Regional_GDP_weight[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_empowerment_PES[region]=
	All_region_max_cost_estimate_empowerment_PES * Regional_GDP_weight[region]
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_poverty_PES[region]=
	All_region_max_cost_estimate_poverty_PES * Regional_GDP_weight[region]
	~	G2017pppUSD/Year
	~		|

Global_Each_region_max_cost_estimate_all_TAs_PES_0=
	SUM(Each_region_max_cost_estimate_all_TAs_PES_0[region!])
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_all_TAs_PES_0[region]=
	Each_region_max_cost_estimate_empowerment_PES_with_env_dam_and_reform[region]
	+Each_region_max_cost_estimate_energy_PES_with_env_dam_and_reform[region]
	+Each_region_max_cost_estimate_food_PES_with_env_dam_and_reform[region]
	+Each_region_max_cost_estimate_inequality_PES_with_env_dam_and_reform[region]
	+Each_region_max_cost_estimate_poverty_PES_with_env_dam_and_reform[region]
	~	G2017pppUSD/Year
	~		|

PES_costs_2_as_pct_of_global_GDP=
	Global_Each_region_max_cost_estimate_all_TAs_PES_0 / Global_GDP_USED
	~	1
	~		~	:SUPPLEMENTARY 
	|

Smoothed_RoC_in_GDPpp_display[region]=
	Smoothed_RoC_in_GDPpp[region]
	~	Dmnl/Year
	~		~	:SUPPLEMENTARY 
	|

PES_costs_as_pct_of_global_GDP=
	All_regions_from_Each_region_max_cost_estimate_all_TAs_PES / Global_GDP_USED
	~	1
	~		~	:SUPPLEMENTARY 
	|

Buget_for_all_TA_globally=
	SUM(Budget_for_all_TA_per_region_calculated_as_pct_of_GDP[region!])
	~	G2017pppUSD/Year
	~		~	:SUPPLEMENTARY 
	|

Planned_investments_for_all_TAs[region]=
	Planned_investments_for_energy[region] + Planned_investments_for_food[region] + Planned_investments_for_inequality\
		[region] + Planned_Spending_on_Empowerment[region] + Planned_Spending_on_Poverty[region\
		]
	~	G2017pppUSD/Year
	~		|

Planned_investments_for_energy[region]=
	Planned_Spending_on_CCS[region] + Planned_Spending_on_DAC[region] + Planned_Spending_on_FTPEE\
		[region] + Planned_Spending_on_ISPV[region] + Planned_Spending_on_NEP[region]
	~	G2017pppUSD/Year
	~		|

Cost_per_regional_inequality_policy2[region]=
	Cost_per_regional_inequality_policy[region]
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_Empowerment[region]=
	Spent_on_FEHC[region] + Spent_on_SGMP[region] + Spent_on_XtaxRateEmp[region]
	~	G2017pppUSD/Year
	~		|

Planned_Spending_on_Poverty[region]=
	Planned_Spending_on_ExPS[region] + Planned_Spending_on_FMPLDD[region] + Planned_Spending_on_FPGDC\
		[region] + Planned_Spending_on_Lfrac[region] + Planned_Spending_on_LPB[region] + Planned_Spending_on_LPBgrant\
		[region] + Planned_Spending_on_LPBsplit[region] + Planned_Spending_on_SSGDR[region]\
		 + Planned_Spending_on_TOW[region]
	~	G2017pppUSD/Year
	~		|

pct_of_GDP_budgeted_for_GL=
	0.02
	~	fraction [0,0.05,0.01]
	~		|

Global_Smoothed_Social_tension_index_with_trust_effect=
	Smoothed_Social_tension_index_with_trust_effect[us] * Regional_population_as_fraction_of_total\
		[us]
	+ Smoothed_Social_tension_index_with_trust_effect[af] * Regional_population_as_fraction_of_total\
		[af]
	+ Smoothed_Social_tension_index_with_trust_effect[cn] * Regional_population_as_fraction_of_total\
		[cn]
	+ Smoothed_Social_tension_index_with_trust_effect[me] * Regional_population_as_fraction_of_total\
		[me]
	+ Smoothed_Social_tension_index_with_trust_effect[sa] * Regional_population_as_fraction_of_total\
		[sa]
	+ Smoothed_Social_tension_index_with_trust_effect[la] * Regional_population_as_fraction_of_total\
		[la]
	+ Smoothed_Social_tension_index_with_trust_effect[pa] * Regional_population_as_fraction_of_total\
		[pa]
	+ Smoothed_Social_tension_index_with_trust_effect[ec] * Regional_population_as_fraction_of_total\
		[ec]
	+ Smoothed_Social_tension_index_with_trust_effect[eu] * Regional_population_as_fraction_of_total\
		[eu]
	+ Smoothed_Social_tension_index_with_trust_effect[se] * Regional_population_as_fraction_of_total\
		[se]
	~	1
	~		~	:SUPPLEMENTARY 
	|

Budget_for_all_TA_per_region_calculated_as_pct_of_GDP[region]=
	GDP_USED[region] * pct_of_GDP_budgeted_for_GL
	~	G2017pppUSD/Year
	~		|

Global_Actual_inequality_index_higher_is_more_unequal=
	Actual_inequality_index_higher_is_more_unequal[us] * Regional_population_as_fraction_of_total\
		[us]
	+ Actual_inequality_index_higher_is_more_unequal[af] * Regional_population_as_fraction_of_total\
		[af]
	+ Actual_inequality_index_higher_is_more_unequal[cn] * Regional_population_as_fraction_of_total\
		[cn]
	+ Actual_inequality_index_higher_is_more_unequal[me] * Regional_population_as_fraction_of_total\
		[me]
	+ Actual_inequality_index_higher_is_more_unequal[sa] * Regional_population_as_fraction_of_total\
		[sa]
	+ Actual_inequality_index_higher_is_more_unequal[la] * Regional_population_as_fraction_of_total\
		[la]
	+ Actual_inequality_index_higher_is_more_unequal[pa] * Regional_population_as_fraction_of_total\
		[pa]
	+ Actual_inequality_index_higher_is_more_unequal[ec] * Regional_population_as_fraction_of_total\
		[ec]
	+ Actual_inequality_index_higher_is_more_unequal[eu] * Regional_population_as_fraction_of_total\
		[eu]
	+ Actual_inequality_index_higher_is_more_unequal[se] * Regional_population_as_fraction_of_total\
		[se]
	~	1
	~		~	:SUPPLEMENTARY 
	|

Scaled_Effect_of_wealth_on_social_tension_and_trust[region]=
	Effect_on_Wealth_on_Social_Tension[region] * Scaling_factor_of_eff_of_wealth_on_social_tension
	~	1
	~		|

Multiple_of_spec_assets_to_GDP_in_1980[region]=
	5, 0.5, 0.5, 10, 0.3, 0.7, 2, 0.1, 2, 1.5
	~	Dmnl
	~	https://www.mckinsey.com/industries/financial-services/our-insights/global-\
		banking-annual-review Exhibit 1
	|

Scaling_factor_of_eff_of_wealth_on_social_tension=
	1
	~	Dmnl [0,1,0.1]
	~	sytem-wide causal calibratrion
	|

Global_Average_wellbeing_index=
	Average_wellbeing_index[us] * Regional_population_as_fraction_of_total[us]
	+ Average_wellbeing_index[af] * Regional_population_as_fraction_of_total[af]
	+ Average_wellbeing_index[cn] * Regional_population_as_fraction_of_total[cn]
	+ Average_wellbeing_index[me] * Regional_population_as_fraction_of_total[me]
	+ Average_wellbeing_index[sa] * Regional_population_as_fraction_of_total[sa]
	+ Average_wellbeing_index[la] * Regional_population_as_fraction_of_total[la]
	+ Average_wellbeing_index[pa] * Regional_population_as_fraction_of_total[pa]
	+ Average_wellbeing_index[ec] * Regional_population_as_fraction_of_total[ec]
	+ Average_wellbeing_index[eu] * Regional_population_as_fraction_of_total[eu]
	+ Average_wellbeing_index[se] * Regional_population_as_fraction_of_total[se]
	~	1
	~		~	:SUPPLEMENTARY 
	|

Effect_on_Wealth_on_Social_Tension[region]= WITH LOOKUP (
	Speculative_asset_pool_relative_to_init_as_share_of_GDP[region],
		 ([(0,0)-(10,10)],(0,0.5),(0.5,0.9),(1,1),(2,2),(5,5),(10,15) ))
	~	Dmnl
	~		|

Global_Energy_intensity_kWh_per_usd=
	Energy_intensity_kWh_per_usd[us] * GDP_USED[us] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[se] * GDP_USED[se] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[af] * GDP_USED[af] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[cn] * GDP_USED[cn] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[me] * GDP_USED[me] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[sa] * GDP_USED[sa] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[la] * GDP_USED[la] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[pa] * GDP_USED[pa] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[ec] * GDP_USED[ec] / Global_GDP_USED
	 + Energy_intensity_kWh_per_usd[eu] * GDP_USED[eu] / Global_GDP_USED
	~	TWh/G2017pppUSD
	~	TWh/G2017pppUSD = kWh/$ the units used normally, also by our world in data
	~	:SUPPLEMENTARY 
	|

Global_Fossil_fuel_for_NON_El_use_that_CANNOT_be_electrified=
	SUM(Fossil_fuel_for_NON_El_use_that_CANNOT_be_electrified[region!])
	~	Mtoe/Year
	~		~	:SUPPLEMENTARY 
	|

Global_Fossil_fuel_for_NON_El_use_that_IS_NOT_being_electrified=
	SUM(Fossil_fuel_for_NON_El_use_that_IS_NOT_being_electrified[region!])
	~	Mtoe/Year
	~		~	:SUPPLEMENTARY 
	|

Global_C_taken_out_of_the_atmo=
	SUM(Actual_CO2_taken_directly_out_of_the_atmosphere_ie_direct_air_capture[region!])
	~	GtCO2/Year
	~		|

Indicated_crop_yield_min_SE=
	IF_THEN_ELSE(Nitrogen_use[se] >= 5, Indicated_crop_yield_func_SE, Indicated_crop_yield_SE_min\
		)
	~	Mtac/(Year*Mha)
	~		|

Output_growth_rate[region]=
	SMOOTHI (Output_growth_rate_instant[region], One_year, Output_growth_in_1980 )
	~	1/y
	~		~	:SUPPLEMENTARY 
	|

Effect_of_poverty_on_dying_from_policy_start_scaled_to_zero[region]=
	IF_THEN_ELSE(Time > Policy_start_year, (Effect_of_poverty_on_dying[region] -1) * Strength_of_poverty_effect\
		, 0)
	~	Dmnl
	~		|

Malnutition_scaled_to_zero[region]=
	IF_THEN_ELSE(Time > Policy_start_year , (Ratio_of_demand_and_supply_of_crops_smoothed\
		[region] -1) * Strength_of_malnutrition_effect
	, 0)
	~	Dmnl
	~		|

Additional_tax_rate_needed_to_pay_for_SGMP_after_policy_start[region]=
	IF_THEN_ELSE(Time > Policy_start_year, Additional_tax_rate_needed_to_pay_for_SGMP[region\
		], 0)
	~	Dmnl
	~		|

Actual_fraction_of_people_60plus_drawing_a_pension[region]=
	IF_THEN_ELSE(Pension_age[region] < 60 , 1, Theoretical_fraction_of_people_60plus_drawing_a_pension\
		[region])
	~	Dmnl
	~		|

Indicated_reform_willingness_at_2025[region]=
	1.11495, 1.04327, 1.2296, 1.07187, 1.07767, 1.08293, 1.14946, 1.07685, 1.08014, 1.09736
	~	Dmnl
	~	Hard-wired to avoid the SAMPLE IF TRUE function in python. Read off of the \
		tltl run in 2025
	|

Average_wellbeing_index_1980_is_1_scaled[region]=
	1+ ( Average_wellbeing_index_1980_is_1[region] - 1 ) * 15
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Average_wellbeing_index_in_1980[region]=
	0.963519, 0.900166, 0.722803, 0.776837, 0.693668, 0.81494, 0.868185, 0.865638, 0.904384\
		, 0.880155
	~	Dmnl
	~	= INITIAL(Average_wellbeing_index)
	|

Average_wellbeing_index_1980_is_1[region]=
	Average_wellbeing_index[region] / Average_wellbeing_index_in_1980[region]
	~	1
	~		|

Future_Annual_reduction_in_UAC=
	IF_THEN_ELSE(Time >= 2020, Annual_reduction_in_UAC / 100, 0)
	~	Dmnl/Year
	~		|

Change_in_UACre=
	Future_Annual_reduction_in_UAC * UAC_reduction_effort
	~	Dmnl/Year
	~		|

Planetary_risk_for_game_display=
	Planetary_risk
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Renewable_energy_share_in_the_total_final_energy_consumption_for_game_display[region]\
		=
	Renewable_energy_share_in_the_total_final_energy_consumption[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Unemployment_rate_smoothed_for_game_display[region]=
	Unemployment_rate_smoothed[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

RoC_Populated_land_for_game_display[region]=
	RoC_Populated_land[region]
	~	Dmnl/Year
	~		~	:SUPPLEMENTARY 
	|

Total_government_revenue_as_a_proportion_of_GDP_for_game_display[region]=
	Total_government_revenue_as_a_proportion_of_GDP[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Nitrogen_use_per_ha_for_game_display[region]=
	Nitrogen_use_per_ha[region]
	~	MtN/(Year*Mha)
	~		~	:SUPPLEMENTARY 
	|

Local_private_and_govt_investment_share_for_game_display[region]=
	Local_private_and_govt_investment_share[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

LPB_investment_share_for_game_display[region]=
	LPB_investment_share[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

REFOREST_policy_with_RW[region]=
	REFOREST_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region] 
	* Smoothed_Multplier_from_empowerment_on_speed_of_food_TA[region]
	~	1
	~		|

Heat_in_atmosphere_needed_to_available_ratio=
	Heat_gained_or_needed_for_the_desired_freezing_or_unfreezing_of_permafrost_ZJ_py / Heat_in_atmosphere_ZJ
	~	1/Year
	~		|

Fossil_fuel_reserves_in_ground_current_to_inital_ratio=
	Fossil_fuel_reserves_in_ground_GtC / Fossil_fuel_reserves_in_ground_at_initial_time_GtC
	~	1
	~		|

Land_covered_with_ice_to_land_area_ratio=
	Land_covered_with_ice_km2 / Land_area_km2
	~	1
	~		|

Arctic_ice_on_sea_area_to_arctic_ice_area_max_ratio=
	Arctic_ice_on_sea_area_km2 / Arctic_ice_area_max_km2
	~	1
	~		|

Heat_in_atmosphere_current_to_initial_ratio=
	Heat_in_atmosphere_ZJ / Heat_in_atmosphere_in_1850_ZJ
	~	1
	~		|

Future_leakage_indicated[region]=
	Future_TLTL_leakage[region] * (1-Lfrac_policy[region])
	~	1
	~		|

Consumption_and_investment[region]=
	Investment_demand[region] + Total_consumption[region]
	~	G2017pppUSD/Year
	~		|

FMPLDD_policy_converted_to_pa[region]=
	FMPLDD_pol_div_100[region] * UNIT_conv_to_pa
	~	1/Year
	~		|

Inventory_coverage_to_goal_ratio[region]=
	Inventory_coverage[region] / Goal_for_inventory_coverage
	~	1
	~		|

TOW_policy_converted_to_pa[region]=
	TOW_pol_div_100[region] * TOW_UNIT_conv_to_pa
	~	1/Year
	~		|

Desired_crop_import_indicated[region]=
	All_crop_regional_dmd_last_year[region] * Ratio_of_demand_to_regional_supply_of_crops\
		[region] * Fraction_of_supply_imbalance_to_be_closed_by_imports_after_policy[region\
		]
	~	Mtac/Year
	~		|

All_region_max_cost_estimate_empowerment_PES=
	1000
	~	G2017pppUSD/Year [0,2000,250]
	~	This number goes back to Per Espens original educated guess in 2022
		1 T$ = 1 trn $ = 1000 G$ = 1000 bn $ (real 2017-USD-ppp)
		Poverty, empowerment, food was around 1 T$ per year,  8 T$ for 8 years
		This is the max cost, if all policies are used to the max
	|

All_region_max_cost_estimate_energy_PES=
	1000
	~	G2017pppUSD/Year [0,2000,250]
	~	This number goes back to Per Espens original educated guess in 2022
		1 T$ = 1 trn $ = 1000 G$ = 1000 bn $ (real 2017-USD-ppp)
		Poverty, empowerment, food was around 1 T$ per year,  8 T$ for 8 years
		This is the max cost, if all policies are used to the max
	|

All_region_max_cost_estimate_food_PES=
	1000
	~	G2017pppUSD/Year [0,2000,250]
	~	This number goes back to Per Espens original educated guess in 2022
		1 T$ = 1 trn $ = 1000 G$ = 1000 bn $ (real 2017-USD-ppp)
		Poverty, empowerment, food was around 1 T$ per year,  8 T$ for 8 years
		This is the max cost, if all policies are used to the max
	|

All_region_max_cost_estimate_inequality_PES=
	4000
	~	G2017pppUSD/Year [0,20000,2500]
	~	This number goes back to Per Espens original educated guess in 2022
		4 T$ = 4 trn $ = 4000 G$ = 4000 bn $ (real 2017-USD-ppp)
		4 T$ per year from 32 T$ for 8 years
		This is the max cost, if all policies are used to the max
	|

All_region_max_cost_estimate_poverty_PES=
	1000
	~	G2017pppUSD/Year [0,2000,250]
	~	This number goes back to Per Espens original educated guess in 2022
		1 T$ = 1 trn $ = 1000 G$ = 1000 bn $ (real 2017-USD-ppp)
		Poverty, empowerment, food was around 1 T$ per year,  8 T$ for 8 years
		This is the max cost, if all policies are used to the max
	|

All_regions_from_Each_region_max_cost_estimate_all_TAs_PES=
	SUM(Each_region_max_cost_estimate_all_TAs_PES[region!])
	~	G2017pppUSD/Year
	~		|

Each_region_max_cost_estimate_all_TAs_PES[region]=
	Each_region_max_cost_estimate_empowerment_PES[region]+Each_region_max_cost_estimate_energy_PES\
		[region]+Each_region_max_cost_estimate_food_PES[region]+Each_region_max_cost_estimate_inequality_PES\
		[region]+Each_region_max_cost_estimate_poverty_PES[region]
	~	G2017pppUSD/Year
	~		|

Nbr_of_relevant_empowerment_policies=
	3
	~	Dmnl [0,20,1]
	~	FEHC, XtaxRateEmp, SGMP
		see t240412 TA cost revenue distribution.xlsx for detail - always use the \
		latest file
	|

Nbr_of_relevant_energy_policies=
	5
	~	Dmnl [0,20,1]
	~	FTPEE, NEP, ISPV, CCS, DAC
		see t240412 TA cost revenue distribution.xlsx for detail - always use the \
		latest file
	|

Nbr_of_relevant_food_policies=
	5
	~	Dmnl [0,20,1]
	~	FWRP, FLWR, RMDR, RIPLGF, FC, REFOREST
		see t240412 TA cost revenue distribution.xlsx for detail - always use the \
		latest file
	|

Nbr_of_relevant_inequality_policies=
	9
	~	Dmnl [0,20,1]
	~	XtaxFrac, StrUP, Wreaction, XtaxCom, ICTR, IOITR, IWITR, Ctax, SGRPI
		see t240412 TA cost revenue distribution.xlsx for detail - always use the \
		latest file
	|

Nbr_of_relevant_poverty_policies=
	9
	~	Dmnl [0,20,1]
	~	ExPS, LPB, LPBsplit, LPBgrant, FMPLDD, TOW, FPGDC, Lfrac, SSGDR
		see t240412 TA cost revenue distribution.xlsx for detail - always use the \
		latest file
	|

Cost_per_regional_empowerment_policy[region]=
	Each_region_max_cost_estimate_empowerment_PES_with_env_dam_and_reform[region] / Nbr_of_relevant_empowerment_policies
	~	G2017pppUSD/Year
	~		|

Cost_per_regional_energy_policy[region]=
	Each_region_max_cost_estimate_energy_PES_with_env_dam_and_reform[region] / Nbr_of_relevant_energy_policies
	~	G2017pppUSD/Year
	~		|

Cost_per_regional_food_policy[region]=
	Each_region_max_cost_estimate_food_PES_with_env_dam_and_reform[region] / Nbr_of_relevant_food_policies
	~	G2017pppUSD/Year
	~		|

Cost_per_regional_inequality_policy[region]=
	Each_region_max_cost_estimate_inequality_PES_with_env_dam_and_reform[region] / Nbr_of_relevant_inequality_policies
	~	G2017pppUSD/Year
	~		|

Cost_per_regional_poverty_policy[region]=
	Each_region_max_cost_estimate_poverty_PES_with_env_dam_and_reform[region]  / Nbr_of_relevant_poverty_policies
	~	G2017pppUSD/Year
	~		|

Temp_surface_anfang_less_zero_k=
	Temp_surface_1850 - 273.15
	~	k
	~	-273.15 is zero Kelvin https://en.wikipedia.org/wiki/Absolute_zero
	|

Future_volcanic_emissions_shape_pulse_train=
	PULSE_TRAIN( NEvt_2a_Volcanic_eruptions_in_the_future_VAEs_first_future_pulse, VAES_pulse_duration\
		, VAES_puls_repetition
	, 9999) * VAES_pulse_height
	~	GtVAe/yr
	~	PULSE TRAIN( {start} , {duration} , {repeattime} , {end} ); 9999 is the \
		end time, ie never
	|

Air_Pollution_risk_score=
	IF_THEN_ELSE(Smoothed_Urban_aerosol_concentration_future > pb_Urban_aerosol_concentration_green_threshold\
		, 1, 0)
	~	1
	~		|

RIPLGF_smoothing_time[region]=
	Time_to_implement_UN_policies[region] + RIPLGF_Addl_time_to_shift_govt_expenditure
	~	Year
	~		|

Urban_aerosol_concentration_future=
	Indicated_Urban_aerosol_concentration_future * UAC_reduction_effort
	~	UAC
	~		|

Smoothed_Urban_aerosol_concentration_future=
	SMOOTH3I(Urban_aerosol_concentration_future, Time_to_smooth_UAC, Urban_aerosol_concentration_in_2020\
		)
	~	UAC
	~		|

pb_Air_Pollution_overloading=
	Smoothed_Urban_aerosol_concentration_future / pb_Urban_aerosol_concentration_green_threshold
	~	1
	~		|

Time_to_implement_SGRPI_policy[region]=
	Time_to_implement_UN_policies[region] + Addl_time_to_shift_govt_expenditure
	~	Year
	~		|

Indicated_inequality_index_with_tax[region]=
	Indicated_inequality_index_higher_is_more_unequal[region] / Effect_of_Worker_to_owner_income_after_tax_ratio_scaled_to_init\
		[region]
	~	1
	~		|

Ctax_policy_with_inequality_effect[region]=
	MIN(Ctax_policy_Max , Ctax_pol_div_100[region] / Inequality_effect_on_energy_TA[region\
		])
	~	Dmnl
	~		|

Worker_to_owner_income_after_tax_ratio_scaled_to_init[region]=
	Worker_to_owner_income_after_tax_ratio[region] / Worker_to_owner_income_after_tax_ratio_in_1980\
		[region]
	~	1
	~		|

Worker_to_owner_income_after_tax_ratio[region]=
	Worker_income_after_tax[region] / Owner_income_after_tax_but_before_lending_transactions\
		[region]
	~	1
	~		|

Effect_of_Worker_to_owner_income_after_tax_ratio_scaled_to_init[region]=
	1 + Strength_of_effect_of_income_ratio_after_tax * ( Worker_to_owner_income_after_tax_ratio_scaled_to_init\
		[region] -1)
	~	1
	~		|

Worker_to_owner_income_after_tax_ratio_in_1980[region]=
	1.27683, 1.19194, 1.18794, 1.2262, 1.17016, 1.19347, 1.22728, 1.19954, 1.24581, 1.19309
	~	1
	~	= INITIAL (Worker_income_after_tax[region] / \
		Owner_income_after_tax_but_before_lending_transactions[region])
	|

Strength_of_effect_of_income_ratio_after_tax=
	0.1
	~	Dmnl [0,0.4,0.1]
	~		|

Smoothed_Forest_land_rel_to_init=
	SMOOTH3(Forest_land_rel_to_init, Time_to_smooth_forest_land_comparison)
	~	Dmnl
	~		|

Time_to_smooth_forest_land_comparison=
	15
	~	y
	~		|

Fraction_deforested[region]=
	SMOOTH(Indicted_Fraction_deforested[region], Time_to_implement_deforestation)
	~	Dmnl/Year
	~		|

Time_to_implement_deforestation=
	5
	~	y
	~		|

Reforestation_policy[region]=
	Forest_land[region] * ( REFOREST_policy_used[region] ) * Reforestation_cutoff_from_lack_of_barren_land\
		[region]
	~	Mha/Year
	~		|

Global_forest_land_in_1980=
	SUM ( Forest_land_in_1980[region!] )
	~	Mha
	~		|

Reforestation_cutoff_from_lack_of_barren_land[region]= WITH LOOKUP (
	Barren_land_which_is_ice_and_snow[region],
		 ([(0,0)-(10,10)],(0,0),(10,0),(20,0.06),(30,0.2),(40,0.5),(50,0.8),(60,0.95),(70,1\
		) ))
	~	Dmnl
	~		|

Forest_land_rel_to_init=
	Global_forest_land / Global_forest_land_in_1980
	~	1
	~		|

Global_forest_land=
	SUM( Forest_land[region!] )
	~	Mha
	~		|

REFOREST_policy_used[region]=
	REFOREST_policy[region] / 10 * UNIT_conv_to_1_per_yr
	~	1/Year
	~		|

REFOREST_R1_via_Excel[region]=
	GET_XLS_CONSTANTS( 'e4a-game-policies.xlsx' , 'r1', 'D38')
	~	Dmnl [0,95,5]
	~		|

REFOREST_R2_via_Excel[region]=
	GET_XLS_CONSTANTS( 'e4a-game-policies.xlsx' , 'r2', 'D38')
	~	Dmnl [0,95,5]
	~		|

REFOREST_R3_via_Excel[region]=
	GET_XLS_CONSTANTS( 'e4a-game-policies.xlsx' , 'r3', 'D38')
	~	Dmnl [0,95,5]
	~		|

REFOREST_rounds_via_Excel[region]=
	IF_THEN_ELSE(Time >= Round3_start, REFOREST_R3_via_Excel[region], IF_THEN_ELSE(Time \
		>= Round2_start, REFOREST_R2_via_Excel
	[region], IF_THEN_ELSE(Time >= Policy_start_year, REFOREST_R1_via_Excel[region], REFOREST_policy_Min\
		)))
	~	Dmnl
	~		|

REFOREST_pol_div_100[region]=
	MIN( REFOREST_policy_Max,MAX( REFOREST_policy_Min , REFOREST_policy_with_RW[region])\
		) / 100
	~	Dmnl
	~		|

REFOREST_policy[region]=
	SMOOTH3(REFOREST_pol_div_100[region], REFOREST_policy_Time_to_implement_goal)
	~	Dmnl
	~		|

REFOREST_policy_contribution_to_GL[region]=
	(REFOREST_policy[region]* 100 - REFOREST_policy_Min ) / (REFOREST_policy_Max - 
	REFOREST_policy_Min)
	~	Dmnl
	~		|

REFOREST_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o38' )
	~	Dmnl [0,3,0.5]
	~		|

REFOREST_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n38' )
	~	Dmnl [0,3,0.5]
	~		|

REFOREST_policy_Time_to_implement_goal=
	15
	~	y [5,30,5]
	~	Regrowing a forest takes a long time
	|

Nuclear_gen_cap_after_depreciation[region]=
	Nuclear_gen_cap[region] * Nuclear_net_depreciation_multiplier_on_gen_cap
	~	GW
	~		|

Nuclear_net_depreciation_multiplier_on_gen_cap= INTEG (
	-Nuclear_net_depreciation,
		1)
	~	Dmnl
	~	The generating capacity of hydro and nuclear was originally kept constant \
		in the future. This led to the situation that with a falling population \
		nuclear and hydro came to dominate energy capacity. We could have a much \
		more operational formulation for the generation capacity with investment, \
		depreciation, lifetime. However, since the e4a focus is *not* on the \
		energy carrier mix, we model a simple depreciation multiplier, to reflect \
		the lifetime of the generating capacity. We could, in theory, set the \
		depreciation rate to a negative value, simulating a revival of either \
		hydro or nuclear.
	|

Nuclear_net_depreciation=
	IF_THEN_ELSE(Time > 2025, Nuclear_net_depreciation_multiplier_on_gen_cap * Nuclear_future_net_dep_rate\
		, 0)
	~	1/Year
	~		|

Nuclear_future_net_dep_rate=
	0.02
	~	1/yr
	~	Setting this to 0 means there is no net depreciation of nuclear capacity.
		We could / should set this regionally.
	|

Hydro_future_net_dep_rate=
	0.01
	~	1/yr
	~	Setting this to 0 means there is no net depreciation of hydro capacity.
		We could / should set this regionally.
	|

Hydro_net_depreciation_multiplier_on_gen_cap= INTEG (
	-Hydro_net_depreciation,
		1)
	~	Dmnl
	~	The generating capacity of hydro and nuclear was originally kept constant \
		in the future. This led to the situation that with a falling population \
		hydro came to dominate renewables. We could have a much more operational \
		formulation for the generation capacity with investment, depreciation, \
		lifetime. However, since the e4a focus is *not* on the energy carrier mix, \
		we model a simple depreciation multiplier, to reflect the lifetime of the \
		generating capacity. We could, in theory, set the depreciation rate to a \
		negative value, simulating a revival of either hydro or nuclear.
	|

Hydro_net_depreciation=
	IF_THEN_ELSE(Time > 2025, Hydro_net_depreciation_multiplier_on_gen_cap * Hydro_future_net_dep_rate\
		, 0)
	~	1/Year
	~		|

Cost_of_capital_for_worker_borrowing_smoothed[region]=
	SMOOTH(Cost_of_capital_for_worker_borrowing[region], Time_to_smooth_cost_of_capital_for_workers\
		)
	~	Dmnl/Year
	~		|

Time_to_smooth_cost_of_capital_for_workers=
	10
	~	y [1,20,3]
	~		|

Acidification_risk_score=
	IF_THEN_ELSE(pb_Ocean_acidification_green_threshold > pb_Ocean_acidification, 1, 0)
	~	1
	~		|

Time_to_smooth_non_energy_footprint_changes=
	5
	~	y
	~		|

Effect_of_Wealth_on_non_energy_footprint= WITH LOOKUP (
	Global_GDPpp_USED,
		 ([(0,0)-(10,10)],(0,1.5),(10,1.2),(20,1),(30,1.1),(40,1.2),(50,1.4),(75,1.8),(100,\
		1.9) ))
	~	Dmnl
	~		|

Biocapacity_with_population_effect=
	Biocapacity_reference / Effect_of_population_on_forest_degradation_and_biocapacity
	~	Mha
	~		|

Non_energy_footprint_future=
	Non_energy_footprint_pp_future * Global_population * UNIT_conv_to_Mha_footprint * Smoothed_Effect_of_Wealth_on_non_energy_footprint
	~	Mha
	~		|

Biocapacity_risk_score=
	IF_THEN_ELSE(Biocapacity_fraction_unused < pb_Biodiversity_loss_green_threshold, 1, \
		0)
	~	1
	~		|

Biocapacity_fraction_unused=
	(Biocapacity - Smoothed_Non_energy_footprint ) / Biocapacity
	~	1
	~		|

Biocapacity_reference=
	1.2e+07
	~	Mha
	~		|

Forest_degradation_risk_score=
	IF_THEN_ELSE(pb_Forest_degradation_green_threshold > pb_Forest_degradation, 0, 1)
	~	1
	~		|

Smoothed_Non_energy_footprint=
	SMOOTH(Non_energy_footprint, Time_to_smooth_non_energy_footprint_changes)
	~	Mha
	~		|

Smoothed_Effect_of_Wealth_on_non_energy_footprint=
	SMOOTH(Effect_of_Wealth_on_non_energy_footprint, Time_to_smooth_non_energy_footprint_changes\
		)
	~	Dmnl
	~		|

pb_Biodiversity_loss_overloading=
	Biocapacity_fraction_unused / pb_Biodiversity_loss_green_threshold
	~	1
	~		|

Non_energy_footprint=
	IF_THEN_ELSE(Time >= 2020, Non_energy_footprint_future, Non_energy_footprint_hist)
	~	Mha
	~		|

Ozone_depletion_risk_score=
	IF_THEN_ELSE(pb_Ozone_depletion > pb_Ozone_depletion_green_threshold, 1, 0)
	~	1
	~		|

Global_warming_risk_score=
	IF_THEN_ELSE(pb_Global_Warming > pb_Global_Warming_green_threshold, 1, 0)
	~	1
	~		|

Nutrient_risk_score=
	( Nitrogen_risk_score + Phosphorous_risk_score ) / 2
	~	1
	~		|

Phosphorous_risk_score=
	IF_THEN_ELSE(Phosphorous_release_global > Phosphorous_PB_green_threshold, 1, 0)
	~	1
	~		|

Nitrogen_risk_score=
	IF_THEN_ELSE(Nitrogen_syn_use_global > Nitrogen_PB_green_threshold, 1, 0)
	~	1
	~		|

Freshwater_withdrawal_risk_score=
	IF_THEN_ELSE(pb_Freshwater_withdrawal_global > pb_Freshwater_withdrawal_green_threshold\
		, 1, 0)
	~	1
	~		|

Planetary_risk=
	Acidification_risk_score + Air_Pollution_risk_score + Biocapacity_risk_score + Forest_degradation_risk_score\
		 + Freshwater_withdrawal_risk_score + Global_warming_risk_score + Nutrient_risk_score\
		 + Ozone_depletion_risk_score + PB_Toxic_risk_score
	~	Dmnl
	~	counts the number of boundaries transgressed. Healthy: 0, 1 and more: \
		sicker and sicker
	|

PB_Toxic_risk_score=
	IF_THEN_ELSE(Lead_release_global > Lead_PB_green_threshold, 1, 0)
	~	1
	~		|

SDG_12_threshold_red_PES=
	SDG12_global_red_threshold / Global_population * UNIT_conv_to_kgN
	~	kgN/(Year*p)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted to per person-year
	|

SDG12_global_red_threshold=
	82
	~	MtN/yr
	~	https://www.science.org/doi/10.1126/sciadv.adh2458 Table 1
	|

SDG_12_threshold_green_PES=
	SDG12_global_green_threshold / Global_population * UNIT_conv_to_kgN
	~	kgN/(Year*p)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted to per person-year
	|

SDG12_global_green_threshold=
	62
	~	MtN/yr
	~	https://www.science.org/doi/10.1126/sciadv.adh2458 Table 1
	|

Total_CO2_emissionslast_yr[region]=
	SMOOTH3(Total_CO2_emissions[region], One_year)
	~	GtCO2/Year
	~		|

RoC_Total_CO2_emissions[region]=
	(Total_CO2_emissions[region] - Total_CO2_emissionslast_yr[region] ) / Total_CO2_emissionslast_yr\
		[region] / One_year
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

P_Pb_Phaseout_time_TLTL=
	150
	~	y
	~		|

Freshwater_withdrawal_per_person=
	Freshwater_withdrawal_per_person_TLTL * Effect_of_GL_on_freshwater_use
	~	m3/(Year*p)
	~		|

Planetary_health=
	( pb_Global_warming_overloading + PB_Toxic_entities + pb_Air_Pollution_overloading +\
		 pb_Biodiversity_loss_overloading + pb_Forest_degradation_overloading + pb_Freshwater_withdrawal_overloading\
		 + pb_Nutrient_overloading + pb_Ocean_acidification_overloading + pb_Ozone_depletion_overloading\
		) / 9
	~	Dmnl
	~	below 1 is healthy, above 1 is boundaries exceeded
	~	:SUPPLEMENTARY 
	|

Global_population_TLTL= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,4429.29),(1981,4496.99),(1982,4565.8),(1983,4637.14),(1984,\
		4714.02),(1985,4794.22),(1986,4875.37),(1987,4958.62),(1988,5043.24),(1989,5127.61)\
		,(1990,5212.36),(1991,5297.99),(1992,5383.77),(1993,5469.92),(1994,5557.22),(1995,5645.17\
		),(1996,5733.67),(1997,5823.18),(1998,5913.28),(1999,6003.57),(2000,6094.22),(2001,\
		6184.81),(2002,6274.89),(2003,6364.45),(2004,6453.16),(2005,6540.68),(2006,6626.99)\
		,(2007,6711.97),(2008,6795.42),(2009,6877.37),(2010,6957.8),(2011,7036.66),(2012,7114\
		),(2013,7189.88),(2014,7264.28),(2015,7337.26),(2016,7408.86),(2017,7479.08),(2018,\
		7547.94),(2019,7615.46),(2020,7681.64),(2021,7746.45),(2022,7809.85),(2023,7871.81)\
		,(2024,7932.28),(2025,7991.25),(2026,8047.86),(2027,8101.52),(2028,8152.71),(2029,8201.73\
		),(2030,8248.72),(2031,8293.72),(2032,8336.72),(2033,8377.71),(2034,8416.69),(2035,\
		8453.68),(2036,8488.76),(2037,8522.04),(2038,8553.65),(2039,8583.67),(2040,8612.19)\
		,(2041,8639.29),(2042,8665.03),(2043,8689.41),(2044,8712.45),(2045,8734.12),(2046,8754.36\
		),(2047,8773.13),(2048,8790.31),(2049,8805.78),(2050,8819.42),(2051,8831.18),(2052,\
		8840.97),(2053,8848.77),(2054,8854.55),(2055,8858.34),(2056,8860.17),(2057,8860.14)\
		,(2058,8858.33),(2059,8854.75),(2060,8849.43),(2061,8842.46),(2062,8833.91),(2063,8823.88\
		),(2064,8812.43),(2065,8799.62),(2066,8785.51),(2067,8770.14),(2068,8753.54),(2069,\
		8735.72),(2070,8716.76),(2071,8696.74),(2072,8675.78),(2073,8653.93),(2074,8631.19)\
		,(2075,8607.58),(2076,8583.07),(2077,8557.64),(2078,8531.2),(2079,8503.61),(2080,8474.78\
		),(2081,8444.72),(2082,8413.47),(2083,8381.08),(2084,8347.63),(2085,8313.15),(2086,\
		8277.66),(2087,8241.18),(2088,8203.7),(2089,8165.26),(2090,8125.93),(2091,8085.86),\
		(2092,8045.2),(2093,8004.14),(2094,7962.83),(2095,7921.42),(2096,7880.01),(2097,7838.69\
		),(2098,7797.53),(2099,7756.59),(2100,7715.93) ))
	~	Mp
	~		|

pb_Freshwater_withdrawal[region]=
	Freshwater_withdrawal_per_person * Population[region] * UNIT_conv_to_cubic_km_pr_yr
	~	km3/Year
	~		|

pb_Forest_degradation=
	(NF_area + TROP_area) * Effect_of_population_on_forest_degradation_and_biocapacity
	~	Mkm2
	~		|

P_Pb_Phaseout_time=
	P_Pb_Phaseout_time_TLTL * Effect_of_GL_on_phaseout_time
	~	y
	~	from Earth3
	|

Effect_of_GL_on_freshwater_use= WITH LOOKUP (
	Which_Scenario_is_run_globally,
		  ([(0,0)-(10,10)],(0,1),(0.25,0.97),(0.5,0.9),(0.75,0.8),(1,0.66) ))
	~	Dmnl
	~	The more globally we are moving towards GL, the bigger the efforts to \
		phaseout phosphorous and lead
	|

Effect_of_GL_on_phaseout_time= WITH LOOKUP (
	Which_Scenario_is_run_globally,
		 ([(0,0)-(10,10)],(0,1),(0.25,0.97),(0.5,0.9),(0.75,0.5),(1,0.33) ))
	~	Dmnl
	~	The more globally we are moving towards GL, the bigger the efforts to \
		phaseout phosphorous and lead
	|

Effect_of_population_on_forest_degradation_and_biocapacity=
	Global_population / Global_population_TLTL
	~	1
	~		|

pb_Ozone_depletion=
	Release_of_Montreal_gases * Effect_of_population_on_forest_degradation_and_biocapacity
	~	Mt/Year
	~		|

Annual_reduction_in_UAC=
	Annual_reduction_in_UAC_TLTL * (1 - Which_Scenario_is_run_globally) + Annual_reduction_in_UAC_GL\
		 * Which_Scenario_is_run_globally
	~	1/Year
	~		|

Annual_reduction_in_UAC_GL=
	2
	~	1/y
	~		|

Annual_reduction_in_UAC_TLTL=
	0.2
	~	1/y
	~		|

Lead_release_global=
	((Lead_release_a * LN(GLobal_GDP / Unit_conv_to_make_LN_dmnl_from_terra_USD) - Lead_release_b\
		 ) * P_Pb_Phaseout_multiplier
	 )  * Lead_UNIT_conv_to_Mt_pr_yr
	~	Mt/Year
	~		|

Lead_UNIT_conv_to_Mt_pr_yr=
	1
	~	Mt/y
	~		|

GLobal_GDP_in_terraUSD=
	GLobal_GDP * UNIT_conv_to_TUSD
	~	T2017pppUSD/Year
	~		|

UNIT_conv_to_TUSD=
	1/1000
	~	T2017pppUSD/G2017pppUSD
	~		|

pb_Urban_aerosol_concentration_green_threshold=
	20
	~	UAC
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab PB-overview
		PES 240709 Our PB Air pollution / Aerosol loading boundary comes out very big… \
		while in the latest PB update 
		(Richardson 2023 https://www.science.org/doi/10.1126/sciadv.adh2458) the PB Aerosol \
		loading is in the green zone.
		So they put their proxy (AOD) for PB Aerosol loading current value to 0,08 and the \
		planetary boundary/red zone threshold to 0,1, 
		in other words still in the green, while with our estimate it is at  400% above the \
		green level (in 2020, and in our TLTL more or less stable to 2100).
		
		I propose we do a quick fix here, by just changing the threshold variable pb Urban \
		aerosol concentration green threshold from its current 10 to a higher 
		threshold, let’s say 20.  That stops the aerosol overloading from dominating the \
		entire planetary health average. 
		Please make a comment in the formula for the variable, with a date, so we \
		remember why we did it.
	|

Indicated_Urban_aerosol_concentration_future=
	IF_THEN_ELSE(Time >= 2020, pb_Air_Pollution_global* UNIT_conv_to_UAC, Urban_aerosol_concentration_hist\
		)
	~	UAC
	~		|

Lead_PB_green_threshold=
	5
	~	Mt/y
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

UAC_reduction_effort= INTEG (
	-Change_in_UACre,
		1)
	~	Dmnl
	~		|

Lead_release_b=
	4.0412
	~	Dmnl
	~		|

Urban_aerosol_concentration_in_2020=
	43.5
	~	UAC
	~		|

pb_Air_Pollution_global=
	pb_Air_Pollution_a * (GLobal_GDP_in_terraUSD / pb_Air_Pollution_Unit_conv_to_make_LN_dmnl_from_terra_USD\
		) +  pb_Air_Pollution_b
	~	1
	~		|

PB_Toxic_entities=
	Lead_release_global / Lead_PB_green_threshold
	~	1
	~		|

Urban_aerosol_concentration_hist= WITH LOOKUP (
	Time,
		  ([(0,0)-(10,10)],(1990,39.7),(1995,39.6),(2000,40.1),(2005,41),(2010,41.9),(2015,\
		41.9),(2020,43.5) ))
	~	UAC
	~	UAC = µg 2.5M/m3
	|

Lead_release_a=
	3.2
	~	Dmnl
	~	from Earth3
	|

Time_to_smooth_UAC=
	10
	~	y
	~		|

Biocapacity=
	IF_THEN_ELSE(Time >= 2020, Biocapacity_with_population_effect, Biocapacity_reference\
		)
	~	Mha
	~		|

Change_in_future_footprint_pp=
	IF_THEN_ELSE(Time >= 2020, Non_energy_footprint_pp_future / Half_life_of_tech_progress_in_non_energy_footprint\
		, 0)
	~	Gha/p/y
	~		|

pb_Freshwater_withdrawal_overloading=
	pb_Freshwater_withdrawal_global / pb_Freshwater_withdrawal_green_threshold
	~	1
	~		|

pb_Global_Warming=
	Temp_surface_anomaly_compared_to_anfang_degC
	~	degC
	~		|

pb_Global_Warming_green_threshold=
	1
	~	degC
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

Freshwater_withdrawal_per_person_TLTL=
	415
	~	m3/p/y
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

pb_Nutrient_overloading=
	(N_pb_overloading + Phosphorous_overloading ) / 2
	~	1
	~		|

pb_Ocean_acidification=
	pH_in_surface
	~	pH
	~		|

Half_life_of_tech_progress_in_non_energy_footprint=
	120
	~	y
	~		|

N_pb_overloading=
	Nitrogen_syn_use_global / Nitrogen_PB_green_threshold
	~	1
	~		|

NF_area=
	NF_Living_biomass_GtBiomass / NF_living_biomass_densitiy_tBiomass_pr_km2 * UNIT_conv_to_Mkm2
	~	Mkm2
	~		|

Nitrogen_PB_green_threshold=
	100
	~	MtN/y
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

Nitrogen_syn_use_global=
	SUM(Nitrogen_syn_use[region!])
	~	MtN/Year
	~		|

Non_energy_footprint_hist=
	Non_energy_footprint_pp * Global_population * UNIT_conv_to_Mha_footprint
	~	Mha
	~		|

Non_energy_footprint_pp= WITH LOOKUP (
	Time,
		 ([(0,0)-(10,10)],(1980,1.6),(1985,1.5),(1990,1.44),(1995,1.35),(2000,1.28),(2005,1.24\
		),(2010,1.13),(2015,1.04),(2020,0.99) ))
	~	Gha/p
	~	from Earth3 t181009 faster air pollution clean up FINAL EARTH-3-core.xlsx \
		tab W-1 lines 466-477 and upstream calculations and sources
	|

Non_energy_footprint_pp_future= INTEG (
	-Change_in_future_footprint_pp,
		0.99)
	~	Gha/p
	~		|

P_Pb_Phaseout_multiplier=
	EXP(-((Time - Start_year_P_Pb_phaseout) / P_Pb_Phaseout_time))
	~	1
	~		|

P_release_a=
	5.3439
	~	Dmnl
	~	from Earth3
	|

P_release_b=
	7.6136
	~	Dmnl
	~		|

pb_Air_Pollution_a=
	0.0425
	~	Dmnl
	~	from Earth3
	|

pb_Air_Pollution_b=
	37.7
	~	Dmnl
	~	calibrated against historical data from Earth3
	|

pb_Air_Pollution_Unit_conv_to_make_LN_dmnl_from_terra_USD=
	1
	~	T2017pppUSD/y
	~		|

UNIT_conv_to_UAC=
	1
	~	UAC
	~		|

pb_Biodiversity_loss_green_threshold=
	0.4
	~	1
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab PB-overview
		240709 Changed to .4 because .25 gives results that are always in the \
		green zone. Has to do with the old idea of a non-energy footprint which \
		was an invention of JR
	|

pb_Forest_degradation_green_threshold=
	25
	~	Mkm2
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

pb_Forest_degradation_overloading=
	pb_Forest_degradation / pb_Forest_degradation_green_threshold
	~	1
	~	fixed wrong numerator / denominator 240709
	|

pb_Freshwater_withdrawal_global=
	SUM(pb_Freshwater_withdrawal[region!])
	~	km3/Year
	~		|

pb_Freshwater_withdrawal_green_threshold=
	3000
	~	km3/yr
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

pb_Ozone_depletion_green_threshold=
	0.25
	~	Mt/y
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

pb_Ozone_depletion_overloading=
	pb_Ozone_depletion / pb_Ozone_depletion_green_threshold
	~	1
	~		|

Phosphorous_overloading=
	Phosphorous_release_global / Phosphorous_PB_green_threshold
	~	1
	~		|

pb_Global_warming_overloading=
	pb_Global_Warming / pb_Global_Warming_green_threshold
	~	1
	~		|

Start_year_P_Pb_phaseout=
	2020
	~	y
	~	from Earth3
	|

TROP_area=
	TROP_Living_biomass_GtBiomass / TROP_living_biomass_densitiy_tBiomass_pr_km2 * UNIT_conv_to_Mkm2
	~	Mkm2
	~		|

pb_Ocean_acidification_green_threshold=
	8.15
	~	pH
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

pb_Ocean_acidification_overloading=
	pb_Ocean_acidification_green_threshold / pb_Ocean_acidification
	~	1
	~		|

UNIT_conv_to_Mkm2=
	1000
	~	Mkm2/((km2*GtBiomass)/tB)
	~		|

UNIT_conv_to_Mt_pr_yr=
	1
	~	Mt/y
	~		|

UNIT_conversion_to_M=
	1000
	~	kt/Mt
	~		|

Phosphorous_PB_green_threshold=
	10
	~	Mt/y
	~	from Earth3 t200721 SafetyMargin PBmodule faster urb_aerosol_PES.xlsx tab \
		PB-overview
	|

Phosphorous_release_global=
	((P_release_a * LN(GLobal_GDP / Unit_conv_to_make_LN_dmnl_from_terra_USD) - P_release_b\
		 ) * P_Pb_Phaseout_multiplier
	 )  * UNIT_conv_to_Mt_pr_yr
	~	Mt/Year
	~		|

UNIT_conv_to_cubic_km_pr_yr=
	1/1000
	~	(p/Mp)*(km3/m3)
	~		|

Unit_conv_to_make_LN_dmnl_from_terra_USD=
	1000
	~	G2017pppUSD/y
	~		|

UNIT_conv_to_Mha_footprint=
	1000
	~	(p/Mp)/(Gha/Mha)
	~		|

Release_of_Montreal_gases=
	Montreal_gases_emissions / UNIT_conversion_to_M
	~	Mt/yr
	~		|

Eff_of_env_damage_on_costs_of_TAs[region]=
	EXP(Combined_env_damage_indicator * expSoE_of_ed_on_cost_of_TAs) / Actual_eff_of_relative_wealth_on_env_damage\
		[region]
	~	1
	~	We assume damage to be exponentially rising - the parameters are so far \
		educated guesses, which they have to be, since we are moving into \
		territory where humanity has never been.
	|

expSoE_of_ed_on_cost_of_TAs=
	3
	~	Dmnl [0,3,0.5]
	~		|

********************************************************
	.mov240607_jr_sergio_curious_un_e4a_10reg
********************************************************~
		Model developed from Randers Earth4All Global Model \
		(https://stockholmuniversity.app.box.com/s/uh7fjh52pvh7yx1mqfwqcyxdcvegrodf\
		) If the link is dead, try https://earth4all.life/the-science/
		Regional model developement by U Goluke and PE Espen.
		Available under the GNU Affero General Public License \
		https://www.gnu.org/licenses/agpl-3.0.en.html
	|

historical_deforestation[region]=
	IF_THEN_ELSE(Time >= Policy_start_year, 0, Indicated_historical_deforestation[region\
		])
	~	Mha/Year
	~		|

Forest_land_last_year[region]=
	SMOOTH3I(Forest_land[region], One_year, Forest_land_in_1980[region])
	~	Mha
	~		|

Natural_CH4_emissions=
	0.19
	~	GtC/yr
	~	0.11 GtC pr yr read off from Historical Anthropogenic Emissions \
		Inventories for Greenhouse Gases and Major Criteria Pollutants, MIT Joint \
		Program on the Science and Policy of Global Change, Technical Note 8, June \
		2006 page 7 figure 2 http://globalchange.mit.edu/research/publications/526 \
		[link as of May 2021 \
		https://globalchange.mit.edu/search/google/Historical%20Anthropogenic%20Emi\
		ssions%20Inventories%20for%20Greenhouse%20Gases%20and%20Major%20Criteria%20\
		Pollutants] converted from CH4 to C by respective molar weights (16/12 \
		g/mol) To reproduce history must be tuned to 1000 yr if we use a halflife \
		of 12 yrs for CH4 in the atmosphere, the value needs to be adjusted to \
		0.1408 if we use a halflife of 7 yrs for CH4 in the atmosphere, the value \
		needs to be adjusted to 0.24 To reproduce history must be tuned to 0.19
	|

Deep_ocean_cold_volume=
	Cold_surface_water_volume
	+ Cold_water_volume_downwelling
	+ Deep_water_volume_1km_to_4km
	~	Gm3
	~		|

Surface_ocean_warm_volume=
	Warm_surface_water_volume + Intermediate_upwelling_water_volume_100m_to_1km
	~	Gm3
	~		|

Carbon_concentration_in_deep_box_GtC_per_G_cubicM=
	C_in_deep_water_volume_1km_to_bottom_GtC / ( Deep_water_volume_1km_to_4km + Cumulative_ocean_volume_increase_due_to_ice_melting_km3
	 * UNIT_conversion_km3_to_Gm3
	 * Frac_vol_deep_ocean_of_total)
	~	GtC / Gm3
	~		|

Carbon_concentration_in_intermdiate_box_GtC_per_G_cubicM=
	C_in_intermediate_upwelling_water_100m_to_1km_GtC / (Intermediate_upwelling_water_volume_100m_to_1km\
		 + Cumulative_ocean_volume_increase_due_to_ice_melting_km3
	 * UNIT_conversion_km3_to_Gm3
	 * Frac_vol_ocean_upwelling_of_total)
	~	GtC / Gm3
	~	This formulation assumes that in the melting ice there is no carbon - is \
		this realistic?
	|

Carbon_concentration_in_warm_surface=
	C_in_warm_surface_water_GtC / (Warm_surface_water_volume + Cumulative_ocean_volume_increase_due_to_ice_melting_km3\
		 
	* UNIT_conversion_km3_to_Gm3
	* Frac_vol_warm_ocean_0_to_100m_of_total)
	~	GtC / Gm3
	~		|

Carbon_concentration_in_cold_surface_ocean=
	C_in_cold_surface_water_GtC / (Cold_surface_water_volume + Cumulative_ocean_volume_increase_due_to_ice_melting_km3\
		 
	* UNIT_conversion_km3_to_Gm3 
	* Frac_vol_cold_ocean_0_to_100m_of_total)
	~	GtC / Gm3
	~		|

Carbon_concentration_in_CWTtB=
	C_in_cold_water_trunk_downwelling_GtC / (Cold_water_volume_downwelling + Cumulative_ocean_volume_increase_due_to_ice_melting_km3
	 * UNIT_conversion_km3_to_Gm3
	 * Frac_vol_cold_ocean_downwelling_of_total)
	~	GtC / Gm3
	~		|

Avg_C_concentration_in_top_layer=
	Carbon_in_top_ocean_layer_GtC
	/ (Cold_surface_water_volume + Warm_surface_water_volume )
	~	GtC/Gm3
	~	G = 1e9, t=tons, C=Carbon, m3= cubic meter
	|

Speculative_asset_pool_relative_to_init[region]= INTEG (
	increase_in_speculative_asset_pool[region]-decrease_in_speculative_asset_pool[region\
		],
		Speculative_asset_pool_relative_to_init_in_1980[region])
	~	G2017pppUSD
	~		|

Owner_wealth_accumulated[region]= INTEG (
	Owner_wealth_accumulating[region]-Wealth_taxing[region],
		Owner_wealth_accumulated_in_1980[region])
	~	G2017pppUSD
	~		|

Initiating_capacity_construction[region]=
	MAX (( Private_Investment_in_new_capacity[region] + Increase_in_public_capacity[region\
		] + GL_spending_going_to_private_investments[region]) * ( 1 - Future_leakage[region\
		]) / Eff_of_env_damage_on_cost_of_new_capacity[region] , 0 )
	~	G2017pppUSD/y
	~		|

Increase_in_public_capacity[region]=
	(Govt_investment_in_public_capacity[region] + Public_money_from_LPB_policy_to_investment\
		[region] + GL_spending_going_to_public_investments[region]) * (1 - Future_leakage[region\
		])
	~	G2017pppUSD/y
	~		|

increase_in_speculative_asset_pool[region]=
	MAX ( 0, Annual_surplus_of_available_private_capital[region] + Increase_in_funds_leaked\
		[region])
	~	G2017pppUSD/Year
	~		|

Worker_income[region]=
	National_income[region] * Worker_share_of_output_with_unemployment_effect[region] + \
		State_guaranteed_minimum_pension[region] + GL_spending_going_to_workers_wages[region\
		]
	~	G2017pppUSD/y
	~		|

Universal_basic_dividend[region]=
	National_income[region] * XtaxCom_policy[region]
	~	G2017pppUSD/Year
	~		|

Owner_income[region]=
	National_income[region] * ( 1 - Worker_share_of_output_with_unemployment_effect[region\
		] )
	~	G2017pppUSD/y
	~		|

Female_leadership_spending[region]=
	National_income[region] * XtaxRateEmp_policy[region]
	~	G2017pppUSD/Year
	~	The amount spent to reduce / remove the genderspecifc pay gap and other \
		activities to promote women's equality
	|

Demand_imbalance[region]=
	( Investment_demand[region] + Total_consumption[region] ) / Optimal_real_output[region\
		]
	~	1
	~		|

Indicted_Fraction_deforested[region]=
	Annual_pct_deforested[region] / UNIT_conv_pct_to_fraction
	~	1/y
	~		|

Which_Scenario_is_run[region]=
	(CCS_contribution_to_GL[region] 
	+ Ctax_contribution_to_GL[region] 
	+ DAC_contribution_to_GL[region] 
	+ FEHC_contribution_to_GL[region] 
	+ FLWR_contribution_to_GL[region] 
	+ FTPEE_contribution_to_GL[region] 
	+ FWRP_contribution_to_GL[region] 
	+ FPGDC_contribution_to_GL[region] 
	+ ICTR_contribution_to_GL[region] 
	+ IOITR_contribution_to_GL[region] 
	+ ISPV_contribution_to_GL[region] 
	+ IWITR_contribution_to_GL[region] 
	+ Lfrac_contribution_to_GL[region] 
	+ LPB_contribution_to_GL[region] 
	+ LPBgrant_contribution_to_GL[region] 
	+ LPBsplit_contribution_to_GL[region] 
	+ NEP_contribution_to_GL[region] 
	+ RMDR_contribution_to_GL[region] 
	+ SGMP_contribution_to_GL[region] 
	+ SGRPI_contribution_to_GL[region] 
	+ SSDGR_contribution_to_GL[region] 
	+ StrUP_contribution_to_GL[region] 
	+ WReaction_contribution_to_GL[region] 
	+ XtaxCom_contribution_to_GL[region] 
	+ Xtaxfrac_contribution_to_GL[region] 
	+ XtaxRateEmp_contribution_to_GL[region] 
	+ TOW_contribution_to_GL[region] 
	+ RIPLGF_contribution_to_GL[region] 
	+ REFOREST_policy_contribution_to_GL[region]) /Nbr_of_policies
	~	Dmnl
	~		|

Public_money_from_LPB_policy_to_investment[region]=
	Public_money_from_LPB_policy[region] * LPBsplit_policy[region] * Effect_of_public_loan_defaults_on_availability_of_new_loans
	[region]
	~	G2017pppUSD/Year
	~		|

Debt_cancelling_pulse[region]=
	((STEP(Debt_cancelling_stepheight,  Policy_start_year) - STEP (Debt_cancelling_stepheight\
		, Policy_start_year + Govt_debt_cancelling_spread[region] )) 
	+ (STEP(Debt_cancelling_stepheight,  Round2_start) - STEP (Debt_cancelling_stepheight\
		, 
	Round2_start + Govt_debt_cancelling_spread[region] )) 
	+ (STEP(Debt_cancelling_stepheight,  Round3_start) - STEP (Debt_cancelling_stepheight\
		, 
	Round3_start + Govt_debt_cancelling_spread[region] ))) 
	* ExPS_pol_div_100[region]
	~	Dmnl
	~		|

decrease_in_speculative_asset_pool[region]=
	MAX(0,Annual_shortfall_of_available_private_capital[region])
	~	G2017pppUSD/Year
	~		|

Indicated_Social_tension_index[region]=
	1 + ( 1 / ( 1 + Perceived_RoC_in_Living_conditions_index_with_env_damage[region] ) -\
		 1 ) * Scaling_factor_for_amplitude_in_RoC_in_living_conditions_index
	 * Scaled_and_smoothed_Effect_of_poverty_on_social_tension_and_trust[region] * Scaled_Effect_of_wealth_on_social_tension_and_trust\
		[region]
	~	1
	~		|

Speculative_asset_pool_relative_to_init_as_share_of_GDP[region]=
	Speculative_asset_pool_relative_to_init[region] / GDP_USED[region]
	~	Year
	~		|

Energy_intensity_kWh_per_usd[region]=
	(El_from_all_sources[region] + (Fossil_fuel_for_NON_El_use_that_IS_NOT_being_electrified\
		[region] + Fossil_fuel_for_NON_El_use_that_CANNOT_be_electrified[region] ) * Conversion_Mtoe_to_TWh\
		[region]*3) / GDP_USED[region]
	~	TWh/G2017pppUSD
	~	TWh/G2017pppUSD = kWh/2017pppUSD a measure of energy intensity
	|

Global_C_taken_directly_out_of_the_atmosphere_ie_direct_air_capture=
	Global_C_taken_out_of_the_atmo / UNIT_conv_CO2_to_C
	~	GtC/Year
	~		|

Actual_wellbeing_from_env_damage=
	SMOOTH3 ( Indicated_wellbeing_from_env_damage , Time_for_env_damage_to_affect_wellbeing\
		 )
	~	Dmnl
	~		|

Living_conditions_index_with_env_damage[region]=
	Living_conditions_index[region] * Weight_on_living_conditions +  Actual_wellbeing_from_env_damage\
		 * Weight_on_env_conditions
	~	Dmnl
	~		|

Indicated_crop_yield_func_SE=
	Indicated_crop_yield_SE_L / (1 + EXP (- Indicated_crop_yield_SE_k * ( Nitrogen_use[se\
		] * UNIT_conv_N_to_yield - Indicated_crop_yield_SE_x ))) - ( Indicated_crop_yield_SE_L2\
		 / (1 + EXP (- Indicated_crop_yield_SE_k2
	 * ( Nitrogen_use[se] * UNIT_conv_N_to_yield - Indicated_crop_yield_SE_x2 ))))
	~	Mtac/(Mha*Year)
	~	We make the assumption that regenerative agricultural practices do *not* reduce \
		yield as compared to conventional practices, they *only* reduce the amount \
		of nitrogen used. 'Downstream' they actually increase yield since they \
		reduce the degradation of the soil quality from to much fertilizer use.
		For se the odd min function comes from difficulties we had during the \
		calibration phase.
	|

Crop_yield_from_N_use[region]=
	IF_THEN_ELSE(region = se, Indicated_crop_yield_min_SE, Indicated_crop_yield_rest[region\
		])
	~	Mtac/(Mha*Year)
	~		|

Malnutrition[region]=
	1 + Malnutition_scaled_to_zero[region]
	~	Dmnl
	~		|

Effect_of_poverty_on_dying_from_policy_start[region]=
	1 + Effect_of_poverty_on_dying_from_policy_start_scaled_to_zero[region]
	~	Dmnl
	~	We assume the effect has been 'priced in' the historical data already. So \
		we are interested in the effect in the future
	|

Income_tax_rate_owners_after_GITx[region]=
	Income_tax_rate_ie_fraction_owners_before_policies + IOITR_policy[region] +
	Additional_tax_rate_needed_to_pay_for_SGMP_after_policy_start[region]
	~	1
	~		|

C_diffusion_into_ocean_from_atm_net=
	Guldberg_Waage_air_sea_formulation
	~	GtC/yr
	~		|

Cumulative_ocean_volume_increase_due_to_ice_melting_km3= INTEG (
	Antarctic_ice_melting_as_water_km3_py + Glacial_ice_melting_as_water_km3_py + Greenland_ice_melting_as_water_km3_py\
		,
		46498.3)
	~	km3
	~		|

Heat_in_surface= INTEG (
	LW_clear_sky_emissions_to_surface+LW_re_radiated_by_clouds+SW_surface_absorption-Convection_aka_sensible_heat_flow\
		-Evaporation_aka_latent_heat_flow-Heat_withdrawn_from_ocean_surface_by_melting_pos_or_added_neg_by_freezing_antarctic_ice_ZJ_py\
		-Heat_withdrawn_from_ocean_surface_by_melting_pos_or_added_neg_by_freezing_arctic_ice_ZJ_py\
		-LW_surface_emission-Net_heat_flow_ocean_from_surface_to_deep_ZJ_py,
		Heat_in_surface_in_1980)
	~	ZJ
	~		|

Ocean_heat_used_for_melting_ZJ_py=
	(Heat_withdrawn_from_ocean_surface_by_melting_pos_or_added_neg_by_freezing_antarctic_ice_ZJ_py
	+Heat_withdrawn_from_ocean_surface_by_melting_pos_or_added_neg_by_freezing_arctic_ice_ZJ_py
	)/Heat_in_surface
	~	1/yr
	~		|

Heat_withdrawn_from_atm_by_melting_pos_or_added_neg_by_freezing_ice_ZJ_py=
	Heat_used_in_melting_is_pos_or_freezing_is_neg_glacial_ice_ZJ_py
	+ Heat_used_in_melting_is_pos_or_freezing_is_neg_antarctic_ice_ZJ_py * Fraction_of_heat_needed_to_melt_antarctic_ice_coming_from_air
	+ Heat_used_in_melting_is_pos_or_freezing_is_neg_Greenland_ice_ZJ_py
	+ Heat_used_in_melting_is_pos_or_freezing_is_neg_arctic_sea_ice_ZJ_py * Fraction_of_heat_needed_to_melt_arctic_ice_coming_from_air
	+ Heat_actually_gained_or_needed_for_freezing_or_unfreezing_of_permafrost_ZJ_py
	~	ZJ/yr
	~		|

Greenland_ice_volume_on_Greenland_km3= INTEG (
	-Greenland_ice_melting_is_pos_or_freezing_is_neg_km3_py,
		Greenland_ice_volume_in_1980)
	~	km3
	~		|

Human_activity_CH4_emissions=
	Global_CH4_emissions_GtC_py
	~	GtC/yr
	~		|

Indicated_effect_of_worker_share_of_output_on_capital_labour_ratio[region]=
	1 + Slope_of_Indicated_effect_of_worker_share_of_output_on_capital_labour_ratio * ( \
		Worker_share_of_output_with_unemployment_effect
	[region]/ Worker_share_of_output_with_unemployment_effect_in_1980[region] - 1)
	~	1
	~		|

WSO_effect_on_available_capital[region]=
	1+ Slope_of_Worker_share_of_output_with_unemployment_effect_on_available_capital *(Worker_share_of_output_with_unemployment_effect
	[region] / Worker_share_of_output_with_unemployment_effect_in_1980[region] - 1)
	~	1
	~		|

Consumption_taxes_in_1980[region]=
	84.9169, 21.154, 30.8086, 24.4263, 20.8022, 42.7945, 42.9795, 69.2588, 105.452, 16.1664
	~	G2017pppUSD/Year
	~	= INITIAL(Consumption taxes)
	|

Owner_income_in_1980[region]=
	2444.98, 401.637, 682.245, 517.372, 422.518, 922.901, 1303.15, 1498.14, 3036.57, 325.045
	~	G2017pppUSD/y
	~	= INITIAL(Owner income after tax but before lending transactions)
	|

All_crop_dmd_food_in_1980[region]=
	170.267, 217.006, 452.252, 99.7209, 454.033, 556.297,119.587, 267.5, 470.721, 193.064
	~	Mtac/Year
	~	= INITIAL(All_crop_dmd_food)
	|

NF_being_harvested_Mkm2_py=
	Use_of_NF_biomass_for_energy / NF_living_biomass_densitiy_tBiomass_pr_km2 * UNIT_conversion_GtBiomass_py_to_Mkm2_py\
		 * NF_usage_cutoff
	~	Mkm2/yr
	~		|

Montreal_gases_emissions_JR_RCP3_or_SSP245=
	Emissions_of_Montreal_gases_with_JR_shape_kt_py
	~	kt/yr
	~		|

Emissions_of_CO2_1850_to_2100_GtC_py=
	Global_Total_CO2_emissions_GtC_py
	~	GtC/yr
	~		|

Kyoto_Fluor_emissions_JR_RCP3_or_SSP245=
	Emissions_of_Kyoto_Fluor_with_JR_shape_kt_py
	~	kt/yr
	~		|

N2O_emissions_JR_RCP3_or_SSP245=
	Global_N2O_emissions
	~	MtN2O/yr
	~		|

GDP_in_1980[region]=
	7070, 1160, 1970, 1510, 1210, 2650, 3750, 4290, 8780, 940
	~	G2017pppUSD/y
	~		|

Global_GDP_USED=
	GLobal_GDP
	~	G2017pppUSD/y
	~		|

GDP_USED[region]=
	GDP_model[region]
	~	G2017pppUSD/y
	~		|

Avg_thickness_Antarctic_km=
	2.14
	~	km
	~	see Excel sheet effect of ice melting on albedo.xlsx, calculated from \
		volume and extent
	|

Contrib_of_ICE_ON_LAND_to_albedo_land=
	Antarctic_ice_area_km2 * Conversion_Million_km2_to_km2 / Area_of_land_Mkm2 * Albedo_Antarctic
	+ Glacial_ice_area_km2 * Conversion_Million_km2_to_km2 / Area_of_land_Mkm2 * Albedo_glacier
	+ Greenland_ice_area_km2 * Conversion_Million_km2_to_km2 / Area_of_land_Mkm2 * Albedo_Greenland
	~	fraction
	~	Units: 0 to 1; 1 is bright i.e. reflects all incoming energy, 0 is dark \
		i.e. reflects no incoming energy.
	|

Reform_willingness_scaled_to_today[region]=
	IF_THEN_ELSE(Time < Policy_start_year, 1, Indicated_reform_willingness[region] / Indicated_reform_willingness_at_2025\
		[region])
	~	1
	~	Past reform willingness has already been 'priced' into the historical \
		data, hence we are interested only in how reform willingness develops in \
		the future relative to today.
	|

Income_and_policy_taxes_paid_by_owners[region]=
	Owner_income[region] * Income_tax_rate[region] + Extra_policy_taxes_paid_by_owners[region\
		]
	~	G2017pppUSD/y
	~		|

Worker_income_and_policy_taxes[region]=
	Worker_income[region] * Income_tax_rate_workers[region] + Extra_policy_taxes_paid_by_workers\
		[region]
	~	G2017pppUSD/y
	~		|

N2O_emi_from_agri[region]=
	IF_THEN_ELSE(region = af, N2O_emi_from_agri_AF, N2O_emi_from_agri_X_AF[region])
	~	MtN2O/Year
	~		|

Net_heat_flow_ocean_between_surface_and_deep_per_K_of_difference_ZJ_py_K=
	10
	~	ZJ/(yr*k)
	~		|

Avg_thickness_glacier_km=
	0.23
	~	km
	~	see Excel sheet effect of ice melting on albedo.xlsx
	|

DAC_policy_with_RW[region]=
	DAC_CCS_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region]
	~	1
	~		|

NEP_policy_with_RW[region]=
	NEP_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region]
	~	1
	~		|

CCS_policy_with_RW[region]=
	CCS_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region]
	~	1
	~		|

ISPV_policy_with_RW[region]=
	ISPV_policy_Min + ( ISPV_rounds_via_Excel[region] - ISPV_policy_Min ) * Smoothed_Reform_willingness\
		[region] / Inequality_effect_on_energy_TA
	[region]
	~	1
	~		|

FTPEE_policy_with_RW[region]=
	FTPEE_policy_Min + (FTPEE_rounds_via_Excel[region] - FTPEE_policy_Min ) * Smoothed_Reform_willingness\
		[region] / Inequality_effect_on_energy_TA
	[region]
	~	1
	~		|

RMDR_policy_with_RW[region]=
	RMDR_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region] * Smoothed_Multplier_from_empowerment_on_speed_of_food_TA
	[region]
	~	1
	~		|

FLWR_policy_with_RW[region]=
	FLWR_rounds_via_Excel_future[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region
	] * Smoothed_Multplier_from_empowerment_on_speed_of_food_TA[region]
	~	1
	~		|

RIPLGF_policy_with_RW[region]=
	RIPLGF_rounds_via_Excel[region] * Smoothed_Reform_willingness[region] / Inequality_effect_on_energy_TA\
		[region] * 
	Smoothed_Multplier_from_empowerment_on_speed_of_food_TA[region]
	~	1
	~		|

SGMP_policy_with_RW[region]=
	SGMP_rounds_via_Excel[region] * Smoothed_Reform_willingness[region]
	~	1
	~		|

XtaxEmp_policy_with_RW[region]=
	XtaxEmp_rounds_via_Excel[region] * Smoothed_Reform_willingness[region]

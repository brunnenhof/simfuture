Abandoned_crop_and_grazing_land[region]= INTEG (
	c_to_acgl[region] + gl_to_acgl[region] + apl_to_acgl[region] - acgl_to_c[region] - acgl_to_fa\
		[region] - acgl_to_gl[region] - acgl_to_pl[region],
		0)
	~	Mha
	~		|

Abandoned_populated_land[region]= INTEG (
	pl_to_apl[region] - apl_to_pl[region] - apl_to_acgl[region],
		0)
	~	Mha
	~		|

acgl_to_c[region]=
	MIN ( Abandoned_crop_and_grazing_land[region], MAX ( 0 , Cropland_gap[region])) * Fraction_of_cropland_gap_closed_from_acgl\
		[region]
	~	Mha/y
	~	First (MIN) you cannot use more land for development than you have \
		abandoned land, and second (MAX) you only want to develop land if need > \
		actual i.e. gap > 0
	|

acgl_to_fa[region]=
	Abandoned_crop_and_grazing_land[region] /Time_for_abandoned_agri_land_to_become_forest
	~	Mha/y
	~		|

acgl_to_gl[region]=
	MIN ( Abandoned_crop_and_grazing_land[region], MAX ( 0 , Grazing_land_gap[region]) )\
		 * Fraction_of_grazing_land_gap_closed_from_acgl
	~	Mha/y
	~	First (MIN) you cannot use more land for grazing than you have abandoned \
		land, and second (MAX) you only want to develop grazing land if need > \
		actual i.e. gap > 0
	|

acgl_to_pl[region]=
	MIN ( Abandoned_crop_and_grazing_land[region], MAX ( 0 , Populated_land_gap[region])\
		 ) * Fraction_of_abandoned_agri_land_developed_for_urban_land
	~	Mha/y
	~	First (MIN) you cannot use more land for development than you have \
		abandoned land, and second (MAX) you only want to develop land if need > \
		actual i.e. gap > 0
	|


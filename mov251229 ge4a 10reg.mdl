	~	kgwmeat/Mtwmeat
	~		|

red_meat_dmd_func_pp[region]=
	red_meat_dmd_func_pp_L[region] / ( 1 + EXP ( - red_meat_dmd_func_pp_k[region] * ( GDPpp_USED\
		[region] * UNIT_conv_to_make_exp_dmnl - red_meat_dmd_func_pp_x0[region]) ) ) + red_meat_dmd_func_pp_min\
		[region]

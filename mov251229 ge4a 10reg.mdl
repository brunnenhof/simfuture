	~		|

RMDR_Time_to_implement_policy=
	10
	~	y
	~		|

red_meat_not_wasted_pp[region]=
	red_meat_demand_pp_consumed[region] * UNIT_conv_kgrmeat_to_kg
	~	kg/(Year*p)
	~		|

RMDR_contribution_to_GL[region]=
	(RMDR_policy[region] * 100 - RMDR_policy_Min ) / (RMDR_policy_Max - RMDR_policy_Min)
	~	Dmnl
	~		|

red_meat_demand_pp_consumed[region]=
	red_meat_demand_pp[region] * ( 1 - Food_wasted_in_1980[region])
	~	kgrmeat/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

RMDR_multiplier_used[region]=
	1 - RMDR_policy[region]
	~	Dmnl
	~		|

RMDR_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o35' )
	~	Dmnl [0,95,10]
	~		|

red_meat_demand_pp_wasted[region]=
	red_meat_demand_pp[region] * Fraction_of_food_wasted[region]
	~	kgrmeat/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

red_meat_demand[region]=
	(red_meat_demand_pp_consumed[region] + red_meat_demand_pp_wasted[region]) * Population\
		[region] / UNIT_conv_kgrmeat_and_Mtrmea * UNIT_conv_btw_p_and_Mp
	~	Mtrmeat/Year
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

RMDR_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n35' )
	~	Dmnl [0,95,10]
	~		|

All_crop_dmd_food[region]=
	(cereal_dmd_food_pp_consumed[region] + cereal_dmd_food_pp_wasted[region] + oth_crop_dmd_food_pp_consumed\
		[region] + oth_crop_dmd_food_pp_wasted[region]) * Population[region]  / UNIT_conv_from_kg_to_Mt\
		 * UNIT_conv_btw_p_and_Mp
	~	Mtac/Year
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

cereal_dmd_food_pp_consumed[region]=
	cereal_dmd_food_pp[region] * ( 1-Food_wasted_in_1980[region])
	~	kgac/(Year*p)
	~	History source: Source: see get_faodata.R and plot5_process_hydedata.R
	|

cereal_dmd_food_pp_wasted[region]=
	cereal_dmd_food_pp[region] * Fraction_of_food_wasted[region]
	~	kgac/(Year*p)
	~	History source: Source: see get_faodata.R and plot5_process_hydedata.R
	|

all_crop_not_wasted_pp[region]=
	(cereal_dmd_food_pp_consumed[region] + oth_crop_dmd_food_pp_consumed[region]) * UNIT_conv_kgac_to_kg
	~	kg/(Year*p)
	~		|

white_meat_not_wasted_pp[region]=
	white_meat_demand_pp_consumed[region] * UNIT_conv_kgwmeat_to_kg
	~	kg/(Year*p)
	~		|

oth_crop_dmd_food_pp_consumed[region]=
	oth_crop_dmd_food_pp[region] * ( 1- Food_wasted_in_1980[region])
	~	kgac/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

oth_crop_dmd_food_pp_wasted[region]=
	oth_crop_dmd_food_pp[region] * Fraction_of_food_wasted[region]
	~	kgac/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

white_meat_demand_pp_wasted[region]=
	white_meat_demand_pp[region] * Fraction_of_food_wasted[region]
	~	kgwmeat/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

white_meat_demand[region]=
	(white_meat_demand_pp_consumed[region] + white_meat_demand_pp_wasted[region]) * Population\
		[region] / UNIT_conv_kgwmeat_and_Mtwmeat * UNIT_conv_btw_p_and_Mp
	~	Mtwmeat/Year
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

white_meat_demand_pp_consumed[region]=
	white_meat_demand_pp[region] * (1 - Food_wasted_in_1980[region])
	~	kgwmeat/(Year*p)
	~	History Source: see get_faodata.R and plot5_process_hydedata.R
	|

FLWR_Time_to_implement_ISPV_goal=
	5
	~	y
	~	Building up capacity for direct air capture takes time
	|

Too_much_regen_cropland[region]=
	IF_THEN_ELSE(Desired_regenerative_cropland_fraction[region] + FLWR_policy[region] - \
		Regenerative_cropland_fraction[region] < 0 , (Desired_regenerative_cropland_fraction\
		[region] + FLWR_policy[region] - Regenerative_cropland_fraction[region]) * -1 ,0)
	~	1
	~		|

Regenerative_cropland_fraction[region]= INTEG (
	Increase_in_regen_cropland[region]-Decrease_in_regen_cropland[region],
		0)
	~	Dmnl
	~		|

Time_to_implement_regen_practices=
	5
	~	y
	~		|

Not_enough_regen_cropland[region]=
	IF_THEN_ELSE(Desired_regenerative_cropland_fraction[region] + FLWR_policy[region] - \
		Regenerative_cropland_fraction[region] >= 0.03 , (Desired_regenerative_cropland_fraction\
		[region] + FLWR_policy[region] - Regenerative_cropland_fraction[region])  , 0)
	~	1
	~		|

Decrease_in_regen_cropland[region]=
	Too_much_regen_cropland[region] / Time_to_implement_conventional_practices
	~	1/Year
	~		|

Desired_regenerative_cropland_fraction[region]= WITH LOOKUP (
	Smoothed_cumulative_N_use_for_regenerative_choice[region],
		  ([(0,0)-(10,10)],(0,0),(10,0.02),(20,0.1),(30,0.5) ))
	~	Dmnl
	~		|

DAC_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n44' )
	~	Dmnl [0,1.5,0.25]
	~		|

Actual_CO2_taken_directly_out_of_the_atmosphere_ie_direct_air_capture[region]=
	DAC_policy[region] * UNIT_conv_to_GtCO2_pr_yr
	~	GtCO2/Year
	~		|

UNIT_conv_to_GtCO2_pr_yr=
	1
	~	GtCO2/yr
	~		|

DAC_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o44' )
	~	Dmnl [0,1.5,0.25]
	~		|

DAC_contribution_to_GL[region]=
	(DAC_policy[region] * 1 - DAC_policy_Min ) / (DAC_policy_Max - DAC_policy_Min)
	~	Dmnl
	~		|

DAC_Time_to_implement_goal=
	15
	~	y [5,50,5]
	~	Building up capacity for direct air capture takes time
	|

NEP_Time_to_implement_goal=
	3
	~	y
	~		|

CCS_contribution_to_GL[region]=
	(CCS_policy[region] * 100 - CCS_policy_Min ) / (CCS_policy_Max - CCS_policy_Min)
	~	Dmnl
	~		|

CCS_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o43' )
	~	Dmnl [0,80,10]
	~		|

Time_to_implement_CCS_goal=
	10
	~	y
	~	CCS is tricky, costly and challenging to implement at scale
	|

NEP_contribution_to_GL[region]=
	(NEP_policy[region] * 100 - NEP_policy_Min ) / (NEP_policy_Max - NEP_policy_Min)
	~	Dmnl
	~		|

CCS_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n43' )
	~	Dmnl [0,80,10]
	~		|

NEP_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o41' )
	~	Dmnl [0,95,5]
	~		|

NEP_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n41' )
	~	Dmnl [0,95,5]
	~		|

Fraction_of_fossil_fuels_compensated_by_CCS[region]=
	CCS_policy[region]
	~	Dmnl
	~		|

Fossil_fuel_for_NON_El_use_that_IS_being_electrified[region]=
	Fossil_fuel_for_NON_El_use_that_COULD_be_electrified[region] * NEP_policy[region]
	~	Mtoe/Year
	~		|

Increase_in_exepi[region]=
	Extra_energy_productivity_index_2024_is_1[region] * (FTPEE_rate_of_change_policy[region\
		] / 100) * UNIT_conv_to_1_per_yr
	~	1/Year
	~	The / 100 converts percent to fraction
	|

FTPEE_Time_to_implement_goal=
	3
	~	y [1,20,3]
	~		|

FTPEE_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o40' )
	~	Dmnl [1,2.5,0.5]
	~		|

FTPEE_contribution_to_GL[region]=
	(FTPEE_rate_of_change_policy[region] * 1 - FTPEE_policy_Min ) / (FTPEE_policy_Max - \
		FTPEE_policy_Min)
	~	Dmnl
	~		|

ISPV_policy_Max=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'o42' )
	~	Dmnl [50,95,5]
	~		|

ISPV_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n42' )
	~	Dmnl [50,95,5]
	~		|

FTPEE_policy_Min=
	GET_XLS_CONSTANTS('e4a-game-policies.xlsx', 'r1' , 'n40' )
	~	Dmnl [1,2.5,0.5]
	~		|

ISPV_contribution_to_GL[region]=
	(wind_and_PV_el_share_max[region] * 100 - ISPV_policy_Min) / (ISPV_policy_Max - ISPV_policy_Min\
		)
	~	Dmnl
	~		|

wind_and_PV_el_share[region]=
	wind_and_PV_el_share_max[region] / ( 1 + EXP ( - wind_and_PV_el_share_k[region] * ( \
		(GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl
	) - wind_and_PV_el_share_x0[region]) ) )
	~	Dmnl
	~		|

Round2_start=
	2040
	~	y
	~	Year at which round 2 kicks in
	|

Round3_start=
	2060
	~	y
	~	Year at which round 3 kicks in
	|

Policy_start_year=
	2025
	~	y [2025,2100,5]
	~	Year at which round 1 kicks in
	|

Scenario_global=
	2
	~	Dmnl [1,2,1]
	~	1 = TLTL 2 = GL just to check policies, so far
	~	:SUPPLEMENTARY 
	|

Time_to_implement_ISPV_goal=
	3
	~	y [1,10,2]
	~		|

UNIT_conv_to_G2017pppUSD=
	1
	~	(G2017pppUSD*t)/(GtCO2*pppUSD)
	~		|

Gross_Govt_income[region]=
	Income_and_policy_taxes_paid_by_owners[region] + Worker_income_and_policy_taxes[region\
		] + Consumption_taxes_last_year[region] + Universal_basic_dividend[region] + Wealth_taxing\
		[region] + Carbon_taxes[region]
	~	G2017pppUSD/y
	~		|

Increase_in_funds_leaked[region]=
	Funds_from_private_investment_leaked[region] + Funds_leaked_during_transfer_to_workers\
		[region] + Funds_leaks_on_the_way_to_investment_in_public_capacity[region] + Funds_leaks_on_the_way_to_public_services\
		[region]
	~	G2017pppUSD/Year
	~		|

Funds_leaked_cumulatively[region]= INTEG (
	Increase_in_funds_leaked[region],
		0)
	~	G2017pppUSD
	~		~	:SUPPLEMENTARY 
	|

Funds_leaked_annually_as_pct_of_GDP[region]=
	Increase_in_funds_leaked[region] / GDP_USED[region]
	~	1
	~		~	:SUPPLEMENTARY 
	|

Obligation_for_payback_of_debt_from_public_lenders[region]=
	Govt_debt_from_public_lenders[region] / Time_to_payback_public_debt[region]
	~	G2017pppUSD/Year
	~		|

Govt_debt_repayment_obligation[region]=
	Govt_debt_owed_to_private_lenders[region] / Govt_payback_period_to_PL[region]
	~	G2017pppUSD/Year
	~		|

Fraction_of_public_loans_not_serviced[region]=
	ZIDZ( All_loan_service_obligations_to_public_lenders_not_met[region] , All_loan_service_obligations_to_public_lenders\
		[region])
	~	1
	~	When there is more cash than obligations, all obligations are met, if not, \
		only the fraction for which there is money can be met
	|

Govt_interest_payment_to_PL[region]=
	Govt_interest_payment_obligation_to_PL[region] * (Fraction_of_govt_loan_obligations_to_PL_met\
		[region])
	~	G2017pppUSD/Year
	~		~	:SUPPLEMENTARY 
	|

Govt_loan_obligation_to_PL_not_met[region]=
	MAX(0, Govt_loan_obligations_to_PL[region] - Govt_loan_obligations_to_PL_MET[region]\
		)
	~	G2017pppUSD/Year
	~		|

Normal_time_to_payback_public_debt=
	30
	~	y
	~		|

Govt_loan_obligations_to_PL_MET[region]=
	MIN( Govt_loan_obligations_to_PL[region] , Govt_cash_to_meet_private_loan_obligations\
		[region])
	~	G2017pppUSD/Year
	~		|

Govt_debt_from_public_lenders_cancelled[region]=
	Govt_debt_from_public_lenders[region] * Public_Debt_cancelling_pulse[region]
	~	G2017pppUSD/Year
	~		|

Govt_debt_from_public_lenders[region]= INTEG (
	Increase_in_GDPL[region]-Decrease_in_GDPL[region]-Govt_debt_from_public_lenders_cancelled\
		[region],
		0)
	~	G2017pppUSD
	~	should be set for 1980 regionally as it actually was.
	|

Decrease_in_GDPL[region]=
	Obligation_for_payback_of_debt_from_public_lenders[region] * ( 1 - Fraction_of_public_loans_not_serviced\
		[region])
	~	G2017pppUSD/y
	~		|

Actual_govt_cash_inflow[region]=
	Govt_income_after_transfers[region] - Govt_cashflow_to_owners[region] - Obligation_for_interest_payments_on_debt_from_public_lenders_actually_met\
		[region]
	~	G2017pppUSD/y
	~		|

Public_Govt_debt_cancelling_spread[region]=
	2
	~	y
	~		|

All_loan_service_obligations_to_public_lenders_met[region]=
	MIN(All_loan_service_obligations_to_public_lenders[region] , Govt_cash_to_meet_public_loan_obligations\
		[region])
	~	G2017pppUSD/Year
	~		|

Govt_cashflow_to_owners[region]=
	Govt_loan_obligations_to_PL_MET[region] - Govt_new_debt_from_private_lenders[region]
	~	G2017pppUSD/Year
	~		|

Effect_of_public_loan_defaults_on_availability_of_new_loans[region]= WITH LOOKUP (
	Public_loan_defaults_as_fraction_of_GDP[region],
		   ([(0,0)-(10,10)],(0,1),(0.25,1),(0.5,1),(0.75,0.98),(1,0.95),(1.5,0.7),(2,0.3),(\
		3,0) ))
	~	Dmnl
	~	A region with lots of public loans in default cannot, eventually, borrow \
		new money.
	|

Fraction_of_govt_loan_obligations_to_PL_met[region]=
	ZIDZ(Govt_loan_obligations_to_PL_MET[region], Govt_loan_obligations_to_PL[region])
	~	Dmnl
	~	You cannot meet more than all your obligations, hence the Min function
	|

Owner_consumption[region]=
	Owner_cash_inflow_seasonally_adjusted[region] * Owner_consumption_fraction[region]
	~	G2017pppUSD/y
	~		|

Owner_wealth_accumulating[region]=
	Owner_cash_inflow_seasonally_adjusted[region] * Owner_wealth_accumulation_fraction[region\
		]
	~	G2017pppUSD/Year
	~		|

Govt_loan_obligations_to_PL[region]=
	Govt_debt_repayment_obligation[region] + Govt_interest_payment_obligation_to_PL[region\
		]
	~	G2017pppUSD/Year
	~		|

Time_at_which_govt_public_debt_is_cancelled[region]=
	2025
	~	y
	~		|

All_loan_service_obligations_to_public_lenders_not_met[region]=
	MAX(0, All_loan_service_obligations_to_public_lenders[region] - All_loan_service_obligations_to_public_lenders_met\
		[region])
	~	G2017pppUSD/Year
	~	If I have more than enough money to meet my obligations, the obligations \
		NOT met are at most 0, they do not become negative
	|

Obligation_for_interest_payments_on_debt_from_public_lenders[region]=
	Govt_debt_from_public_lenders[region] * Long_term_interest_rate_applied[region]
	~	G2017pppUSD/Year
	~		|

Public_loan_defaults[region]= INTEG (
	Increase_in_public_loan_defaults[region] - Decrease_in_public_loan_defaults[region],
		0)
	~	G2017pppUSD
	~	Should be initialized with actual loans in default to public lenders, by \
		region
	|

Public_loan_defaults_as_fraction_of_GDP[region]=
	Public_loan_defaults[region] / GDP_USED[region]
	~	Year
	~		|

Decrease_in_public_loan_defaults[region]=
	Public_loan_defaults[region] / Time_to_write_of_public_loan_defaults
	~	G2017pppUSD/Year
	~		|

Time_to_write_of_public_loan_defaults=
	30
	~	y
	~		|

Effect_of_public_loan_defaults_on_interest_rate[region]= WITH LOOKUP (
	Public_loan_defaults_as_fraction_of_GDP[region],
		  ([(0,0)-(10,10)],(0,0),(0.25,0),(0.5,0.005),(0.75,0.01),(1,0.02),(1.5,0.05),(2,0.1\
		) ))
	~	1/y
	~	The first effect of regions in default of public loans is an increase in \
		the interest rate they have to pay.
	|

Govt_cash_to_meet_private_loan_obligations[region]=
	Govt_cash_available_to_meet_all_loan_obligations[region] * Fraction_of_avail_cash_used_to_meet_private_lender_obligations\
		[region]
	~	G2017pppUSD/Year
	~		|

Govt_cash_to_meet_public_loan_obligations[region]=
	Govt_cash_available_to_meet_all_loan_obligations[region] * ( 1 - Fraction_of_avail_cash_used_to_meet_private_lender_obligations\
		[region])
	~	G2017pppUSD/Year
	~		|

All_loan_service_obligations_to_public_lenders[region]=
	Obligation_for_interest_payments_on_debt_from_public_lenders[region] + Obligation_for_payback_of_debt_from_public_lenders\
		[region]
	~	G2017pppUSD/Year
	~		|

Increase_in_public_loan_defaults[region]=
	All_loan_service_obligations_to_public_lenders_not_met[region]
	~	G2017pppUSD/Year
	~		|

Obligation_for_interest_payments_on_debt_from_public_lenders_actually_met[region]=
	Obligation_for_interest_payments_on_debt_from_public_lenders[region] * (1 - Fraction_of_public_loans_not_serviced\
		[region])
	~	G2017pppUSD/Year
	~		|

Public_money_from_LPB_policy_to_public_spending[region]=
	Public_money_from_LPB_policy[region] - Public_money_from_LPB_policy_to_investment[region\
		]
	~	G2017pppUSD/Year
	~		|

Normal_Time_to_implement_UN_policies=
	5
	~	y [0,10,2]
	~		|

Govt_interest_payment_obligation_to_PL[region]=
	Govt_debt_owed_to_private_lenders[region] * Long_term_interest_rate_used_by_private_lenders\
		[region] * Effect_of_defaulting_on_debt_obligations_on_cost_of_capital_for_govt_borrowing
	[region]
	~	G2017pppUSD/y
	~		|

Time_to_implement_UN_policies[region]=
	Normal_Time_to_implement_UN_policies / Smoothed_Reform_willingness[region]
	~	y
	~		|

Fraction_of_avail_cash_used_to_meet_private_lender_obligations[region]=
	0.9
	~	Dmnl
	~	This is a policy
	|

Time_to_smooth_unemp_rate=
	5
	~	y
	~		|

Unemployment_rate_smoothed[region]=
	SMOOTH(Unemployment_rate[region], Time_to_smooth_unemp_rate)
	~	Dmnl
	~		|

Time_to_smooth_RoC_in_GDPpp=
	4
	~	y
	~		|

Worker_to_owner_income_ratio[region]=
	Worker_income_after_tax[region] / Owner_income_after_tax_but_before_lending_transactions\
		[region]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Total_government_revenue_as_a_proportion_of_GDP[region]=
	Govt_income_after_transfers[region] / GDP_USED[region]
	~	1
	~		|

Disposable_income_pp_post_tax_pre_loan_impact[region]=
	( Worker_cash_inflow_seasonally_adjusted[region] - Worker_cashflow_to_owners[region]\
		 ) / Population[region]
	~	G2017pppUSD/(y*Mp)
	~		|

Ratio_of_demand_to_regional_supply_of_crops[region]=
	All_crop_regional_dmd[region] / Crop_grown_regionally[region]
	~	1
	~		|

Addition_to_N_use_over_the_years[region]=
	IF_THEN_ELSE( Time > 2022, Nitrogen_use_after_soil_regeneration[region] * UNIT_conv_kgN_to_Nt\
		, 0)
	~	MtN/(Mha*Year)
	~	We assume that nitrogen use in the past has already been 'priced' ie \
		considered into the decisions to switch to regenerative farming or not
	|

Indicated_crop_yield_rest[region]=
	Indicated_crop_yield_rest_L[region] / ( 1 + EXP(- Indicated_crop_yield_rest_k[region\
		] * ( Nitrogen_use[region] * UNIT_conv_N_to_yield
	 - Indicated_crop_yield_rest_x0[region])))
	~	Mtac/(Mha*Year)
	~	We make the assumption that regenerative agricultural practices do *not* \
		reduce yield as compared to conventional practices, they *only* reduce the \
		amount of nitrogen used. 'Downstream' they actually increase yield since \
		they reduce the degradation of the soil quality from to much fertilizer \
		use.
	|

Smoothed_Crop_yield_from_N_use[region]=
	SMOOTHI ( Crop_yield_from_N_use[region] , One_year , crop_yield_in_1980[region] )
	~	Mtac/(Year*Mha)
	~		|

Crop_yield_last_year[region]=
	SMOOTHI (Crop_yield_with_soil_quality_CO2_and_env_dam_effects[region] , One_year , crop_yield_in_1980\
		[region] )
	~	Mtac/(Mha*Year)
	~		|

Govt_defaulting[region]=
	Govt_loan_obligation_to_PL_not_met[region]
	~	G2017pppUSD/y
	~		|

Govt_defaulting_N_yrs_ago[region]=
	SMOOTHI(Govt_defaulting[region], Time_for_defaulting_to_impact_cost_of_capital, 0)
	~	G2017pppUSD/Year
	~		|

Worker_defaults_written_off[region]=
	Worker_debt_defaults_outstanding[region] / Time_to_write_off_worker_defaults
	~	G2017pppUSD/Year
	~		|

Fraction_set_aside_to_service_loans[region]=
	0.9
	~	Dmnl
	~	This is the fraction govts set aside to service loans. By definition it \
		cannot exceed 1, in reality it will always be less than one, where weaker \
		govt's / regions may be forced by lenders to set aside more than stronger \
		ones. cf Greece in the past. Should (?) be set regionally.
	|

Govt_debt_paid_back_to_private_lenders[region]=
	Govt_debt_repayment_obligation[region] * Fraction_of_govt_loan_obligations_to_PL_met\
		[region]
	~	G2017pppUSD/y
	~		|

Govt_default_ratio[region]=
	Govt_defaulting_N_yrs_ago[region] / Govt_income_after_transfers[region]
	~	1
	~		|

Owner_income_from_lending_activity[region]=
	Worker_cashflow_to_owners[region] + Govt_cashflow_to_owners[region]
	~	G2017pppUSD/y
	~		|

Govt_cash_available_to_meet_all_loan_obligations[region]=
	Govt_income_after_transfers[region] * Fraction_set_aside_to_service_loans[region]
	~	G2017pppUSD/Year
	~		|

Effect_of_defaulting_on_debt_obligations_on_cost_of_capital_for_govt_borrowing[region\
		]= WITH LOOKUP (
	Govt_default_ratio[region],
		    ([(0,0)-(10,10)],(0,1),(0.25,1.04),(0.5,1.1),(0.75,1.3),(1,1.6),(1.5,2.5),(2,4)\
		 ))
	~	Dmnl
	~		|

Effect_of_defaulting_on_debt_obligations_on_cost_of_capital_for_worker_borrowing[region\
		]= WITH LOOKUP (
	Worker_default_ratio[region],
		    ([(0,0)-(10,10)],(0,1),(0.25,1.04),(0.5,1.1),(0.75,1.3),(1,1.6),(1.5,2.5),(2,4)\
		 ))
	~	Dmnl
	~		|

Time_for_defaulting_to_impact_cost_of_capital=
	3
	~	y
	~		|

Worker_debt_defaulting_N_yrs_ago[region]=
	SMOOTHI(Worker_debt_defaulting[region], Time_for_defaulting_to_impact_cost_of_capital\
		, 0)
	~	G2017pppUSD/Year
	~		|

Worker_default_ratio[region]=
	Worker_debt_defaulting_N_yrs_ago[region] / Worker_income_after_tax[region]
	~	1
	~		|

Worker_debt_defaulting[region]=
	MAX( 0, W_loan_obligations_not_met[region] )
	~	G2017pppUSD/Year
	~	If loan obligations are less than the new cash inflow, workers can service \
		their obligations to owners (the ones who give out loans) in full and do \
		not increase the debt defaults outstanding. One could argue that in such \
		situations workers repay loans in default ...
	|

Worker_debt_defaults_outstanding[region]= INTEG (
	Worker_debt_defaulting[region] - Worker_defaults_written_off[region],
		0)
	~	G2017pppUSD
	~	Should reflect the actual situation in 1980 - let us know if you have actual \
		respectable / legitimate data
		It also should have a causal effect on the cost of capital workers need to \
		pay
	|

Worker_interest_payment_obligation_met[region]=
	Worker_interest_payment_obligation[region] * Fraction_of_worker_loan_obligations_met\
		[region]
	~	G2017pppUSD/Year
	~		|

Worker_debt_repayment_obligation[region]=
	Workers_debt[region] / Workers_payback_period
	~	G2017pppUSD/Year
	~		|

Workers_debt_payback[region]=
	Worker_debt_repayment_obligation[region] * Fraction_of_worker_loan_obligations_met[region\
		]
	~	G2017pppUSD/y
	~		|

W_loan_obligations_not_met[region]=
	Worker_loan_repayment_obligations[region] * ( 1 - Fraction_of_worker_loan_obligations_met\
		[region])
	~	G2017pppUSD/Year
	~	If workers cannot met their debt obligations in full, the shortfall will \
		increase their debt amounts in default
	|

Fraction_of_worker_loan_obligations_met[region]=
	MIN ( 1, Worker_cash_available_to_meet_loan_obligations[region] / Worker_loan_repayment_obligations\
		[region] )
	~	1
	~	Note: no check done if loan obligations are zero, which would cause a \
		division by zero error.
	|

Worker_cashflow_to_owners[region]=
	Worker_interest_payment_obligation_met[region] + Workers_debt_payback[region] - Workers_taking_on_new_debt\
		[region]
	~	G2017pppUSD/y
	~		|

Worker_cash_available_to_meet_loan_obligations[region]=
	(Worker_income_after_tax[region] + Workers_taking_on_new_debt[region] ) * Fraction_by_law_or_custom_left_for_surviving
	~	G2017pppUSD/Year
	~		|

Worker_loan_repayment_obligations[region]=
	Worker_interest_payment_obligation[region] + Worker_debt_repayment_obligation[region\
		]
	~	G2017pppUSD/y
	~	Borrowers are obligated to pay back both interest and principle on a loan \
		- can they? This formulation assumes that you can use new debt to pay back \
		old debt. In reality, there might be a penalty (higher interest rate?) to \
		do so, is this too detailed to model? So far, we decided it is.
	|

Time_to_write_off_worker_defaults=
	5
	~	y
	~	This is private insolvency which is regulated in some regions, thus it \
		should reflect cultural / legal regional norms
	|

Fraction_by_law_or_custom_left_for_surviving=
	0.5
	~	Dmnl [0.25,0.75,0.05]
	~	This reflects the fact that in most societies the debtor cannot claim more \
		than a certain share of the cash inflow , the rest cannot be seized.
	|

Actual_govt_cash_inflow_seasonally_adjusted[region]=
	SMOOTH ( Actual_govt_cash_inflow[region] , Time_to_adjust_budget )
	~	G2017pppUSD/Year
	~		|

Years_of_schooling[region]=
	(SDG4_a * LN(Public_services_pp[region] / UNIT_conv_to_make_base_and_ln_dmnl) + SDG4_b\
		 ) / Effect_of_FEHC_mult_on_years_of_schooling[region]
	~	1
	~		|

Smoothed_SDG_score_for_effect_of_wellbeing=
	SMOOTH3(Global_All_SDG_Scores, Time_to_smooth_the_anchor_SDG_scores_for_wellbeing)
	~	Dmnl [0,17,1]
	~	We want to capture the effect of comparing ones own SDG score with the \
		global SDG score - as a consequence of policies enacted / implemented. \
		Thus, the initial value is 1 (=neutral) before we enact / implement any \
		policy
	|

Comparison_Effect_of_SDG_score_on_wellbeing[region]=
	IF_THEN_ELSE(Time < 2023, 1, 1 + (All_SDG_Scores[region] / Smoothed_SDG_score_for_effect_of_wellbeing\
		 - 1) * Strength_of_Effect_of_SDG_scores_on_wellbeing)
	~	1
	~	The neutral value for the effect is 1, the Max function ensures that the \
		comparison effect is never negative (since it is a multiplier)
	|

Strength_of_FEHC_mult_on_years_of_schooling=
	0.1
	~	Dmnl [0,1,0.1]
	~	Placeholder: We know there is a causal connection between an 'Education \
		for all' policy and years of schooling. But we do not, yet, know the shape \
		nor the strength of that causality. We invite anyone looking at this part \
		of the model to help us improve.
	|

Effect_of_FEHC_mult_on_years_of_schooling[region]=
	1 + (FEHC_mult_used[region] - 1) * Strength_of_FEHC_mult_on_years_of_schooling
	~	1
	~	The neutral value of FEHC mult is 1, thus we multiply the strenght on the \
		delta
	|

Smoothed_comparison_Effect_of_SDG_score_on_wellbeing[region]=
	SMOOTH3I(Comparison_Effect_of_SDG_score_on_wellbeing[region], Time_to_smooth_SDG_scores_for_wellbeing\
		,1)
	~	1
	~	The neutral value for the effect is 1
	|

Time_to_smooth_SDG_scores_for_wellbeing=
	5
	~	y
	~		|

Average_wellbeing_index[region]=
	(Living_conditions_index_with_env_damage[region] * Weight_on_physical_conditions +
	Wellbeing_from_social_tension[region] * ( 1 - Weight_on_physical_conditions) ) * Smoothed_comparison_Effect_of_SDG_score_on_wellbeing\
		[region]
	~	1
	~		|

Strength_of_Effect_of_SDG_scores_on_wellbeing=
	0.3
	~	Dmnl [0,0.5,0.1]
	~		|

Time_to_smooth_the_anchor_SDG_scores_for_wellbeing=
	5
	~	y
	~		|

Global_All_SDG_Scores=
	All_SDG_Scores[us] * Regional_population_as_fraction_of_total[us] 
	+ All_SDG_Scores[af] * Regional_population_as_fraction_of_total[af] 
	+ All_SDG_Scores[cn] * Regional_population_as_fraction_of_total[cn] 
	+ All_SDG_Scores[me] * Regional_population_as_fraction_of_total[me] 
	+ All_SDG_Scores[sa] * Regional_population_as_fraction_of_total[sa] 
	+ All_SDG_Scores[la] * Regional_population_as_fraction_of_total[la] 
	+ All_SDG_Scores[pa] * Regional_population_as_fraction_of_total[pa] 
	+ All_SDG_Scores[ec] * Regional_population_as_fraction_of_total[ec] 
	+ All_SDG_Scores[eu] * Regional_population_as_fraction_of_total[eu] 
	+ All_SDG_Scores[se] * Regional_population_as_fraction_of_total[se]
	~	1
	~		|

Safe_water_and_sanitation[region]=
	(Safe_sanitation[region] + Safe_water[region]) /2
	~	1
	~		~	:SUPPLEMENTARY 
	|

pH_in_surface_regionally[region]=
	pH_in_surface
	~	pH
	~	This variable only exists to make the interface coding simpler
	~	:SUPPLEMENTARY 
	|

TROP_with_normal_cover_regionally[region]=
	TROP_with_normal_cover
	~	Mkm2
	~	Contrary to its name this variable does *not* give regional values for \
		trop cover, it only exists to make the interface coding easier
	~	:SUPPLEMENTARY 
	|

UNIT_conv_to_1_per_yr=
	1
	~	1/y
	~		|

Sea_level_change_from_melting_ice_and_thermal_expansion_mm=
	Sea_level_change_from_melting_ice_and_thermal_expansion_m / UNIT_conversion_mm_to_m
	~	mm
	~	For history: A good overview / introduction is here \
		http://sealevel.colorado.edu/content/tide-gauge-sea-level. We use Church \
		and White 2011 \
		(http://link.springer.com/article/10.1007%2Fs10712-011-9119-1), the data \
		is here: http://www.cmar.csiro.au/sealevel/sl_data_cmar.html and here \
		http://www.psmsl.org/products/reconstructions/church.php and Jevrejeva et \
		al 2008, data is here: \
		http://www.psmsl.org/products/reconstructions/jevrejevaetal2008.php there \
		is also the Permanent Service for Mean Sea Level at http://www.psmsl.org/ \
		, but to access their data is not intuitive.
	~	:SUPPLEMENTARY 
	|

Global_Births=
	SUM(Births[region!])
	~	Mp/y
	~		~	:SUPPLEMENTARY 
	|

Long_term_interest_rate_used_by_public_lenders[region]=
	SMOOTH(Indicated_long_term_interest_rate_after_global_considerations[region], Long_term_interest_rate_expectation_formation_time\
		)
	~	1/y
	~		|

Indicated_long_term_interest_rate[region]=
	Short_term_interest_rate[region] + Long_term_risk_margin
	~	1/y
	~		|

Indicated_long_term_interest_rate_after_global_considerations[region]=
	MIN( Long_term_interest_rate_used_by_private_lenders[region], Avg_global_long_term_interest_rate\
		)
	~	1/y
	~		|

Sales[region]=
	(Effective_purchasing_power[region] / (Delivery_delay_index[region] / Delivery_delay_index_in_1980\
		[region] ))
	~	G2017pppUSD/y
	~		|

GenEq_before_female_leadership_spending[region]=
	IF_THEN_ELSE(region = cn, GenEq_cn, 
	IF_THEN_ELSE(region = ec, GenEq_ec, 
	IF_THEN_ELSE(region = me, GenEq_me, 
	IF_THEN_ELSE(region = sa, GenEq_sa, 
	IF_THEN_ELSE(region = la, GenEq_la, 
	IF_THEN_ELSE(region = af, GenEq_af, 
	GenEq_se_eu_pa_us[region]))))))
	~	1
	~	I could handle sa la af by using :OR: but I don't know how SDeverywhere \
		nor my transpiler to Python would handle this. Left for a rainy day.
	|

GenEq[region]=
	GenEq_before_female_leadership_spending[region] * Effect_of_Female_Leadership_on_gender_equality\
		[region]
	~	1
	~		|

Effect_of_Female_Leadership_on_gender_equality[region]=
	1 + Female_leadership_spending[region] / GDP_USED[region]
	~	1
	~		|

N_excreted_CN=
	N_excreted_a[cn] * EXP(Red_and_White_meat_production[cn] / UNIT_conv_to_dmnl_for_MtNmeat\
		 * N_excreted_b[cn])
	~	Dmnl
	~		|

GenEq_af=
	GenEq_sa_la_af_a * LN(GDPpp_USED[af] / UNIT_conv_to_make_base_dmnless) + GenEq_sa_la_af_b
	~	Dmnl
	~		|

GenEq_la=
	GenEq_sa_la_af_a * LN(GDPpp_USED[la] / UNIT_conv_to_make_base_dmnless) + GenEq_sa_la_af_b
	~	Dmnl
	~		|

Annual_shortfall_of_available_private_capital[region]=
	Available_private_capital_for_investment[region] * Annual_shortfall_fraction_of_available_private_capital\
		[region]
	~	G2017pppUSD/Year
	~		|

N_excreted_per_unit_of_meat_production_func[region]=
	IF_THEN_ELSE(region = af, N_excreted_AF, 
	IF_THEN_ELSE(region = cn, N_excreted_CN, N_excreted_without_AF_CN[region]))
	~	1
	~	History Source: calculated from https://www.fao.org/faostat/en/#data/FB and  /EMN \
		accessed September 25 2021
		IF THEN ELSE(region = af :OR: region = cn, N excreted AF CN[region], N \
		excreted without US AF CN[region])
	|

Annual_surplus_of_available_private_capital[region]=
	Available_private_capital_for_investment[region] * Annual_surplus_fraction_of_available_private_capital\
		[region]
	~	G2017pppUSD/Year
	~		|

Annual_shortfall_fraction_of_available_private_capital[region]=
	IF_THEN_ELSE(Fraction_of_available_capital_to_new_capacity[region] >
	 1, Fraction_of_available_capital_to_new_capacity[region] - 1, 0)
	~	1
	~		|

Annual_surplus_fraction_of_available_private_capital[region]=
	IF_THEN_ELSE(Fraction_of_available_capital_to_new_capacity[region] < 1, 1 - Fraction_of_available_capital_to_new_capacity\
		[region], 0)
	~	1
	~		|

Leaving_the_labor_pool_limitation[region]= WITH LOOKUP (
	Unemployed_to_labor_pool_ratio[region],
		        ([(0,0)-(0.55382,39.1651)],(0.01,0),(0.02,0.02),(0.04,0.25),(0.06,0.7),(0.08\
		,0.95),(0.1,1) ))
	~	Dmnl
	~		|

Getting_a_job_cut_off[region]= WITH LOOKUP (
	Unemployed_to_labor_pool_ratio[region],
		     ([(0,0)-(10,10)],(0.01,0),(0.02,0.02),(0.04,0.25),(0.06,0.7),(0.08,0.95),(0.1,\
		1) ))
	~	Dmnl
	~		|

Unemployed_to_labor_pool_ratio[region]=
	Unemployed[region] / Labor_pool[region]
	~	1
	~		|

Laying_off_cut_off[region]= WITH LOOKUP (
	Employed_to_labor_pool_ratio[region],
		       ([(0,0)-(10,10)],(0.01,0),(0.02,0.02),(0.04,0.25),(0.06,0.7),(0.08,0.95),(0.1\
		,1) ))
	~	Dmnl
	~		|

Employed_to_labor_pool_ratio[region]=
	Employed[region] / Labor_pool[region]
	~	1
	~		|

dying_as_pct_of_pop[region]=
	dying[region] / Population[region]
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

Fraction_of_owner_income_left_for_consumption_or_wealth_accumulation[region]=
	1 - Owner_saving_fraction[region]
	~	Dmnl
	~		|

SDG4_Score[region]=
	IF_THEN_ELSE(Years_of_schooling[region] < SDG4_threshold_red, 0, IF_THEN_ELSE(Years_of_schooling\
		[region] < SDG4_threshold_green
	, 0.5, 1))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

Scaled_Effect_of_TAs_on_inequality[region]=
	(Effect_of_TAs_on_inequality[region] - 1 ) * Strength_of_Effect_of_TAs_on_inequality
	~	1/Year
	~		|

Strength_of_worker_reaction_to_owner_power[region]=
	Strength_of_worker_reaction_to_owner_power_normal * Eff_of_scenario_on_strength_of_worker_reaction_to_owner_power\
		[region
	] + Scaled_Effect_of_TAs_on_inequality[region]
	~	1/Year
	~		|

Strength_of_inequality_effect_on_food_TA=
	2
	~	Dmnl [0,2,0.25]
	~		|

Effect_of_TAs_on_inequality[region]=
	Reform_willingness_with_inequality[region] / Smoothed_Reform_willingness[region]
	~	1
	~	Comparing smoothed reform willingness with the one where the inequality \
		effect has been taken into account.
	|

Multplier_from_empowerment_on_speed_of_food_TA[region]=
	1 + (Empowerment_score[region] - 0.5) * Strength_of_Effect_of_empowerment_on_speed_of_food_TA
	~	1
	~	We try to capture the effect of empowerment (our proxies are schooling and \
		gender equality) on the speed of the food TA. For lack of empirical data \
		on this relationship we use, as a placeholder until we have this data, the \
		SDG 4 and 5 (quality education and gender equality) score. That score is \
		scaled to 0-1 depending on the red and green thresholds. A multiplier must \
		have a range centered on 1 (which is neutral). We can also vary the \
		strength of the influence.
	|

Multplier_from_gender_inequality_on_indicated_social_trust[region]=
	1 + (SDG_5_Score[region] - 0.5) * Strength_of_Effect_of_gender_inequality_on_social_trust
	~	1
	~	We try to capture the effect of empowerment (our proxies are schooling and \
		gender equality) on the building / destroying of social trust. For lack of \
		empirical data on this relationship we use, as a placeholder until we have \
		this data, the SDG 5 (gender equality) score. That score is scaled to 0-1 \
		depending on the red and green thresholds. A multiplier must have a range \
		centered on 1 (which is neutral). We can also vary the strength of the \
		influence.
	|

Smoothed_Multplier_from_gender_inequality_on_indicated_social_trust[region]=
	SMOOTH3(Multplier_from_gender_inequality_on_indicated_social_trust[region], Time_to_smooth_Multplier_from_empowerment_on_indicated_social_trust
	)
	~	Dmnl
	~	Humans are social animals, hence we use a 3rd order delay to capture the \
		propagation (waxing and waning) of trust in a population.
	|

Strength_of_Effect_of_schooling_on_social_trust=
	0.1
	~	Dmnl
	~		|

Reform_willingness_with_inequality[region]=
	( Smoothed_Reform_willingness[region] / Inequality_effect_on_food_TA[region])
	~	1
	~	Reform willingness signals the speed and ambition of a turn-around.
		We divide because the higher the index the more unequal
	|

Strength_of_inequality_effect_on_mortality=
	0.5
	~	Dmnl [0,2,0.25]
	~		|

Smoothed_Multplier_from_empowerment_on_speed_of_food_TA[region]=
	SMOOTH3(Multplier_from_empowerment_on_speed_of_food_TA[region], Time_to_smooth_Multplier_from_empowerment_on_speed_of_food_TA\
		)
	~	Dmnl
	~	Humans are social animals, hence we use a 3rd order delay to capture the \
		propagation (waxing and waning) of trust in a population.
	|

Strength_of_Effect_of_gender_inequality_on_social_trust=
	0.1
	~	Dmnl
	~		|

Smoothed_Multplier_from_schooling_on_indicated_social_trust[region]=
	SMOOTH3(Multplier_from_schooling_on_indicated_social_trust[region], Time_to_smooth_Multplier_from_empowerment_on_indicated_social_trust\
		)
	~	Dmnl
	~	Humans are social animals, hence we use a 3rd order delay to capture the \
		propagation (waxing and waning) of trust in a population.
	|

Inequality_effect_on_mortality[region]=
	1 + (Actual_inequality_index_higher_is_more_unequal[region] - 1 ) * Strength_of_inequality_effect_on_mortality
	~	1
	~	1 is neutral
	|

Strength_of_Effect_of_TAs_on_inequality=
	0.1
	~	1/y [0,0.3,0.1]
	~	As long as we do not have emperical data on the strength of the effect of \
		TAs on inequality, this serves as a placeholder and a "what-if" handle
	|

Strength_of_inequality_effect_on_energy_TA=
	2
	~	Dmnl [0,2,0.25]
	~		|

Change_in_worker_resistance[region]=
	Owner_power_or_weakness[region] * Strength_of_worker_reaction_to_owner_power[region]
	~	1/Year
	~		|

Time_to_smooth_Multplier_from_empowerment_on_indicated_social_trust=
	5
	~	y
	~		|

Strength_of_Effect_of_empowerment_on_speed_of_food_TA=
	0.1
	~	Dmnl
	~		|

Time_to_smooth_Multplier_from_empowerment_on_speed_of_food_TA=
	5
	~	y
	~		|

Inequality_effect_on_food_TA[region]=
	1 + (Actual_inequality_index_higher_is_more_unequal[region] - 1 ) * Strength_of_inequality_effect_on_food_TA
	~	1
	~	1 is neutral
	|

Inequality_effect_on_energy_TA[region]=
	1 + (Actual_inequality_index_higher_is_more_unequal[region] - 1 ) * Strength_of_inequality_effect_on_energy_TA
	~	1
	~	1 is neutral
	|

Smoothed_Social_tension_index_with_trust_effect[region]=
	Smoothed_Social_tension_index_ie_rate_of_progress[region] / Eff_of_social_trust_on_reform_willingness_and_social_tension\
		[region]
	~	1
	~	The effect of social trust could be changed with a (strength) multiplyer
	|

Smoothed_Reform_willingness[region]=
	SMOOTH3 (Reform_willingness_scaled_to_today[region] , Time_to_adjust_reform_willingness
	)
	~	1
	~	People are social animals, so we use a third order delay to model the \
		change in reform willingness, mimicing best the S-shaped uptake of new \
		ideas.
	|

Wellbeing_from_social_tension[region]=
	1 + SoE_of_Wellbeing_from_social_tension *( Smoothed_Social_tension_index_with_trust_effect\
		[region] / Social_tension_index_in_1980
	 - 1 )
	~	1
	~		|

N2O_emi_X_agri_CN_a=
	0.4272
	~	MtN2O/y
	~		|

N2O_emi_X_agri_CN_b=
	-0.2683
	~	MtN2O/y
	~		|

CH4_emi_from_energy_EC_b=
	18.271
	~	MtCH4/y
	~		|

Global_RoC_in_Carbon_intensity=
	RoC_in_Carbon_intensity[us] * Regional_population_as_fraction_of_total[us]
	+ RoC_in_Carbon_intensity[af] * Regional_population_as_fraction_of_total[af]
	+ RoC_in_Carbon_intensity[cn] * Regional_population_as_fraction_of_total[cn]
	+ RoC_in_Carbon_intensity[me] * Regional_population_as_fraction_of_total[me]
	+ RoC_in_Carbon_intensity[sa] * Regional_population_as_fraction_of_total[sa]
	+ RoC_in_Carbon_intensity[la] * Regional_population_as_fraction_of_total[la]
	+ RoC_in_Carbon_intensity[pa] * Regional_population_as_fraction_of_total[pa]
	+ RoC_in_Carbon_intensity[ec] * Regional_population_as_fraction_of_total[ec]
	+ RoC_in_Carbon_intensity[eu] * Regional_population_as_fraction_of_total[eu]
	+ RoC_in_Carbon_intensity[se] * Regional_population_as_fraction_of_total[se]
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

Montreal_emissions_allocated_to_region[region]=
	Montreal_emissions_GtCO2e_py * Regional_population_as_fraction_of_total[region]
	~	GtCO2e/Year
	~		|

CH4_Emissions_CO2e[region]=
	CH4_emissions[region] * Global_Warming_Potential_CH4
	~	GtCO2e/Year
	~		|

N2O_emi_X_agri_SA=
	N2O_emi_X_agri_SA_a * LN(GDPpp_USED[sa] * UNIT_conv_to_make_exp_dmnl) + N2O_emi_X_agri_SA_b
	~	MtN2O/Year
	~	Source: calculated by fitting a logarithmic function to historical data. \
		GDPpp calculated from Penn World Table 10.0, emissions from \
		https://www.pik-potsdam.de/paris-reality-check/primap-hist/. Calculations \
		done in file e4a-reg-v2-exo.xlsx on tab nnemi where nn stands for the \
		regions we use in e4a, i.e. US, ...
	|

N2O_emi_X_agri_SA_a=
	0.1257
	~	MtN2O/y
	~		|

N2O_emi_X_agri_SA_b=
	0.0234
	~	MtN2O/y [-1,2]
	~		|

N2O_emi_from_agri_AF=
	N2O_emi_from_agri_AF_a * LN(All_N_use_syn_and_excreted[af] / UNIT_conv_to_make_LN_dmnl\
		) + N2O_emi_from_agri_AF_b
	~	MtN2O/Year
	~		|

N2O_emi_from_agri_AF_a=
	0.5301
	~	MtN2O/Year
	~		|

N2O_emi_from_agri_AF_b=
	-0.579
	~	MtN2O/Year
	~		|

CO2_emi_from_IPC_2_CN=
	CO2_emi_from_IPC_2_CN_L / (1 + EXP( - CO2_emi_from_IPC_2_CN_k * ((GDPpp_USED[cn] * UNIT_conv_to_make_exp_dmnl\
		) - CO2_emi_from_IPC_2_CN_x0)))
	~	GtCO2/Year
	~	A logarithmic function, as we use for the other regions, gives a negative result for \
		early historical values, something that cannot physically be in reality
		Might in future be a double exponential function to capture technical \
		progress in the future.
	|

CO2_emi_from_IPC_2_CN_k=
	0.25
	~	Dmnl
	~		|

CO2_emi_from_IPC_2_CN_L=
	2
	~	GtCO2/y
	~		|

CO2_emi_from_IPC_2_CN_x0=
	10
	~	Dmnl
	~		|

Total_GHG_emissions[region]=
	CH4_Emissions_CO2e[region] + N2O_emissions_in_CO2e[region] + Total_CO2_emissions_in_CO2e\
		[region] + Kyoto_Fluor_emissions_allocated_to_region
	[region] + Montreal_emissions_allocated_to_region[region]
	~	GtCO2e/Year
	~		|

CO2_emi_from_IPC2_use[region]=
	IF_THEN_ELSE(region = cn, CO2_emi_from_IPC_2_CN, CO2_emi_from_IPC2_use_wo_CN[region]\
		)
	~	GtCO2/Year
	~		|

Low_carbon_heat_production[region]=
	Green_hydrogen_in_Mtoe_py[region]
	~	Mtoe/Year
	~		|

CH4_emi_from_energy_EC=
	MAX(0,CH4_emi_from_energy_EC_a * LN(Total_use_of_fossil_fuels[ec] / UNIT_conv_to_make_fossil_fuels_dmnl\
		) + CH4_emi_from_energy_EC_b)
	~	MtCH4/Year
	~	If users are really agressive about the energy efficiency policy it is \
		possible that fossil use goes to zero. This correlation would then \
		generate negative values for emissions, which makes no sense.
	|

Global_RoC_GHG_intensity=
	RoC_GHG_intensity[us] * Regional_population_as_fraction_of_total[us]
	+ RoC_GHG_intensity[af] * Regional_population_as_fraction_of_total[af]
	+ RoC_GHG_intensity[cn] * Regional_population_as_fraction_of_total[cn]
	+ RoC_GHG_intensity[me] * Regional_population_as_fraction_of_total[me]
	+ RoC_GHG_intensity[sa] * Regional_population_as_fraction_of_total[sa]
	+ RoC_GHG_intensity[la] * Regional_population_as_fraction_of_total[la]
	+ RoC_GHG_intensity[pa] * Regional_population_as_fraction_of_total[pa]
	+ RoC_GHG_intensity[ec] * Regional_population_as_fraction_of_total[ec]
	+ RoC_GHG_intensity[eu] * Regional_population_as_fraction_of_total[eu]
	+ RoC_GHG_intensity[se] * Regional_population_as_fraction_of_total[se]
	~	1/Year
	~		~	:SUPPLEMENTARY 
	|

CO2_emi_from_IPC2_use_wo_CN[region]=
	CO2_emi_from_IPC2_use_a[region] * LN( GDPpp_USED[region] * UNIT_conv_to_make_exp_dmnl\
		) + CO2_emi_from_IPC2_use_b[region
	]
	~	GtCO2/Year
	~		|

CH4_emissions[region]=
	(CH4_emi_from_agriculture[region] + CH4_emi_from_energy[region] + CH4_emi_from_waste\
		[region])*UNIT_conversion_from_MtCH4_to_GtC
	~	GtC/Year
	~		|

GHG_intensity[region]=
	Total_GHG_emissions[region] / GDP_USED[region] * UNIT_conversion_to_tCO2e_pr_USD
	~	kgCO2e/USD
	~		|

N2O_emi_from_agri_X_AF[region]=
	N2O_emi_from_agri_a[region] * All_N_use_syn_and_excreted[region] + N2O_emi_from_agri_b\
		[region]
	~	MtN2O/Year
	~		|

N2O_emi_X_agri[region]=
	IF_THEN_ELSE(region = us, N2O_emi_X_agri_US, IF_THEN_ELSE(region = eu, N2O_emi_X_agri_EU\
		, IF_THEN_ELSE(region = cn, N2O_emi_X_agri_CN
	, IF_THEN_ELSE(region = sa, N2O_emi_X_agri_SA, N2O_emi_X_agri_WO_US_EU_CN_SA[region]\
		))))
	~	MtN2O/Year
	~		|

Kyoto_Fluor_emissions_allocated_to_region[region]=
	Kyoto_Fluor_emissions_GtCO2e_py * Regional_population_as_fraction_of_total[region]
	~	GtCO2e/Year
	~		|

N2O_emi_X_agri_CN=
	N2O_emi_X_agri_CN_a * LN(GDPpp_USED[cn] * UNIT_conv_to_make_exp_dmnl) + N2O_emi_X_agri_CN_b
	~	MtN2O/Year
	~	Source: calculated by fitting a logarithmic function to historical data. \
		GDPpp calculated from Penn World Table 10.0, emissions from \
		https://www.pik-potsdam.de/paris-reality-check/primap-hist/. Calculations \
		done in file e4a-reg-v2-exo.xlsx on tab nnemi where nn stands for the \
		regions we use in e4a, i.e. US, ...
	|

N2O_emissions_in_CO2e[region]=
	(N2O_emi_from_agri[region] + N2O_emi_X_agri[region]) * Global_Warming_Potential_N20 \
		/ UNIT_conversion_Gt_to_Mt
	~	GtCO2e/Year
	~		|

Carbon_intensity_last_year[region]=
	SMOOTH3(Carbon_intensity[region], One_year)
	~	kgCO2/USD
	~		|

RoC_GHG_intensity[region]=
	(GHG_intensity[region] - GHG_intensity_last_year[region]) / GHG_intensity_last_year[\
		region] / One_year
	~	1/Year
	~		|

Global_warming_potential_CO2=
	1
	~	GtCO2e/GtCO2
	~		|

GHG_intensity_last_year[region]=
	SMOOTH3(GHG_intensity[region], One_year)
	~	kgCO2e/USD
	~		|

CH4_emi_from_energy[region]=
	IF_THEN_ELSE(region = eu, CH4_emi_from_energy_EU, IF_THEN_ELSE(region = us, CH4_emi_from_energy_US\
		, IF_THEN_ELSE(region = ec, CH4_emi_from_energy_EC, CH4_emi_from_energy_WO_US_EC_EU\
		[region])))
	~	MtCH4/Year
	~		|

UNIT_conversion_to_tCO2e_pr_USD=
	1000
	~	(kgCO2e/USD)/(GtCO2e/G2017pppUSD)
	~		|

CH4_emi_from_energy_EC_a=
	11.39
	~	MtCH4/y
	~		|

UNIT_conv_to_make_LN_dmnl=
	1
	~	MtN/Year
	~		|

Total_CO2_emissions_in_CO2e[region]=
	Total_CO2_emissions[region] * Global_warming_potential_CO2
	~	GtCO2e/Year
	~		|

RoC_in_Carbon_intensity[region]=
	(Carbon_intensity[region] - Carbon_intensity_last_year[region]) / Carbon_intensity_last_year\
		[region] / One_year
	~	1/Year
	~		|

Actual_Social_tension_index[region]= WITH LOOKUP (
	Indicated_Social_tension_index[region],
		 ([(0,0)-(10,10)],(0,0.1),(0.25,0.13),(0.5,0.23),(0.75,0.5),(1,1),(1.25,1.5),(1.5,1.85\
		),(1.75,1.95),(2,2) ))
	~	1
	~	The Indicated socail tension tension index can pass through 0 which makes \
		no sense for a cardinal value where 1 = neutral
	|

Time_to_smooth_social_tension_index=
	3
	~	y
	~		|

Smoothed_Social_tension_index_ie_rate_of_progress[region]=
	SMOOTH(Actual_Social_tension_index[region], Time_to_smooth_social_tension_index)
	~	1
	~	The Indicated socail tension tension index can pass through 0 which makes \
		no sense for a cardinal value where 1 = neutral
	|

Actual_capital_labor_ratio[region]=
	Capacity[region] / Employed[region]
	~	G2017pppUSD/Mp
	~		~	:SUPPLEMENTARY 
	|

El_from_all_sources[region]=
	El_gen_from_fossil_fuels[region] + wind_PV_nuclear_hydro_el_generation[region]
	~	TWh/Year
	~		|

wind_PV_nuclear_hydro_el_generation[region]=
	El_from_wind_and_PV[region] + El_from_nuclear[region] + El_from_Hydro[region]
	~	TWh/Year
	~		|

Actual_el_use_pp[region]=
	El_from_all_sources[region] / Population[region] * UNIT_conv_to_kWh_ppp
	~	kWh/(Year*p)
	~		|

Demand_for_el_from_fossil_fuel[region]=
	MAX ( 0 , Demand_for_El_afer_NEP[region] - wind_PV_nuclear_hydro_el_generation[region\
		] )
	~	TWh/Year
	~		|

Working_age_population[region]=
	Cohort_20_to_40[region] + Cohort_40_to_44[region] + Cohort_45_to_49[region] + Population_over_50_still_working\
		[region]
	~	Mp
	~		~	:SUPPLEMENTARY 
	|

Global_el_generation_from_all_sources=
	SUM ( El_from_all_sources[region!] )
	~	TWh/Year
	~		~	:SUPPLEMENTARY 
	|

SDG_8_threshold_red=
	15
	~	G2017pppUSD/(y*Mp)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
		Changed 24-07-20 from 22 on the advice of PES
	|

Access_to_electricity[region]=
	Access_to_electricity_L / (1+EXP(-Access_to_electricity_k*((GDPpp_USED[region]/UNIT_conv_to_make_base_dmnless\
		)-Access_to_electricity_x0))) + Access_to_electricity_min
	~	1
	~		|

Access_to_electricity_k=
	0.5
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab electricity
	|

Access_to_electricity_L=
	0.999
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab electricity
	|

Access_to_electricity_min=
	-0.01
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab electricity
	|

Access_to_electricity_x0=
	3
	~	Dmnl
	~	calibration from e4a-public-spending4-cor.xlsx tab electricity
	|

SDG_15_threshold_red=
	15
	~	Mkm2
	~		|

SDG_10_threshold_green=
	0.6
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores adjusted to regional conditions
		adjusted since switching to labour share of GDP
	|

SDG_10_threshold_red=
	0.4
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted to regional conditions
		adjusted since switching to labour share of GDP
	|

SDG_11_Score[region]=
	IF_THEN_ELSE(Energy_footprint_pp[region] < SDG_11_threshold_green, 1, IF_THEN_ELSE(Energy_footprint_pp\
		[region] < SDG_11_threshold_red
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_11_threshold_green=
	0
	~	tCO2/(p*Year)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_11_threshold_red=
	2
	~	tCO2/(p*Year)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_12_threshold_green=
	5
	~	kgN/(Year*p)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted to per person-year
	~	:SUPPLEMENTARY 
	|

SDG_12_threshold_red=
	12
	~	kgN/(Year*p)
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores, adjusted to per person-year
	~	:SUPPLEMENTARY 
	|

SDG_13_Score[region]=
	IF_THEN_ELSE(Temp_surface_anomaly_compared_to_anfang_degC < SDG_13_threshold_green, \
		1, IF_THEN_ELSE(Temp_surface_anomaly_compared_to_anfang_degC
	 < SDG_13_threshold_red
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_13_threshold_green=
	1
	~	degC
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_13_threshold_red=
	1.5
	~	degC
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_14_Score[region]=
	IF_THEN_ELSE(pH_in_surface > SDG_14_threshold_green, 1, IF_THEN_ELSE(pH_in_surface >\
		 SDG_14_threshold_red
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_14_threshold_green=
	8.15
	~	pH
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_14_threshold_red=
	8.1
	~	pH
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_15_Score[region]=
	IF_THEN_ELSE(TROP_with_normal_cover > SDG_15_threshold_green, 1, IF_THEN_ELSE(TROP_with_normal_cover\
		 > SDG_15_threshold_red
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

SDG_15_threshold_green=
	25
	~	Mkm2
	~		|

SDG_7_threshold_red=
	0.9
	~	Dmnl
	~	Source: sdg_analysis_3_PES.xlsx tab SDG scores
	|

SDG_16_Score[region]=
	IF_THEN_ELSE(Public_services_pp[region] > SDG_16_threshold_green, 1, IF_THEN_ELSE(Public_services_pp\
		[region] > SDG_16_threshold_red
	, 0.5, 0))
	~	Dmnl
	~	The logic comes all the way from our work on Earth3: \
		https://www.researchgate.net/publication/343791128_Transformation_is_feasib\
		le_How_to_achieve_the_sustainable_development_goals_within_planetary_bounda\
		ries
	|

